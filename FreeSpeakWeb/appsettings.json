{
  "SiteName": "FreeSpeak",
  "MaxFeedPostCommentDepth": 4,
  "MaxFeedPostDirectCommentCount": 30,

  // SystemAdministratorInitInfo: Used to automatically create a system administrator account on first run.
  // This configuration ensures that at least one user with the SystemAdministrator role exists in the database.
  // The account will only be created if it doesn't already exist (checked by email).
  //
  // Password Requirements:
  // - At least one uppercase letter (A-Z)
  // - At least one digit (0-9)
  // - At least one non-alphanumeric character (e.g., !, @, #, $, %, etc.)
  //
  // IMPORTANT: For security reasons, this section should be REMOVED from appsettings.json
  // in production environments after the initial system administrator account has been created.
  // You can verify the account was created by checking the AspNetUsers and AspNetUserRoles tables.
  "SystemAdministratorInitInfo": {
    "UserName": "sysadmin",
    "Email": "sysadmin@freespeakWeb.com",
    "Password": "SysAdmin123!",
    "PhoneNumber": "",
    "FirstName": "sys",
    "LastName": "admin"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=FreeSpeak;Username=youruser;Password=yourpassword"
  },
  "Caching": {
    "UseRedis": false,
    "RedisConnectionString": "localhost:6379,abortConnect=false"
  },

  // RateLimiting: Configure rate limiting policies for DOS/DDOS protection.
  // Set "UseDistributed" to true to use Redis-based distributed rate limiting (requires Caching:UseRedis = true).
  // When false, uses ASP.NET Core's built-in in-memory rate limiting (suitable for single-server deployments).
  "RateLimiting": {
    "UseDistributed": false,
    "Global": {
      "MaxRequests": 500,
      "WindowMinutes": 1,
      "QueueLimit": 20
    },
    "FileDownload": {
      "MaxRequests": 100,
      "WindowMinutes": 1,
      "QueueLimit": 10
    },
    "Login": {
      "MaxRequests": 10,
      "WindowMinutes": 5,
      "QueueLimit": 0
    },
    "Api": {
      "MaxRequests": 200,
      "WindowMinutes": 1,
      "QueueLimit": 5
    }
  },

  // VirusScan: Configure ClamAV virus scanning for uploaded files.
  // Requires a running ClamAV daemon (clamd) accessible via TCP.
  // Set "Enabled" to true and configure ClamAvHost/ClamAvPort to enable scanning.
  // FailOpen: When true, files are allowed through if ClamAV is unavailable (less secure).
  //           When false, files are rejected if scanning fails (more secure, default).
  "VirusScan": {
    "Enabled": false,
    "ClamAvHost": "localhost",
    "ClamAvPort": 3310,
    "MaxStreamSizeBytes": 104857600,
    "FailOpen": false,
    "TimeoutSeconds": 60
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
