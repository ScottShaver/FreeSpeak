@page "/Account/Manage/PersonalData"

@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using Microsoft.Extensions.Localization
@using FreeSpeakWeb.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject IOptions<SiteSettings> SiteSettings
@inject IStringLocalizer<FreeSpeakWeb.Resources.Account.Pages.Manage.ManageAccount> Localizer

<PageTitle>@SiteSettings.Value.SiteName - @Localizer["PersonalData"]</PageTitle>

<StatusMessage />
<h3>@Localizer["PersonalData"]</h3>

<div class="row">
    <div class="col-md-6">
        <p>@Localizer["DeleteAccountWarning"]</p>
        <form action="Account/Manage/DownloadPersonalData" method="post">
            <AntiforgeryToken />
            <button class="btn btn-primary" type="submit">@Localizer["Download"]</button>
        </form>
        <p>
            <a href="Account/Manage/DeletePersonalData" class="btn btn-danger">@Localizer["DeleteAccount"]</a>
        </p>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        var user  = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
        }
    }
}
