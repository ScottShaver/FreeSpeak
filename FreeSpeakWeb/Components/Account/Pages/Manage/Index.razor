@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject IOptions<SiteSettings> SiteSettings
@inject ProfilePictureService ProfilePictureService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<Index> Logger
@inject NavigationStateService NavigationState
@inject IAuditLogRepository AuditLogRepository
@inject AlertService AlertService

<PageTitle>@SiteSettings.Value.SiteName - Profile</PageTitle>

<h3>Profile</h3>
<StatusMessage Message="@statusMessage" />

<div class="row">
    <div class="col-xl-8">
        <!-- Profile Picture Section -->
        <EditForm Model="@this" FormName="profilePicture" OnValidSubmit="OnProfilePictureSubmitAsync" method="post" enctype="multipart/form-data">
            <div class="mb-4">
                <label class="form-label">Profile Picture</label>
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(user?.ProfilePictureUrl))
                    {
                        <img src="@user.ProfilePictureUrl" alt="Profile Picture" class="rounded-circle" style="width: 168px; height: 168px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center" style="width: 168px; height: 168px;">
                            <span class="text-white fs-1">@username?.Substring(0, 1).ToUpper()</span>
                        </div>
                    }
                    <div class="flex-grow-1">
                        <InputFile OnChange="OnFileSelected" class="form-control" accept="image/*" />
                        <div class="form-text">
                            Upload an image (max 5MB). Image will be resized to 168x168 pixels.
                        </div>
                        @if (!string.IsNullOrEmpty(profilePictureError))
                        {
                            <div class="text-danger mt-2">@profilePictureError</div>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-theme-primary mt-3" disabled="@(selectedFile is null)">Upload new profile picture</button>
            </div>
        </EditForm>

        <EditForm Model="Input" FormName="profile" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-floating mb-3">
                <input type="text" value="@username" id="username" class="form-control" placeholder="Choose your username." disabled />
                <label for="username" class="form-label">Username</label>
            </div>
            <div class="form-floating mb-3">
                <input type="text" value="@user?.FirstName" id="firstName" class="form-control" placeholder="First name" disabled />
                <label for="firstName" class="form-label">First Name</label>
            </div>
            <div class="form-floating mb-3">
                <input type="text" value="@user?.LastName" id="lastName" class="form-control" placeholder="Last name" disabled />
                <label for="lastName" class="form-label">Last Name</label>
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.NameSuffix" id="Input.NameSuffix" class="form-control" placeholder="Jr., Sr., III, etc." />
                <label for="Input.NameSuffix" class="form-label">Name Suffix</label>
                <ValidationMessage For="() => Input.NameSuffix" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputDate @bind-Value="Input.DateOfBirth" id="Input.DateOfBirth" class="form-control" />
                <label for="Input.DateOfBirth" class="form-label">Date of Birth</label>
                <ValidationMessage For="() => Input.DateOfBirth" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.City" id="Input.City" class="form-control" placeholder="Enter your city" />
                <label for="Input.City" class="form-label">City</label>
                <ValidationMessage For="() => Input.City" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.State" id="Input.State" class="form-control" placeholder="Enter your state" />
                <label for="Input.State" class="form-label">State</label>
                <ValidationMessage For="() => Input.State" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Occupation" id="Input.Occupation" class="form-control" placeholder="Enter your occupation" />
                <label for="Input.Occupation" class="form-label">Occupation</label>
                <ValidationMessage For="() => Input.Occupation" class="text-danger" />
            </div>
            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.PhoneNumber" id="Input.PhoneNumber" class="form-control" placeholder="Enter your phone number" />
                <label for="Input.PhoneNumber" class="form-label">Phone number</label>
                <ValidationMessage For="() => Input.PhoneNumber" class="text-danger" />
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-theme-primary">Save</button>
        </EditForm>
    </div>
</div>

@code {
    private ApplicationUser? user;
    private string? username;
    private string? phoneNumber;
    private string? statusMessage;
    private string? profilePictureError;
    private IBrowserFile? selectedFile;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        NavigationState.ActiveMenuItem = "/Account/Manage";

        Input ??= new();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        user = await UserManager.GetUserAsync(authState.User);
        if (user is null)
        {
            NavigationManager.NavigateTo("Account/InvalidUser");
            return;
        }

        username = await UserManager.GetUserNameAsync(user);
        phoneNumber = await UserManager.GetPhoneNumberAsync(user);

        Input.PhoneNumber ??= phoneNumber;
        Input.NameSuffix ??= user.NameSuffix;
        Input.DateOfBirth ??= user.DateOfBirth;
        Input.City ??= user.City;
        Input.State ??= user.State;
        Input.Occupation ??= user.Occupation;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        profilePictureError = null;
        StateHasChanged();
    }

    private async Task OnProfilePictureSubmitAsync()
    {
        if (user is null)
        {
            NavigationManager.NavigateTo("Account/InvalidUser");
            return;
        }

        if (selectedFile is null)
        {
            return;
        }

        try
        {
            using var stream = selectedFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024); // 5MB
            var result = await ProfilePictureService.SaveProfilePictureAsync(stream, user.Id);

            if (result.Success)
            {
                user.ProfilePictureUrl = result.RelativeUrl;
                await UserManager.UpdateAsync(user);

                // Log profile picture update to audit log
                await AuditLogRepository.LogActionAsync(user.Id, ActionCategory.UserUpload, new UserUploadDetails
                {
                    UploadType = "ProfilePicture",
                    FileName = selectedFile.Name,
                    ContentType = selectedFile.ContentType,
                    FileSizeBytes = selectedFile.Size,
                    Success = true,
                    StoragePath = result.RelativeUrl
                });

                statusMessage = "Your profile picture has been updated";
                AlertService.ShowSuccess("Your profile picture has been updated successfully.");
                selectedFile = null;
                profilePictureError = null;
            }
            else
            {
                profilePictureError = result.ErrorMessage;
                AlertService.ShowError($"Failed to upload profile picture: {result.ErrorMessage}");
            }
        }
        catch (IOException ex)
        {
            Logger.LogError(ex, "[{ExceptionType}] IOException while uploading profile picture for user {UserId}. File size may exceed limit. Exception: {ExceptionMessage}", ex.GetType().Name, user.Id, ex.Message);
            profilePictureError = "The file is too large. Maximum size is 5MB.";
            AlertService.ShowError("The file is too large. Maximum size is 5MB.");
        }
    }

    private async Task OnValidSubmitAsync()
    {
        if (user is null)
        {
            NavigationManager.NavigateTo("Account/InvalidUser");
            return;
        }

        // Trim all string inputs
        Input.PhoneNumber = Input.PhoneNumber?.Trim();
        Input.NameSuffix = Input.NameSuffix?.Trim();
        Input.City = Input.City?.Trim();
        Input.State = Input.State?.Trim();
        Input.Occupation = Input.Occupation?.Trim();

        // Additional server-side validation for field lengths
        if (Input.NameSuffix?.Length > 75)
        {
            statusMessage = "Error: Name Suffix cannot exceed 75 characters.";
            AlertService.ShowError("Name Suffix cannot exceed 75 characters.");
            return;
        }
        if (Input.City?.Length > 75)
        {
            statusMessage = "Error: City cannot exceed 75 characters.";
            AlertService.ShowError("City cannot exceed 75 characters.");
            return;
        }
        if (Input.State?.Length > 75)
        {
            statusMessage = "Error: State cannot exceed 75 characters.";
            AlertService.ShowError("State cannot exceed 75 characters.");
            return;
        }
        if (Input.Occupation?.Length > 75)
        {
            statusMessage = "Error: Occupation cannot exceed 75 characters.";
            AlertService.ShowError("Occupation cannot exceed 75 characters.");
            return;
        }

        var hasChanges = false;

        // Handle phone number update
        if (Input.PhoneNumber != phoneNumber)
        {
            var setPhoneResult = await UserManager.SetPhoneNumberAsync(user, Input.PhoneNumber);
            if (!setPhoneResult.Succeeded)
            {
                statusMessage = "Error: Failed to set phone number.";
                AlertService.ShowError("Failed to set phone number.");
                return;
            }
            hasChanges = true;
        }

        // Update profile fields
        if (Input.NameSuffix != user.NameSuffix)
        {
            user.NameSuffix = Input.NameSuffix;
            hasChanges = true;
        }

        if (Input.DateOfBirth != user.DateOfBirth)
        {
            user.DateOfBirth = Input.DateOfBirth;
            hasChanges = true;
        }

        if (Input.City != user.City)
        {
            user.City = Input.City;
            hasChanges = true;
        }

        if (Input.State != user.State)
        {
            user.State = Input.State;
            hasChanges = true;
        }

        if (Input.Occupation != user.Occupation)
        {
            user.Occupation = Input.Occupation;
            hasChanges = true;
        }

        if (hasChanges)
        {
            var updateResult = await UserManager.UpdateAsync(user);
            if (!updateResult.Succeeded)
            {
                statusMessage = "Error: Failed to update profile.";
                AlertService.ShowError("Failed to update profile.");
                return;
            }

            // Log profile update to audit log
            await AuditLogRepository.LogActionAsync(user.Id, ActionCategory.UserProfileChange, new UserProfileChangeDetails
            {
                FieldName = "Profile",
                Notes = "Profile information updated"
            });

            statusMessage = "Your profile has been updated";
            AlertService.ShowSuccess("Your profile has been updated successfully.");
        }
    }

    private sealed class InputModel
    {
        [Phone]
        [Display(Name = "Phone number")]
        [StringLength(256, ErrorMessage = "The {0} must be at max {1} characters long.")]
        public string? PhoneNumber { get; set; }

        [StringLength(75, ErrorMessage = "The {0} must be at max {1} characters long.")]
        [Display(Name = "Name Suffix")]
        public string? NameSuffix { get; set; }

        [Display(Name = "Date of Birth")]
        public DateOnly? DateOfBirth { get; set; }

        [StringLength(75, ErrorMessage = "The {0} must be at max {1} characters long.")]
        [Display(Name = "City")]
        public string? City { get; set; }

        [StringLength(75, ErrorMessage = "The {0} must be at max {1} characters long.")]
        [Display(Name = "State")]
        public string? State { get; set; }

        [StringLength(75, ErrorMessage = "The {0} must be at max {1} characters long.")]
        [Display(Name = "Occupation")]
        public string? Occupation { get; set; }
    }
}
