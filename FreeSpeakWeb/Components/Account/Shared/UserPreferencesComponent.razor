@rendermode InteractiveServer

@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@inject UserPreferenceService PreferenceService
@inject UserManager<ApplicationUser> UserManager
@inject ThemeService ThemeService
@inject IAuditLogRepository AuditLogRepository
@inject AlertService AlertService
@inject NavigationManager navigationManager
@inject IStringLocalizer<FreeSpeakWeb.Resources.Account.Shared.UserPreferencesComponent> Localizer

<div class="card mb-4">
    <div class="card-header">
        <h5 class="mb-0">@Localizer["Preferences"]</h5>
    </div>
    <div class="card-body">
        @if (isLoading)
        {
            <div class="text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Localizer["Loading"]</span>
                </div>
            </div>
        }
        else
        {
            <EditForm Model="@this" OnValidSubmit="SavePreferences">
                <!-- Color Scheme -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["ColorScheme"]</label>
                    <select class="form-select" @bind="colorScheme">
                        @foreach (var theme in ThemeService.AvailableThemes)
                        {
                            <option value="@theme.Key">@theme.Value</option>
                        }
                    </select>
                    <div class="form-text">@Localizer["ColorSchemeHelpText"]</div>
                </div>

                <!-- Name Display -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["NameDisplay"]</label>
                    <select class="form-select" @bind="nameDisplay">
                        <option value="@NameDisplayType.FullName">@Localizer["NameDisplayFullName"]</option>
                        <option value="@NameDisplayType.FirstName">@Localizer["NameDisplayFirstName"]</option>
                        <option value="@NameDisplayType.Username">@Localizer["NameDisplayUsername"]</option>
                        <option value="@NameDisplayType.FirstNameLastInitial">@Localizer["NameDisplayFirstNameLastInitial"]</option>
                    </select>
                    <div class="form-text">@Localizer["NameDisplayHelpText"]</div>
                </div>

                <!-- Default Audience Type -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["DefaultPostVisibility"]</label>
                    <select class="form-select" @bind="defaultAudienceType">
                        <option value="@AudienceType.Public">@Localizer["AudiencePublic"]</option>
                        <option value="@AudienceType.FriendsOnly">@Localizer["AudienceFriendsOnly"]</option>
                        <option value="@AudienceType.MeOnly">@Localizer["AudienceMeOnly"]</option>
                    </select>
                    <div class="form-text">@Localizer["DefaultPostVisibilityHelpText"]</div>
                </div>

                <!-- Timezone -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["Timezone"]</label>
                    <select class="form-select" @bind="timezone">
                        <optgroup label="@Localizer["TimezoneGroupUS"]">
                            <option value="America/New_York">Eastern Time (ET)</option>
                            <option value="America/Chicago">Central Time (CT)</option>
                            <option value="America/Denver">Mountain Time (MT)</option>
                            <option value="America/Phoenix">Arizona (MST - No DST)</option>
                            <option value="America/Los_Angeles">Pacific Time (PT)</option>
                            <option value="America/Anchorage">Alaska Time (AKT)</option>
                            <option value="Pacific/Honolulu">Hawaii Time (HST)</option>
                        </optgroup>
                        <optgroup label="@Localizer["TimezoneGroupOther"]">
                            <option value="UTC">UTC (Coordinated Universal Time)</option>
                            <option value="Europe/London">London (GMT/BST)</option>
                            <option value="Europe/Paris">Paris (CET/CEST)</option>
                            <option value="Europe/Berlin">Berlin (CET/CEST)</option>
                            <option value="Asia/Tokyo">Tokyo (JST)</option>
                            <option value="Asia/Shanghai">Shanghai (CST)</option>
                            <option value="Asia/Dubai">Dubai (GST)</option>
                            <option value="Australia/Sydney">Sydney (AEDT/AEST)</option>
                            <option value="America/Toronto">Toronto (ET)</option>
                            <option value="America/Mexico_City">Mexico City (CST)</option>
                        </optgroup>
                    </select>
                    <div class="form-text">@Localizer["TimezoneHelpText"]</div>
                </div>

                <!-- Country -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["Country"]</label>
                    <select class="form-select" @bind="country">
                        <option value="US">United States of America</option>
                        <option value="CA">Canada</option>
                        <option value="GB">United Kingdom</option>
                        <option value="AU">Australia</option>
                        <option value="DE">Germany</option>
                        <option value="FR">France</option>
                        <option value="IT">Italy</option>
                        <option value="ES">Spain</option>
                        <option value="MX">Mexico</option>
                        <option value="BR">Brazil</option>
                        <option value="AR">Argentina</option>
                        <option value="JP">Japan</option>
                        <option value="CN">China</option>
                        <option value="IN">India</option>
                        <option value="KR">South Korea</option>
                        <option value="NL">Netherlands</option>
                        <option value="BE">Belgium</option>
                        <option value="CH">Switzerland</option>
                        <option value="SE">Sweden</option>
                        <option value="NO">Norway</option>
                        <option value="DK">Denmark</option>
                        <option value="FI">Finland</option>
                        <option value="PL">Poland</option>
                        <option value="RU">Russia</option>
                        <option value="ZA">South Africa</option>
                    </select>
                    <div class="form-text">@Localizer["CountryHelpText"]</div>
                </div>

                <!-- Culture (Language & Region) -->
                <div class="mb-4">
                    <label class="form-label fw-bold">@Localizer["LanguageRegion"]</label>
                    <select class="form-select" @bind="culture">
                        <optgroup label="@Localizer["LanguageGroupEnglish"]">
                            <option value="en-US">English (United States)</option>
                            <option value="en-GB">English (United Kingdom)</option>
                            <option value="en-AU">English (Australia)</option>
                            <option value="en-CA">English (Canada)</option>
                        </optgroup>
                        <optgroup label="@Localizer["LanguageGroupSpanish"]">
                            <option value="es-ES">Español (España)</option>
                            <option value="es-MX">Español (México)</option>
                            <option value="es-AR">Español (Argentina)</option>
                        </optgroup>
                        <optgroup label="@Localizer["LanguageGroupFrench"]">
                            <option value="fr-FR">Français (France)</option>
                            <option value="fr-CA">Français (Canada)</option>
                            <option value="fr-BE">Français (Belgique)</option>
                        </optgroup>
                        <optgroup label="@Localizer["LanguageGroupGerman"]">
                            <option value="de-DE">Deutsch (Deutschland)</option>
                            <option value="de-AT">Deutsch (Österreich)</option>
                            <option value="de-CH">Deutsch (Schweiz)</option>
                        </optgroup>
                        <optgroup label="@Localizer["LanguageGroupOther"]">
                            <option value="it-IT">Italiano (Italia)</option>
                            <option value="pt-BR">Português (Brasil)</option>
                            <option value="pt-PT">Português (Portugal)</option>
                            <option value="nl-NL">Nederlands (Nederland)</option>
                            <option value="pl-PL">Polski (Polska)</option>
                            <option value="ru-RU">Русский (Россия)</option>
                            <option value="ja-JP">日本語 (日本)</option>
                            <option value="zh-CN">中文 (中国)</option>
                            <option value="zh-TW">中文 (台灣)</option>
                            <option value="ko-KR">한국어 (대한민국)</option>
                            <option value="ar-SA">العربية (السعودية)</option>
                        </optgroup>
                    </select>
                    <div class="form-text">@Localizer["LanguageRegionHelpText"]</div>
                </div>

                <!-- Notification Expiration -->
                <div class="mb-4">
                    <label class="form-label fw-bold mb-3">@Localizer["NotificationExpiration"]</label>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["PostReactions"]</label>
                            <input type="number" class="form-control" @bind="expirationPostLiked" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["PostComments"]</label>
                            <input type="number" class="form-control" @bind="expirationPostComment" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["CommentReplies"]</label>
                            <input type="number" class="form-control" @bind="expirationCommentReply" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["CommentReactions"]</label>
                            <input type="number" class="form-control" @bind="expirationCommentLiked" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["FriendRequests"]</label>
                            <input type="number" class="form-control" @bind="expirationFriendRequest" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["FriendAccepted"]</label>
                            <input type="number" class="form-control" @bind="expirationFriendAccepted" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["Mentions"]</label>
                            <input type="number" class="form-control" @bind="expirationMention" min="1" max="365" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">@Localizer["SystemNotifications"]</label>
                            <input type="number" class="form-control" @bind="expirationSystem" min="1" max="365" />
                        </div>
                    </div>
                    <div class="form-text mt-2">
                        @Localizer["NotificationExpirationHelpText"]
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert @(statusMessage.Contains("success") || statusMessage.Contains("✓") ? "alert-success" : "alert-danger")" role="alert">
                        @statusMessage
                    </div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        @Localizer["SavePreferences"]
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="ResetToDefaults" disabled="@isSaving">
                        @Localizer["ResetToDefaults"]
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? UserId { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;
    private string? statusMessage;

    // Preference values
    private string colorScheme = "default";
    private NameDisplayType nameDisplay = NameDisplayType.FullName;
    private AudienceType defaultAudienceType = AudienceType.Public;
    private string timezone = "America/New_York";
    private string country = "US";
    private string culture = "en-US";
    private int expirationPostLiked = 15;
    private int expirationPostComment = 15;
    private int expirationCommentReply = 15;
    private int expirationCommentLiked = 15;
    private int expirationFriendRequest = 30;
    private int expirationFriendAccepted = 15;
    private int expirationMention = 30;
    private int expirationSystem = 30;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(UserId))
        {
            return;
        }

        await LoadPreferences();
    }

    private async Task LoadPreferences()
    {
        isLoading = true;
        statusMessage = null;

        try
        {
            var preferences = await PreferenceService.GetAllPreferencesAsync(UserId!);

            colorScheme = preferences.GetValueOrDefault(PreferenceType.ColorScheme, "default");

            if (Enum.TryParse<NameDisplayType>(preferences.GetValueOrDefault(PreferenceType.NameDisplay), out var nd))
                nameDisplay = nd;

            if (Enum.TryParse<AudienceType>(preferences.GetValueOrDefault(PreferenceType.DefaultAudienceType), out var at))
                defaultAudienceType = at;

            timezone = preferences.GetValueOrDefault(PreferenceType.Timezone, "America/New_York");
            country = preferences.GetValueOrDefault(PreferenceType.Country, "US");
            culture = preferences.GetValueOrDefault(PreferenceType.Culture, "en-US");

            expirationPostLiked = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_PostLiked, "15"));
            expirationPostComment = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_PostComment, "15"));
            expirationCommentReply = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_CommentReply, "15"));
            expirationCommentLiked = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_CommentLiked, "15"));
            expirationFriendRequest = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_FriendRequest, "30"));
            expirationFriendAccepted = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_FriendAccepted, "15"));
            expirationMention = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_Mention, "30"));
            expirationSystem = int.Parse(preferences.GetValueOrDefault(PreferenceType.NotificationExpiration_System, "30"));
        }
        catch (Exception ex)
        {
            statusMessage = $"Error loading preferences: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Saves the user's preferences to the database.
    /// </summary>
    private async Task SavePreferences()
    {
        isSaving = true;
        statusMessage = null;

        try
        {
            // Get current preferences to detect culture changes
            var currentPrefs = await PreferenceService.GetAllPreferencesAsync(UserId!);
            var oldCulture = currentPrefs.GetValueOrDefault(PreferenceType.Culture, "en-US");

            var preferences = new Dictionary<PreferenceType, string>
            {
                { PreferenceType.ColorScheme, colorScheme },
                { PreferenceType.NameDisplay, nameDisplay.ToString() },
                { PreferenceType.DefaultAudienceType, defaultAudienceType.ToString() },
                { PreferenceType.Timezone, timezone },
                { PreferenceType.Country, country },
                { PreferenceType.Culture, culture },
                { PreferenceType.NotificationExpiration_PostLiked, expirationPostLiked.ToString() },
                { PreferenceType.NotificationExpiration_PostComment, expirationPostComment.ToString() },
                { PreferenceType.NotificationExpiration_CommentReply, expirationCommentReply.ToString() },
                { PreferenceType.NotificationExpiration_CommentLiked, expirationCommentLiked.ToString() },
                { PreferenceType.NotificationExpiration_FriendRequest, expirationFriendRequest.ToString() },
                { PreferenceType.NotificationExpiration_FriendAccepted, expirationFriendAccepted.ToString() },
                { PreferenceType.NotificationExpiration_Mention, expirationMention.ToString() },
                { PreferenceType.NotificationExpiration_System, expirationSystem.ToString() }
            };

            var success = await PreferenceService.SetPreferencesAsync(UserId!, preferences);

            if (success)
            {
                // Apply theme immediately
                await ThemeService.SetThemeAsync(colorScheme);

                // Log the preference change to audit log
                await AuditLogRepository.LogActionAsync(UserId!, ActionCategory.UserPreference, new UserPreferenceDetails
                {
                    PreferenceCategory = "All",
                    SettingName = "BulkUpdate",
                    NewValue = "Multiple preferences updated"
                });

                // Check if culture changed - requires page reload to apply new localization
                bool cultureChanged = oldCulture != culture;

                if (cultureChanged)
                {
                    statusMessage = "✓ Preferences saved successfully! Reloading page to apply language changes...";
                    AlertService.ShowSuccess("Preferences saved. Reloading page to apply language changes...");

                    // Reload the page after a short delay to apply new culture
                    await Task.Delay(1500);
                    navigationManager.NavigateTo(navigationManager.Uri, forceLoad: true);
                }
                else
                {
                    statusMessage = "✓ Preferences saved successfully!";
                    AlertService.ShowSuccess("Your preferences have been saved.");
                }
            }
            else
            {
                statusMessage = "Error saving preferences. Please try again.";
                AlertService.ShowError("Failed to save preferences. Please try again.");
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Error: {ex.Message}";
            AlertService.ShowError($"An error occurred while saving preferences.");
        }
        finally
        {
            isSaving = false;
        }
    }

    /// <summary>
    /// Resets all preferences to their default values and saves them.
    /// </summary>
    private async Task ResetToDefaults()
    {
        colorScheme = "default";
        nameDisplay = NameDisplayType.FullName;
        defaultAudienceType = AudienceType.FriendsOnly;
        timezone = "America/New_York";
        country = "US";
        culture = "en-US";
        expirationPostLiked = 15;
        expirationPostComment = 15;
        expirationCommentReply = 15;
        expirationCommentLiked = 15;
        expirationFriendRequest = 30;
        expirationFriendAccepted = 15;
        expirationMention = 30;
        expirationSystem = 30;

        // Log the reset action to audit log
        await AuditLogRepository.LogActionAsync(UserId!, ActionCategory.UserPreference, new UserPreferenceDetails
        {
            PreferenceCategory = "All",
            SettingName = "ResetToDefaults",
            NewValue = "All preferences reset to defaults"
        });

        await SavePreferences();
    }
}
