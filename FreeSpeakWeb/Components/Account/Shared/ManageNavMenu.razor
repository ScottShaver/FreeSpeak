@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@using FreeSpeakWeb.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject IStringLocalizer<FreeSpeakWeb.Resources.Account.Pages.Manage.ManageAccount> Localizer

<ul class="nav nav-pills flex-column">
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage" Match="NavLinkMatch.All" data-enhance-nav="false">@Localizer["Profile"]</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/Email" data-enhance-nav="false">@Localizer["Email"]</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/ChangePassword" data-enhance-nav="false">@Localizer["Password"]</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/Preferences" data-enhance-nav="false">@Localizer["Preferences"]</NavLink>
    </li>
    @if (hasExternalLogins)
    {
        <li class="nav-item">
            <NavLink class="nav-link" href="Account/Manage/ExternalLogins" data-enhance-nav="false">@Localizer["ExternalLogins"]</NavLink>
        </li>
    }
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/TwoFactorAuthentication" data-enhance-nav="false">@Localizer["TwoFactorAuthentication"]</NavLink>
    </li>
    <li class="nav-item">
        <NavLink class="nav-link" href="Account/Manage/PersonalData" data-enhance-nav="false">@Localizer["PersonalData"]</NavLink>
    </li>
</ul>

@code {
    private bool hasExternalLogins;

    protected override async Task OnInitializedAsync()
    {
        hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
    }
}
