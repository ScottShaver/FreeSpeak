@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Services.Abstractions
@using FreeSpeakWeb.DTOs
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.SocialFeed
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization

@inject GroupService GroupService
@inject GroupMemberService GroupMemberService
@inject GroupPostService GroupPostService
@inject GroupContentReportService ReportService
@inject IGroupFileService GroupFileService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<GroupModerationModal> Logger
@inject IStringLocalizer<FreeSpeakWeb.Resources.Groups.GroupModerationModal> Localizer

<div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0, 0, 0, 0.5);">
    <div class="modal-dialog modal-dialog-centered modal-xl" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-shield-check me-2"></i>@Localizer["Title"]
                </h5>
                <button type="button" class="btn-close" @onclick="OnClose" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (isLoading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">@Localizer["Loading"]</span>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Tab Navigation -->
                    <ul class="nav nav-tabs mb-4" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(activeTab == "reported" ? "active" : "")" 
                                    type="button" 
                                    @onclick="@(() => SetActiveTab("reported"))">
                                <i class="bi bi-flag me-1"></i>@Localizer["ReportedContent"]
                                @if (reportedContentCount > 0)
                                {
                                    <span class="badge bg-warning ms-1">@reportedContentCount</span>
                                }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(activeTab == "pending" ? "active" : "")" 
                                    type="button" 
                                    @onclick="@(() => SetActiveTab("pending"))">
                                    <i class="bi bi-hourglass-split me-1"></i>@Localizer["PendingApproval"]
                                        @if (pendingPostsCount > 0)
                                        {
                                            <span class="badge bg-info ms-1">@pendingPostsCount</span>
                                        }
                                    </button>
                                </li>
                                @if (Group.EnableFileUploads && Group.RequiresFileApproval)
                                {
                                    <li class="nav-item" role="presentation">
                                        <button class="nav-link @(activeTab == "pendingfiles" ? "active" : "")" 
                                                type="button" 
                                                @onclick="@(() => SetActiveTab("pendingfiles"))">
                                            <i class="bi bi-folder2 me-1"></i>@Localizer["PendingFiles"]
                                            @if (pendingFilesCount > 0)
                                            {
                                                <span class="badge bg-info ms-1">@pendingFilesCount</span>
                                            }
                                        </button>
                                    </li>
                                }
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link @(activeTab == "modlog" ? "active" : "")"
                                    type="button" 
                                    @onclick="@(() => SetActiveTab("modlog"))">
                                <i class="bi bi-journal-text me-1"></i>@Localizer["ModerationLog"]
                            </button>
                        </li>
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content">
                        @if (activeTab == "reported")
                        {
                            <div class="tab-pane fade show active">
                                @if (!showReportDetail)
                                {
                                    <h6 class="mb-3">@Localizer["ReportedContentDescription"]</h6>

                                    @if (isLoadingReports)
                                    {
                                        <div class="text-center py-4">
                                            <div class="spinner-border text-primary" role="status">
                                                <span class="visually-hidden">@Localizer["Loading"]</span>
                                            </div>
                                        </div>
                                    }
                                    else if (!pendingReports.Any())
                                    {
                                        <div class="alert alert-success">
                                            <i class="bi bi-check-circle me-2"></i>@Localizer["NoReports"]
                                        </div>
                                    }
                                    else
                                    {
                                        @foreach (var report in pendingReports)
                                        {
                                            <div class="card mb-3">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div class="flex-grow-1">
                                                            <div class="d-flex align-items-center mb-2">
                                                                <i class="@GetReasonIcon(report.Reason) text-danger me-2"></i>
                                                                <strong>@GetReasonDisplayName(report.Reason)</strong>
                                                                @if (report.Reason == ReportReason.ViolatesGroupRule && report.ViolatedRule != null)
                                                                {
                                                                    <span class="ms-2 badge bg-secondary">@report.ViolatedRule.Title</span>
                                                                }
                                                            </div>
                                                            <div class="small text-muted mb-1">
                                                                <i class="bi bi-person me-1"></i>
                                                                <span>@Localizer["ReportedBy"] @GetReporterName(report)</span>
                                                                <span class="mx-2">•</span>
                                                                <i class="bi bi-clock me-1"></i>
                                                                <span>@GetRelativeTime(report.CreatedAt)</span>
                                                            </div>
                                                            <div class="small">
                                                                <span class="badge bg-info me-2">
                                                                    @if (report.PostId.HasValue)
                                                                    {
                                                                        <i class="bi bi-file-text me-1"></i>@Localizer["Post"]
                                                                    }
                                                                    else
                                                                    {
                                                                        <i class="bi bi-chat-left-text me-1"></i>@Localizer["Comment"]
                                                                    }
                                                                </span>
                                                                <span class="text-muted">@GetContentPreview(report)</span>
                                                            </div>
                                                        </div>
                                                        <div class="d-flex flex-column gap-2 ms-3">
                                                            @if (report.PostId.HasValue)
                                                            {
                                                                <button type="button" 
                                                                        class="btn btn-outline-primary btn-sm" 
                                                                        @onclick="@(() => ViewReportedPost(report))"
                                                                        title="@Localizer["ViewPostTooltip"]">
                                                                    <i class="bi bi-eye me-1"></i>@Localizer["View"]
                                                                </button>
                                                            }
                                                            <button type="button" 
                                                                    class="btn btn-outline-warning btn-sm" 
                                                                    @onclick="@(() => ShowReportDetail(report))"
                                                                    title="@Localizer["ModerateTooltip"]">
                                                                <i class="bi bi-shield-check me-1"></i>@Localizer["Moderate"]
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                                else if (selectedReport != null)
                                {
                                    <!-- Report Detail View -->
                                    <div class="report-detail">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <button type="button" class="btn btn-link p-0" @onclick="CloseReportDetail">
                                                <i class="bi bi-arrow-left me-1"></i>@Localizer["BackToList"]
                                            </button>
                                        </div>

                                        <div class="card mb-3">
                                            <div class="card-header bg-danger text-white">
                                                <h6 class="mb-0">
                                                    <i class="@GetReasonIcon(selectedReport.Reason) me-2"></i>
                                                    @GetReasonDisplayName(selectedReport.Reason)
                                                </h6>
                                            </div>
                                            <div class="card-body">
                                                @if (selectedReport.Reason == ReportReason.ViolatesGroupRule && selectedReport.ViolatedRule != null)
                                                {
                                                    <div class="alert alert-warning mb-3">
                                                        <strong>@Localizer["ViolatedRule"]</strong>
                                                        <p class="mb-0">@selectedReport.ViolatedRule.Title</p>
                                                        <small class="text-muted">@selectedReport.ViolatedRule.Description</small>
                                                    </div>
                                                }

                                                <div class="mb-3">
                                                    <strong>@Localizer["ReportedBy"]</strong>
                                                    <p class="mb-0">@GetReporterName(selectedReport) • @GetRelativeTime(selectedReport.CreatedAt)</p>
                                                </div>

                                                @if (!string.IsNullOrEmpty(selectedReport.Description))
                                                {
                                                    <div class="mb-3">
                                                        <strong>@Localizer["ReporterDescription"]</strong>
                                                        <p class="mb-0">@selectedReport.Description</p>
                                                    </div>
                                                }
                                            </div>
                                        </div>

                                        <div class="card mb-3">
                                            <div class="card-header">
                                                <h6 class="mb-0">
                                                    @if (selectedReport.PostId.HasValue)
                                                    {
                                                        <i class="bi bi-file-text me-2"></i>@Localizer["ReportedPost"]
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-chat-left-text me-2"></i>@Localizer["ReportedComment"]
                                                    }
                                                </h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="mb-2">
                                                    <strong>@Localizer["Author"]</strong>
                                                    <span class="ms-2">@GetContentAuthorName(selectedReport)</span>
                                                </div>
                                                <div class="content-preview p-3 bg-light rounded">
                                                    @if (selectedReport.PostId.HasValue && selectedReport.Post != null)
                                                    {
                                                        <p class="mb-0">@selectedReport.Post.Content</p>
                                                    }
                                                    else if (selectedReport.CommentId.HasValue && selectedReport.Comment != null)
                                                    {
                                                        <p class="mb-0">@selectedReport.Comment.Content</p>
                                                    }
                                                    else
                                                    {
                                                        <p class="mb-0 text-muted fst-italic">@Localizer["ContentDeleted"]</p>
                                                    }
                                                </div>
                                            </div>
                                        </div>

                                        <div class="card">
                                            <div class="card-header">
                                                <h6 class="mb-0">@Localizer["ModeratorNotes"]</h6>
                                            </div>
                                            <div class="card-body">
                                                <textarea class="form-control mb-3" 
                                                          rows="3" 
                                                          maxlength="2000"
                                                          @bind="reviewerNotes"
                                                          placeholder="@Localizer["NotesPlaceholder"]"></textarea>
                                                <div class="d-flex gap-2 flex-wrap">
                                                    <button type="button" 
                                                            class="btn btn-success" 
                                                            @onclick="DismissReport"
                                                            disabled="@(processingReportId.HasValue)">
                                                        @if (processingReportId == selectedReport.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        <i class="bi bi-x-circle me-1"></i>@Localizer["DismissReport"]
                                                    </button>
                                                    <button type="button" 
                                                            class="btn btn-danger" 
                                                            @onclick="TakeActionOnReport"
                                                            disabled="@(processingReportId.HasValue)">
                                                        @if (processingReportId == selectedReport.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        <i class="bi bi-shield-exclamation me-1"></i>@Localizer["TakeAction"]
                                                    </button>
                                                    <button type="button" 
                                                            class="btn btn-secondary" 
                                                            @onclick="ResolveReport"
                                                            disabled="@(processingReportId.HasValue)">
                                                        @if (processingReportId == selectedReport.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        <i class="bi bi-check-circle me-1"></i>@Localizer["Resolve"]
                                                    </button>
                                                </div>
                                                <div class="mt-2 small text-muted">
                                                    <strong>@Localizer["ActionExplanation"]</strong><br/>
                                                    <strong>@Localizer["DismissReport"]:</strong> @Localizer["DismissExplanation"]<br/>
                                                    <strong>@Localizer["TakeAction"]:</strong> @Localizer["ActionExplanation2"]<br/>
                                                    <strong>@Localizer["Resolve"]:</strong> @Localizer["ResolveExplanation"]
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else if (activeTab == "pending")
                        {
                            <div class="tab-pane fade show active">
                                @if (!Group.RequiresPostApproval)
                                {
                                    <div class="alert alert-info">
                                        <i class="bi bi-info-circle me-2"></i>@Localizer["PostApprovalDisabled"]
                                    </div>
                                }
                                else if (isLoadingPendingPosts)
                                {
                                    <div class="text-center py-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">@Localizer["Loading"]</span>
                                        </div>
                                    </div>
                                }
                                else if (showPendingPostDetail && selectedPendingPost != null)
                                {
                                    <!-- Pending Post Detail View -->
                                    <div class="pending-post-detail">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <button type="button" class="btn btn-link p-0" @onclick="ClosePendingPostDetail">
                                                <i class="bi bi-arrow-left me-1"></i>@Localizer["BackToList"]
                                            </button>
                                        </div>

                                        <div class="card mb-3">
                                            <div class="card-header">
                                                <div class="d-flex align-items-center">
                                                    <UserAvatar ImageUrl="@selectedPendingPost.Author?.ProfilePictureUrl"
                                                                Name="@GetPostAuthorName(selectedPendingPost)"
                                                                Size="md" />
                                                    <div class="ms-3">
                                                        <h6 class="mb-0">@GetPostAuthorName(selectedPendingPost)</h6>
                                                        <small class="text-muted">
                                                            <i class="bi bi-clock me-1"></i>@Localizer["PostedAt"] @GetRelativeTime(selectedPendingPost.CreatedAt)
                                                        </small>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card-body">
                                                <div class="post-content mb-3">
                                                    <p class="mb-0" style="white-space: pre-wrap;">@selectedPendingPost.Content</p>
                                                </div>
                                                @if (selectedPendingPost.Images != null && selectedPendingPost.Images.Any())
                                                {
                                                    <div class="post-images mt-3">
                                                        <h6 class="mb-2">
                                                            <i class="bi bi-images me-1"></i>@Localizer["AttachedImages"] (@selectedPendingPost.Images.Count)
                                                        </h6>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            @foreach (var image in selectedPendingPost.Images)
                                                            {
                                                                <img src="@image.ImageUrl" 
                                                                     alt="Post image" 
                                                                     class="img-thumbnail" 
                                                                     style="max-width: 200px; max-height: 200px; object-fit: cover;" />
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                            <div class="card-footer">
                                                <div class="d-flex gap-2">
                                                    <button type="button" 
                                                            class="btn btn-success" 
                                                            @onclick="@(() => ApprovePostFromDetail())"
                                                            disabled="@(processingPostId == selectedPendingPost.Id)">
                                                        @if (processingPostId == selectedPendingPost.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-check-lg me-1"></i>
                                                        }
                                                        @Localizer["Approve"]
                                                    </button>
                                                    <button type="button" 
                                                            class="btn btn-danger" 
                                                            @onclick="@(() => DeclinePostFromDetail())"
                                                            disabled="@(processingPostId == selectedPendingPost.Id)">
                                                        @if (processingPostId == selectedPendingPost.Id)
                                                        {
                                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-x-lg me-1"></i>
                                                        }
                                                        @Localizer["Decline"]
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6 class="mb-0">@Localizer["PendingApprovalDescription"]</h6>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="LoadPendingPostsAsync" disabled="@isLoadingPendingPosts">
                                            <i class="bi bi-arrow-clockwise me-1"></i>@Localizer["Refresh"]
                                        </button>
                                    </div>

                                    @if (!pendingPosts.Any())
                                    {
                                        <div class="alert alert-success">
                                            <i class="bi bi-check-circle me-2"></i>@Localizer["NoPendingPosts"]
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted small mb-3">
                                            <i class="bi bi-info-circle me-1"></i>@pendingPosts.Count @Localizer["PendingPostsCount"]
                                        </div>

                                        @foreach (var post in pendingPosts.OrderBy(p => p.CreatedAt))
                                        {
                                            <div class="card mb-3">
                                                <div class="card-body">
                                                    <div class="d-flex justify-content-between align-items-start">
                                                        <div class="d-flex align-items-start flex-grow-1">
                                                            <div class="me-3">
                                                                <UserAvatar ImageUrl="@post.Author?.ProfilePictureUrl"
                                                                            Name="@GetPostAuthorName(post)"
                                                                            Size="md" />
                                                            </div>
                                                            <div class="flex-grow-1">
                                                                <h6 class="mb-1">@GetPostAuthorName(post)</h6>
                                                                <small class="text-muted">
                                                                    <i class="bi bi-clock me-1"></i>@Localizer["PostedAt"] @GetRelativeTime(post.CreatedAt)
                                                                </small>
                                                                <p class="mt-2 mb-2">@TruncateContent(post.Content, 300)</p>
                                                                @if (post.Images != null && post.Images.Any())
                                                                {
                                                                    <div class="mb-2">
                                                                        <span class="badge bg-secondary">
                                                                            <i class="bi bi-image me-1"></i>@post.Images.Count @Localizer["Images"]
                                                                        </span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="d-flex flex-column gap-2 ms-3">
                                                            <button type="button" 
                                                                    class="btn btn-outline-primary btn-sm" 
                                                                    @onclick="@(() => ViewPendingPost(post))"
                                                                    title="@Localizer["ViewPostTooltip"]">
                                                                <i class="bi bi-eye me-1"></i>@Localizer["View"]
                                                            </button>
                                                            <button type="button" 
                                                                    class="btn btn-outline-warning btn-sm" 
                                                                    @onclick="@(() => ShowPendingPostDetail(post))"
                                                                    title="@Localizer["ModerateTooltip"]">
                                                                <i class="bi bi-shield-check me-1"></i>@Localizer["Moderate"]
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                        }
                        else if (activeTab == "pendingfiles")
                        {
                            <div class="tab-pane fade show active">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="mb-0">@Localizer["PendingFilesDescription"]</h6>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="LoadPendingFilesAsync" disabled="@isLoadingPendingFiles">
                                        <i class="bi bi-arrow-clockwise me-1"></i>@Localizer["Refresh"]
                                    </button>
                                </div>

                                @if (isLoadingPendingFiles)
                                {
                                    <div class="text-center py-4">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">@Localizer["Loading"]</span>
                                        </div>
                                    </div>
                                }
                                else if (!pendingFiles.Any())
                                {
                                    <div class="alert alert-success">
                                        <i class="bi bi-check-circle me-2"></i>@Localizer["NoPendingFiles"]
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small mb-3">
                                        @Localizer["ShowingPendingFiles", pendingFiles.Count]
                                    </div>
                                    @foreach (var file in pendingFiles)
                                    {
                                        <div class="card mb-3">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="d-flex align-items-start flex-grow-1">
                                                        <div class="me-3">
                                                            <i class="bi @file.FileIcon fs-2 @GetFileIconColorClass(file)"></i>
                                                        </div>
                                                        <div class="flex-grow-1">
                                                            <h6 class="mb-1">@file.OriginalFileName</h6>
                                                            @if (!string.IsNullOrWhiteSpace(file.Description))
                                                            {
                                                                <p class="text-muted small mb-1">@file.Description</p>
                                                            }
                                                            <div class="small text-muted">
                                                                <span class="me-3"><i class="bi bi-hdd me-1"></i>@file.FormattedFileSize</span>
                                                                <span><i class="bi bi-clock me-1"></i>@file.RelativeUploadTime</span>
                                                            </div>
                                                            <div class="small text-muted mt-1">
                                                                <i class="bi bi-person me-1"></i>@Localizer["UploadedBy"] @file.UploaderName
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex flex-column gap-2 ms-3">
                                                        <button type="button" 
                                                                class="btn btn-success btn-sm" 
                                                                @onclick="@(() => ApproveFile(file.Id))"
                                                                disabled="@(processingFileId == file.Id)"
                                                                title="@Localizer["ApproveTooltip"]">
                                                            @if (processingFileId == file.Id)
                                                            {
                                                                <span class="spinner-border spinner-border-sm"></span>
                                                            }
                                                            else
                                                            {
                                                                <i class="bi bi-check-lg me-1"></i>
                                                            }
                                                            @Localizer["Approve"]
                                                        </button>
                                                        <button type="button" 
                                                                class="btn btn-danger btn-sm" 
                                                                @onclick="@(() => OpenDeclineFileModal(file))"
                                                                disabled="@(processingFileId == file.Id)"
                                                                title="@Localizer["DeclineTooltip"]">
                                                            <i class="bi bi-x-lg me-1"></i>@Localizer["Decline"]
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        }
                        else if (activeTab == "modlog")
                        {
                            <div class="tab-pane fade show active">
                                <h6 class="mb-3">@Localizer["ModerationLogDescription"]</h6>
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle me-2"></i>@Localizer["ModerationLogPlaceholder"]
                                </div>
                                <!-- Future: Log of moderation actions taken -->
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success mt-3" role="alert">
                            <i class="bi bi-check-circle me-2"></i>@successMessage
                        </div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="OnClose">
                    @Localizer["Close"]
                </button>
            </div>
        </div>
    </div>
</div>

@* Reported Post Detail Modal - wrapped with higher z-index to appear above moderation modal *@
@if (showReportedPostDetailModal && selectedReportedPost != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1060;">
        <GroupPostDetailModal 
            PostId="@selectedReportedPost.Id"
            GroupId="@selectedReportedPost.GroupId"
            GroupName="@Group.Name"
            AuthorId="@selectedReportedPost.AuthorId"
            AuthorName="@GetReportedPostAuthorName()"
            AuthorImageUrl="@selectedReportedPost.Author?.ProfilePictureUrl"
            AuthorGroupPoints="@null"
            EnablePointsSystem="@Group.EnablePointsSystem"
            IsGroupAdmin="false"
            IsGroupModerator="false"
            CurrentUserId="@CurrentUserId"
            CreatedAt="@selectedReportedPost.CreatedAt"
            LikeCount="@selectedReportedPost.LikeCount"
            CommentCount="@selectedReportedPost.CommentCount"
            ShareCount="0"
            CurrentUserImageUrl="@currentUserImageUrl"
            CurrentUserName="@currentUserName"
            ReactionBreakdown="@reportedPostReactions"
            UserReaction="@reportedPostUserReaction"
            IsPinned="false"
            Images="@ConvertGroupPostImagesToPostImages(selectedReportedPost.Images)"
            IsReadOnly="true"
            OnClose="@CloseReportedPostDetailModal">
            <ArticleContent>
                @((MarkupString)FormatContentWithLineBreaks(selectedReportedPost.Content))
            </ArticleContent>
        </GroupPostDetailModal>
    </div>
}

@* Pending Post Detail Modal - wrapped with higher z-index to appear above moderation modal *@
@if (showPendingPostDetailModal && selectedPendingPostForModal != null)
{
    <div style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 1060;">
        <GroupPostDetailModal 
            PostId="@selectedPendingPostForModal.Id"
            GroupId="@selectedPendingPostForModal.GroupId"
            GroupName="@Group.Name"
            AuthorId="@selectedPendingPostForModal.AuthorId"
            AuthorName="@GetPendingPostAuthorName()"
            AuthorImageUrl="@selectedPendingPostForModal.Author?.ProfilePictureUrl"
            AuthorGroupPoints="@null"
            EnablePointsSystem="@Group.EnablePointsSystem"
            IsGroupAdmin="false"
            IsGroupModerator="false"
            CurrentUserId="@CurrentUserId"
            CreatedAt="@selectedPendingPostForModal.CreatedAt"
            LikeCount="@selectedPendingPostForModal.LikeCount"
            CommentCount="@selectedPendingPostForModal.CommentCount"
            ShareCount="0"
            CurrentUserImageUrl="@currentUserImageUrl"
            CurrentUserName="@currentUserName"
            ReactionBreakdown="@pendingPostReactions"
            UserReaction="@pendingPostUserReaction"
            IsPinned="false"
            Images="@ConvertGroupPostImagesToPostImages(selectedPendingPostForModal.Images)"
            IsReadOnly="true"
            OnClose="@ClosePendingPostDetailModal">
            <ArticleContent>
                @((MarkupString)FormatContentWithLineBreaks(selectedPendingPostForModal.Content))
            </ArticleContent>
        </GroupPostDetailModal>
    </div>
}

@* Decline File Modal *@
@if (showDeclineFileModal && fileToDecline != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1070;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-x-circle text-danger me-2"></i>@Localizer["DeclineFile"]</h5>
                    <button type="button" class="btn-close" @onclick="CloseDeclineFileModal"></button>
                </div>
                <div class="modal-body">
                    <p>@Localizer["DeclineFileConfirmation", fileToDecline.OriginalFileName]</p>
                    <div class="mb-3">
                        <label for="declineFileReason" class="form-label">@Localizer["DeclineReason"]</label>
                        <textarea id="declineFileReason" class="form-control" rows="3" @bind="declineFileReason"
                                  placeholder="@Localizer["DeclineReasonPlaceholder"]"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeclineFileModal">@Localizer["Cancel"]</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeclineFile" disabled="@(processingFileId == fileToDecline.Id)">
                        @if (processingFileId == fileToDecline.Id)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="bi bi-x-lg me-1"></i>
                        }
                        @Localizer["Decline"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// The group to moderate.
    /// </summary>
    [Parameter]
    public Group Group { get; set; } = null!;

    /// <summary>
    /// The current user's ID.
    /// </summary>
    [Parameter]
    public string CurrentUserId { get; set; } = string.Empty;

    /// <summary>
    /// Callback invoked when the modal is closed.
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>
    /// Callback invoked when any moderation action is performed.
    /// </summary>
    [Parameter]
    public EventCallback OnModerationActionPerformed { get; set; }

    private string activeTab = "reported";
    private bool isLoading = false;
    private string? errorMessage;
    private string? successMessage;
    private int reportedContentCount = 0;
    private int pendingPostsCount = 0;

    // Reports state
    private List<GroupContentReport> pendingReports = new();
    private bool isLoadingReports = false;
    private GroupContentReport? selectedReport = null;
    private bool showReportDetail = false;
    private int? processingReportId = null;
    private string? reviewerNotes = null;

    // Reported post detail modal state
    private bool showReportedPostDetailModal = false;
    private GroupPost? selectedReportedPost = null;
    private Dictionary<LikeType, int> reportedPostReactions = new();
    private LikeType? reportedPostUserReaction = null;
    private string currentUserName = string.Empty;
    private string? currentUserImageUrl = null;

    // Pending posts state
    private List<GroupPost> pendingPosts = new();
    private bool isLoadingPendingPosts = false;
    private int? processingPostId = null;
    private GroupPost? selectedPendingPost = null;
    private bool showPendingPostDetail = false;

    // Pending post detail modal state (for viewing full post)
    private bool showPendingPostDetailModal = false;
    private GroupPost? selectedPendingPostForModal = null;
    private Dictionary<LikeType, int> pendingPostReactions = new();
    private LikeType? pendingPostUserReaction = null;

    // Pending files state
    private List<GroupFileDto> pendingFiles = [];
    private bool isLoadingPendingFiles = false;
    private int pendingFilesCount = 0;
    private int? processingFileId = null;
    private GroupFileDto? fileToDecline = null;
    private bool showDeclineFileModal = false;
    private string declineFileReason = "";

    /// <summary>
    /// Initializes the component by loading initial data.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    /// <summary>
    /// Loads the initial data for all tabs.
    /// </summary>
    private async Task LoadDataAsync()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            // Load reported content count
            reportedContentCount = await ReportService.GetPendingReportCountAsync(Group.Id);

            // Load pending reports
            pendingReports = await ReportService.GetPendingReportsAsync(Group.Id);

            // Load pending posts count for approval
            if (Group.RequiresPostApproval)
            {
                pendingPostsCount = await GroupPostService.GetPendingPostCountAsync(Group.Id);
            }
            else
            {
                pendingPostsCount = 0;
            }

            // Load pending files count for approval
            if (Group.EnableFileUploads && Group.RequiresFileApproval)
            {
                pendingFilesCount = await GroupFileService.GetPendingFileCountAsync(Group.Id);
            }
            else
            {
                pendingFilesCount = 0;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading group moderation data for group {GroupId}", Group.Id);
            errorMessage = Localizer["ErrorLoadingData"];
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Sets the active tab.
    /// </summary>
    /// <param name="tabName">The name of the tab to activate.</param>
    private async Task SetActiveTab(string tabName)
    {
        activeTab = tabName;
        errorMessage = null;
        successMessage = null;
        showReportDetail = false;
        selectedReport = null;

        if (tabName == "reported")
        {
            await LoadReportsAsync();
        }
        else if (tabName == "pending")
        {
            await LoadPendingPostsAsync();
        }
        else if (tabName == "pendingfiles")
        {
            await LoadPendingFilesAsync();
        }

        StateHasChanged();
    }

    /// <summary>
    /// Loads the pending reports for the group.
    /// </summary>
    private async Task LoadReportsAsync()
    {
        isLoadingReports = true;
        StateHasChanged();

        try
        {
            pendingReports = await ReportService.GetPendingReportsAsync(Group.Id);
            reportedContentCount = pendingReports.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading reports for group {GroupId}", Group.Id);
            errorMessage = Localizer["ErrorLoadingReports"];
        }
        finally
        {
            isLoadingReports = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Shows the detail view for a report.
    /// </summary>
    private async Task ShowReportDetail(GroupContentReport report)
    {
        // Load full report details
        var fullReport = await ReportService.GetReportByIdAsync(report.Id);
        if (fullReport != null)
        {
            selectedReport = fullReport;
            showReportDetail = true;
            reviewerNotes = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Closes the report detail view.
    /// </summary>
    private void CloseReportDetail()
    {
        showReportDetail = false;
        selectedReport = null;
        reviewerNotes = null;
        StateHasChanged();
    }

    /// <summary>
    /// Dismisses the selected report.
    /// </summary>
    private async Task DismissReport()
    {
        if (selectedReport == null) return;

        processingReportId = selectedReport.Id;
        StateHasChanged();

        try
        {
            var (success, error) = await ReportService.DismissReportAsync(
                selectedReport.Id, 
                CurrentUserId, 
                reviewerNotes);

            if (success)
            {
                successMessage = Localizer["ReportDismissed"];
                pendingReports.RemoveAll(r => r.Id == selectedReport.Id);
                reportedContentCount = pendingReports.Count;
                CloseReportDetail();
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingReport"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error dismissing report {ReportId}", selectedReport.Id);
            errorMessage = Localizer["ErrorProcessingReport"];
        }
        finally
        {
            processingReportId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Marks action taken on the selected report.
    /// </summary>
    private async Task TakeActionOnReport()
    {
        if (selectedReport == null) return;

        processingReportId = selectedReport.Id;
        StateHasChanged();

        try
        {
            var (success, error) = await ReportService.MarkActionTakenAsync(
                selectedReport.Id, 
                CurrentUserId, 
                reviewerNotes);

            if (success)
            {
                successMessage = Localizer["ActionTaken"];
                pendingReports.RemoveAll(r => r.Id == selectedReport.Id);
                reportedContentCount = pendingReports.Count;
                CloseReportDetail();
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingReport"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error marking action taken on report {ReportId}", selectedReport.Id);
            errorMessage = Localizer["ErrorProcessingReport"];
        }
        finally
        {
            processingReportId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Resolves the selected report without taking action.
    /// </summary>
    private async Task ResolveReport()
    {
        if (selectedReport == null) return;

        processingReportId = selectedReport.Id;
        StateHasChanged();

        try
        {
            var (success, error) = await ReportService.ResolveReportAsync(
                selectedReport.Id, 
                CurrentUserId, 
                reviewerNotes);

            if (success)
            {
                successMessage = Localizer["ReportResolved"];
                pendingReports.RemoveAll(r => r.Id == selectedReport.Id);
                reportedContentCount = pendingReports.Count;
                CloseReportDetail();
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingReport"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error resolving report {ReportId}", selectedReport.Id);
            errorMessage = Localizer["ErrorProcessingReport"];
        }
        finally
        {
            processingReportId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Gets the display name for a report reason.
    /// </summary>
    private string GetReasonDisplayName(ReportReason reason)
    {
        return reason switch
        {
            ReportReason.ViolatesGroupRule => Localizer["ReasonViolatesGroupRule"],
            ReportReason.Spam => Localizer["ReasonSpam"],
            ReportReason.HarassmentOrBullying => Localizer["ReasonHarassment"],
            ReportReason.HateSpeech => Localizer["ReasonHateSpeech"],
            ReportReason.Misinformation => Localizer["ReasonMisinformation"],
            ReportReason.AdultContent => Localizer["ReasonAdultContent"],
            ReportReason.ViolenceOrGraphicContent => Localizer["ReasonViolence"],
            ReportReason.IntellectualPropertyViolation => Localizer["ReasonCopyright"],
            ReportReason.OffTopic => Localizer["ReasonOffTopic"],
            ReportReason.PrivacyViolation => Localizer["ReasonPrivacy"],
            ReportReason.SelfHarmOrSuicide => Localizer["ReasonSelfHarm"],
            ReportReason.IllegalActivity => Localizer["ReasonIllegal"],
            ReportReason.Other => Localizer["ReasonOther"],
            _ => reason.ToString()
        };
    }

    /// <summary>
    /// Gets the icon for a report reason.
    /// </summary>
    private string GetReasonIcon(ReportReason reason)
    {
        return reason switch
        {
            ReportReason.ViolatesGroupRule => "bi bi-list-check",
            ReportReason.Spam => "bi bi-envelope-exclamation",
            ReportReason.HarassmentOrBullying => "bi bi-person-x",
            ReportReason.HateSpeech => "bi bi-chat-square-x",
            ReportReason.Misinformation => "bi bi-exclamation-diamond",
            ReportReason.AdultContent => "bi bi-eye-slash",
            ReportReason.ViolenceOrGraphicContent => "bi bi-shield-exclamation",
            ReportReason.IntellectualPropertyViolation => "bi bi-c-circle",
            ReportReason.OffTopic => "bi bi-chat-left-dots",
            ReportReason.PrivacyViolation => "bi bi-person-lock",
            ReportReason.SelfHarmOrSuicide => "bi bi-heart-pulse",
            ReportReason.IllegalActivity => "bi bi-slash-circle",
            ReportReason.Other => "bi bi-three-dots",
            _ => "bi bi-flag"
        };
    }

    /// <summary>
    /// Gets the reporter's display name.
    /// </summary>
    private string GetReporterName(GroupContentReport report)
    {
        if (report.Reporter == null) return Localizer["UnknownUser"];
        var name = $"{report.Reporter.FirstName} {report.Reporter.LastName}".Trim();
        return string.IsNullOrEmpty(name) ? report.Reporter.UserName ?? Localizer["UnknownUser"] : name;
    }

    /// <summary>
    /// Gets the content author's display name.
    /// </summary>
    private string GetContentAuthorName(GroupContentReport report)
    {
        if (report.PostId.HasValue && report.Post?.Author != null)
        {
            var name = $"{report.Post.Author.FirstName} {report.Post.Author.LastName}".Trim();
            return string.IsNullOrEmpty(name) ? report.Post.Author.UserName ?? Localizer["UnknownUser"] : name;
        }
        if (report.CommentId.HasValue && report.Comment?.Author != null)
        {
            var name = $"{report.Comment.Author.FirstName} {report.Comment.Author.LastName}".Trim();
            return string.IsNullOrEmpty(name) ? report.Comment.Author.UserName ?? Localizer["UnknownUser"] : name;
        }
        return Localizer["UnknownUser"];
    }

    /// <summary>
    /// Gets a preview of the reported content.
    /// </summary>
    private string GetContentPreview(GroupContentReport report, int maxLength = 100)
    {
        string? content = null;

        if (report.PostId.HasValue && report.Post != null)
        {
            content = report.Post.Content;
        }
        else if (report.CommentId.HasValue && report.Comment != null)
        {
            content = report.Comment.Content;
        }

        if (string.IsNullOrEmpty(content)) return Localizer["ContentDeleted"];

        if (content.Length <= maxLength) return content;
        return content.Substring(0, maxLength).TrimEnd() + "...";
    }

    /// <summary>
    /// Formats a relative time string.
    /// </summary>
    private string GetRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;

        if (timeSpan.TotalMinutes < 1)
            return Localizer["JustNow"];
        if (timeSpan.TotalMinutes < 60)
            return string.Format(Localizer["MinutesAgo"], (int)timeSpan.TotalMinutes);
        if (timeSpan.TotalHours < 24)
            return string.Format(Localizer["HoursAgo"], (int)timeSpan.TotalHours);
        if (timeSpan.TotalDays < 30)
            return string.Format(Localizer["DaysAgo"], (int)timeSpan.TotalDays);

        return dateTime.ToString("MMM dd, yyyy");
    }

    #region Reported Post Detail Modal Methods

    /// <summary>
    /// Opens the full post detail modal for a reported post.
    /// </summary>
    /// <param name="report">The report containing the post to view.</param>
    private async Task ViewReportedPost(GroupContentReport report)
    {
        if (!report.PostId.HasValue)
        {
            errorMessage = Localizer["CannotViewComment"];
            return;
        }

        try
        {
            // Load the full post with author and images
            var post = await GroupPostService.GetGroupPostByIdAsync(report.PostId.Value);
            if (post == null)
            {
                errorMessage = Localizer["PostNotFound"];
                return;
            }

            selectedReportedPost = post;

            // Load reaction data for the post
            reportedPostReactions = await GroupPostService.GetReactionBreakdownAsync(post.Id);
            reportedPostUserReaction = await GroupPostService.GetUserReactionAsync(post.Id, CurrentUserId);

            // Load current user info for the modal
            await LoadCurrentUserInfoAsync();

            showReportedPostDetailModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading reported post {PostId}", report.PostId);
            errorMessage = Localizer["ErrorLoadingPost"];
        }
    }

    /// <summary>
    /// Loads the current user's display info for the post detail modal.
    /// </summary>
    private async Task LoadCurrentUserInfoAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                currentUserName = user.Identity.Name ?? string.Empty;

                var currentUser = await UserManager.FindByIdAsync(CurrentUserId);
                if (currentUser != null)
                {
                    currentUserImageUrl = currentUser.ProfilePictureUrl;
                    // Format name properly
                    var fullName = $"{currentUser.FirstName} {currentUser.LastName}".Trim();
                    if (!string.IsNullOrEmpty(fullName))
                    {
                        currentUserName = fullName;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Error loading current user info");
        }
    }

    /// <summary>
    /// Closes the reported post detail modal.
    /// </summary>
    private void CloseReportedPostDetailModal()
    {
        showReportedPostDetailModal = false;
        selectedReportedPost = null;
        reportedPostReactions = new();
        reportedPostUserReaction = null;
        StateHasChanged();
    }

    /// <summary>
    /// Gets the author name for the reported post.
    /// </summary>
    private string GetReportedPostAuthorName()
    {
        if (selectedReportedPost?.Author == null) return Localizer["UnknownUser"];
        var name = $"{selectedReportedPost.Author.FirstName} {selectedReportedPost.Author.LastName}".Trim();
        return string.IsNullOrEmpty(name) ? selectedReportedPost.Author.UserName ?? Localizer["UnknownUser"] : name;
    }

    /// <summary>
    /// Formats post content with line breaks for display.
    /// </summary>
    private string FormatContentWithLineBreaks(string? content)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        return System.Web.HttpUtility.HtmlEncode(content).Replace("\n", "<br />");
    }

    /// <summary>
    /// Converts GroupPostImage collection to PostImage list for component compatibility.
    /// </summary>
    /// <param name="groupImages">The group post images to convert.</param>
    /// <returns>A list of PostImage objects.</returns>
    private List<PostImage>? ConvertGroupPostImagesToPostImages(ICollection<GroupPostImage>? groupImages)
    {
        if (groupImages == null || !groupImages.Any())
            return null;

        return groupImages.Select(gi => new PostImage
        {
            Id = gi.Id,
            PostId = gi.PostId,
            ImageUrl = gi.ImageUrl,
            DisplayOrder = gi.DisplayOrder,
            UploadedAt = gi.UploadedAt
        }).ToList();
    }

    #endregion

    #region Pending Posts Methods

    /// <summary>
    /// Loads pending posts awaiting approval.
    /// </summary>
    private async Task LoadPendingPostsAsync()
    {
        if (!Group.RequiresPostApproval) return;

        isLoadingPendingPosts = true;
        StateHasChanged();

        try
        {
            pendingPosts = await GroupPostService.GetPendingPostsAsync(Group.Id);
            pendingPostsCount = pendingPosts.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading pending posts for group {GroupId}", Group.Id);
            errorMessage = Localizer["ErrorLoadingPendingPosts"];
        }
        finally
        {
            isLoadingPendingPosts = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Approves a pending post.
    /// </summary>
    private async Task ApprovePost(int postId)
    {
        processingPostId = postId;
        StateHasChanged();

        try
        {
            var (success, error) = await GroupPostService.ApprovePostAsync(postId, CurrentUserId);

            if (success)
            {
                successMessage = Localizer["PostApproved"];
                pendingPosts.RemoveAll(p => p.Id == postId);
                pendingPostsCount = pendingPosts.Count;
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingPost"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error approving post {PostId}", postId);
            errorMessage = Localizer["ErrorProcessingPost"];
        }
        finally
        {
            processingPostId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Declines a pending post.
    /// </summary>
    private async Task DeclinePost(int postId)
    {
        processingPostId = postId;
        StateHasChanged();

        try
        {
            var (success, error) = await GroupPostService.DeclinePostAsync(postId, CurrentUserId);

            if (success)
            {
                successMessage = Localizer["PostDeclined"];
                pendingPosts.RemoveAll(p => p.Id == postId);
                pendingPostsCount = pendingPosts.Count;
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingPost"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error declining post {PostId}", postId);
            errorMessage = Localizer["ErrorProcessingPost"];
        }
        finally
        {
            processingPostId = null;
            StateHasChanged();
        }
    }

    #region Pending Files Methods

    /// <summary>
    /// Loads the pending files for the group.
    /// </summary>
    private async Task LoadPendingFilesAsync()
    {
        isLoadingPendingFiles = true;
        StateHasChanged();

        try
        {
            pendingFiles = await GroupFileService.GetPendingFilesAsync(Group.Id, 0, 50);
            pendingFilesCount = pendingFiles.Count;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading pending files for group {GroupId}", Group.Id);
            errorMessage = Localizer["ErrorLoadingFiles"];
        }
        finally
        {
            isLoadingPendingFiles = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Approves a pending file.
    /// </summary>
    /// <param name="fileId">The ID of the file to approve.</param>
    private async Task ApproveFile(int fileId)
    {
        processingFileId = fileId;
        StateHasChanged();

        try
        {
            var (success, error) = await GroupFileService.ApproveFileAsync(fileId, CurrentUserId);

            if (success)
            {
                successMessage = Localizer["FileApproved"];
                pendingFiles.RemoveAll(f => f.Id == fileId);
                pendingFilesCount = pendingFiles.Count;
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingFile"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error approving file {FileId}", fileId);
            errorMessage = Localizer["ErrorProcessingFile"];
        }
        finally
        {
            processingFileId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Opens the decline file modal.
    /// </summary>
    /// <param name="file">The file to decline.</param>
    private void OpenDeclineFileModal(GroupFileDto file)
    {
        fileToDecline = file;
        declineFileReason = "";
        showDeclineFileModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Closes the decline file modal.
    /// </summary>
    private void CloseDeclineFileModal()
    {
        showDeclineFileModal = false;
        fileToDecline = null;
        declineFileReason = "";
        StateHasChanged();
    }

    /// <summary>
    /// Confirms and executes file decline.
    /// </summary>
    private async Task ConfirmDeclineFile()
    {
        if (fileToDecline == null) return;

        processingFileId = fileToDecline.Id;
        StateHasChanged();

        try
        {
            var (success, error) = await GroupFileService.DeclineFileAsync(
                fileToDecline.Id, 
                CurrentUserId,
                string.IsNullOrWhiteSpace(declineFileReason) ? null : declineFileReason.Trim());

            if (success)
            {
                successMessage = Localizer["FileDeclined"];
                pendingFiles.RemoveAll(f => f.Id == fileToDecline.Id);
                pendingFilesCount = pendingFiles.Count;
                CloseDeclineFileModal();
                await OnModerationActionPerformed.InvokeAsync();
            }
            else
            {
                errorMessage = error ?? Localizer["ErrorProcessingFile"];
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error declining file {FileId}", fileToDecline.Id);
            errorMessage = Localizer["ErrorProcessingFile"];
        }
        finally
        {
            processingFileId = null;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Gets the CSS color class for a file icon based on file type.
    /// </summary>
    /// <param name="file">The file DTO.</param>
    /// <returns>A Bootstrap text color class.</returns>
    private static string GetFileIconColorClass(GroupFileDto file)
    {
        if (file.IsImage) return "text-success";
        if (file.IsPdf) return "text-danger";
        if (file.IsDocument) return "text-primary";
        if (file.IsArchive) return "text-warning";
        return "text-secondary";
    }

    #endregion

    /// <summary>
    /// Gets the post author's display name.
    /// </summary>
    private string GetPostAuthorName(GroupPost post)
    {
        if (post.Author == null) return Localizer["UnknownUser"];
        var name = $"{post.Author.FirstName} {post.Author.LastName}".Trim();
        return string.IsNullOrEmpty(name) ? post.Author.UserName ?? Localizer["UnknownUser"] : name;
    }

    /// <summary>
    /// Truncates content to specified length.
    /// </summary>
    private string TruncateContent(string content, int maxLength)
    {
        if (string.IsNullOrEmpty(content)) return string.Empty;
        if (content.Length <= maxLength) return content;
        return content.Substring(0, maxLength).TrimEnd() + "...";
    }

    /// <summary>
    /// Shows the detail view for a pending post.
    /// </summary>
    /// <param name="post">The pending post to view in detail.</param>
    private void ShowPendingPostDetail(GroupPost post)
    {
        selectedPendingPost = post;
        showPendingPostDetail = true;
        StateHasChanged();
    }

    /// <summary>
    /// Opens the full post detail modal for a pending post.
    /// </summary>
    /// <param name="post">The pending post to view.</param>
    private async Task ViewPendingPost(GroupPost post)
    {
        try
        {
            // Load the full post with author and images (in case not fully loaded)
            var fullPost = await GroupPostService.GetGroupPostByIdAsync(post.Id);
            if (fullPost == null)
            {
                errorMessage = Localizer["PostNotFound"];
                return;
            }

            selectedPendingPostForModal = fullPost;

            // Load reaction data for the post
            pendingPostReactions = await GroupPostService.GetReactionBreakdownAsync(fullPost.Id);
            pendingPostUserReaction = await GroupPostService.GetUserReactionAsync(fullPost.Id, CurrentUserId);

            // Load current user info for the modal
            await LoadCurrentUserInfoAsync();

            showPendingPostDetailModal = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading pending post {PostId}", post.Id);
            errorMessage = Localizer["ErrorLoadingPost"];
        }
    }

    /// <summary>
    /// Closes the pending post detail modal.
    /// </summary>
    private void ClosePendingPostDetailModal()
    {
        showPendingPostDetailModal = false;
        selectedPendingPostForModal = null;
        pendingPostReactions = new();
        pendingPostUserReaction = null;
        StateHasChanged();
    }

    /// <summary>
    /// Gets the author name for the pending post modal.
    /// </summary>
    private string GetPendingPostAuthorName()
    {
        if (selectedPendingPostForModal?.Author == null) return Localizer["UnknownUser"];
        var name = $"{selectedPendingPostForModal.Author.FirstName} {selectedPendingPostForModal.Author.LastName}".Trim();
        return string.IsNullOrEmpty(name) ? selectedPendingPostForModal.Author.UserName ?? Localizer["UnknownUser"] : name;
    }

    /// <summary>
    /// Closes the pending post detail view.
    /// </summary>
    private void ClosePendingPostDetail()
    {
        showPendingPostDetail = false;
        selectedPendingPost = null;
        StateHasChanged();
    }

    /// <summary>
    /// Approves the currently selected pending post from the detail view.
    /// </summary>
    private async Task ApprovePostFromDetail()
    {
        if (selectedPendingPost == null) return;

        var postId = selectedPendingPost.Id;
        await ApprovePost(postId);

        // Close the detail view after approval
        if (!pendingPosts.Any(p => p.Id == postId))
        {
            ClosePendingPostDetail();
        }
    }

    /// <summary>
    /// Declines the currently selected pending post from the detail view.
    /// </summary>
    private async Task DeclinePostFromDetail()
    {
        if (selectedPendingPost == null) return;

        var postId = selectedPendingPost.Id;
        await DeclinePost(postId);

        // Close the detail view after declining
        if (!pendingPosts.Any(p => p.Id == postId))
        {
            ClosePendingPostDetail();
        }
    }

    #endregion
}
