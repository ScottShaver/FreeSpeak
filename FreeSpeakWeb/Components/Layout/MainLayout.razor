@inherits LayoutComponentBase
@using FreeSpeakWeb.Components.Shared
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<FreeSpeakWeb.Resources.Layout.MainLayout> Localizer

<NavigationGuard />
<ThemeInitializer />
<AlertContainer />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="content-container">
            <article class="content-left">
                @Body
            </article>
            <aside class="content-right px-3">
                <!-- Right sidebar content goes here -->
            </aside>
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Localizer["ErrorMessage"]
    <a href="." class="reload">@Localizer["Reload"]</a>
    <span class="dismiss">🗙</span>
</div>
