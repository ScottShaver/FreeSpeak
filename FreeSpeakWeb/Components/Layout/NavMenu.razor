@implements IDisposable
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.Shared

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IOptions<SiteSettings> SiteSettings
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject ThemeService ThemeService

<!-- Always visible header across the top -->
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex align-items-center" style="width: 100%;">
        <div class="d-flex align-items-center gap-2" style="flex: 1;">
            <ThemeSelector />
            <button class="navbar-toggler" @onclick="ToggleNavMenu" type="button" title="Toggle navigation menu" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="" data-enhance-nav="false">@SiteSettings.Value.SiteName</a>
        </div>

        <div class="d-flex align-items-center gap-3 justify-content-center" style="flex: 1;">
            <AuthorizeView>
                <Authorized>
                    <a href="/" title="Home" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-house-door-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="friends" title="Friends" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "friends" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "friends" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-people-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="my-uploads" title="My Uploads" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "my-uploads" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "my-uploads" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-images-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="notifications" title="Notifications" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "notifications" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "notifications" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-bell-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="/Account/Manage" title="@context.User.Identity?.Name" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                        {
                            <img src="@currentUser.ProfilePictureUrl" alt="Profile" class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="bi bi-person-fill-nav-menu" style="margin: 0; top: 0;"></span>
                        }
                    </a>

                    <form action="Account/Logout" method="post" style="display: inline-flex; align-items: center; margin: 0; padding: 0; line-height: 1;">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-icon-link btn-link" title="Logout" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; padding: 0; margin: 0; border: none; background-color: transparent;">
                            <span class="bi bi-arrow-bar-left-nav-menu" style="margin: 0; top: 0;"></span>
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/Account/Register" title="Register" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-person-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="/Account/Login" title="Login" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-person-badge-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>

            <a href="technology-credits" title="Technology Credits" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "technology-credits" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "technology-credits" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                <span class="bi bi-info-circle-nav-menu" style="margin: 0; top: 0;"></span>
            </a>
        </div>

        <div style="flex: 1;"></div>
    </div>
</div>

<!-- Collapsible navigation menu -->
<div class="@NavMenuCssClass" @onclick="HandleNavMenuClick">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/" ? "active" : "")" href="/" data-enhance-nav="false">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "friends" ? "active" : "")" href="friends" data-enhance-nav="false">
                        <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Friends
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "my-uploads" ? "active" : "")" href="my-uploads" data-enhance-nav="false">
                        <span class="bi bi-images-nav-menu" aria-hidden="true"></span> My Uploads
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "notifications" ? "active" : "")" href="notifications" data-enhance-nav="false">
                        <span class="bi bi-bell-fill-nav-menu" aria-hidden="true"></span> Notifications
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link d-flex align-items-center gap-2 @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "active" : "")" href="/Account/Manage" data-enhance-nav="false">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                        {
                            <img src="@currentUser.ProfilePictureUrl" alt="Profile" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                        }
                        <span>@context.User.Identity?.Name</span>
                    </a>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "active" : "")" href="/Account/Register" data-enhance-nav="false">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Register
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "active" : "")" href="/Account/Login" data-enhance-nav="false">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <hr class="nav-divider" />

        <div class="nav-item px-3">
            <a class="nav-link @(GetActiveMenuItemFromUrl() == "technology-credits" ? "active" : "")" href="technology-credits" data-enhance-nav="false">
                <span class="bi bi-info-circle-nav-menu" aria-hidden="true"></span> Technology Credits
            </a>
        </div>
    </nav>
</div>

@code {
    private bool showNavMenu = true;  // Start visible, JavaScript will hide on mobile
    private string? currentUrl;
    private string _activeMenuItem = "";
    private IJSObjectReference? module;
    private IJSObjectReference? resizeHandler;
    private DotNetObjectReference<NavMenu>? dotNetReference;
    private ApplicationUser? currentUser;

    private string? NavMenuCssClass => showNavMenu ? "nav-scrollable show" : "nav-scrollable";

    private void ToggleNavMenu()
    {
        showNavMenu = !showNavMenu;
        StateHasChanged();
    }

    private async Task HandleNavMenuClick()
    {
        // Only close the nav menu if we're on mobile or narrow window
        if (module != null)
        {
            try
            {
                var shouldClose = await module.InvokeAsync<bool>("shouldAutoCloseNav");
                if (shouldClose)
                {
                    showNavMenu = false;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException)
            {
                // Page is being unloaded, ignore
            }
        }
    }

    [JSInvokable]
    public void OnWindowResizedToNarrow()
    {
        showNavMenu = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnWindowResizedToWide()
    {
        showNavMenu = true;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        UpdateActiveMenuItem();
        NavigationManager.LocationChanged += OnLocationChanged;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            currentUser = await userManager.GetUserAsync(authState.User);
        }
    }

    protected override void OnParametersSet()
    {
        // Update active menu item whenever component state changes
        // This handles server-side redirects that don't trigger LocationChanged
        UpdateActiveMenuItem();
    }

    private void UpdateActiveMenuItem()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var path = uri.Split('?')[0].TrimStart('/');

        if (string.IsNullOrEmpty(path))
            _activeMenuItem = "/";
        else if (path.Equals("Account/Login", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Login";
        else if (path.Equals("Account/Register", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Register";
        else if (path.Equals("Account/Manage", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Manage";
        else if (path.Equals("friends", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "friends";
        else if (path.Equals("my-uploads", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "my-uploads";
        else if (path.Equals("notifications", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "notifications";
        else if (path.Equals("technology-credits", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "technology-credits";
        else
            _activeMenuItem = "/" + path;
    }

    private string GetActiveMenuItemFromUrl()
    {
        return _activeMenuItem;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Layout/NavMenu.razor.js");
                dotNetReference = DotNetObjectReference.Create(this);
                resizeHandler = await module.InvokeAsync<IJSObjectReference>("setupResizeHandler", dotNetReference);

                // Check if we should hide the menu on mobile
                var shouldHide = await module.InvokeAsync<bool>("shouldAutoCloseNav");
                if (shouldHide)
                {
                    showNavMenu = false;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException)
            {
                // Page is being unloaded, ignore
            }
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        UpdateActiveMenuItem();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        dotNetReference?.Dispose();

        // Note: We intentionally don't dispose JavaScript resources here
        // When the page is being unloaded (e.g., logout), the browser automatically
        // cleans up all JavaScript. Attempting to call JS interop during disposal
        // causes JSDisconnectedException which is harmless but creates noise in logs.
    }
}


