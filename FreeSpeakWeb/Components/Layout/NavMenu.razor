@implements IDisposable
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using Microsoft.JSInterop
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.Shared
@using Microsoft.Extensions.Localization

@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject IOptions<SiteSettings> SiteSettings
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject ThemeService ThemeService
@inject NotificationBadgeService NotificationBadgeService
@inject UserPreferenceService UserPreferenceService
@inject GroupMemberService GroupMemberService
@inject FriendsService FriendsService
@inject IStringLocalizer<FreeSpeakWeb.Resources.Layout.NavMenu> Localizer

<!-- Always visible header across the top -->
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid d-flex align-items-center" style="width: 100%; flex-wrap: nowrap;">
        <div class="d-flex align-items-center gap-2" style="flex: 1;">
            <ThemeSelector />
            <button class="navbar-toggler" @onclick="ToggleNavMenu" type="button" title="@Localizer["ToggleNavigation"]" aria-label="@Localizer["ToggleNavigation"]">
                <span class="navbar-toggler-icon"></span>
            </button>
            <a class="navbar-brand" href="" data-enhance-nav="false">@SiteSettings.Value.SiteName</a>
        </div>

        <div class="d-flex align-items-center gap-3 justify-content-center" style="">
            <AuthorizeView>
                <Authorized>
                    <a href="/home" title="@Localizer["Home"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/home" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/home" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-house-door-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="friends" title="@Localizer["Friends"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "friends" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "friends" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-people-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="groups" title="@Localizer["Groups"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "groups" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "groups" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-diagram-3-fill-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    @if (SiteSettings.Value.AllowPostAttachments)
                    {
                        <a href="my-uploads" title="@Localizer["MyUploads"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "my-uploads" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "my-uploads" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                            <span class="bi bi-images-nav-menu" style="margin: 0; top: 0;"></span>
                        </a>
                    }

                    <a href="notifications" title="@Localizer["Notifications"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "notifications" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; position: relative; @(GetActiveMenuItemFromUrl() == "notifications" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-bell-fill-nav-menu" style="margin: 0; top: 0;"></span>
                        @if (unreadNotificationCount > 0)
                        {
                            <span class="notification-badge">@(unreadNotificationCount > 99 ? "99+" : unreadNotificationCount.ToString())</span>
                        }
                    </a>

                    <a href="/Account/Manage" title="@currentUserDisplayName" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                        {
                            <img src="@currentUser.ProfilePictureUrl" alt="Profile" class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="bi bi-person-fill-nav-menu" style="margin: 0; top: 0;"></span>
                        }
                    </a>

                    <form action="Account/Logout" method="post" style="display: inline-flex; align-items: center; margin: 0; padding: 0; line-height: 1;">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-icon-link btn-link" title="@Localizer["Logout"]" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; padding: 0; margin: 0; border: none; background-color: transparent;">
                            <span class="bi bi-arrow-bar-left-nav-menu" style="margin: 0; top: 0;"></span>
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="/Account/Register" title="@Localizer["Register"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-person-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>

                    <a href="/Account/Login" title="@Localizer["Login"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                        <span class="bi bi-person-badge-nav-menu" style="margin: 0; top: 0;"></span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>

            <a href="technology-credits" title="@Localizer["TechnologyCredits"]" class="nav-icon-link @(GetActiveMenuItemFromUrl() == "technology-credits" ? "active" : "")" data-enhance-nav="false" style="display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; @(GetActiveMenuItemFromUrl() == "technology-credits" ? "background-color: rgba(255,255,255,0.37); color: white; border-radius: 4px;" : "")">
                <span class="bi bi-info-circle-nav-menu" style="margin: 0; top: 0;"></span>
            </a>
        </div>

        <div style="flex: 1;"></div>
    </div>
</div>

<!-- Collapsible navigation menu -->
<div class="@NavMenuCssClass" @onclick="HandleNavMenuClick">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                @* System Administration Menu Items *@
                @if (isSystemAdministrator)
                {
                    <div class="nav-item px-3">
                        <a class="nav-link @(GetActiveMenuItemFromUrl() == "system-admin" ? "active" : "")" href="system-admin" data-enhance-nav="false">
                            <span class="bi bi-shield-lock-fill" aria-hidden="true"></span> @Localizer["SystemAdministration"]
                        </a>
                    </div>
                }

                @if (isSystemAdministrator || isSystemModerator)
                {
                    <div class="nav-item px-3">
                        <a class="nav-link @(GetActiveMenuItemFromUrl() == "system-moderator" ? "active" : "")" href="system-moderator" data-enhance-nav="false">
                            <span class="bi bi-shield-check" aria-hidden="true"></span> @Localizer["SystemModerator"]
                        </a>
                    </div>
                }

                @if (isSystemAdministrator || isSystemModerator)
                {
                    <hr class="nav-divider" />
                }

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/home" ? "active" : "")" href="/home" data-enhance-nav="false">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> @Localizer["Home"]
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "friends" ? "active" : "")" href="friends" data-enhance-nav="false">
                        <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> @Localizer["Friends"]
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "groups" ? "active" : "")" href="groups" data-enhance-nav="false">
                        <span class="bi bi-diagram-3-fill-nav-menu" aria-hidden="true"></span> @Localizer["Groups"]
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "my-uploads" ? "active" : "")" href="my-uploads" data-enhance-nav="false">
                        <span class="bi bi-images-nav-menu" aria-hidden="true"></span> @Localizer["MyUploads"]
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "notifications" ? "active" : "")" href="notifications" data-enhance-nav="false" style="position: relative;">
                        <span class="bi bi-bell-fill-nav-menu" aria-hidden="true"></span> @Localizer["Notifications"]
                        @if (unreadNotificationCount > 0)
                        {
                            <span class="notification-badge-sidebar">@(unreadNotificationCount > 99 ? "99+" : unreadNotificationCount.ToString())</span>
                        }
                    </a>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link d-flex align-items-center gap-2 @(GetActiveMenuItemFromUrl() == "/Account/Manage" ? "active" : "")" href="/Account/Manage" data-enhance-nav="false">
                        @if (!string.IsNullOrEmpty(currentUser?.ProfilePictureUrl))
                        {
                            <img src="@currentUser.ProfilePictureUrl" alt="Profile" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                        }
                        <span>@currentUserDisplayName</span>
                    </a>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> @Localizer["Logout"]
                        </button>
                    </form>
                </div>

                @if ((userFriends != null && userFriends.Any()) || (userGroups != null && userGroups.Any()))
                {
                    <hr class="nav-divider" />

                    @if (userFriends != null && userFriends.Any())
                    {
                        <div class="nav-item px-3 position-relative">
                            <button type="button" class="nav-link w-100 text-start d-flex align-items-center justify-content-between" @onclick="ToggleFriendsPopup" @onclick:stopPropagation="true">
                                <span>
                                    <span class="bi bi-box-arrow-up-right" aria-hidden="true"></span> @Localizer["JumpToFriend"]
                                </span>
                                <span class="bi @(showFriendsPopup ? "bi-chevron-up" : "bi-chevron-down")" style="font-size: 0.75rem;"></span>
                            </button>

                            @if (showFriendsPopup)
                            {
                                <div class="friends-popup-menu" @onclick:stopPropagation="true">
                                    @foreach (var friend in userFriends)
                                    {
                                        var displayName = friendDisplayNames.ContainsKey(friend.Id) ? friendDisplayNames[friend.Id] : (friend.UserName ?? "User");
                                        <a href="@($"/friend/{friend.Id}")" 
                                           class="friends-popup-item @(GetActiveMenuItemFromUrl() == $"friend/{friend.Id}" ? "active" : "")" 
                                           data-enhance-nav="false"
                                           @onclick="CloseFriendsPopup"
                                           @onclick:stopPropagation="true">
                                            <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span>
                                            <span class="friend-name">@displayName</span>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }

                    @if (userGroups != null && userGroups.Any())
                    {
                        <div class="nav-item px-3 position-relative">
                            <button type="button" class="nav-link w-100 text-start d-flex align-items-center justify-content-between" @onclick="ToggleGroupsPopup" @onclick:stopPropagation="true">
                                <span>
                                    <span class="bi bi-box-arrow-up-right" aria-hidden="true"></span> @Localizer["JumpToGroup"]
                                </span>
                                <span class="bi @(showGroupsPopup ? "bi-chevron-up" : "bi-chevron-down")" style="font-size: 0.75rem;"></span>
                            </button>

                            @if (showGroupsPopup)
                            {
                                <div class="groups-popup-menu" @onclick:stopPropagation="true">
                                    @foreach (var groupUser in userGroups)
                                    {
                                        <a href="@($"/group/{groupUser.GroupId}")" 
                                           class="groups-popup-item @(GetActiveMenuItemFromUrl() == $"group/{groupUser.GroupId}" ? "active" : "")" 
                                           data-enhance-nav="false"
                                           @onclick="CloseGroupsPopup">
                                            <span class="bi bi-diagram-3-fill-nav-menu" aria-hidden="true"></span>
                                            <span class="group-name">@groupUser.Group?.Name</span>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/Account/Register" ? "active" : "")" href="/Account/Register" data-enhance-nav="false">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> @Localizer["Register"]
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link @(GetActiveMenuItemFromUrl() == "/Account/Login" ? "active" : "")" href="/Account/Login" data-enhance-nav="false">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> @Localizer["Login"]
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>

        <hr class="nav-divider" />

        <div class="nav-item px-3">
            <a class="nav-link @(GetActiveMenuItemFromUrl() == "technology-credits" ? "active" : "")" href="technology-credits" data-enhance-nav="false">
                <span class="bi bi-info-circle-nav-menu" aria-hidden="true"></span> @Localizer["TechnologyCredits"]
            </a>
        </div>
    </nav>
</div>

@code {
    private bool showNavMenu = true;  // Start visible, JavaScript will hide on mobile
    private bool showGroupsPopup = false;
    private bool isTogglingGroupsPopup = false;
    private bool showFriendsPopup = false;
    private bool isTogglingFriendsPopup = false;
    private string? currentUrl;
    private string _activeMenuItem = "";
    private IJSObjectReference? module;
    private IJSObjectReference? resizeHandler;
    private DotNetObjectReference<NavMenu>? dotNetReference;
    private ApplicationUser? currentUser;
    private string? currentUserDisplayName;
    private int unreadNotificationCount = 0;
    private List<GroupUser>? userGroups;
    private List<ApplicationUser>? userFriends;
    private Dictionary<string, string> friendDisplayNames = new();
    private bool isSystemAdministrator = false;
    private bool isSystemModerator = false;

    private string? NavMenuCssClass => showNavMenu ? "nav-scrollable show" : "nav-scrollable";

    private void ToggleNavMenu()
    {
        showNavMenu = !showNavMenu;
        StateHasChanged();
    }

    /// <summary>
    /// Toggles the visibility of the groups popup menu.
    /// </summary>
    private void ToggleGroupsPopup()
    {
        isTogglingGroupsPopup = true;
        showGroupsPopup = !showGroupsPopup;

        // Close friends popup when opening groups popup
        if (showGroupsPopup && showFriendsPopup)
        {
            showFriendsPopup = false;
        }

        StateHasChanged();
        // Reset the flag after a brief delay to allow the parent click handler to check it
        _ = Task.Delay(50).ContinueWith(_ => isTogglingGroupsPopup = false);
    }

    /// <summary>
    /// Closes the groups popup menu.
    /// </summary>
    private void CloseGroupsPopup()
    {
        showGroupsPopup = false;
        StateHasChanged();
    }

    /// <summary>
    /// Toggles the visibility of the friends popup menu.
    /// </summary>
    private void ToggleFriendsPopup()
    {
        isTogglingFriendsPopup = true;
        showFriendsPopup = !showFriendsPopup;

        // Close groups popup when opening friends popup
        if (showFriendsPopup && showGroupsPopup)
        {
            showGroupsPopup = false;
        }

        StateHasChanged();
        // Reset the flag after a brief delay to allow the parent click handler to check it
        _ = Task.Delay(50).ContinueWith(_ => isTogglingFriendsPopup = false);
    }

    /// <summary>
    /// Closes the friends popup menu.
    /// </summary>
    private void CloseFriendsPopup()
    {
        showFriendsPopup = false;
        StateHasChanged();
    }

    private async Task HandleNavMenuClick()
    {
        // Don't close the groups popup if we just toggled it
        if (showGroupsPopup && !isTogglingGroupsPopup)
        {
            showGroupsPopup = false;
        }

        // Don't close the friends popup if we just toggled it
        if (showFriendsPopup && !isTogglingFriendsPopup)
        {
            showFriendsPopup = false;
        }

        // Only close the nav menu if we're on mobile or narrow window
        if (module != null)
        {
            try
            {
                var shouldClose = await module.InvokeAsync<bool>("shouldAutoCloseNav");
                if (shouldClose)
                {
                    showNavMenu = false;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException)
            {
                // Page is being unloaded, ignore
            }
        }
    }

    [JSInvokable]
    public void OnWindowResizedToNarrow()
    {
        showNavMenu = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnWindowResizedToWide()
    {
        showNavMenu = true;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        UpdateActiveMenuItem();
        NavigationManager.LocationChanged += OnLocationChanged;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            await using var scope = ScopeFactory.CreateAsyncScope();
            var userManager = scope.ServiceProvider.GetRequiredService<UserManager<ApplicationUser>>();
            currentUser = await userManager.GetUserAsync(authState.User);

            // Check user roles
            if (currentUser != null)
            {
                isSystemAdministrator = await userManager.IsInRoleAsync(currentUser, "SystemAdministrator");
                isSystemModerator = await userManager.IsInRoleAsync(currentUser, "SystemModerator");
            }

            // Initialize notification badge service
            if (currentUser != null)
            {
                // Format user display name according to their preference
                currentUserDisplayName = await UserPreferenceService.FormatUserDisplayNameAsync(
                    currentUser.Id,
                    currentUser.FirstName,
                    currentUser.LastName,
                    currentUser.UserName ?? "User"
                );

                NotificationBadgeService.OnUnreadCountChanged += HandleUnreadCountChanged;
                await NotificationBadgeService.InitializeAsync(currentUser.Id);
                unreadNotificationCount = NotificationBadgeService.UnreadCount;

                // Load user's groups
                await LoadUserGroupsAsync();

                // Load user's friends (with error handling to prevent breaking login)
                try
                {
                    await LoadUserFriendsAsync();
                }
                catch
                {
                    // Silently fail - friends list is not critical for basic navigation
                    userFriends = new List<ApplicationUser>();
                }
            }
        }
    }

    private async Task LoadUserGroupsAsync()
    {
        if (currentUser == null) return;

        try
        {
            var groups = await GroupMemberService.GetUserGroupsAsync(currentUser.Id);
            // Sort alphabetically by group name
            userGroups = groups
                .OrderBy(gu => gu.Group?.Name ?? string.Empty)
                .ToList();
        }
        catch
        {
            // Silently fail - groups list is not critical for basic navigation
            userGroups = new List<GroupUser>();
        }
    }

    private async Task LoadUserFriendsAsync()
    {
        if (currentUser == null) return;

        try
        {
            var friends = await FriendsService.GetFriendsAsync(currentUser.Id);

            // Pre-format display names for each friend
            friendDisplayNames.Clear();
            var friendsWithFormattedNames = new List<(ApplicationUser Friend, string DisplayName)>();

            foreach (var friend in friends)
            {
                var displayName = await UserPreferenceService.FormatUserDisplayNameAsync(
                    friend.Id,
                    friend.FirstName ?? string.Empty,
                    friend.LastName ?? string.Empty,
                    friend.UserName ?? "User"
                );

                friendDisplayNames[friend.Id] = displayName;
                friendsWithFormattedNames.Add((friend, displayName));
            }

            // Sort alphabetically by display name
            userFriends = friendsWithFormattedNames
                .OrderBy(f => f.DisplayName)
                .Select(f => f.Friend)
                .ToList();
        }
        catch (Exception ex)
        {
            // Log error but don't let it break the component
            // Friends list is not critical for navigation
            userFriends = new List<ApplicationUser>();
            friendDisplayNames.Clear();
        }
    }

    public async Task RefreshUserGroupsAsync()
    {
        try
        {
            await LoadUserGroupsAsync();
            StateHasChanged();
        }
        catch
        {
            // Silently fail
        }
    }

    public async Task RefreshUserFriendsAsync()
    {
        try
        {
            await LoadUserFriendsAsync();
            StateHasChanged();
        }
        catch
        {
            // Silently fail
            friendDisplayNames.Clear();
        }
    }

    protected override void OnParametersSet()
    {
        // Update active menu item whenever component state changes
        // This handles server-side redirects that don't trigger LocationChanged
        UpdateActiveMenuItem();
    }

    private void UpdateActiveMenuItem()
    {
        var uri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        var path = uri.Split('?')[0].TrimStart('/');

        if (string.IsNullOrEmpty(path))
            _activeMenuItem = "/";
        else if (path.Equals("home", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/home";
        else if (path.Equals("Account/Login", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Login";
        else if (path.Equals("Account/Register", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Register";
        else if (path.Equals("Account/Manage", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "/Account/Manage";
        else if (path.Equals("system-admin", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "system-admin";
        else if (path.Equals("system-moderator", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "system-moderator";
        else if (path.Equals("friends", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "friends";
        else if (path.Equals("groups", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "groups";
        else if (path.Equals("my-uploads", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "my-uploads";
        else if (path.Equals("notifications", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "notifications";
        else if (path.Equals("technology-credits", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = "technology-credits";
        else if (path.StartsWith("group/", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = path.ToLowerInvariant();
        else if (path.StartsWith("friend/", StringComparison.OrdinalIgnoreCase))
            _activeMenuItem = path.ToLowerInvariant();
        else
            _activeMenuItem = "/" + path;
    }

    private string GetActiveMenuItemFromUrl()
    {
        return _activeMenuItem;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Layout/NavMenu.razor.js");
                dotNetReference = DotNetObjectReference.Create(this);
                resizeHandler = await module.InvokeAsync<IJSObjectReference>("setupResizeHandler", dotNetReference);

                // Check if we should hide the menu on mobile
                var shouldHide = await module.InvokeAsync<bool>("shouldAutoCloseNav");
                if (shouldHide)
                {
                    showNavMenu = false;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException)
            {
                // Page is being unloaded, ignore
            }
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        UpdateActiveMenuItem();
        InvokeAsync(StateHasChanged);
    }

    private void HandleUnreadCountChanged(int count)
    {
        unreadNotificationCount = count;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        NotificationBadgeService.OnUnreadCountChanged -= HandleUnreadCountChanged;
        dotNetReference?.Dispose();

        // Note: We intentionally don't dispose JavaScript resources here
        // When the page is being unloaded (e.g., logout), the browser automatically
        // cleans up all JavaScript. Attempting to call JS interop during disposal
        // causes JSDisconnectedException which is harmless but creates noise in logs.
    }
}


