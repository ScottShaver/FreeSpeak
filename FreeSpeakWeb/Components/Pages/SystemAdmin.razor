@page "/system-admin"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "SystemAdministrator")]
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Repositories.Abstractions

@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUserRepository UserRepository
@inject ILogger<SystemAdmin> Logger

<PageTitle>System Administration Functions</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">
                <i class="bi bi-shield-lock-fill me-2"></i>
                System Administration Functions
            </h1>

            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle me-2"></i>
                <strong>Welcome, System Administrator!</strong> This page is only accessible to users with the SystemAdministrator role.
            </div>

            @if (!string.IsNullOrEmpty(currentUserName))
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-person-circle fs-3"></i>
                            <div>
                                <p class="mb-1"><strong>@currentUserName</strong> (@currentUserEmail)</p>
                                <p class="mb-0 text-muted">Roles: @string.Join(", ", userRoles)</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Tabbed Interface -->
            <ul class="nav nav-tabs" id="adminTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="user-management-tab" data-bs-toggle="tab" data-bs-target="#user-management" type="button" role="tab" aria-controls="user-management" aria-selected="true">
                        <i class="bi bi-people me-2"></i>User Management
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="system-config-tab" data-bs-toggle="tab" data-bs-target="#system-config" type="button" role="tab" aria-controls="system-config" aria-selected="false">
                        <i class="bi bi-gear me-2"></i>System Configuration
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="content-moderation-tab" data-bs-toggle="tab" data-bs-target="#content-moderation" type="button" role="tab" aria-controls="content-moderation" aria-selected="false">
                        <i class="bi bi-shield-check me-2"></i>Site-wide Content Moderation
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="analytics-tab" data-bs-toggle="tab" data-bs-target="#analytics" type="button" role="tab" aria-controls="analytics" aria-selected="false">
                        <i class="bi bi-graph-up me-2"></i>Analytics and Reporting
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="database-tab" data-bs-toggle="tab" data-bs-target="#database" type="button" role="tab" aria-controls="database" aria-selected="false">
                        <i class="bi bi-database me-2"></i>Database Maintenance Tools
                    </button>
                </li>
            </ul>

            <div class="tab-content border border-top-0 p-4" id="adminTabsContent">
                <!-- User Management Tab -->
                <div class="tab-pane fade show active" id="user-management" role="tabpanel" aria-labelledby="user-management-tab">
                    <h3 class="mb-3">
                        <i class="bi bi-people me-2"></i>User Management
                    </h3>
                    <p class="text-muted">Manage user accounts, roles, and permissions across the system.</p>

                    <!-- User Search Section -->
                    <div class="card mb-4">
                        <div class="card-body">
                            <h5 class="card-title"><i class="bi bi-search me-2"></i>Search Users</h5>
                            <p class="card-text text-muted">Search across username, email, name, city, state, and occupation.</p>

                            <div class="search-section mb-3">
                                <input type="text" 
                                       class="form-control" 
                                       placeholder="Start typing to search users..." 
                                       @bind="searchTerm"
                                       @bind:event="oninput"
                                       @onkeyup="HandleSearchKeyUp" />
                            </div>

                            @if (isSearching)
                            {
                                <div class="text-center py-3">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Searching...</span>
                                    </div>
                                </div>
                            }
                            else if (searchResults.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead>
                                            <tr>
                                                <th>Username</th>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Location</th>
                                                <th>Occupation</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var user in searchResults)
                                            {
                                                <tr>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(user.ProfilePictureUrl))
                                                        {
                                                            <img src="@user.ProfilePictureUrl" alt="Profile" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover;" />
                                                        }
                                                        @user.UserName
                                                    </td>
                                                    <td>@user.FirstName @user.LastName</td>
                                                    <td>@user.Email</td>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(user.City) || !string.IsNullOrEmpty(user.State))
                                                        {
                                                            <span>@user.City@(!string.IsNullOrEmpty(user.City) && !string.IsNullOrEmpty(user.State) ? ", " : "")@user.State</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">—</span>
                                                        }
                                                    </td>
                                                    <td>@(user.Occupation ?? "—")</td>
                                                    <td>
                                                        <div class="dropdown">
                                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" 
                                                                    type="button" 
                                                                    id="userActions-@user.Id" 
                                                                    data-bs-toggle="dropdown" 
                                                                    aria-expanded="false"
                                                                    title="Actions">
                                                                <i class="bi bi-three-dots-vertical"></i>
                                                            </button>
                                                            <ul class="dropdown-menu" aria-labelledby="userActions-@user.Id">
                                                                <li>
                                                                    <button type="button" class="dropdown-item" @onclick="() => OpenRoleModal(user)">
                                                                        <i class="bi bi-person-badge me-2"></i>Edit Roles
                                                                    </button>
                                                                </li>
                                                                <li>
                                                                    <button type="button" class="dropdown-item" @onclick="() => OpenLockoutModal(user)">
                                                                        <i class="bi bi-lock me-2"></i>Lockout Info
                                                                    </button>
                                                                </li>
                                                                <li><hr class="dropdown-divider" /></li>
                                                                <li>
                                                                    <button type="button" class="dropdown-item" disabled>
                                                                        <i class="bi bi-eye me-2"></i>View Profile
                                                                    </button>
                                                                </li>
                                                                <li>
                                                                    <button type="button" class="dropdown-item" disabled>
                                                                        <i class="bi bi-person-x me-2"></i>Suspend User
                                                                    </button>
                                                                </li>
                                                                <li>
                                                                    <button type="button" class="dropdown-item" disabled>
                                                                        <i class="bi bi-envelope me-2"></i>Send Message
                                                                    </button>
                                                                </li>
                                                            </ul>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                @if (searchResults.Count >= 100)
                                {
                                    <div class="alert alert-info" role="alert">
                                        <i class="bi bi-info-circle me-2"></i>
                                        Showing first 100 results. Please refine your search for more specific results.
                                    </div>
                                }
                            }
                            else if (hasSearched && !isSearching)
                            {
                                <div class="alert alert-info" role="alert">
                                    <p class="mb-0">No users found matching "@searchTerm".</p>
                                </div>
                            }
                            else if (!hasSearched)
                            {
                                <div class="alert alert-info" role="alert">
                                    <p class="mb-0">Start typing in the search box to find users.</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <div class="alert alert-danger" role="alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>@errorMessage
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Other User Management Features -->
                    <h5 class="mb-3">Additional Features</h5>
                    <div class="row mt-4">
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title"><i class="bi bi-person-plus me-2"></i>Create User</h5>
                                    <p class="card-text">Add new users to the system manually.</p>
                                    <button class="btn btn-primary" @onclick="OpenCreateUserModal">Create New User</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title"><i class="bi bi-clock-history me-2"></i>Audit Log</h5>
                                    <p class="card-text">View user activity and account changes.</p>
                                    <button class="btn btn-primary" disabled>Coming Soon</button>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Export Users</h5>
                                    <p class="card-text">Export user data for analysis or backup.</p>
                                    <button class="btn btn-primary" disabled>Coming Soon</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- System Configuration Tab -->
