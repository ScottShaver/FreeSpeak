    /// <summary>
    /// Handles the event when a new user is successfully created.
    /// Refreshes the search results if a search term exists.
    /// </summary>
    private async Task HandleUserCreated()
    {
        Logger.LogInformation("New user created successfully");

        // If there's an active search, refresh the results
        if (!string.IsNullOrWhiteSpace(searchTerm) && hasSearched)
        {
            try
            {
                searchResults = await UserRepository.AdminSearchUsersAsync(searchTerm);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error refreshing search results after user creation");
            }
        }
    }

