@* Role Management Modal *@
@if (showRoleModal && selectedUser != null)
{
    <FreeSpeakWeb.Components.Admin.UserRoleManagementModal 
        User="@selectedUser"
        OnClose="CloseRoleModal"
        OnRolesUpdated="HandleRolesUpdated" />
}

@* Lockout Management Modal *@
@if (showLockoutModal && selectedUser != null)
{
    <FreeSpeakWeb.Components.Admin.UserLockoutManagementModal 
        User="@selectedUser"
        OnClose="CloseLockoutModal"
        OnLockoutUpdated="HandleLockoutUpdated" />
}

@* Create User Modal *@
@if (showCreateUserModal)
{
    <FreeSpeakWeb.Components.Admin.UserCreationModal 
        OnClose="CloseCreateUserModal"
        OnUserCreated="HandleUserCreated" />
}

@code {
    private string? currentUserName;
    private string? currentUserEmail;
    private List<string> userRoles = new();
    private string searchTerm = string.Empty;
    private List<ApplicationUser> searchResults = new();
    private bool isSearching = false;
    private bool hasSearched = false;
    private string? errorMessage;
    private System.Threading.Timer? searchDebounceTimer;

    // Role management modal state
    private bool showRoleModal = false;
    private ApplicationUser? selectedUser = null;

    // Lockout management modal state
    private bool showLockoutModal = false;

    // Create user modal state
    private bool showCreateUserModal = false;

    /// <summary>
    /// Initializes the component by loading the current user's information and roles.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var currentUser = await UserManager.GetUserAsync(user);
            if (currentUser != null)
            {
                currentUserName = currentUser.UserName;
                currentUserEmail = currentUser.Email;

                var roles = await UserManager.GetRolesAsync(currentUser);
                userRoles = roles.ToList();
            }
        }
    }

    /// <summary>
    /// Handles the keyup event on the search input with debouncing.
    /// Triggers a search 300ms after the user stops typing.
    /// </summary>
    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        // Dispose existing timer
        searchDebounceTimer?.Dispose();

        // Capture the current search term value
        var currentSearchTerm = searchTerm;

        // Create new timer that will trigger search after 300ms of no typing
        searchDebounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                // Use the captured search term to ensure we search for the correct value
                if (string.IsNullOrWhiteSpace(currentSearchTerm))
                {
                    searchResults.Clear();
                    hasSearched = false;
                    StateHasChanged();
                }
                else if (!isSearching)
                {
                    isSearching = true;
                    hasSearched = true;
                    errorMessage = null;

                    try
                    {
                        searchResults = await UserRepository.AdminSearchUsersAsync(currentSearchTerm);
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "[{ExceptionType}] Error occurred while searching for users. Search term: {SearchTerm}. Exception: {ExceptionMessage}", ex.GetType().Name, currentSearchTerm, ex.Message);
                        errorMessage = "An error occurred while searching. Please try again.";
                        searchResults.Clear();
                    }
                    finally
                    {
                        isSearching = false;
                        StateHasChanged();
                    }
                }
            });
        }, null, 300, Timeout.Infinite);
    }

