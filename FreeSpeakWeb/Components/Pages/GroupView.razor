    private string GetRelativeTime(DateTime? dateTime)
    {
        if (dateTime == null)
            return "Never";

        var timeSpan = DateTime.UtcNow - dateTime.Value;

        if (timeSpan.TotalMinutes < 1)
            return "just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)timeSpan.TotalDays}d ago";

        return dateTime.Value.ToString("MMM dd, yyyy");
    }

    /// <summary>
    /// Gets the Bootstrap badge CSS class for a member level.
    /// </summary>
    /// <param name="level">The member level.</param>
    /// <returns>A Bootstrap badge class name.</returns>
    private static string GetLevelBadgeClass(MemberLevel level)
    {
        return level switch
        {
            MemberLevel.AllStarContributor => "bg-warning text-dark",
            MemberLevel.TopContributor => "bg-primary",
            MemberLevel.RisingContributor => "bg-success",
            MemberLevel.Member => "bg-secondary",
            _ => "bg-secondary"
        };
    }

