@page "/group/{GroupId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inherits PostPageBase<GroupPost, GroupPostComment>

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.DTOs
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Pages.Base
@using System.Security.Claims
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IOptions<SiteSettings> SiteSettings
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GroupPostService GroupPostService
@inject PinnedGroupPostService PinnedGroupPostService
@inject GroupService GroupService
@inject GroupMemberService GroupMemberService
@inject UserManager<ApplicationUser> UserManager
@inject UserPreferenceService UserPreferenceService
@inject HtmlSanitizationService HtmlSanitizationService
@inject ImageUploadService ImageUploadService
@inject FreeSpeakWeb.Repositories.Abstractions.IGroupCommentRepository GroupCommentRepository

<PageTitle>@(group?.Name ?? "Group") - @SiteSettings.Value.SiteName</PageTitle>

<div class="group-view-container">
    @if (isLoadingGroup)
    {
        <div class="loading-indicator">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3">Loading group information...</p>
        </div>
    }
    else if (group == null)
    {
        <div class="alert alert-danger">
            <h4>Group Not Found</h4>
            <p>The group you're looking for doesn't exist or you don't have access to it.</p>
            <a href="/groups" class="btn btn-primary">Go to Groups</a>
        </div>
    }
    else
    {
        <!-- Group Header -->
        <div class="group-header">
            @if (!string.IsNullOrEmpty(group.HeaderImageUrl))
            {
                <div class="group-header-image" style="background-image: url('@group.HeaderImageUrl');"></div>
            }
            <div class="group-header-content">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h1>@group.Name</h1>
                    @if (!string.IsNullOrEmpty(currentUserId) && group.CreatorId == currentUserId)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="OpenGroupSettings" title="Group Settings">
                            <i class="bi bi-gear me-1"></i>Settings
                        </button>
                    }
                </div>
                <p class="group-description">@group.Description</p>
                
                <div class="group-stats">
                    <div class="stat-item">
                        <span class="stat-label">Members</span>
                        <span class="stat-value">@memberCount</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Total Posts</span>
                        <span class="stat-value">@totalPosts</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Posts This Week</span>
                        <span class="stat-value">@postsThisWeek</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Posts Today</span>
                        <span class="stat-value">@postsToday</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Last Activity</span>
                        <span class="stat-value">@GetRelativeTime(lastActivity)</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Group Feed -->
        <div class="group-feed-section">
            <!-- Post Creator -->
            <div class="group-post-creator mb-4">
                <PostCreator 
                    CurrentUserImageUrl="@currentUserImageUrl"
                    CurrentUserName="@currentUserName"
                    ShowAudienceSelector="false"
                    OnPostCreated="HandleGroupPostCreated" />
            </div>

            <h3>Recent Posts</h3>
            
            @if (isLoadingPosts && !groupPosts.Any())
            {
                <div class="loading-indicator">
                    <p>Loading posts...</p>
                </div>
            }
            else if (!groupPosts.Any() && !isLoadingPosts)
            {
                <div class="empty-feed">
                    <p>No posts in this group yet. Be the first to post!</p>
                </div>
            }
            else
            {
                @foreach (var post in groupPosts)
                {
                    var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                    var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                    var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                    var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;
                    var isMuted = postMuteStatus.ContainsKey(post.Id) ? postMuteStatus[post.Id] : (bool?)null;

                    <GroupPostArticle 
                        PostId="@post.Id"
                        GroupId="@post.GroupId"
                        GroupName="@group.Name"
                        AuthorId="@post.AuthorId"
                        AuthorName="@post.AuthorName"
                        AuthorImageUrl="@post.AuthorImageUrl"
                        AuthorGroupPoints="@post.AuthorGroupPoints"
                        CreatedAt="@post.CreatedAt"
                        LikeCount="@post.LikeCount"
                        CommentCount="@post.CommentCount"
                        ShareCount="@post.ShareCount"
                        LoadCommentsInternally="true"
                        CommentsToShow="3"
                        RefreshTrigger="@refreshTrigger"
                        CurrentUserId="@currentUserId"
                        CurrentUserImageUrl="@currentUserImageUrl"
                        CurrentUserName="@currentUserName"
                        ReactionBreakdown="@postReactions"
                        UserReaction="@userReaction"
                        IsPinned="@isPinned"
                        IsMuted="@isMuted"
                        Images="@ConvertPostImageDtosToPostImages(post.Images)"
                        OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(post.Id, reactionType))"
                        OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(post.Id))"
                        OnPinPost="@HandlePinGroupPost"
                        OnUnpinPost="@HandleUnpinGroupPost"
                        OnPostDeleted="@HandleGroupPostDeleted"
                        OnEditPost="@HandleEditGroupPost"
                        OnCommentAdded="@HandleGroupPostCommentAdded"
                        OnReplySubmitted="@HandleGroupPostReplySubmitted"
                        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
                        OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
                        OnDeleteComment="@HandleDeleteComment"
                        OnCommentUpdated="@HandleCommentUpdated"
                        OnReportComment="@HandleReportComment"
                        OnShowPostDetail="@(() => ShowGroupPostDetail(post))"
                        OnShowComments="@(() => ShowGroupPostDetail(post))">
                        <ArticleContent>
                            @((MarkupString)FormatContentWithLineBreaks(post.Content))
                        </ArticleContent>
                    </GroupPostArticle>
                }

                @if (isLoadingMorePosts)
                {
                    <div class="loading-more">
                        <p>Loading more posts...</p>
                    </div>
                }

                @if (hasMorePosts == false && groupPosts.Any())
                {
                    <div class="no-more-posts">
                        <p>No more posts at this time</p>
                    </div>
                }
            }
        </div>
    }
</div>

@if (showGroupPostDetailModal && selectedGroupPost != null)
{
    var postReactions = postReactionData.ContainsKey(selectedGroupPost.Id) ? postReactionData[selectedGroupPost.Id] : new Dictionary<LikeType, int>();
    var userReaction = postUserReactions.ContainsKey(selectedGroupPost.Id) ? postUserReactions[selectedGroupPost.Id] : null;
    var isPinned = pinnedPosts.ContainsKey(selectedGroupPost.Id) && pinnedPosts[selectedGroupPost.Id];

    <GroupPostDetailModal 
        PostId="@selectedGroupPost.Id"
        GroupId="@selectedGroupPost.GroupId"
        GroupName="@(group?.Name ?? string.Empty)"
        AuthorId="@selectedGroupPost.AuthorId"
        AuthorName="@selectedGroupPost.AuthorName"
        AuthorImageUrl="@selectedGroupPost.AuthorImageUrl"
        CurrentUserId="@currentUserId"
        CreatedAt="@selectedGroupPost.CreatedAt"
        LikeCount="@selectedGroupPost.LikeCount"
        CommentCount="@selectedGroupPost.CommentCount"
        ShareCount="@selectedGroupPost.ShareCount"
        CurrentUserImageUrl="@currentUserImageUrl"
        CurrentUserName="@currentUserName"
        ReactionBreakdown="@postReactions"
        UserReaction="@userReaction"
        IsPinned="@isPinned"
        Images="@ConvertPostImageDtosToPostImages(selectedGroupPost.Images)"
        OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(selectedGroupPost.Id, reactionType))"
        OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(selectedGroupPost.Id))"
        OnPinPost="@HandlePinGroupPost"
        OnUnpinPost="@HandleUnpinGroupPost"
        OnPostDeleted="@HandleGroupPostDeleted"
        OnEditPost="@HandleEditGroupPost"
        OnCommentAdded="@HandleGroupPostCommentAdded"
        OnReplySubmitted="@HandleGroupPostReplySubmitted"
        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
        OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
        OnDeleteComment="@HandleDeleteComment"
        OnCommentUpdated="@HandleCommentUpdated"
        OnReportComment="@HandleReportComment"
        OnClose="@CloseGroupPostDetailModal">
        <ArticleContent>
            @((MarkupString)FormatContentWithLineBreaks(selectedGroupPost.Content))
        </ArticleContent>
    </GroupPostDetailModal>
}

<UploadProgressModal 
    IsVisible="@showUploadProgress"
    Title="@uploadProgressTitle"
    Message="@uploadProgressMessage"
    Progress="@uploadProgress"
    CurrentStep="@uploadCurrentStep"
    TotalSteps="@uploadTotalSteps" />

@if (showGroupSettings && group != null)
{
    <FreeSpeakWeb.Components.Groups.GroupSettingsModal 
        Group="@group"
        CurrentUserId="@currentUserId"
        OnClose="CloseGroupSettings"
        OnSettingsSaved="HandleGroupSettingsSaved" />
}

@code {
    [Parameter]
    public int GroupId { get; set; }

    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;

    // Group information
    private Group? group;
    private bool isLoadingGroup = false;
    private int memberCount = 0;
    private int totalPosts = 0;
    private int postsThisWeek = 0;
    private int postsToday = 0;
    private DateTime? lastActivity;

    // Posts state
    private List<GroupPostViewModel> groupPosts = new();
    private bool isLoadingPosts = false;
    private bool isLoadingMorePosts = false;
    private bool? hasMorePosts = null;
    private int currentPage = 1;
    private const int pageSize = 20;
    private Dictionary<int, bool> postMuteStatus = new();

    // JavaScript interop
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<GroupView>? dotNetHelper;

    // Upload progress tracking
    private bool showUploadProgress = false;
    private string uploadProgressTitle = "Adding Your Post";
    private string uploadProgressMessage = "Please wait...";
    private int uploadProgress = 0;
    private int uploadCurrentStep = 0;
    private int uploadTotalSteps = 0;

    // Group-specific dictionaries (rename to use base class naming)
    // Base class provides: postRefreshTriggers, postReactionData, postUserReactions, pinnedPosts, postAuthorNames

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(currentUserId))
            {
                var appUser = await UserManager.FindByIdAsync(currentUserId);
                if (appUser != null)
                {
                    currentUserImageUrl = appUser.ProfilePictureUrl;
                    currentUserName = $"{appUser.FirstName} {appUser.LastName}";
                }

                await LoadGroupInformation();
                await LoadGroupPosts();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(currentUserId))
        {
            try
            {
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Groups.razor.js");
                dotNetHelper = DotNetObjectReference.Create(this);
                await jsModule.InvokeAsync<object?>("initializeInfiniteScroll", (object?)null, dotNetHelper);
            }
            catch (Exception)
            {
                // Silently fail - infinite scroll optional
            }
        }
    }

    /// <summary>
    /// Loads the group information and statistics.
    /// Includes a guard to prevent concurrent loading operations.
    /// </summary>
    private async Task LoadGroupInformation()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Prevent concurrent loading operations
        if (isLoadingGroup) return;

        isLoadingGroup = true;
        StateHasChanged();

        try
        {
            // Check if user is a member
            var isMember = await GroupMemberService.IsMemberAsync(GroupId, currentUserId);
            if (!isMember)
            {
                group = null;
                isLoadingGroup = false;
                StateHasChanged();
                return;
            }

            // Load group details
            group = await GroupService.GetGroupByIdAsync(GroupId);
            if (group == null)
            {
                isLoadingGroup = false;
                StateHasChanged();
                return;
            }

            // Load statistics
            memberCount = await GroupMemberService.GetMemberCountAsync(GroupId);
            totalPosts = await GroupPostService.GetTotalPostCountAsync(GroupId);
            
            var oneWeekAgo = DateTime.UtcNow.AddDays(-7);
            postsThisWeek = await GroupPostService.GetPostCountSinceAsync(GroupId, oneWeekAgo);
            
            var oneDayAgo = DateTime.UtcNow.AddDays(-1);
            postsToday = await GroupPostService.GetPostCountSinceAsync(GroupId, oneDayAgo);
            
            lastActivity = await GroupPostService.GetLastActivityAsync(GroupId) ?? group.CreatedAt;
        }
        catch (Exception)
        {
            group = null;
        }
        finally
        {
            isLoadingGroup = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads the group posts for display.
    /// Includes a guard to prevent concurrent loading operations.
    /// </summary>
    private async Task LoadGroupPosts()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Prevent concurrent loading operations
        if (isLoadingPosts) return;

        isLoadingPosts = true;
        StateHasChanged();

        try
        {
            currentPage = 1;
            var loadedDtos = await GroupPostService.GetGroupPostsAsProjectionAsync(GroupId, 0, pageSize);

            groupPosts = GroupPostViewModel.FromDtos(loadedDtos);
            hasMorePosts = loadedDtos.Count >= pageSize;

            // Load additional data for posts (reactions, pinned status, mute status)
            await LoadGroupPostDataAsync(groupPosts);
        }
        catch (Exception)
        {
            // Silently fail - posts will show empty
        }
        finally
        {
            isLoadingPosts = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task LoadMoreGroupPostsAsync()
    {
        if (string.IsNullOrEmpty(currentUserId) || isLoadingMorePosts || hasMorePosts == false) return;

        isLoadingMorePosts = true;
        StateHasChanged();

        try
        {
            currentPage++;
            var skip = (currentPage - 1) * pageSize;
            var loadedDtos = await GroupPostService.GetGroupPostsAsProjectionAsync(GroupId, skip, pageSize);

            if (loadedDtos.Any())
            {
                var newPosts = GroupPostViewModel.FromDtos(loadedDtos);
                groupPosts.AddRange(newPosts);
                hasMorePosts = loadedDtos.Count >= pageSize;

                // Load additional data for new posts
                await LoadGroupPostDataAsync(newPosts);
            }
            else
            {
                hasMorePosts = false;
            }
        }
        catch (Exception)
        {
            // Silently fail - pagination will stop
        }
        finally
        {
            isLoadingMorePosts = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads additional data for a list of group post view models, including reactions, pinned status, and mute status.
    /// Uses batch queries where possible to optimize performance.
    /// Note: Author names and group names are already included in the ViewModel from the DTO projection.
    /// </summary>
    /// <param name="posts">The list of group post view models to load data for.</param>
    private async Task LoadGroupPostDataAsync(List<GroupPostViewModel> posts)
    {
        if (!posts.Any()) return;

        // Get post IDs that need reaction data loaded
        var postIdsNeedingReactions = posts
            .Where(p => !postReactionData.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingReactions.Any())
        {
            // Load reaction data for all posts in a single query
            var reactions = await GroupPostService.GetReactionBreakdownForPostsAsync(postIdsNeedingReactions);
            foreach (var kvp in reactions)
            {
                postReactionData[kvp.Key] = kvp.Value;
            }
        }

        // Get post IDs that need user reactions loaded
        var postIdsNeedingUserReactions = posts
            .Where(p => !postUserReactions.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingUserReactions.Any() && currentUserId != null)
        {
            // Load user reactions for all posts in a single query
            var userReactions = await GroupPostService.GetUserReactionsForPostsAsync(postIdsNeedingUserReactions, currentUserId);
            foreach (var kvp in userReactions)
            {
                postUserReactions[kvp.Key] = kvp.Value;
            }
        }

        // Load pinned status (still per-post, could be optimized separately)
        foreach (var post in posts)
        {
            if (!pinnedPosts.ContainsKey(post.Id) && currentUserId != null)
            {
                var isPinned = await PinnedGroupPostService.IsGroupPostPinnedAsync(currentUserId, post.Id);
                pinnedPosts[post.Id] = isPinned;
            }
        }

        // Load mute status in batch to avoid N+1 queries
        var postIdsNeedingMuteStatus = posts
            .Where(p => !postMuteStatus.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingMuteStatus.Any() && currentUserId != null)
        {
            var muteStatus = await GroupPostService.GetMuteStatusForPostsAsync(postIdsNeedingMuteStatus, currentUserId);
            foreach (var kvp in muteStatus)
            {
                postMuteStatus[kvp.Key] = kvp.Value;
            }
        }
    }

    private async Task HandleGroupPostReactionChanged(int postId, LikeType reactionType)
    {
        // Delegate to base class implementation
        await HandlePostReactionChanged(postId, reactionType);
    }

    private async Task HandleRemoveGroupPostReaction(int postId)
    {
        // Delegate to base class implementation
        await HandleRemovePostReaction(postId);
    }

    private async Task HandlePinGroupPost(int postId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        var (success, errorMessage) = await PinnedGroupPostService.PinGroupPostAsync(currentUserId, postId);

        if (success)
        {
            pinnedPosts[postId] = true;

            // Log group post pin to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(currentUserId, ActionCategory.UserGroupPost, new UserPinPostDetails
                {
                    PostId = postId,
                    OperationType = OperationTypeEnum.Pin.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            StateHasChanged();
        }
        else
        {
            AlertService.ShowError(errorMessage ?? "Failed to pin post.");
        }
    }

    private async Task HandleUnpinGroupPost(int postId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        var (success, errorMessage) = await PinnedGroupPostService.UnpinGroupPostAsync(currentUserId, postId);

        if (success)
        {
            pinnedPosts[postId] = false;

            // Log group post unpin to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(currentUserId, ActionCategory.UserGroupPost, new UserPinPostDetails
                {
                    PostId = postId,
                    OperationType = OperationTypeEnum.Unpin.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            StateHasChanged();
        }
        else
        {
            AlertService.ShowError(errorMessage ?? "Failed to unpin post.");
        }
    }

    private async Task HandleGroupPostDeleted(int postId)
    {
        groupPosts.RemoveAll(p => p.Id == postId);
        totalPosts = Math.Max(0, totalPosts - 1);
        StateHasChanged();
    }

    /// <summary>
    /// Handles the creation of a new group post from the PostCreator component.
    /// Uploads images if provided, creates the post, and refreshes the post list.
    /// </summary>
    /// <param name="postData">Tuple containing post content, audience type (unused for groups), and selected images.</param>
    private async Task HandleGroupPostCreated((string Content, AudienceType AudienceType, List<ImageUploadModal.SelectedImage> Images) postData)
    {
        if (string.IsNullOrEmpty(currentUserId) || group == null) return;

        try
        {
            var imageUrls = new List<string>();

            // Calculate total steps
            var hasImages = postData.Images != null && postData.Images.Any();
            uploadTotalSteps = hasImages ? 2 : 1;
            uploadCurrentStep = 0;

            // Show progress modal
            showUploadProgress = true;
            uploadProgress = 0;
            StateHasChanged();

            // Step 1: Upload images if any
            if (hasImages && postData.Images != null)
            {
                uploadCurrentStep = 1;
                uploadProgressMessage = $"Uploading {postData.Images.Count} {(postData.Images.Count == 1 ? "image" : "images")}...";
                StateHasChanged();

                // Convert selected images to upload format
                var imagesToUpload = postData.Images.Select(img => (
                    FileName: img.FileName,
                    Base64Data: img.DataUrl,
                    ContentType: img.ContentType
                )).ToList();

                // Create progress reporter
                var progress = new Progress<int>(percent =>
                {
                    uploadProgress = percent / 2;
                    InvokeAsync(StateHasChanged);
                });

                var uploadResult = await ImageUploadService.UploadImagesAsync(currentUserId, imagesToUpload, progress, groupId: GroupId);

                if (!uploadResult.Success)
                {
                    showUploadProgress = false;
                    StateHasChanged();
                    return;
                }

                imageUrls = uploadResult.ImageUrls;
                uploadProgress = 50;
                StateHasChanged();
            }

            // Step 2: Create the group post
            uploadCurrentStep = hasImages ? 2 : 1;
            uploadProgressMessage = "Creating your post...";
            uploadProgress = hasImages ? 50 : 0;
            StateHasChanged();

            var result = await GroupPostService.CreateGroupPostAsync(GroupId, currentUserId, postData.Content, imageUrls);

            if (result.Success && result.Post != null)
            {
                uploadProgress = 100;
                StateHasChanged();

                // Small delay to show 100% completion
                await Task.Delay(500);

                // Hide progress modal
                showUploadProgress = false;
                StateHasChanged();

                // Note: Audit logging for group post creation is handled by GroupPostService.CreateGroupPostAsync

                // Update statistics
                totalPosts++;
                postsToday++;
                postsThisWeek++;
                lastActivity = DateTime.UtcNow;

                // Reload the group posts to include the new post
                await LoadGroupPosts();

                // Scroll to top to show the new post
                if (jsModule != null)
                {
                    try
                    {
                        await jsModule.InvokeVoidAsync("scrollToTop");
                    }
                    catch
                    {
                        // Ignore scroll errors
                    }
                }

                StateHasChanged();
            }
            else
            {
                showUploadProgress = false;
                AlertService.ShowError(result.ErrorMessage ?? "Failed to create post.");
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            showUploadProgress = false;
            AlertService.ShowError("An error occurred while creating your post.");
            StateHasChanged();
        }
    }

    /// <summary>
    /// Handles the edit post action by opening the post detail modal.
    /// </summary>
    /// <param name="postId">The ID of the post to edit.</param>
    private async Task HandleEditGroupPost(int postId)
    {
        var post = groupPosts.FirstOrDefault(p => p.Id == postId);
        if (post != null)
        {
            await ShowGroupPostDetail(post);
        }
    }

    private async Task HandleGroupPostCommentAdded((int PostId, string Content) args)
    {
        // Delegate to base class implementation
        await HandleCommentAdded(args);
    }

    private async Task HandleGroupPostReplySubmitted((int ParentCommentId, string Content) args)
    {
        // Delegate to base class implementation
        await HandleReplySubmitted(args);
    }

    private async Task HandleGroupPostCommentReactionChanged((int CommentId, LikeType ReactionType) args)
    {
        // Delegate to base class implementation
        await HandleCommentReactionChanged(args);
    }

    private async Task HandleRemoveGroupPostCommentReaction(int commentId)
    {
        // Delegate to base class implementation
        await HandleRemoveCommentReaction(commentId);
    }

    // Modal state
    private bool showGroupPostDetailModal = false;
    private GroupPostViewModel? selectedGroupPost = null;

    // Group settings modal state
    private bool showGroupSettings = false;

    /// <summary>
    /// Opens the group settings modal.
    /// </summary>
    private void OpenGroupSettings()
    {
        showGroupSettings = true;
        StateHasChanged();
    }

    /// <summary>
    /// Closes the group settings modal.
    /// </summary>
    private void CloseGroupSettings()
    {
        showGroupSettings = false;
        StateHasChanged();
    }

    /// <summary>
    /// Handles the event when group settings are saved successfully.
    /// Refreshes the group information to reflect changes.
    /// </summary>
    private async Task HandleGroupSettingsSaved()
    {
        // The group object has already been updated by the modal
        // Just refresh the UI
        StateHasChanged();
    }

    /// <summary>
    /// Shows the detailed view modal for a group post.
    /// </summary>
    /// <param name="post">The group post view model to display in detail.</param>
    private async Task ShowGroupPostDetail(GroupPostViewModel post)
    {
        selectedGroupPost = post;
        showGroupPostDetailModal = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

    private void CloseGroupPostDetailModal()
    {
        showGroupPostDetailModal = false;
        selectedGroupPost = null;
        StateHasChanged();
    }

    private GroupPostComment? FindCommentInTree(List<GroupPostComment> comments, int commentId)
    {
        foreach (var comment in comments)
        {
            if (comment.Id == commentId)
            {
                return comment;
            }

            if (comment.Replies != null && comment.Replies.Any())
            {
                var found = FindCommentInTree(comment.Replies.ToList(), commentId);
                if (found != null)
                {
                    return found;
                }
            }
        }
        return null;
    }

    private async Task<string> FormatUserDisplayName(ApplicationUser? user)
    {
        if (user == null)
            return "Unknown";

        return await UserPreferenceService.FormatUserDisplayNameAsync(
            user.Id,
            user.FirstName,
            user.LastName,
            user.UserName ?? "Unknown"
        );
    }

    /// <summary>
    /// Converts a collection of PostImageDto objects to PostImage objects.
    /// This is needed for compatibility with shared components that expect PostImage type.
    /// </summary>
    /// <param name="imageDtos">The collection of post image DTOs to convert.</param>
    /// <returns>A list of PostImage objects, or null if the input is null or empty.</returns>
    private List<PostImage>? ConvertPostImageDtosToPostImages(IReadOnlyList<PostImageDto>? imageDtos)
    {
        if (imageDtos == null || !imageDtos.Any())
            return null;

        return imageDtos.Select(dto => new PostImage
        {
            Id = dto.Id,
            PostId = 0, // Not used for display; set to 0 for DTO-based rendering
            ImageUrl = dto.ImageUrl,
            DisplayOrder = dto.DisplayOrder
        }).ToList();
    }

    private string FormatContentWithLineBreaks(string content)
    {
        if (string.IsNullOrWhiteSpace(content))
            return string.Empty;

        return HtmlSanitizationService.SanitizeAndFormatContent(content);
    }

    private string GetRelativeTime(DateTime? dateTime)
    {
        if (dateTime == null)
            return "Never";

        var timeSpan = DateTime.UtcNow - dateTime.Value;

        if (timeSpan.TotalMinutes < 1)
            return "just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)timeSpan.TotalDays}d ago";

        return dateTime.Value.ToString("MMM dd, yyyy");
    }

