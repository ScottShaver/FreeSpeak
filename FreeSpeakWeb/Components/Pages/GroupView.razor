@page "/group/{GroupId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@inherits PostPageBase<GroupPost, GroupPostComment>

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.DTOs
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Pages.Base
@using System.Security.Claims
@using Microsoft.JSInterop
@using Microsoft.Extensions.Localization

@implements IAsyncDisposable

@inject IOptions<SiteSettings> SiteSettings
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GroupPostService GroupPostService
@inject PinnedGroupPostService PinnedGroupPostService
@inject GroupService GroupService
@inject GroupMemberService GroupMemberService
@inject UserManager<ApplicationUser> UserManager
@inject UserPreferenceService UserPreferenceService
@inject HtmlSanitizationService HtmlSanitizationService
@inject ImageUploadService ImageUploadService
@inject GroupPointsService GroupPointsService
@inject FreeSpeakWeb.Repositories.Abstractions.IGroupCommentRepository GroupCommentRepository
@inject IStringLocalizer<FreeSpeakWeb.Resources.Pages.GroupView> Localizer

<PageTitle>@(group?.Name ?? "Group") - @SiteSettings.Value.SiteName</PageTitle>

<div class="group-view-container">
    @if (isLoadingGroup)
    {
        <LoadingSpinner Text="@Localizer["LoadingGroupInformation"]" Size="lg" />
    }
    else if (group == null)
    {
        <div class="alert alert-danger">
            <h4>@Localizer["GroupNotFound"]</h4>
            <p>@Localizer["GroupNotFoundMessage"]</p>
            <a href="/groups" class="btn btn-primary">@Localizer["GoToGroups"]</a>
        </div>
    }
    else
    {
        <!-- Group Header -->
        <div class="group-header">
            @if (!string.IsNullOrEmpty(group.HeaderImageUrl))
            {
                <div class="group-header-image" style="background-image: url('@group.HeaderImageUrl');"></div>
            }
            <div class="group-header-content">
                @* Role indicator row - shows if user is admin or moderator *@
                @if (isGroupAdmin || isGroupModerator || group.CreatorId == currentUserId)
                {
                    <div class="group-role-indicators mb-2">
                        @if (group.CreatorId == currentUserId)
                        {
                            <span class="badge bg-warning text-dark me-2" title="@Localizer["YouAreGroupCreator"]">
                                <i class="bi bi-star-fill me-1"></i>@Localizer["Creator"]
                            </span>
                        }
                        @if (isGroupAdmin)
                        {
                            <span class="badge bg-primary me-2" title="@Localizer["YouAreGroupAdmin"]">
                                <i class="bi bi-shield-lock-fill me-1"></i>@Localizer["Admin"]
                            </span>
                        }
                        @if (isGroupModerator && !isGroupAdmin)
                        {
                            <span class="badge bg-info text-dark me-2" title="@Localizer["YouAreGroupModerator"]">
                                <i class="bi bi-shield-check me-1"></i>@Localizer["Moderator"]
                            </span>
                        }
                    </div>
                }
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <h1>@group.Name</h1>
                    <div class="group-header-actions d-flex gap-2">
                        @if (CanAccessGroupAdministration)
                        {
                            <button class="btn btn-outline-primary btn-sm" @onclick="OpenGroupAdministration" title="@Localizer["GroupAdministration"]">
                                <i class="bi bi-shield-lock me-1"></i>@Localizer["GroupAdministration"]
                            </button>
                        }
                        @if (CanAccessGroupModeration)
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="OpenGroupModeration" title="@Localizer["GroupModeration"]">
                                <i class="bi bi-shield-check me-1"></i>@Localizer["GroupModeration"]
                            </button>
                        }
                        @if (!string.IsNullOrEmpty(currentUserId) && group.CreatorId == currentUserId)
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="OpenGroupSettings" title="Group Settings">
                                <i class="bi bi-gear me-1"></i>@Localizer["Settings"]
                            </button>
                        }
                    </div>
                </div>
                <p class="group-description">@group.Description</p>

                <div class="group-stats">
                    <StatItem Label="@Localizer["Members"]" 
                              Value="@memberCount" 
                              Icon="bi-people" />
                    <StatItem Label="@Localizer["TotalPosts"]" 
                              Value="@totalPosts" 
                              Icon="bi-file-post" />
                    <StatItem Label="@Localizer["PostsThisWeek"]" 
                              Value="@postsThisWeek" 
                              Icon="bi-calendar-week" />
                    <StatItem Label="@Localizer["PostsToday"]" 
                              Value="@postsToday" 
                              Icon="bi-calendar-day" />
                    <div class="stat-item">
                        <span class="stat-label">@Localizer["LastActivity"]</span>
                        <span class="stat-value">@GetRelativeTime(lastActivity)</span>
                    </div>
                </div>

                <div class="user-stats-display mt-3 p-3 rounded border">
                    <div class="d-flex align-items-center gap-4 flex-wrap">
                        @* User's Post Count *@
                        <div class="d-flex align-items-center gap-2">
                            <div class="stat-icon">
                                <i class="bi bi-file-post text-info fs-4"></i>
                            </div>
                            <div class="stat-info">
                                <div class="stat-label text-muted small">@Localizer["YourPosts"]</div>
                                <span class="stat-value fw-bold fs-5">@currentUserPostCount.ToString("N0")</span>
                            </div>
                        </div>

                        @* User's Points (only if points system is enabled) *@
                        @if (group.EnablePointsSystem)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div class="points-icon">
                                    <i class="bi @GroupPointsService.GetMemberLevelIcon(currentUserLevel) @GroupPointsService.GetMemberLevelColor(currentUserLevel) fs-4"></i>
                                </div>
                                <div class="points-info">
                                    <div class="points-label text-muted small">@Localizer["YourPoints"]</div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="points-value fw-bold fs-5">@currentUserPoints.ToString("N0")</span>
                                        <span class="badge @GetLevelBadgeClass(currentUserLevel)">
                                            @GroupPointsService.GetMemberLevelName(currentUserLevel)
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Group Feed -->
        <div class="group-feed-section">
            <!-- Post Creator -->
            <div class="group-post-creator mb-4">
                <PostCreator 
                    CurrentUserImageUrl="@currentUserImageUrl"
                    CurrentUserName="@currentUserName"
                    ShowAudienceSelector="false"
                    OnPostCreated="HandleGroupPostCreated" />
            </div>

            <h3>@Localizer["RecentPosts"]</h3>

            @if (isLoadingPosts && !groupPosts.Any())
            {
                <LoadingSpinner Text="@Localizer["LoadingPosts"]" />
            }
            else if (!groupPosts.Any() && !isLoadingPosts)
            {
                <EmptyState Message="@Localizer["NoPostsYet"]" Icon="bi-file-post" />
            }
            else
            {
                @foreach (var post in groupPosts)
                {
                    var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                    var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                    var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                    var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;
                    var isMuted = postMuteStatus.ContainsKey(post.Id) ? postMuteStatus[post.Id] : (bool?)null;
                    var postStatus = postStatuses.ContainsKey(post.Id) ? postStatuses[post.Id] : PostStatus.Posted;

                    @* Show status banner for user's own pending/declined posts *@
                    @if (post.AuthorId == currentUserId && postStatus != PostStatus.Posted)
                    {
                        <div class="post-status-banner mb-2 p-2 rounded @(postStatus == PostStatus.Pending ? "bg-warning bg-opacity-25 border border-warning" : "bg-danger bg-opacity-25 border border-danger")">
                            @if (postStatus == PostStatus.Pending)
                            {
                                <i class="bi bi-hourglass-split text-warning me-2"></i>
                                <span class="text-warning fw-bold">@Localizer["PostPending"]</span>
                                <span class="text-muted small ms-2">@Localizer["PostPendingDescription"]</span>
                            }
                            else if (postStatus == PostStatus.Declined)
                            {
                                <i class="bi bi-x-circle text-danger me-2"></i>
                                <span class="text-danger fw-bold">@Localizer["PostDeclined"]</span>
                                <span class="text-muted small ms-2">@Localizer["PostDeclinedDescription"]</span>
                            }
                        </div>
                    }

                    <UnifiedArticle
                        ArticlePostType="PostType.GroupPost"
                        PostId="@post.Id"
                        GroupId="@post.GroupId"
                        GroupName="@group.Name"
                        AuthorId="@post.AuthorId"
                        AuthorName="@post.AuthorName"
                        AuthorImageUrl="@post.AuthorImageUrl"
                        AuthorGroupPoints="@post.AuthorGroupPoints"
                        CreatedAt="@post.CreatedAt"
                        LikeCount="@post.LikeCount"
                        CommentCount="@post.CommentCount"
                        ShareCount="@post.ShareCount"
                        LoadCommentsInternally="true"
                        CommentsToShow="3"
                        RefreshTrigger="@refreshTrigger"
                        CurrentUserId="@currentUserId"
                        CurrentUserImageUrl="@currentUserImageUrl"
                        CurrentUserName="@currentUserName"
                        ReactionBreakdown="@postReactions"
                        UserReaction="@userReaction"
                        IsPinned="@isPinned"
                        IsMuted="@isMuted"
                        Images="@ConvertPostImageDtosToPostImages(post.Images)"
                        OnReactionChanged="@((LikeType reactionType) => HandleGroupPostReactionChanged(post.Id, reactionType))"
                        OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(post.Id))"
                        OnPinPost="@HandlePinGroupPost"
                        OnUnpinPost="@HandleUnpinGroupPost"
                        OnPostDeleted="@HandleGroupPostDeleted"
                        OnEditPost="@HandleEditGroupPost"
                        OnCommentAdded="@HandleGroupPostCommentAdded"
                        OnReplySubmitted="@HandleGroupPostReplySubmitted"
                        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
                        OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
                        OnDeleteComment="@HandleDeleteComment"
                        OnCommentUpdated="@HandleCommentUpdated"
                        OnReportComment="@HandleReportComment"
                        OnShowPostDetail="@(() => ShowGroupPostDetail(post))"
                        OnShowComments="@(() => ShowGroupPostDetail(post))">
                        <ArticleContent>
                            @((MarkupString)FormatContentWithLineBreaks(post.Content))
                        </ArticleContent>
                    </UnifiedArticle>
                }

                @if (isLoadingMorePosts)
                {
                    <LoadingSpinner Text="Loading more posts..." Size="sm" />
                }

                @if (hasMorePosts == false && groupPosts.Any())
                {
                    <EmptyState Message="No more posts at this time" CssClass="no-more-posts" />
                }
            }
        </div>
    }
</div>

@if (showGroupPostDetailModal && selectedGroupPost != null)
{
    var postReactions = postReactionData.ContainsKey(selectedGroupPost.Id) ? postReactionData[selectedGroupPost.Id] : new Dictionary<LikeType, int>();
    var userReaction = postUserReactions.ContainsKey(selectedGroupPost.Id) ? postUserReactions[selectedGroupPost.Id] : null;
    var isPinned = pinnedPosts.ContainsKey(selectedGroupPost.Id) && pinnedPosts[selectedGroupPost.Id];

    <GroupPostDetailModal 
        PostId="@selectedGroupPost.Id"
        GroupId="@selectedGroupPost.GroupId"
        GroupName="@(group?.Name ?? string.Empty)"
        AuthorId="@selectedGroupPost.AuthorId"
        AuthorName="@selectedGroupPost.AuthorName"
        AuthorImageUrl="@selectedGroupPost.AuthorImageUrl"
        CurrentUserId="@currentUserId"
        CreatedAt="@selectedGroupPost.CreatedAt"
        LikeCount="@selectedGroupPost.LikeCount"
        CommentCount="@selectedGroupPost.CommentCount"
        ShareCount="@selectedGroupPost.ShareCount"
        CurrentUserImageUrl="@currentUserImageUrl"
        CurrentUserName="@currentUserName"
        ReactionBreakdown="@postReactions"
        UserReaction="@userReaction"
        IsPinned="@isPinned"
        Images="@ConvertPostImageDtosToPostImages(selectedGroupPost.Images)"
        OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(selectedGroupPost.Id, reactionType))"
        OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(selectedGroupPost.Id))"
        OnPinPost="@HandlePinGroupPost"
        OnUnpinPost="@HandleUnpinGroupPost"
        OnPostDeleted="@HandleGroupPostDeleted"
        OnEditPost="@HandleEditGroupPost"
        OnCommentAdded="@HandleGroupPostCommentAdded"
        OnCommentAddedComplete="@HandleCommentAddedFromModal"
        OnReplySubmitted="@HandleGroupPostReplySubmitted"
        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
        OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
        OnDeleteComment="@HandleDeleteComment"
        OnCommentDeleted="@HandleCommentDeletedFromModal"
        OnCommentUpdated="@HandleCommentUpdated"
        OnReportComment="@HandleReportComment"
        OnClose="@CloseGroupPostDetailModal">
        <ArticleContent>
            @((MarkupString)FormatContentWithLineBreaks(selectedGroupPost.Content))
        </ArticleContent>
    </GroupPostDetailModal>
}

<UploadProgressModal 
    IsVisible="@showUploadProgress"
    Title="@uploadProgressTitle"
    Message="@uploadProgressMessage"
    Progress="@uploadProgress"
    CurrentStep="@uploadCurrentStep"
    TotalSteps="@uploadTotalSteps" />

@if (showGroupSettings && group != null)
{
    <FreeSpeakWeb.Components.Groups.GroupSettingsModal 
        Group="@group"
        CurrentUserId="@currentUserId"
        OnClose="CloseGroupSettings"
        OnSettingsSaved="HandleGroupSettingsSaved" />
}

@if (showGroupAdministration && group != null)
{
    <FreeSpeakWeb.Components.Groups.GroupAdministrationModal 
        Group="@group"
        CurrentUserId="@currentUserId"
        OnClose="CloseGroupAdministration"
        OnAdministrationActionPerformed="HandleAdministrationActionPerformed" />
}

@if (showGroupModeration && group != null)
{
    <FreeSpeakWeb.Components.Groups.GroupModerationModal 
        Group="@group"
        CurrentUserId="@currentUserId"
        OnClose="CloseGroupModeration"
        OnModerationActionPerformed="HandleModerationActionPerformed" />
}

@* Report Comment Modal *@
@if (showReportCommentModal && reportingCommentId.HasValue && group != null)
{
    <FreeSpeakWeb.Components.Groups.ReportContentModal
        GroupId="@GroupId"
        CommentId="@reportingCommentId"
        ReporterId="@currentUserId"
        OnClose="CloseReportCommentModal"
        OnReportSubmitted="HandleCommentReportSubmitted" />
}

@* Edit Group Post Modal *@
@if (showEditGroupPost && editGroupPost != null)
{
    <PostEditModal 
        @ref="groupPostEditModalRef"
        PostId="@editGroupPost.Id"
        AuthorName="@(editGroupPost.Author != null ? (postAuthorNames.ContainsKey(editGroupPost.Id) ? postAuthorNames[editGroupPost.Id] : "Unknown") : "Unknown")"
        AuthorImageUrl="@editGroupPost.Author?.ProfilePictureUrl"
        CreatedAt="@editGroupPost.CreatedAt"
        InitialContent="@editGroupPost.Content"
        InitialImages="@(editGroupPost.Images?.Select(img => new PostImage { Id = img.Id, PostId = editGroupPost.Id, ImageUrl = img.ImageUrl, UploadedAt = img.UploadedAt }).ToList())"
        AudienceType="@AudienceType.Public"
        CurrentUserId="@currentUserId"
        OnSave="@HandleSaveGroupPostEdit"
        OnCancel="@CloseEditGroupPostModal"
        OnImageUploadStateChanged="@HandleEditGroupPostImageUploadStateChanged"
        OnImagesSelected="@HandleEditGroupPostImagesSelected" />
}

@if (showEditGroupPostImageUpload)
{
    <ImageUploadModal 
        IsVisible="true"
        OnImagesSelected="@HandleEditGroupPostImagesSelected"
        OnClose="@(() => showEditGroupPostImageUpload = false)"
        MaxImages="10" />
}

@code {
    [Parameter]
    public int GroupId { get; set; }

    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;

    // Group information
    private Group? group;
    private bool isLoadingGroup = false;
    private int memberCount = 0;
    private int totalPosts = 0;
    private int postsThisWeek = 0;
    private int postsToday = 0;
    private DateTime? lastActivity;

    // Admin/Moderator permissions
    private bool isGroupAdmin = false;
    private bool isGroupModerator = false;
    private bool isSystemAdmin = false;
    private bool isSystemModerator = false;
    private bool showGroupAdministration = false;
    private bool showGroupModeration = false;

    // User points state
    private int currentUserPoints = 0;
    private int currentUserPostCount = 0;
    private MemberLevel currentUserLevel = MemberLevel.Member;

    // Report comment modal state
    private bool showReportCommentModal = false;
    private int? reportingCommentId = null;

    // Posts state
    private List<GroupPostViewModel> groupPosts = new();
    private bool isLoadingPosts = false;
    private bool isLoadingMorePosts = false;
    private bool? hasMorePosts = null;
    private int currentPage = 1;
    private const int pageSize = 20;
    private Dictionary<int, bool> postMuteStatus = new();
    private Dictionary<int, PostStatus> postStatuses = new();

    // JavaScript interop
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<GroupView>? dotNetHelper;

    // Upload progress tracking
    private bool showUploadProgress = false;
    private string uploadProgressTitle = "Adding Your Post";
    private string uploadProgressMessage = "Please wait...";
    private int uploadProgress = 0;
    private int uploadCurrentStep = 0;
    private int uploadTotalSteps = 0;

    // Group-specific dictionaries (rename to use base class naming)
    // Base class provides: postRefreshTriggers, postReactionData, postUserReactions, pinnedPosts, postAuthorNames

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            // Check system-level roles
            isSystemAdmin = user.IsInRole("SystemAdministrator");
            isSystemModerator = user.IsInRole("SystemModerator");

            if (!string.IsNullOrEmpty(currentUserId))
            {
                var appUser = await UserManager.FindByIdAsync(currentUserId);
                if (appUser != null)
                {
                    currentUserImageUrl = appUser.ProfilePictureUrl;
                    currentUserName = $"{appUser.FirstName} {appUser.LastName}";
                }

                await LoadGroupInformation();
                await LoadGroupPosts();

                // Check group-level permissions after group is loaded
                if (group != null)
                {
                    isGroupAdmin = await GroupMemberService.IsAdminAsync(GroupId, currentUserId);
                    isGroupModerator = await GroupMemberService.IsModeratorAsync(GroupId, currentUserId);
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(currentUserId))
        {
            try
            {
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Groups.razor.js");
                dotNetHelper = DotNetObjectReference.Create(this);
                await jsModule.InvokeAsync<object?>("initializeInfiniteScroll", (object?)null, dotNetHelper);
            }
            catch (Exception)
            {
                // Silently fail - infinite scroll optional
            }
        }
    }

    /// <summary>
    /// Loads the group information and statistics.
    /// Includes a guard to prevent concurrent loading operations.
    /// </summary>
    private async Task LoadGroupInformation()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Prevent concurrent loading operations
        if (isLoadingGroup) return;

        isLoadingGroup = true;
        StateHasChanged();

        try
        {
            // Check if user is a member
            var isMember = await GroupMemberService.IsMemberAsync(GroupId, currentUserId);
            if (!isMember)
            {
                group = null;
                isLoadingGroup = false;
                StateHasChanged();
                return;
            }

            // Load group details
            group = await GroupService.GetGroupByIdAsync(GroupId);
            if (group == null)
            {
                isLoadingGroup = false;
                StateHasChanged();
                return;
            }

            // Load statistics
            memberCount = await GroupMemberService.GetMemberCountAsync(GroupId);
            totalPosts = await GroupPostService.GetTotalPostCountAsync(GroupId);
            
            var oneWeekAgo = DateTime.UtcNow.AddDays(-7);
            postsThisWeek = await GroupPostService.GetPostCountSinceAsync(GroupId, oneWeekAgo);
            
            var oneDayAgo = DateTime.UtcNow.AddDays(-1);
            postsToday = await GroupPostService.GetPostCountSinceAsync(GroupId, oneDayAgo);

            lastActivity = await GroupPostService.GetLastActivityAsync(GroupId) ?? group.CreatedAt;

            // Load user's post count and points if points system is enabled
            if (!string.IsNullOrEmpty(currentUserId))
            {
                currentUserPostCount = await GroupPostService.GetUserPostCountInGroupAsync(GroupId, currentUserId);

                if (group.EnablePointsSystem)
                {
                    currentUserPoints = await GroupPointsService.GetUserPointsAsync(currentUserId, GroupId);
                    currentUserLevel = GroupPointsService.GetMemberLevel(currentUserPoints);
                }
            }
        }
        catch (Exception)
        {
            group = null;
        }
        finally
        {
            isLoadingGroup = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads the group posts for display.
    /// Includes a guard to prevent concurrent loading operations.
    /// </summary>
    private async Task LoadGroupPosts()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Prevent concurrent loading operations
        if (isLoadingPosts) return;

        isLoadingPosts = true;
        StateHasChanged();

        try
        {
            currentPage = 1;
            var loadedDtos = await GroupPostService.GetGroupPostsAsProjectionAsync(GroupId, 0, pageSize);

            groupPosts = GroupPostViewModel.FromDtos(loadedDtos);

            // If this group requires post approval, also load the current user's posts with any status
            // so they can see their own pending/declined posts
            if (group.RequiresPostApproval && !string.IsNullOrEmpty(currentUserId))
            {
                var userPosts = await GroupPostService.GetUserPostsIncludingAllStatusesAsync(GroupId, currentUserId);

                // Track post statuses for the user's posts
                foreach (var userPost in userPosts)
                {
                    postStatuses[userPost.Id] = userPost.Status;
                }

                var userPostDtos = userPosts.Select(p => new GroupPostListDto(
                    p.Id,
                    p.GroupId,
                    group.Name,
                    p.AuthorId,
                    $"{p.Author?.FirstName} {p.Author?.LastName}".Trim(), // Default name, will be reformatted based on preferences
                    p.Author?.FirstName ?? "",
                    p.Author?.LastName ?? "",
                    p.Author?.UserName ?? "",
                    p.Author?.ProfilePictureUrl,
                    p.Content,
                    p.CreatedAt,
                    p.UpdatedAt,
                    p.LikeCount,
                    p.CommentCount,
                    p.ShareCount,
                    0, // Group points - will be loaded separately
                    p.Images?.Select(i => new PostImageDto(i.Id, i.ImageUrl, i.DisplayOrder)).ToList() ?? new List<PostImageDto>()
                )).ToList();

                var userPostViewModels = GroupPostViewModel.FromDtos(userPostDtos);

                // Add user posts that aren't already in the list (non-Posted statuses)
                foreach (var userPost in userPostViewModels)
                {
                    if (!groupPosts.Any(p => p.Id == userPost.Id))
                    {
                        groupPosts.Insert(0, userPost); // Insert at top so user sees their pending posts first
                    }
                }
            }

            hasMorePosts = loadedDtos.Count >= pageSize;

            // Load additional data for posts (reactions, pinned status, mute status)
            await LoadGroupPostDataAsync(groupPosts);
        }
        catch (Exception)
        {
            // Silently fail - posts will show empty
        }
        finally
        {
            isLoadingPosts = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task LoadMoreGroupPostsAsync()
    {
        if (string.IsNullOrEmpty(currentUserId) || isLoadingMorePosts || hasMorePosts == false) return;

        isLoadingMorePosts = true;
        StateHasChanged();

        try
        {
            currentPage++;
            var skip = (currentPage - 1) * pageSize;
            var loadedDtos = await GroupPostService.GetGroupPostsAsProjectionAsync(GroupId, skip, pageSize);

            if (loadedDtos.Any())
            {
                var newPosts = GroupPostViewModel.FromDtos(loadedDtos);
                groupPosts.AddRange(newPosts);
                hasMorePosts = loadedDtos.Count >= pageSize;

                // Load additional data for new posts
                await LoadGroupPostDataAsync(newPosts);
            }
            else
            {
                hasMorePosts = false;
            }
        }
        catch (Exception)
        {
            // Silently fail - pagination will stop
        }
        finally
        {
            isLoadingMorePosts = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Loads additional data for a list of group post view models, including reactions, pinned status, and mute status.
    /// Uses batch queries where possible to optimize performance.
    /// </summary>
    /// <param name="posts">The list of group post view models to load data for.</param>
    private async Task LoadGroupPostDataAsync(List<GroupPostViewModel> posts)
    {
        if (!posts.Any()) return;

        // PERFORMANCE: Batch format author names based on user preferences
        await ApplyAuthorNamePreferencesAsync(posts);

        // Get post IDs that need reaction data loaded
        var postIdsNeedingReactions = posts
            .Where(p => !postReactionData.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingReactions.Any())
        {
            // Load reaction data for all posts in a single query
            var reactions = await GroupPostService.GetReactionBreakdownForPostsAsync(postIdsNeedingReactions);
            foreach (var kvp in reactions)
            {
                postReactionData[kvp.Key] = kvp.Value;
            }
        }

        // Get post IDs that need user reactions loaded
        var postIdsNeedingUserReactions = posts
            .Where(p => !postUserReactions.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingUserReactions.Any() && currentUserId != null)
        {
            // Load user reactions for all posts in a single query
            var userReactions = await GroupPostService.GetUserReactionsForPostsAsync(postIdsNeedingUserReactions, currentUserId);
            foreach (var kvp in userReactions)
            {
                postUserReactions[kvp.Key] = kvp.Value;
            }
        }

        // Load pinned status (still per-post, could be optimized separately)
        foreach (var post in posts)
        {
            if (!pinnedPosts.ContainsKey(post.Id) && currentUserId != null)
            {
                var isPinned = await PinnedGroupPostService.IsGroupPostPinnedAsync(currentUserId, post.Id);
                pinnedPosts[post.Id] = isPinned;
            }
        }

        // Load mute status in batch to avoid N+1 queries
        var postIdsNeedingMuteStatus = posts
            .Where(p => !postMuteStatus.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingMuteStatus.Any() && currentUserId != null)
        {
            var muteStatus = await GroupPostService.GetMuteStatusForPostsAsync(postIdsNeedingMuteStatus, currentUserId);
            foreach (var kvp in muteStatus)
            {
                postMuteStatus[kvp.Key] = kvp.Value;
            }
        }
    }

    /// <summary>
    /// Applies user display name preferences to author names in group posts.
    /// Uses batch loading to fetch all preferences in a single query.
    /// </summary>
    /// <param name="posts">The list of group post view models to update.</param>
    private async Task ApplyAuthorNamePreferencesAsync(List<GroupPostViewModel> posts)
    {
        if (!posts.Any()) return;

        try
        {
            // Collect all unique author details
            var userDetails = new Dictionary<string, (string firstName, string lastName, string userName)>();
            foreach (var post in posts)
            {
                if (!string.IsNullOrEmpty(post.AuthorId) && !userDetails.ContainsKey(post.AuthorId))
                {
                    userDetails[post.AuthorId] = (
                        post.AuthorFirstName ?? "",
                        post.AuthorLastName ?? "",
                        post.AuthorUserName ?? ""
                    );
                }
            }

            if (userDetails.Any())
            {
                // Batch format all display names in a single database query
                var formattedNames = await UserPreferenceService.FormatUserDisplayNamesAsync(userDetails);

                // Apply formatted names to posts
                foreach (var post in posts)
                {
                    if (formattedNames.TryGetValue(post.AuthorId, out var formattedName))
                    {
                        post.AuthorName = formattedName;
                    }
                }
            }
        }
        catch (Exception)
        {
            // Silently fail - keep default names from DTO
        }
    }

