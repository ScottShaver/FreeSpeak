    /// <summary>
    /// Handles the creation of a new group post from the PostCreator component.
    /// Uploads images if provided, creates the post, and refreshes the post list.
    /// </summary>
    /// <param name="postData">Tuple containing post content, audience type (unused for groups), and selected images.</param>
    private async Task HandleGroupPostCreated((string Content, AudienceType AudienceType, List<ImageUploadModal.SelectedImage> Images) postData)
    {
        if (string.IsNullOrEmpty(currentUserId) || group == null) return;

        try
        {
            var imageUrls = new List<string>();

            // Calculate total steps
            var hasImages = postData.Images != null && postData.Images.Any();
            uploadTotalSteps = hasImages ? 2 : 1;
            uploadCurrentStep = 0;

            // Show progress modal
            showUploadProgress = true;
            uploadProgress = 0;
            StateHasChanged();

            // Step 1: Upload images if any
            if (hasImages && postData.Images != null)
            {
                uploadCurrentStep = 1;
                uploadProgressMessage = $"Uploading {postData.Images.Count} {(postData.Images.Count == 1 ? "image" : "images")}...";
                StateHasChanged();

                // Convert selected images to upload format
                var imagesToUpload = postData.Images.Select(img => (
                    FileName: img.FileName,
                    Base64Data: img.DataUrl,
                    ContentType: img.ContentType
                )).ToList();

                // Create progress reporter
                var progress = new Progress<int>(percent =>
                {
                    uploadProgress = percent / 2;
                    InvokeAsync(StateHasChanged);
                });

                var uploadResult = await ImageUploadService.UploadImagesAsync(currentUserId, imagesToUpload, progress, groupId: GroupId);

                if (!uploadResult.Success)
                {
                    showUploadProgress = false;
                    StateHasChanged();
                    return;
                }

                imageUrls = uploadResult.ImageUrls;
                uploadProgress = 50;
                StateHasChanged();
            }

            // Step 2: Create the group post
            uploadCurrentStep = hasImages ? 2 : 1;
            uploadProgressMessage = "Creating your post...";
            uploadProgress = hasImages ? 50 : 0;
            StateHasChanged();

            var result = await GroupPostService.CreateGroupPostAsync(GroupId, currentUserId, postData.Content, imageUrls);

            if (result.Success && result.Post != null)
            {
                uploadProgress = 100;
                StateHasChanged();

                // Small delay to show 100% completion
                await Task.Delay(500);

                // Hide progress modal
                showUploadProgress = false;
                StateHasChanged();

                // Note: Audit logging for group post creation is handled by GroupPostService.CreateGroupPostAsync

                // Update statistics
                totalPosts++;
                postsToday++;
                postsThisWeek++;
                lastActivity = DateTime.UtcNow;

                // Reload the group posts to include the new post
                await LoadGroupPosts();

                // Scroll to top to show the new post
                if (jsModule != null)
                {
                    try
                    {
                        await jsModule.InvokeVoidAsync("scrollToTop");
                    }
                    catch
                    {
                        // Ignore scroll errors
                    }
                }

                StateHasChanged();
            }
            else
            {
                showUploadProgress = false;
                AlertService.ShowError(result.ErrorMessage ?? "Failed to create post.");
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            showUploadProgress = false;
            AlertService.ShowError("An error occurred while creating your post.");
            StateHasChanged();
        }
    }

