@page "/notifications"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Localization
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.SocialFeed
@using System.Text.Json

@attribute [Authorize]

@inject UserManager<ApplicationUser> UserManager
@inject NotificationService NotificationService
@inject PostService PostService
@inject GroupPostService GroupPostService
@inject PinnedGroupPostService PinnedGroupPostService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject UserPreferenceService UserPreferenceService
@inject HtmlSanitizationService HtmlSanitizationService
@inject NotificationBadgeService NotificationBadgeService
@inject AlertService AlertService
@inject IAuditLogRepository AuditLogRepository
@inject IOptions<SiteSettings> SiteSettings
@inject IStringLocalizer<FreeSpeakWeb.Resources.Pages.Notifications> Localizer

<PageTitle>@SiteSettings.Value.SiteName - @Localizer["PageTitle"]</PageTitle>

<div class="notifications-container">
    <div class="notifications-header">
        <h3>@Localizer["Title"]</h3>
        <div class="notifications-actions">
            @if (unreadCount > 0)
            {
                <button class="btn btn-sm btn-primary" @onclick="MarkAllAsRead" disabled="@isMarkingAllRead">
                    @if (isMarkingAllRead)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @Localizer["MarkAllAsRead"]
                </button>
            }
            @if (notifications.Any(n => n.IsRead))
            {
                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteAllRead" disabled="@isDeletingRead">
                    @if (isDeletingRead)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @Localizer["ClearRead"]
                </button>
            }
        </div>
    </div>

    <div class="notifications-tabs">
        <button class="tab-button @(showOnlyUnread ? "" : "active")" @onclick="() => ShowAll()">
            @Localizer["All"] (@allNotificationsCount)
        </button>
        <button class="tab-button @(showOnlyUnread ? "active" : "")" @onclick="() => ShowUnread()">
            @Localizer["Unread"] (@unreadCount)
        </button>
    </div>

    <div class="notifications-list">
        @if (isLoading)
        {
            <div class="loading-container">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Localizer["Loading"]</span>
                </div>
                <p class="mt-3">@Localizer["LoadingNotifications"]</p>
            </div>
        }
        else if (!notifications.Any())
        {
            <div class="empty-state">
                <span class="bi bi-bell-slash" style="font-size: 48px; color: var(--bs-secondary-color);"></span>
                <p class="mt-3">@(showOnlyUnread ? Localizer["NoUnreadNotifications"] : Localizer["NoNotificationsYet"])</p>
            </div>
        }
        else
        {
            @foreach (var notification in notifications)
            {
                <NotificationComponent 
                    Notification="@notification" 
                    OnClick="HandleNotificationClick"
                    OnMarkAsReadOnly="HandleMarkAsReadOnly"
                    OnDelete="HandleDeleteNotification" />
            }

            @if (hasMore)
            {
                <div class="load-more-container">
                    <button class="btn btn-outline-primary" @onclick="LoadMore" disabled="@isLoadingMore">
                        @if (isLoadingMore)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @Localizer["LoadMore"]
                    </button>
                </div>
            }
        }
    </div>
</div>

@if (selectedPost != null)
{
    <PostDetailModal 
        PostId="@selectedPost.Id"
        AuthorId="@selectedPost.AuthorId"
        AuthorName="@selectedPostAuthorName"
        AuthorImageUrl="@selectedPost.Author?.ProfilePictureUrl"
        CurrentUserId="@currentUserId"
        CurrentUserImageUrl="@currentUserImageUrl"
        CurrentUserName="@currentUserName"
        CreatedAt="@selectedPost.CreatedAt"
        LikeCount="@selectedPost.LikeCount"
        CommentCount="@selectedPost.CommentCount"
        ShareCount="@selectedPost.ShareCount"
        Images="@selectedPost.Images?.ToList()"
        TargetCommentId="@targetCommentId"
        ReactionBreakdown="@postReactionBreakdown"
        UserReaction="@userReaction"
        AudienceType="@selectedPost.AudienceType"
        IsPinned="@selectedPostIsPinned"
        OnReactionChanged="@HandleReactionChanged"
        OnRemoveReaction="@HandleRemoveReaction"
        OnPinPost="@HandlePinPost"
        OnUnpinPost="@HandleUnpinPost"
        OnPostDeleted="@HandlePostDeleted"
        OnCommentAdded="@HandleCommentAdded"
        OnCommentReactionChanged="@HandleCommentReactionChanged"
        OnRemoveCommentReaction="@HandleRemoveCommentReaction"
        OnClose="@ClosePostDetail">
        <ArticleContent>
            @((MarkupString)FormatContentWithLineBreaks(selectedPost.Content))
        </ArticleContent>
    </PostDetailModal>
}

@if (selectedGroupPost != null)
{
    <GroupPostDetailModal 
        PostId="@selectedGroupPost.Id"
        GroupId="@selectedGroupPost.GroupId"
        GroupName="@selectedGroupPost.Group?.Name"
        AuthorId="@selectedGroupPost.AuthorId"
        AuthorName="@selectedGroupPostAuthorName"
        AuthorImageUrl="@selectedGroupPost.Author?.ProfilePictureUrl"
        CurrentUserId="@currentUserId"
        CurrentUserImageUrl="@currentUserImageUrl"
        CurrentUserName="@currentUserName"
        CreatedAt="@selectedGroupPost.CreatedAt"
        LikeCount="@selectedGroupPost.LikeCount"
        CommentCount="@selectedGroupPost.CommentCount"
        ShareCount="@selectedGroupPost.ShareCount"
        Images="@ConvertGroupPostImagesToPostImages(selectedGroupPost.Images)"
        TargetCommentId="@targetGroupCommentId"
        ReactionBreakdown="@groupPostReactionBreakdown"
        UserReaction="@groupPostUserReaction"
        IsPinned="@selectedGroupPostIsPinned"
        OnReactionChanged="@HandleGroupPostReactionChanged"
        OnRemoveReaction="@HandleGroupPostRemoveReaction"
        OnPinPost="@HandleGroupPostPin"
        OnUnpinPost="@HandleGroupPostUnpin"
        OnPostDeleted="@HandleGroupPostDeleted"
        OnEditPost="@HandleGroupPostEdit"
        OnCommentAdded="@HandleGroupPostCommentAdded"
        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
        OnRemoveCommentReaction="@HandleGroupPostRemoveCommentReaction"
        OnClose="@CloseGroupPostDetail">
        <ArticleContent>
            @((MarkupString)FormatContentWithLineBreaks(selectedGroupPost.Content))
        </ArticleContent>
    </GroupPostDetailModal>
}

@code {
    private List<UserNotification> notifications = new();
    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;
    private bool isLoading = true;
    private bool isLoadingMore = false;
    private bool isMarkingAllRead = false;
    private bool isDeletingRead = false;
    private bool showOnlyUnread = false;
    private int pageNumber = 1;
    private int pageSize = 20;
    private bool hasMore = false;
    private int unreadCount = 0;
    private int allNotificationsCount = 0;

    // Regular post modal state
    private Post? selectedPost = null;
    private string selectedPostAuthorName = "Unknown";
    private bool selectedPostIsPinned = false;
    private int? targetCommentId = null;
    private Dictionary<LikeType, int>? postReactionBreakdown = null;
    private LikeType? userReaction = null;

    // Group post modal state
    private GroupPost? selectedGroupPost = null;
    private string selectedGroupPostAuthorName = "Unknown";
    private bool selectedGroupPostIsPinned = false;
    private int? targetGroupCommentId = null;
    private Dictionary<LikeType, int>? groupPostReactionBreakdown = null;
    private LikeType? groupPostUserReaction = null;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user != null)
        {
            currentUserId = user.Id;
            currentUserImageUrl = user.ProfilePictureUrl;

            // Use the user's display name preference
            currentUserName = await UserPreferenceService.FormatUserDisplayNameAsync(
                user.Id,
                user.FirstName,
                user.LastName,
                user.UserName ?? "User"
            );

            // Reset the notification badge timer
            await NotificationBadgeService.ResetTimerAsync();

            await LoadNotifications();
        }
    }

    private async Task LoadNotifications()
    {
        if (currentUserId == null) return;

        isLoading = true;
        pageNumber = 1;
        notifications.Clear();

        notifications = await NotificationService.GetUserNotificationsAsync(
            currentUserId,
            pageSize,
            pageNumber,
            showOnlyUnread ? false : null
        );

        // Always fetch both counts so tabs display correct values
        unreadCount = await NotificationService.GetUnreadCountAsync(currentUserId);
        allNotificationsCount = await NotificationService.GetTotalCountAsync(currentUserId);

        // Check if there are more notifications
        var nextPageNotifications = await NotificationService.GetUserNotificationsAsync(
            currentUserId,
            1,
            pageNumber + 1,
            showOnlyUnread ? false : null
        );
        hasMore = nextPageNotifications.Any();

        isLoading = false;
    }

    private async Task LoadMore()
    {
        if (currentUserId == null || isLoadingMore) return;

        isLoadingMore = true;
        pageNumber++;

        var moreNotifications = await NotificationService.GetUserNotificationsAsync(
            currentUserId,
            pageSize,
            pageNumber,
            showOnlyUnread ? false : null
        );

        notifications.AddRange(moreNotifications);

        // Check if there are even more notifications
        var nextPageNotifications = await NotificationService.GetUserNotificationsAsync(
            currentUserId,
            1,
            pageNumber + 1,
            showOnlyUnread ? false : null
        );
        hasMore = nextPageNotifications.Any();

        isLoadingMore = false;
    }

    private async Task ShowAll()
    {
        showOnlyUnread = false;
        await LoadNotifications();
    }

    private async Task ShowUnread()
    {
        showOnlyUnread = true;
        await LoadNotifications();
    }

    private async Task HandleMarkAsReadOnly(UserNotification notification)
    {
        if (currentUserId == null) return;

        // Mark as read without navigating to the post
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id, currentUserId);
            notification.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);

            // Refresh the badge service to update navigation badges
            await NotificationBadgeService.RefreshUnreadCountAsync();

            StateHasChanged();
        }
    }

    private async Task HandleDeleteNotification(UserNotification notification)
    {
        if (currentUserId == null) return;

        var (success, errorMessage) = await NotificationService.DeleteNotificationAsync(notification.Id, currentUserId);

        if (success)
        {
            // Remove from the list
            notifications.Remove(notification);

            // Update both counts
            allNotificationsCount = Math.Max(0, allNotificationsCount - 1);
            if (!notification.IsRead)
            {
                unreadCount = Math.Max(0, unreadCount - 1);
            }

            // Note: Audit logging for notification deletion is handled by NotificationService.DeleteNotificationAsync

            // Refresh the badge service to update navigation badges
            await NotificationBadgeService.RefreshUnreadCountAsync();

            StateHasChanged();
        }
        else
        {
            AlertService.ShowError(errorMessage ?? "Failed to delete notification.");
        }
    }

    private async Task HandleNotificationClick(UserNotification notification)
    {
        if (currentUserId == null) return;

        // Mark as read if not already
        if (!notification.IsRead)
        {
            await NotificationService.MarkAsReadAsync(notification.Id, currentUserId);
            notification.IsRead = true;
            unreadCount = Math.Max(0, unreadCount - 1);

            // Refresh the badge service to update navigation badges
            await NotificationBadgeService.RefreshUnreadCountAsync();

            StateHasChanged();
        }

        // Parse notification data
        if (!string.IsNullOrEmpty(notification.Data))
        {
            try
            {
                // Use case-insensitive deserialization to handle both old (camelCase) and new (PascalCase) data
                var options = new JsonSerializerOptions 
                { 
                    PropertyNameCaseInsensitive = true 
                };
                var data = JsonSerializer.Deserialize<NotificationData>(notification.Data, options);

                // Handle navigation URL (for friend requests, etc.)
                if (!string.IsNullOrEmpty(data?.NavigationUrl))
                {
                    NavigationManager.NavigateTo(data.NavigationUrl, forceLoad: true);
                    return;
                }

                // Handle group post notifications
                if (data?.GroupPostId != null && data?.GroupId != null)
                {
                    var groupPost = await GroupPostService.GetGroupPostByIdAsync(data.GroupPostId.Value);
                    if (groupPost != null)
                    {
                        selectedGroupPost = groupPost;
                        targetGroupCommentId = data.CommentId; // Set the target comment ID for scrolling

                        // Load author's display name using their preference
                        if (groupPost.Author != null)
                        {
                            selectedGroupPostAuthorName = await UserPreferenceService.FormatUserDisplayNameAsync(
                                groupPost.Author.Id,
                                groupPost.Author.FirstName,
                                groupPost.Author.LastName,
                                groupPost.Author.UserName ?? "Unknown"
                            );
                        }

                        // Load pinned status
                        selectedGroupPostIsPinned = currentUserId != null && await PinnedGroupPostService.IsGroupPostPinnedAsync(currentUserId, groupPost.Id);

                        // Load reaction data
                        groupPostReactionBreakdown = await GroupPostService.GetReactionBreakdownAsync(groupPost.Id);
                        groupPostUserReaction = currentUserId != null 
                            ? await GroupPostService.GetUserReactionAsync(groupPost.Id, currentUserId)
                            : null;

                        StateHasChanged();
                        return;
                    }
                }

                // Handle regular post notifications
                if (data?.PostId != null)
                {
                    var post = await PostService.GetPostByIdAsync(data.PostId.Value);
                    if (post != null)
                    {
                        selectedPost = post;
                        targetCommentId = data.CommentId; // Set the target comment ID for scrolling

                        // Load author's display name using their preference
                        if (post.Author != null)
                        {
                            selectedPostAuthorName = await UserPreferenceService.FormatUserDisplayNameAsync(
                                post.Author.Id,
                                post.Author.FirstName,
                                post.Author.LastName,
                                post.Author.UserName ?? "Unknown"
                            );
                        }

                        // Load pinned status
                        selectedPostIsPinned = await PostService.IsPostPinnedAsync(post.Id, post.AuthorId);

                        // Load reaction data
                        postReactionBreakdown = await PostService.GetReactionBreakdownAsync(post.Id);
                        userReaction = await PostService.GetUserReactionAsync(post.Id, currentUserId);

                        StateHasChanged();
                    }
                }
            }
            catch (Exception)
            {
                // Silently fail - notification data parsing optional
            }
        }
        else
        {
            // Notification data is null or empty
        }
    }

    private async Task HandleReactionChanged(LikeType reactionType)
    {
        if (currentUserId == null || selectedPost == null) return;

        try
        {
            var result = await PostService.AddOrUpdateReactionAsync(selectedPost.Id, currentUserId, reactionType);

            if (result.Success)
            {
                // Update user's reaction
                userReaction = reactionType;

                // Reload reaction breakdown
                postReactionBreakdown = await PostService.GetReactionBreakdownAsync(selectedPost.Id);

                // Update like count
                var post = await PostService.GetPostByIdAsync(selectedPost.Id);
                if (post != null)
                {
                    selectedPost.LikeCount = post.LikeCount;
                }

                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - reaction change optional
        }
    }

    private async Task HandleRemoveReaction()
    {
        if (currentUserId == null || selectedPost == null) return;

        try
        {
            var result = await PostService.RemoveLikeAsync(selectedPost.Id, currentUserId);

            if (result.Success)
            {
                // Update user's reaction
                userReaction = null;

                // Reload reaction breakdown
                postReactionBreakdown = await PostService.GetReactionBreakdownAsync(selectedPost.Id);

                // Update like count
                var post = await PostService.GetPostByIdAsync(selectedPost.Id);
                if (post != null)
                {
                    selectedPost.LikeCount = post.LikeCount;
                }

                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - reaction removal optional
        }
    }

    // Group post event handlers
    private async Task HandleGroupPostReactionChanged(LikeType reactionType)
    {
        if (currentUserId == null || selectedGroupPost == null) return;

        try
        {
            var result = await GroupPostService.AddOrUpdateReactionAsync(selectedGroupPost.Id, currentUserId, reactionType);

            if (result.Success)
            {
                // Update user's reaction
                groupPostUserReaction = reactionType;

                // Reload reaction breakdown
                groupPostReactionBreakdown = await GroupPostService.GetReactionBreakdownAsync(selectedGroupPost.Id);

                // Update like count
                var post = await GroupPostService.GetGroupPostByIdAsync(selectedGroupPost.Id);
                if (post != null)
                {
                    selectedGroupPost.LikeCount = post.LikeCount;
                }

                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - reaction change optional
        }
    }

    private async Task HandleGroupPostRemoveReaction()
    {
        if (currentUserId == null || selectedGroupPost == null) return;

        try
        {
            var result = await GroupPostService.RemoveReactionAsync(selectedGroupPost.Id, currentUserId);

            if (result.Success)
            {
                // Update user's reaction
                groupPostUserReaction = null;

                // Reload reaction breakdown
                groupPostReactionBreakdown = await GroupPostService.GetReactionBreakdownAsync(selectedGroupPost.Id);

                // Update like count
                var post = await GroupPostService.GetGroupPostByIdAsync(selectedGroupPost.Id);
                if (post != null)
                {
                    selectedGroupPost.LikeCount = post.LikeCount;
                }

                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - reaction removal optional
        }
    }

    private async Task HandleGroupPostPin(int postId)
    {
        if (currentUserId == null || selectedGroupPost == null) return;

        try
        {
            var result = await PinnedGroupPostService.PinGroupPostAsync(currentUserId, postId);

            if (result.Success)
            {
                selectedGroupPostIsPinned = true;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - pinning optional
        }
    }

    private async Task HandleGroupPostUnpin(int postId)
    {
        if (currentUserId == null || selectedGroupPost == null) return;

        try
        {
            var result = await PinnedGroupPostService.UnpinGroupPostAsync(currentUserId, postId);

            if (result.Success)
            {
                selectedGroupPostIsPinned = false;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - unpinning optional
        }
    }

    private void HandleGroupPostDeleted(int postId)
    {
        // Close the modal since the post is deleted
        CloseGroupPostDetail();
    }

    private async Task HandleGroupPostCommentAdded((int PostId, string Content) data)
    {
        if (currentUserId == null || selectedGroupPost == null) return;

        try
        {
            var result = await GroupPostService.AddCommentAsync(data.PostId, currentUserId, data.Content, null, null);

            if (result.Success && selectedGroupPost != null)
            {
                selectedGroupPost.CommentCount++;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - comment addition optional
        }
    }

    private async Task HandleGroupPostCommentReactionChanged((int CommentId, LikeType ReactionType) data)
    {
        // This is handled by the modal itself
        await Task.CompletedTask;
    }

    private async Task HandleGroupPostRemoveCommentReaction(int commentId)
    {
        // This is handled by the modal itself
        await Task.CompletedTask;
    }

    private void CloseGroupPostDetail()
    {
        selectedGroupPost = null;
        targetGroupCommentId = null;
        groupPostReactionBreakdown = null;
        groupPostUserReaction = null;
        StateHasChanged();
    }

    private async Task HandleGroupPostEdit(int postId)
    {
        // Group post editing is not currently supported from notifications
        // This would require opening the Groups page with the edit modal
        await Task.CompletedTask;
    }

    private async Task HandlePinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.PinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                selectedPostIsPinned = true;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - pinning optional
        }
    }

    private async Task HandleUnpinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.UnpinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                selectedPostIsPinned = false;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - unpinning optional
        }
    }

    private void HandlePostDeleted(int postId)
    {
        // Close the modal since the post is deleted
        ClosePostDetail();
    }

    private async Task HandleCommentAdded((int PostId, string Content) data)
    {
        if (currentUserId == null || selectedPost == null) return;

        try
        {
            var result = await PostService.AddCommentAsync(data.PostId, currentUserId, data.Content);

            if (result.Success && selectedPost != null)
            {
                selectedPost.CommentCount++;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            // Silently fail - comment addition optional
        }
    }

    private async Task HandleCommentReactionChanged((int CommentId, LikeType ReactionType) data)
    {
        // This is handled by the modal itself
        await Task.CompletedTask;
    }

    private async Task HandleRemoveCommentReaction(int commentId)
    {
        // This is handled by the modal itself
        await Task.CompletedTask;
    }

    private string FormatContentWithLineBreaks(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;

        // SECURITY: Sanitize user content to prevent XSS attacks
        return HtmlSanitizationService.SanitizeAndFormatContent(content);
    }

    private void ClosePostDetail()
    {
        selectedPost = null;
        targetCommentId = null; // Clear the target comment ID when closing
        postReactionBreakdown = null;
        userReaction = null;
        StateHasChanged();
    }

    private async Task MarkAllAsRead()
    {
        if (currentUserId == null) return;

        isMarkingAllRead = true;

        var (success, errorMessage, updatedCount) = await NotificationService.MarkAllAsReadAsync(currentUserId);

        if (success)
        {
            // Update all notifications in the current list
            foreach (var notification in notifications)
            {
                notification.IsRead = true;
            }
            unreadCount = 0;

            // Log mark all as read to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(currentUserId, ActionCategory.UserNotification, new UserNotificationDetails
                {
                    OperationType = OperationTypeEnum.MarkAllAsRead.ToString(),
                    ContentSummary = $"Marked {updatedCount} notifications as read"
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            // Refresh the badge service to update navigation badges
            await NotificationBadgeService.RefreshUnreadCountAsync();
        }
        else
        {
            AlertService.ShowError(errorMessage ?? "Failed to mark notifications as read.");
        }

        isMarkingAllRead = false;
    }

    private async Task DeleteAllRead()
    {
        if (currentUserId == null) return;

        isDeletingRead = true;

        var (success, errorMessage, deletedCount) = await NotificationService.DeleteReadNotificationsAsync(currentUserId);

        if (success)
        {
            // Remove read notifications from the list
            notifications.RemoveAll(n => n.IsRead);

            // Log delete all read to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(currentUserId, ActionCategory.UserNotification, new UserNotificationDetails
                {
                    OperationType = OperationTypeEnum.DeleteAllRead.ToString(),
                    ContentSummary = $"Deleted {deletedCount} read notifications"
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            // Refresh both counts
            unreadCount = await NotificationService.GetUnreadCountAsync(currentUserId);
            allNotificationsCount = await NotificationService.GetTotalCountAsync(currentUserId);

            // Refresh the badge service to update navigation badges
            await NotificationBadgeService.RefreshUnreadCountAsync();
        }
        else
        {
            AlertService.ShowError(errorMessage ?? "Failed to delete read notifications.");
        }

        isDeletingRead = false;
    }

    // Helper class to deserialize notification data
    private class NotificationData
    {
        public int? PostId { get; set; }
        public int? GroupPostId { get; set; }
        public int? GroupId { get; set; }
        public int? CommentId { get; set; }
        public string? CommenterId { get; set; }
        public string? ReactorId { get; set; }
        public string? ReactionType { get; set; }
        public string? NavigationUrl { get; set; }
    }

    private List<PostImage>? ConvertGroupPostImagesToPostImages(ICollection<GroupPostImage>? groupPostImages)
    {
        if (groupPostImages == null || !groupPostImages.Any())
            return null;

        return groupPostImages.Select(gpi => new PostImage
        {
            Id = gpi.Id,
            PostId = 0, // Not used for group posts displayed in modal
            ImageUrl = gpi.ImageUrl,
            DisplayOrder = gpi.DisplayOrder,
            UploadedAt = gpi.UploadedAt
        }).ToList();
    }
}
