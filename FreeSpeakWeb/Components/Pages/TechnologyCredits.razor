@page "/technology-credits"

@using FreeSpeakWeb.Services
@inject NavigationStateService NavigationState

@using Microsoft.Extensions.Options
@inject IOptions<SiteSettings> SiteSettings

<PageTitle>@SiteSettings.Value.SiteName - Technology Credits</PageTitle>

<h1>Technology Credits</h1>

<p>This application is built using the following technologies and open-source packages. We are grateful to all contributors!</p>

<div class="row">
    <div class="col-12">
        <h3>Frameworks & Platforms</h3>
        <ul>
            <li><strong>.NET 10</strong> - Modern cross-platform framework</li>
            <li><strong>ASP.NET Core Blazor</strong> - Interactive web UI framework with hybrid rendering
                <ul>
                    <li><em>Static SSR</em> - Server-side rendering for optimal performance</li>
                    <li><em>Interactive Server</em> - Real-time SignalR-based interactivity</li>
                    <li><em>Per-Component Interactivity</em> - Granular control over render modes</li>
                </ul>
            </li>
            <li><strong>ASP.NET Core Identity</strong> - User authentication and authorization</li>
            <li><strong>Entity Framework Core</strong> - Object-relational mapping (ORM)</li>
            <li><strong>PostgreSQL</strong> - Open-source relational database</li>
            <li><strong>SignalR</strong> - Real-time web functionality for interactive components</li>
        </ul>

        <h3>Main Application Packages</h3>
        <ul>
            <li><strong>Microsoft.AspNetCore.Diagnostics.EntityFrameworkCore</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Database error page middleware for development</small>
            </li>
            <li><strong>Microsoft.AspNetCore.Identity.EntityFrameworkCore</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Identity system with Entity Framework Core integration</small>
            </li>
            <li><strong>Microsoft.EntityFrameworkCore.Tools</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>EF Core tools for migrations and database management</small>
            </li>
            <li><strong>Npgsql.EntityFrameworkCore.PostgreSQL</strong> (10.0.0) - <em>PostgreSQL License</em>
                <br/><small>PostgreSQL database provider for Entity Framework Core</small>
            </li>
            <li><strong>SixLabors.ImageSharp</strong> (3.1.12) - <em>Six Labors Split License</em>
                <br/><small>Image processing library with caching and resizing for profile pictures and post images</small>
            </li>
            <li><strong>Net.Codecrete.QrCodeGenerator</strong> (2.1.0) - <em>MIT License</em>
                <br/><small>QR code generation for two-factor authentication</small>
            </li>
            <li><strong>HtmlSanitizer</strong> (9.0.892) - <em>MIT License</em>
                <br/><small>HTML sanitization library to prevent XSS attacks by removing malicious content while preserving safe HTML</small>
            </li>
            <li><strong>Microsoft.Extensions.Caching.StackExchangeRedis</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Distributed caching with Redis for multi-server deployments (optional, configurable via appsettings.json)</small>
            </li>
        </ul>

        <h3>Custom Features & Services</h3>
        <ul>
            <li><strong>Theme System</strong> - 8 customizable color schemes with CSS custom properties
                <br/><small>Default, Dark Mode, Light Mode, Ocean Blue, Forest Green, Sunset Orange, Purple Dream, High Contrast</small>
            </li>
            <li><strong>Image Optimization</strong> - Smart resizing and caching with ImageSharp
                <br/><small>Thumbnail (300px), Medium (400px), and Full-size variants for optimal performance</small>
            </li>
            <li><strong>Notification System</strong> - Real-time notifications for social interactions
                <br/><small>8 notification types with intelligent filtering and auto-expiration</small>
            </li>
            <li><strong>Security Features</strong> - Secure file serving with authenticated endpoints
                <br/><small>Files stored outside wwwroot with rate limiting and authorization checks</small>
            </li>
            <li><strong>Rate Limiting</strong> - Built-in ASP.NET Core rate limiting
                <br/><small>Global and per-endpoint limits to prevent abuse</small>
            </li>
        </ul>

        <h3>Testing Packages</h3>
        <h4>Unit Testing (FreeSpeakWeb.Tests)</h4>
        <ul>
            <li><strong>xUnit</strong> (2.9.3) - <em>Apache 2.0 License</em>
                <br/><small>Unit testing framework</small>
            </li>
            <li><strong>bUnit</strong> (1.35.3) - <em>MIT License</em>
                <br/><small>Testing library for Blazor components</small>
            </li>
            <li><strong>Moq</strong> (4.20.72) - <em>BSD 3-Clause License</em>
                <br/><small>Mocking framework for unit tests</small>
            </li>
            <li><strong>FluentAssertions</strong> (7.0.0) - <em>Apache 2.0 License</em>
                <br/><small>Fluent API for test assertions</small>
            </li>
            <li><strong>Microsoft.EntityFrameworkCore.InMemory</strong> (10.0.0) - <em>MIT License</em>
                <br/><small>In-memory database provider for testing</small>
            </li>
            <li><strong>Microsoft.NET.Test.Sdk</strong> (17.14.1) - <em>MIT License</em>
                <br/><small>MSBuild integration for test execution</small>
            </li>
            <li><strong>coverlet.collector</strong> (6.0.4) - <em>MIT License</em>
                <br/><small>Code coverage collection for tests</small>
            </li>
        </ul>

        <h4>Integration Testing (FreeSpeakWeb.IntegrationTests)</h4>
        <ul>
            <li><strong>Testcontainers.PostgreSql</strong> (4.1.0) - <em>MIT License</em>
                <br/><small>Docker-based PostgreSQL containers for integration tests</small>
            </li>
        </ul>

        <h4>Performance Testing (FreeSpeakWeb.PerformanceTests)</h4>
        <ul>
            <li><strong>BenchmarkDotNet</strong> (0.14.0) - <em>MIT License</em>
                <br/><small>Performance benchmarking library</small>
            </li>
        </ul>

        <h3>Frontend Libraries</h3>
        <ul>
            <li><strong>Bootstrap 5</strong> - <em>MIT License</em>
                <br/><small>CSS framework for responsive design</small>
            </li>
            <li><strong>Bootstrap Icons</strong> - <em>MIT License</em>
                <br/><small>Icon library</small>
            </li>
        </ul>

        <h3>Development Tools & CI/CD</h3>
        <ul>
            <li><strong>GitHub Actions</strong> - Continuous integration and deployment</li>
            <li><strong>Azure DevOps</strong> - Build and release pipelines</li>
            <li><strong>Docker</strong> - Containerization for integration testing</li>
        </ul>

        <h3>License Information</h3>
        <p>
            This application uses open-source software under various licenses. All dependencies are used in compliance 
            with their respective licenses. For specific license details, please refer to each package's official documentation.
        </p>

        <h3>Special Thanks</h3>
        <p>
            We extend our gratitude to:
        </p>
        <ul>
            <li>The <strong>.NET Foundation</strong> and Microsoft for the .NET platform</li>
            <li>The <strong>PostgreSQL Global Development Group</strong> for the PostgreSQL database</li>
            <li>All open-source contributors who make projects like this possible</li>
            <li>The maintainers of every package listed above</li>
        </ul>

        <hr class="my-4" />

        <p class="text-muted">
            <small>
                Last updated: @DateTime.Now.ToString("MMMM yyyy")<br/>
                Technology stack: .NET 10, Blazor (Hybrid SSR + Interactive Server), PostgreSQL, xUnit, bUnit<br/>
                Recent improvements: Database query optimizations (AsNoTracking, AsSplitQuery, compiled queries), projection-based DTOs, optional Redis distributed caching
            </small>
        </p>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        NavigationState.ActiveMenuItem = "technology-credits";
    }

    // Technology credits are maintained manually to ensure accuracy
}
