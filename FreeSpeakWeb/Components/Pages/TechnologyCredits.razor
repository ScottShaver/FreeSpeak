        <hr class="my-4" />

        <p class="text-muted">
            <small>
                Last updated: March 2026<br/>
                Technology stack: .NET 10, Blazor Server, PostgreSQL, xUnit, bUnit
            </small>
        </p>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        NavigationState.ActiveMenuItem = "technology-credits";
    }

    // Technology credits are maintained manually to ensure accuracy
}
