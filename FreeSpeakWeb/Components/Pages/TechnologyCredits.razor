@page "/technology-credits"

@using FreeSpeakWeb.Services
@inject NavigationStateService NavigationState

@using Microsoft.Extensions.Options
@inject IOptions<SiteSettings> SiteSettings

<PageTitle>@SiteSettings.Value.SiteName - Technology Credits</PageTitle>

<h1>Technology Credits</h1>

<p>This application is built using the following technologies and open-source packages. We are grateful to all contributors!</p>

<div class="row">
    <div class="col-12">
        <h3>Frameworks & Platforms</h3>
        <ul>
            <li><strong>.NET 10</strong> - Modern cross-platform framework</li>
            <li><strong>ASP.NET Core Blazor</strong> - Interactive web UI framework with hybrid rendering
                <ul>
                    <li><em>Static SSR</em> - Server-side rendering for optimal performance</li>
                    <li><em>Interactive Server</em> - Real-time SignalR-based interactivity</li>
                    <li><em>Per-Component Interactivity</em> - Granular control over render modes</li>
                </ul>
            </li>
            <li><strong>ASP.NET Core Identity</strong> - User authentication and authorization</li>
            <li><strong>Entity Framework Core</strong> - Object-relational mapping (ORM)</li>
            <li><strong>PostgreSQL</strong> - Open-source relational database</li>
            <li><strong>SignalR</strong> - Real-time web functionality for interactive components</li>
        </ul>

        <h3>Main Application Packages</h3>
        <ul>
            <li><strong>Microsoft.AspNetCore.Diagnostics.EntityFrameworkCore</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Database error page middleware for development</small>
            </li>
            <li><strong>Microsoft.AspNetCore.Identity.EntityFrameworkCore</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Identity system with Entity Framework Core integration</small>
            </li>
            <li><strong>Microsoft.EntityFrameworkCore.Tools</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>EF Core tools for migrations and database management</small>
            </li>
            <li><strong>Npgsql.EntityFrameworkCore.PostgreSQL</strong> (10.0.0) - <em>PostgreSQL License</em>
                <br/><small>PostgreSQL database provider for Entity Framework Core</small>
            </li>
            <li><strong>SixLabors.ImageSharp</strong> (3.1.12) - <em>Six Labors Split License</em>
                <br/><small>Image processing library with caching and resizing for profile pictures and post images</small>
            </li>
            <li><strong>Net.Codecrete.QrCodeGenerator</strong> (2.1.0) - <em>MIT License</em>
                <br/><small>QR code generation for two-factor authentication</small>
            </li>
            <li><strong>HtmlSanitizer</strong> (9.0.892) - <em>MIT License</em>
                <br/><small>HTML sanitization library to prevent XSS attacks by removing malicious content while preserving safe HTML</small>
            </li>
            <li><strong>Microsoft.Extensions.Caching.StackExchangeRedis</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Distributed caching with Redis for multi-server deployments (optional, configurable via appsettings.json)</small>
            </li>
            <li><strong>nClam</strong> (9.0.0) - <em>Apache 2.0 License</em>
                <br/><small>ClamAV antivirus client for scanning uploaded files for viruses and malware (optional, configurable via appsettings.json)</small>
            </li>
        </ul>

        <h3>Custom Features & Services</h3>
        <ul>
            <li><strong>Internationalization (i18n)</strong> - Comprehensive multi-language support
                <br/><small>13 languages with 13,000+ translations across all user-facing features. Built with .NET's IStringLocalizer and resource files (.resx). Supports Arabic (RTL), East Asian languages, and European languages with automatic browser language detection.</small>
            </li>
            <li><strong>Theme System</strong> - 8 customizable color schemes with CSS custom properties
                <br/><small>Default, Dark Mode, Light Mode, Ocean Blue, Forest Green, Sunset Orange, Purple Dream, High Contrast</small>
            </li>
            <li><strong>Image Optimization</strong> - Smart resizing and caching with ImageSharp
                <br/><small>Thumbnail (300px), Medium (400px), and Full-size variants for optimal performance</small>
            </li>
            <li><strong>Notification System</strong> - Real-time notifications for social interactions
                <br/><small>8 notification types with intelligent filtering and auto-expiration</small>
            </li>
            <li><strong>Security Features</strong> - Secure file serving with authenticated endpoints
                <br/><small>Files stored outside wwwroot with rate limiting and authorization checks</small>
            </li>
            <li><strong>Rate Limiting</strong> - Built-in ASP.NET Core rate limiting with optional Redis support
                <br/><small>Global and per-endpoint limits to prevent abuse, distributed rate limiting for multi-server deployments</small>
            </li>
            <li><strong>File Signature Validation</strong> - Magic byte validation for uploaded files
                <br/><small>Prevents disguised malicious files by verifying content matches declared file type. Supports separate validation rules for posts (images/videos only) and group files (documents, archives, images, videos). Blocks executables and scripts.</small>
            </li>
            <li><strong>Group File Sharing</strong> - Secure file sharing within groups
                <br/><small>Upload and share documents (PDF, Office, text), archives (ZIP, RAR, 7z), images, and videos. Includes approval workflow, virus scanning, and download tracking.</small>
            </li>
            <li><strong>Virus Scanning</strong> - Optional ClamAV integration for file uploads
                <br/><small>Scans images and videos for viruses/malware before storage</small>
            </li>
            <li><strong>Group Post Creator</strong> - In-group post creation with image support
                <br/><small>Create posts directly from group pages with multi-image upload, emoji support, and progress tracking</small>
            </li>
        </ul>

        <h3>Internationalization & Localization</h3>
        <ul>
            <li><strong>Microsoft.Extensions.Localization</strong> (10.0.2) - <em>MIT License</em>
                <br/><small>Core localization services with IStringLocalizer dependency injection</small>
            </li>
            <li><strong>Resource Files (.resx)</strong> - Built-in .NET localization system
                <br/><small>XML-based resource files for translations with Visual Studio tooling support</small>
            </li>
            <li><strong>Culture Detection</strong> - ASP.NET Core RequestLocalizationMiddleware
                <br/><small>Automatic browser language detection with fallback to English</small>
            </li>
            <li><strong>Custom Validation Scripts</strong> - PowerShell automation tools
                <br/><small>ValidateTranslations.ps1 for translation completeness auditing and maintenance</small>
            </li>
        </ul>

        <h4>Supported Languages (13 Total)</h4>
        <div class="row">
            <div class="col-md-6">
                <ul>
                    <li>🇸🇦 <strong>Arabic (ar)</strong> - Right-to-left (RTL) support</li>
                    <li>🇩🇪 <strong>German (de)</strong> - Text expansion considerations</li>
                    <li>🇺🇸 <strong>English (en)</strong> - Base language</li>
                    <li>🇪🇸 <strong>Spanish (es)</strong> - Global Spanish</li>
                    <li>🇫🇷 <strong>French (fr)</strong> - International French</li>
                    <li>🇮🇹 <strong>Italian (it)</strong> - Standard Italian</li>
                </ul>
            </div>
            <div class="col-md-6">
                <ul>
                    <li>🇯🇵 <strong>Japanese (ja)</strong> - UTF-8 character encoding</li>
                    <li>🇰🇷 <strong>Korean (ko)</strong> - Hangul script support</li>
                    <li>🇳🇱 <strong>Dutch (nl)</strong> - Netherlands Dutch</li>
                    <li>🇵🇱 <strong>Polish (pl)</strong> - Complex grammar forms</li>
                    <li>🇵🇹 <strong>Portuguese (pt)</strong> - Brazilian Portuguese</li>
                    <li>🇷🇺 <strong>Russian (ru)</strong> - Cyrillic script</li>
                    <li>🇨🇳 <strong>Chinese (zh)</strong> - Simplified Chinese</li>
                </ul>
            </div>
        </div>

        <h4>Translation Coverage</h4>
        <ul>
            <li><strong>Account Management</strong> - 67 keys × 13 languages = 871 translations ✅</li>
            <li><strong>Groups System</strong> - 98 keys × 13 languages = 1,274 translations ✅</li>
            <li><strong>Group Files</strong> - 87 keys × 13 languages = 1,131 translations ✅</li>
            <li><strong>Feed & Posts</strong> - 97 keys × 13 languages = 1,261 translations ✅</li>
            <li><strong>Navigation & UI</strong> - 85 keys × 13 languages = 1,105 translations ✅</li>
            <li><strong>System Administration</strong> - 45 keys × 13 languages = 585 translations ✅</li>
        </ul>
        <p><small><strong>Total Coverage:</strong> 1,009 keys × 13 languages = 13,117 translations • <strong>User-facing:</strong> 100% complete</small></p>

