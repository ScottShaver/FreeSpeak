@page "/home"
@rendermode InteractiveServer
@attribute [Authorize]
@inherits PostPageBase<Post, Comment>

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Helpers
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Pages.Base
@using System.Security.Claims
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IOptions<SiteSettings> SiteSettings
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PostService PostService
@inject ImageUploadService ImageUploadService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationStateService NavigationState
@inject UserPreferenceService UserPreferenceService
@inject HtmlSanitizationService HtmlSanitizationService

<PageTitle>@SiteSettings.Value.SiteName - Home</PageTitle>

<div class="home-container">
            <!-- Tabbed Interface -->
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="feed-tab" data-bs-toggle="tab" data-bs-target="#feed-content" type="button" role="tab" aria-controls="feed-content" aria-selected="true">
                        My Feed
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="pinned-tab" data-bs-toggle="tab" data-bs-target="#pinned-content" type="button" role="tab" aria-controls="pinned-content" aria-selected="false">
                        Pinned Posts
                    </button>
                </li>
            </ul>

            <div class="tab-content">
                <!-- My Feed Tab -->
                <div class="tab-pane fade show active" id="feed-content" role="tabpanel" aria-labelledby="feed-tab">
                    <!-- Reserved space for future content -->
                    <div class="top-section">
                        <PostCreator 
                            CurrentUserImageUrl="@currentUserImageUrl"
                            CurrentUserName="@currentUserName"
                            OnPostCreated="HandlePostCreated" />
                    </div>

                    <!-- Feed section -->
                    <div class="feed-section">
                        @if (isLoading && !posts.Any())
                        {
                            <div class="loading-indicator">
                                <p>Loading your feed...</p>
                            </div>
                        }
                        else if (!posts.Any() && !isLoading)
                        {
                            <div class="empty-feed">
                                <p>No posts to display. Start connecting with friends to see their posts!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var post in posts)
                            {
                                var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                                var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                                var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                                var authorName = postAuthorNames.ContainsKey(post.Id) ? postAuthorNames[post.Id] : "Unknown";
                                var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;

                                <FeedArticle 
                                    PostId="@post.Id"
                                    AuthorId="@post.AuthorId"
                                    AuthorName="@authorName"
                                    AuthorImageUrl="@post.Author?.ProfilePictureUrl"
                                    CreatedAt="@post.CreatedAt"
                                    LikeCount="@post.LikeCount"
                                    CommentCount="@post.CommentCount"
                                    ShareCount="@post.ShareCount"
                                    LoadCommentsInternally="true"
                                    CommentsToShow="3"
                                    RefreshTrigger="@refreshTrigger"
                                    CurrentUserId="@currentUserId"
                                    CurrentUserImageUrl="@currentUserImageUrl"
                                    CurrentUserName="@currentUserName"
                                    ReactionBreakdown="@postReactions"
                                    UserReaction="@userReaction"
                                    AudienceType="@post.AudienceType"
                                    IsPinned="@isPinned"
                                    Images="@post.Images?.ToList()"
                                    OnReactionChanged="@(async (reactionType) => await HandleReactionChanged(post.Id, reactionType))"
                                    OnRemoveReaction="@(async () => await HandleRemoveReaction(post.Id))"
                                    OnPinPost="@HandlePinPost"
                                    OnUnpinPost="@HandleUnpinPost"
                                    OnPostDeleted="@HandlePostDeleted"
                                    OnEditPost="@HandleEditPost"
                                    OnCommentAdded="@HandleCommentAdded"
                                    OnReplySubmitted="@HandleReplySubmitted"
                                    OnCommentReactionChanged="@HandleCommentReactionChanged"
                                    OnRemoveCommentReaction="@HandleRemoveCommentReaction"
                                    OnShowPostDetail="@(() => ShowPostDetail(post))"
                                    OnShowComments="@(() => ShowPostDetail(post))">
                                    <ArticleContent>
                                        @((MarkupString)FormatContentWithLineBreaks(post.Content))
                                    </ArticleContent>
                                </FeedArticle>
                            }

                            @if (isLoadingMore)
                            {
                                <div class="loading-more">
                                    <p>Loading more posts...</p>
                                </div>
                            }

                            @if (hasMorePosts == false && posts.Any())
                            {
                                <div class="no-more-posts">
                                    <p>No more posts at this time</p>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Pinned Posts Tab -->
                <div class="tab-pane fade" id="pinned-content" role="tabpanel" aria-labelledby="pinned-tab">
                    <div class="feed-section">
                        @if (isLoadingPinnedPosts && !pinnedPostsList.Any())
                        {
                            <div class="loading-indicator">
                                <p>Loading your pinned posts...</p>
                            </div>
                        }
                        else if (!pinnedPostsList.Any() && !isLoadingPinnedPosts)
                        {
                            <div class="empty-feed">
                                <p>You haven't pinned any posts yet. Pin posts from your feed to see them here!</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var post in pinnedPostsList)
                            {
                                var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                                var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                                var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                                var authorName = postAuthorNames.ContainsKey(post.Id) ? postAuthorNames[post.Id] : "Unknown";
                                var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;

                                <FeedArticle 
                                    PostId="@post.Id"
                                    AuthorId="@post.AuthorId"
                                    AuthorName="@authorName"
                                    AuthorImageUrl="@post.Author?.ProfilePictureUrl"
                                    CreatedAt="@post.CreatedAt"
                                    LikeCount="@post.LikeCount"
                                    CommentCount="@post.CommentCount"
                                    ShareCount="@post.ShareCount"
                                    LoadCommentsInternally="true"
                                    CommentsToShow="3"
                                    RefreshTrigger="@refreshTrigger"
                                    CurrentUserId="@currentUserId"
                                    CurrentUserImageUrl="@currentUserImageUrl"
                                    CurrentUserName="@currentUserName"
                                    ReactionBreakdown="@postReactions"
                                    UserReaction="@userReaction"
                                    AudienceType="@post.AudienceType"
                                    IsPinned="@isPinned"
                                    Images="@post.Images?.ToList()"
                                    OnReactionChanged="@(async (reactionType) => await HandleReactionChanged(post.Id, reactionType))"
                                    OnRemoveReaction="@(async () => await HandleRemoveReaction(post.Id))"
                                    OnPinPost="@HandlePinPost"
                                    OnUnpinPost="@HandleUnpinPost"
                                    OnPostDeleted="@HandlePostDeleted"
                                    OnEditPost="@HandleEditPost"
                                    OnCommentAdded="@OnCommentAdded"
                                    OnReplySubmitted="@OnReplySubmitted"
                                    OnCommentReactionChanged="@OnCommentReactionChanged"
                                    OnRemoveCommentReaction="@OnRemoveCommentReaction"
                                    OnShowPostDetail="@(() => ShowPostDetail(post))"
                                    OnShowComments="@(() => ShowPostDetail(post))">
                                    <ArticleContent>
                                        @((MarkupString)FormatContentWithLineBreaks(post.Content))
                                    </ArticleContent>
                                </FeedArticle>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (showPostDetail && selectedPost != null)
        {
            var postReactions = postReactionData.ContainsKey(selectedPost.Id) ? postReactionData[selectedPost.Id] : new Dictionary<LikeType, int>();
            var userReaction = postUserReactions.ContainsKey(selectedPost.Id) ? postUserReactions[selectedPost.Id] : null;
            var isPinned = pinnedPosts.ContainsKey(selectedPost.Id) && pinnedPosts[selectedPost.Id];
            var authorName = postAuthorNames.ContainsKey(selectedPost.Id) ? postAuthorNames[selectedPost.Id] : "Unknown";

            <PostDetailModal
                PostId="@selectedPost.Id"
                AuthorId="@selectedPost.AuthorId"
                AuthorName="@authorName"
                AuthorImageUrl="@selectedPost.Author?.ProfilePictureUrl"
                CreatedAt="@selectedPost.CreatedAt"
                LikeCount="@selectedPost.LikeCount"
                CommentCount="@selectedPost.CommentCount"
                CurrentUserId="@currentUserId"
                CurrentUserImageUrl="@currentUserImageUrl"
                CurrentUserName="@currentUserName"
                ReactionBreakdown="@postReactions"
                UserReaction="@userReaction"
                AudienceType="@selectedPost.AudienceType"
                IsPinned="@isPinned"
                Images="@selectedPost.Images?.ToList()"
                OnReactionChanged="@(async (reactionType) => await HandleReactionChanged(selectedPost.Id, reactionType))"
                OnRemoveReaction="@(async () => await HandleRemoveReaction(selectedPost.Id))"
                OnPinPost="@HandlePinPost"
                OnUnpinPost="@HandleUnpinPost"
                OnPostDeleted="@HandlePostDeleted"
                OnCommentAdded="@OnCommentAdded"
                OnReplySubmitted="@OnReplySubmitted"
                OnCommentReactionChanged="@OnCommentReactionChanged"
                OnRemoveCommentReaction="@OnRemoveCommentReaction"
                OnClose="@(async () => await ClosePostDetail())">
                <ArticleContent>
                    @((MarkupString)FormatContentWithLineBreaks(selectedPost.Content))
                </ArticleContent>
            </PostDetailModal>
        }

        <UploadProgressModal 
            IsVisible="@showUploadProgress"
            Title="@uploadProgressTitle"
            Message="@uploadProgressMessage"
            Progress="@uploadProgress"
            CurrentStep="@uploadCurrentStep"
            TotalSteps="@uploadTotalSteps" />

        @if (showEditPost && editPost != null)
        {
            <PostEditModal 
                @ref="postEditModalRef"
                PostId="@editPost.Id"
                AuthorName="@(postAuthorNames.ContainsKey(editPost.Id) ? postAuthorNames[editPost.Id] : "Unknown")"
                AuthorImageUrl="@editPost.Author?.ProfilePictureUrl"
                CreatedAt="@editPost.CreatedAt"
                InitialContent="@editPost.Content"
                InitialImages="@editPost.Images?.ToList()"
                AudienceType="@editPost.AudienceType"
                CurrentUserId="@currentUserId"
                OnSave="@HandleSaveEdit"
                OnCancel="@CloseEditModal"
                OnImageUploadStateChanged="@HandleImageUploadStateChanged"
                OnImagesSelected="@HandleEditPostImagesSelected" />
        }

        @if (showEditPostImageUpload)
        {
            <ImageUploadModal 
                IsVisible="true"
                OnImagesSelected="@HandleEditPostImagesSelected"
                OnClose="@(() => showEditPostImageUpload = false)"
                MaxImages="10" />
        }

@code {
    private List<Post> posts = new();
    private List<Post> pinnedPostsList = new();
    // Base class provides: postRefreshTriggers, postReactionData, postUserReactions, pinnedPosts, postAuthorNames
    private Dictionary<int, List<CommentDisplayModel>> postComments = new();
    private Dictionary<int, int> postDirectCommentCounts = new();

    private int currentPage = 1;
    private const int pageSize = 20;
    private bool isLoading = false;
    private bool isLoadingMore = false;
    private bool hasMorePosts = true;
    private bool isLoadingPinnedPosts = false;
    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<Home>? dotNetHelper;
    private bool showPostDetail = false;
    private Post? selectedPost = null;
    private bool showEditPost = false;
    private Post? editPost = null;
    private bool showEditPostImageUpload = false;
    private PostEditModal? postEditModalRef;

    // Upload progress tracking
    private bool showUploadProgress = false;
    private string uploadProgressTitle = "Adding Your Post";
    private string uploadProgressMessage = "Please wait...";
    private int uploadProgress = 0;
    private int uploadCurrentStep = 0;
    private int uploadTotalSteps = 0;

    protected override async Task OnInitializedAsync()
    {
        NavigationState.ActiveMenuItem = "/";

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (currentUserId != null)
        {
            // Load the actual user from the database to get accurate name and profile picture
            var currentUser = await UserManager.FindByIdAsync(currentUserId);
            if (currentUser != null)
            {
                currentUserImageUrl = currentUser.ProfilePictureUrl ?? null;

                // Use the user's display name preference
                currentUserName = await UserPreferenceService.FormatUserDisplayNameAsync(
                    currentUser.Id,
                    currentUser.FirstName,
                    currentUser.LastName,
                    currentUser.UserName ?? "User"
                );
            }
        }

        await LoadInitialPosts();
        await LoadPinnedPosts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
                dotNetHelper = DotNetObjectReference.Create(this);
                // Pass null for element since we're using window scroll now
                await jsModule.InvokeVoidAsync("initializeInfiniteScroll", (object?)null, dotNetHelper);
            }
            catch (Exception ex)
            {
                // Silently fail - infinite scroll not critical
            }
        }
    }

    private async Task LoadInitialPosts()
    {
        if (currentUserId == null) return;

        isLoading = true;
        try
        {
            var loadedPosts = await PostService.GetFeedPostsAsync(currentUserId, pageSize, currentPage);
            posts = loadedPosts;
            hasMorePosts = loadedPosts.Count == pageSize;

            // Load reaction data for all posts
            await LoadReactionDataForPosts(loadedPosts);

            // Load pinned status for all posts
            await LoadPinnedStatusForPosts(loadedPosts);

            // Load author names for all posts
            await LoadAuthorNamesForPosts(loadedPosts);
        }
        catch (Exception ex)
        {
            // Silently fail - feed will show empty
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadPinnedPosts()
    {
        if (currentUserId == null) return;

        isLoadingPinnedPosts = true;
        try
        {
            var loadedPosts = await PostService.GetPinnedPostsAsync(currentUserId);
            pinnedPostsList = loadedPosts;

            // Load reaction data for pinned posts
            await LoadReactionDataForPosts(loadedPosts);

            // Load pinned status for pinned posts (should all be true, but for consistency)
            await LoadPinnedStatusForPosts(loadedPosts);

            // Load author names for pinned posts
            await LoadAuthorNamesForPosts(loadedPosts);
        }
        catch (Exception ex)
        {
            // Silently fail - pinned feed will show empty
        }
        finally
        {
            isLoadingPinnedPosts = false;
        }
    }

    [JSInvokable]
    public async Task LoadMorePostsAsync()
    {
        if (currentUserId == null || isLoadingMore || !hasMorePosts) return;

        isLoadingMore = true;
        StateHasChanged(); // Update UI to show loading indicator

        try
        {
            currentPage++;
            var loadedPosts = await PostService.GetFeedPostsAsync(currentUserId, pageSize, currentPage);

            if (loadedPosts.Any())
            {
                posts.AddRange(loadedPosts);
                hasMorePosts = loadedPosts.Count == pageSize;

                // Load reaction data for new posts
                await LoadReactionDataForPosts(loadedPosts);

                // Load pinned status for new posts
                await LoadPinnedStatusForPosts(loadedPosts);

                // Load author names for new posts
                await LoadAuthorNamesForPosts(loadedPosts);
            }
            else
            {
                hasMorePosts = false;
            }
        }
        catch (Exception ex)
        {
            // Silently fail - pagination will stop
            currentPage--; // Revert page increment on error
        }
        finally
        {
            isLoadingMore = false;
            StateHasChanged(); // Update UI after loading
        }
    }

    private async Task<string> GetAuthorName(Post post)
    {
        if (post.Author == null) return "Unknown";

        // Use the author's display name preference
        return await UserPreferenceService.FormatUserDisplayNameAsync(
            post.Author.Id,
            post.Author.FirstName,
            post.Author.LastName,
            post.Author.UserName ?? "Unknown"
        );
    }

    private string FormatContentWithLineBreaks(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;

        // SECURITY: Sanitize user content to prevent XSS attacks
        return HtmlSanitizationService.SanitizeAndFormatContent(content);
    }

    private async Task LoadReactionDataForPosts(List<Post> postsToLoad)
    {
        if (currentUserId == null) return;

        foreach (var post in postsToLoad)
        {
            try
            {
                // Get reaction breakdown
                var reactions = await PostService.GetReactionBreakdownAsync(post.Id);
                postReactionData[post.Id] = reactions;

                // Get user's reaction
                var userReaction = await PostService.GetUserReactionAsync(post.Id, currentUserId);
                postUserReactions[post.Id] = userReaction;

                // Get direct comment count
                var directCommentCount = await PostService.GetDirectCommentCountAsync(post.Id);
                postDirectCommentCounts[post.Id] = directCommentCount;

                // Get last 3 comments for feed display
                await LoadCommentsForPost(post.Id, 3);
            }
            catch (Exception ex)
            {
                // Silently fail - reaction data optional
            }
        }
    }

    private async Task LoadPinnedStatusForPosts(List<Post> postsToLoad)
    {
        if (currentUserId == null) return;

        try
        {
            var postIds = postsToLoad.Select(p => p.Id).ToList();

            var pinnedStatus = await PostService.GetPinnedStatusForPostsAsync(postIds, currentUserId);

            foreach (var kvp in pinnedStatus)
            {
                pinnedPosts[kvp.Key] = kvp.Value;
            }
        }
        catch (Exception ex)
        {
            // Silently fail - pinned status optional
        }
    }

    private async Task LoadAuthorNamesForPosts(List<Post> postsToLoad)
    {
        try
        {
            foreach (var post in postsToLoad)
            {
                if (post.Author != null)
                {
                    var displayName = await UserPreferenceService.FormatUserDisplayNameAsync(
                        post.Author.Id,
                        post.Author.FirstName,
                        post.Author.LastName,
                        post.Author.UserName ?? "Unknown"
                    );
                    postAuthorNames[post.Id] = displayName;
                }
                else
                {
                    // Handle cases where author might be null (e.g., deleted user)
                    postAuthorNames[post.Id] = "Unknown User";
                }
            }
        }
        catch (Exception ex)
        {
            // Silently fail - author names optional
        }
    }

    private async Task HandlePinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.PinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                pinnedPosts[postId] = true;

                // Reload pinned posts list to include the newly pinned post
                await LoadPinnedPosts();

                StateHasChanged();
            }
            else
            {
                // Silently fail - pinning unsuccessful
            }
        }
        catch (Exception ex)
        {
            // Silently fail - pinning unsuccessful
        }
    }

    private async Task HandleUnpinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.UnpinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                pinnedPosts[postId] = false;

                // Reload pinned posts list to remove the unpinned post
                await LoadPinnedPosts();

                StateHasChanged();
            }
            else
            {
                // Silently fail - unpinning unsuccessful
            }
        }
        catch (Exception ex)
        {
            // Silently fail - unpinning unsuccessful
        }
    }

    private void HandlePostDeleted(int postId)
    {
        // Remove the post from the list
        var postToRemove = posts.FirstOrDefault(p => p.Id == postId);
        if (postToRemove != null)
        {
            posts.Remove(postToRemove);
        }

        // Clean up related data
        postReactionData.Remove(postId);
        postUserReactions.Remove(postId);
        postComments.Remove(postId);
        postDirectCommentCounts.Remove(postId);
        pinnedPosts.Remove(postId);

        // If the deleted post was being viewed in detail, close the modal
        if (selectedPost?.Id == postId)
        {
            selectedPost = null;
            showPostDetail = false;
        }

        StateHasChanged();
    }

    private async Task LoadCommentsForPost(int postId, int count)
    {
        try
        {
            var comments = await PostService.GetLastCommentsAsync(postId, count);

            // Use batch loading to reduce database round trips
            var commentModels = await CommentHelpers.BuildCommentDisplayModelsAsync(
                comments.ToList(),
                PostService,
                UserPreferenceService,
                currentUserId);

            postComments[postId] = commentModels;
        }
        catch (Exception ex)
        {
            // Silently fail - comments optional
        }
    }

    private async Task HandleReactionChanged(int postId, LikeType reactionType)
    {
        // Delegate to base class implementation
        await HandlePostReactionChanged(postId, reactionType);
    }

    private async Task HandleRemoveReaction(int postId)
    {
        // Delegate to base class implementation
        await HandleRemovePostReaction(postId);
    }

    private async Task OnCommentAdded((int PostId, string Content) data)
    {
        // Delegate to base class implementation
        await HandleCommentAdded(data);
    }

    private async Task OnReplySubmitted((int ParentCommentId, string Content) data)
    {
        // Delegate to base class implementation
        await HandleReplySubmitted(data);
    }

    private async Task OnCommentReactionChanged((int CommentId, LikeType ReactionType) data)
    {
        // Delegate to base class implementation
        await HandleCommentReactionChanged(data);

        // Additionally update the legacy UI comment data
        await UpdateCommentReactionData(data.CommentId, data.ReactionType);
    }

    private async Task OnRemoveCommentReaction(int commentId)
    {
        // Delegate to base class implementation
        await HandleRemoveCommentReaction(commentId);

        // Additionally update the legacy UI comment data
        await UpdateCommentReactionData(commentId, null);
    }

    private async Task UpdateCommentReactionData(int commentId, LikeType? newReaction)
    {
        // Find the comment in the postComments dictionary and update its reaction data
        foreach (var kvp in postComments)
        {
            var comment = CommentHelpers.FindCommentById(kvp.Value, commentId);
            if (comment != null)
            {
                // Update user's reaction
                comment.UserReaction = newReaction;

                // Reload reaction breakdown and like count
                comment.ReactionBreakdown = await PostService.GetCommentReactionBreakdownAsync(commentId);
                comment.LikeCount = await PostService.GetCommentLikeCountAsync(commentId);
                break;
            }
        }
    }

    private async Task HandlePostCreated((string Content, AudienceType AudienceType, List<ImageUploadModal.SelectedImage> Images) postData)
    {
        if (currentUserId == null) return;

        try
        {
            var imageUrls = new List<string>();

            // Calculate total steps
            var hasImages = postData.Images != null && postData.Images.Any();
            uploadTotalSteps = hasImages ? 2 : 1; // 1 for upload, 1 for creating post
            uploadCurrentStep = 0;

            // Show progress modal
            showUploadProgress = true;
            uploadProgress = 0;
            StateHasChanged();

            // Step 1: Upload images if any
            if (hasImages && postData.Images != null)
            {
                uploadCurrentStep = 1;
                uploadProgressMessage = $"Uploading {postData.Images.Count} {(postData.Images.Count == 1 ? "image" : "images")}...";
                StateHasChanged();

                // Convert selected images to upload format
                var imagesToUpload = postData.Images.Select(img => (
                    FileName: img.FileName,
                    Base64Data: img.DataUrl,
                    ContentType: img.ContentType
                )).ToList();

                // Create progress reporter
                var progress = new Progress<int>(percent =>
                {
                    uploadProgress = percent / 2; // Images are first 50%
                    InvokeAsync(StateHasChanged);
                });

                var uploadResult = await ImageUploadService.UploadImagesAsync(currentUserId, imagesToUpload, progress);

                if (!uploadResult.Success)
                {
                    showUploadProgress = false;
                    StateHasChanged();
                    return;
                }

                imageUrls = uploadResult.ImageUrls;
                uploadProgress = 50;
                StateHasChanged();
            }

            // Step 2: Create the post
            uploadCurrentStep = hasImages ? 2 : 1;
            uploadProgressMessage = "Creating your post...";
            uploadProgress = hasImages ? 50 : 0;
            StateHasChanged();

            var result = await PostService.CreatePostAsync(currentUserId, postData.Content, postData.AudienceType, imageUrls);

            if (result.Success && result.Post != null)
            {
                uploadProgress = 100;
                StateHasChanged();

                // Small delay to show 100% completion
                await Task.Delay(500);

                // Hide progress modal
                showUploadProgress = false;
                StateHasChanged();

                // Reload the feed to include the new post
                await LoadInitialPosts();

                // Scroll to top to show the new post
                if (jsModule != null)
                {
                    try
                    {
                        await jsModule.InvokeVoidAsync("scrollToTop");
                    }
                    catch
                    {
                        // Ignore scroll errors
                    }
                }

                StateHasChanged();
            }
            else
            {
                showUploadProgress = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            showUploadProgress = false;
            StateHasChanged();
        }
    }

    private void ShowPostDetail(Post post)
    {
        selectedPost = post;
        showPostDetail = true;
        StateHasChanged();
    }

    private async Task ClosePostDetail()
    {
        // Reload comments for the post before closing, in case they were updated in the modal
        if (selectedPost != null)
        {
            await LoadCommentsForPost(selectedPost.Id, 3);
        }

        showPostDetail = false;
        selectedPost = null;
        StateHasChanged();
    }

    private void HandleEditPost(int postId)
    {
        var post = posts.FirstOrDefault(p => p.Id == postId);
        if (post == null)
        {
            post = pinnedPostsList.FirstOrDefault(p => p.Id == postId);
        }

        if (post != null)
        {
            editPost = post;
            showEditPost = true;
            StateHasChanged();
        }
        else
        {
            // Post not found - silently ignore
        }
    }

    private async Task HandleSaveEdit((int PostId, string Content, List<string> NewImageUrls, List<int> RemovedImageIds) data)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.UpdatePostAsync(data.PostId, currentUserId, data.Content, data.NewImageUrls, data.RemovedImageIds);

            if (result.Success)
            {
                // Update the post in the lists
                var post = posts.FirstOrDefault(p => p.Id == data.PostId);
                if (post != null)
                {
                    post.Content = data.Content;
                    if (result.UpdatedImages != null)
                    {
                        post.Images = result.UpdatedImages;
                    }
                }

                var pinnedPost = pinnedPostsList.FirstOrDefault(p => p.Id == data.PostId);
                if (pinnedPost != null)
                {
                    pinnedPost.Content = data.Content;
                    if (result.UpdatedImages != null)
                    {
                        pinnedPost.Images = result.UpdatedImages;
                    }
                }

                CloseEditModal();
                StateHasChanged();
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("alert", result.ErrorMessage ?? "Failed to update post");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "An error occurred while updating the post.");
        }
    }

    private void CloseEditModal()
    {
        showEditPost = false;
        editPost = null;
        showEditPostImageUpload = false;
        StateHasChanged();
    }

    private void HandleImageUploadStateChanged(bool isOpen)
    {
        showEditPostImageUpload = isOpen;
        StateHasChanged();
    }

    private void HandleEditPostImagesSelected(List<ImageUploadModal.SelectedImage> images)
    {
        // Pass the images to PostEditModal
        postEditModalRef?.AddNewImages(images);
        showEditPostImageUpload = false;
        StateHasChanged();
    }

