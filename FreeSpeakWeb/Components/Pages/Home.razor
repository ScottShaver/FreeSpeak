@page "/"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.SocialFeed
@using System.Security.Claims
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IOptions<SiteSettings> SiteSettings
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PostService PostService
@inject IJSRuntime JSRuntime
@inject UserManager<ApplicationUser> UserManager
@inject NavigationStateService NavigationState

<PageTitle>@SiteSettings.Value.SiteName - Home</PageTitle>

<div class="home-container">
            <!-- Reserved space for future content -->
            <div class="top-section">
                <PostCreator 
                    CurrentUserImageUrl="@currentUserImageUrl"
                    CurrentUserName="@currentUserName"
                    OnPostCreated="HandlePostCreated" />
            </div>

            <!-- Feed section -->
            <div class="feed-section">
                @if (isLoading && !posts.Any())
                {
                    <div class="loading-indicator">
                        <p>Loading your feed...</p>
                    </div>
                }
                else if (!posts.Any() && !isLoading)
                {
                    <div class="empty-feed">
                        <p>No posts to display. Start connecting with friends to see their posts!</p>
                    </div>
                }
                else
                {
                    @foreach (var post in posts)
                    {
                        var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                        var userReaction = userReactions.ContainsKey(post.Id) ? userReactions[post.Id] : null;
                        var comments = postComments.ContainsKey(post.Id) ? postComments[post.Id] : new List<CommentDisplayModel>();
                        var directCommentCount = postDirectCommentCounts.ContainsKey(post.Id) ? postDirectCommentCounts[post.Id] : 0;
                        var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];

                        <FeedArticle 
                            PostId="@post.Id"
                            AuthorId="@post.AuthorId"
                            AuthorName="@GetAuthorName(post)"
                            AuthorImageUrl="@post.Author?.ProfilePictureUrl"
                            CreatedAt="@post.CreatedAt"
                            LikeCount="@post.LikeCount"
                            CommentCount="@post.CommentCount"
                            DirectCommentCount="@directCommentCount"
                            CurrentUserId="@currentUserId"
                            CurrentUserImageUrl="@currentUserImageUrl"
                            CurrentUserName="@currentUserName"
                            ReactionBreakdown="@postReactions"
                            UserReaction="@userReaction"
                            Comments="@comments"
                            AudienceType="@post.AudienceType"
                            IsPinned="@isPinned"
                            OnReactionChanged="@(async (reactionType) => await HandleReactionChanged(post.Id, reactionType))"
                            OnRemoveReaction="@(async () => await HandleRemoveReaction(post.Id))"
                            OnPinPost="@HandlePinPost"
                            OnUnpinPost="@HandleUnpinPost"
                            OnCommentAdded="@HandleCommentAdded"
                            OnReplySubmitted="@HandleReplySubmitted"
                            OnCommentReactionChanged="@HandleCommentReactionChanged"
                            OnRemoveCommentReaction="@HandleRemoveCommentReaction"
                            OnShowPostDetail="@(() => ShowPostDetail(post))"
                            OnShowComments="@(() => ShowPostDetail(post))">
                            <ArticleContent>
                                @((MarkupString)FormatContentWithLineBreaks(post.Content))
                            </ArticleContent>
                        </FeedArticle>
                    }

                    @if (isLoadingMore)
                    {
                        <div class="loading-more">
                            <p>Loading more posts...</p>
                        </div>
                    }

                    @if (hasMorePosts == false && posts.Any())
                    {
                        <div class="no-more-posts">
                            <p>No more posts at this time</p>
                        </div>
                    }
                }
            </div>
        </div>

        @if (showPostDetail && selectedPost != null)
        {
            var postReactions = postReactionData.ContainsKey(selectedPost.Id) ? postReactionData[selectedPost.Id] : new Dictionary<LikeType, int>();
            var userReaction = userReactions.ContainsKey(selectedPost.Id) ? userReactions[selectedPost.Id] : null;
            var isPinned = pinnedPosts.ContainsKey(selectedPost.Id) && pinnedPosts[selectedPost.Id];

            <PostDetailModal
                PostId="@selectedPost.Id"
                AuthorId="@selectedPost.AuthorId"
                AuthorName="@GetAuthorName(selectedPost)"
                AuthorImageUrl="@selectedPost.Author?.ProfilePictureUrl"
                CreatedAt="@selectedPost.CreatedAt"
                LikeCount="@selectedPost.LikeCount"
                CommentCount="@selectedPost.CommentCount"
                CurrentUserId="@currentUserId"
                CurrentUserImageUrl="@currentUserImageUrl"
                CurrentUserName="@currentUserName"
                ReactionBreakdown="@postReactions"
                UserReaction="@userReaction"
                AudienceType="@selectedPost.AudienceType"
                IsPinned="@isPinned"
                OnReactionChanged="@(async (reactionType) => await HandleReactionChanged(selectedPost.Id, reactionType))"
                OnRemoveReaction="@(async () => await HandleRemoveReaction(selectedPost.Id))"
                OnPinPost="@HandlePinPost"
                OnUnpinPost="@HandleUnpinPost"
                OnCommentAdded="@HandleCommentAdded"
                OnCommentReactionChanged="@HandleCommentReactionChanged"
                OnRemoveCommentReaction="@HandleRemoveCommentReaction"
                OnClose="@(async () => await ClosePostDetail())">
                <ArticleContent>
                    @((MarkupString)FormatContentWithLineBreaks(selectedPost.Content))
                </ArticleContent>
            </PostDetailModal>
        }

@code {
    private List<Post> posts = new();
    private Dictionary<int, Dictionary<LikeType, int>> postReactionData = new();
    private Dictionary<int, LikeType?> userReactions = new();
    private Dictionary<int, List<CommentDisplayModel>> postComments = new();
    private Dictionary<int, int> postDirectCommentCounts = new();
    private Dictionary<int, bool> pinnedPosts = new();
    private int currentPage = 1;
    private const int pageSize = 20;
    private bool isLoading = false;
    private bool isLoadingMore = false;
    private bool hasMorePosts = true;
    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<Home>? dotNetHelper;
    private bool showPostDetail = false;
    private Post? selectedPost = null;

    protected override async Task OnInitializedAsync()
    {
        NavigationState.ActiveMenuItem = "/";

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (currentUserId != null)
        {
            // Load the actual user from the database to get accurate name and profile picture
            var currentUser = await UserManager.FindByIdAsync(currentUserId);
            if (currentUser != null)
            {
                currentUserImageUrl = currentUser.ProfilePictureUrl;

                // Use FirstName + LastName if available, otherwise fall back to username
                if (!string.IsNullOrWhiteSpace(currentUser.FirstName) && !string.IsNullOrWhiteSpace(currentUser.LastName))
                {
                    currentUserName = $"{currentUser.FirstName} {currentUser.LastName}";
                }
                else
                {
                    currentUserName = currentUser.UserName ?? "User";
                }
            }
        }

        await LoadInitialPosts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
                dotNetHelper = DotNetObjectReference.Create(this);
                // Pass null for element since we're using window scroll now
                await jsModule.InvokeVoidAsync("initializeInfiniteScroll", (object?)null, dotNetHelper);
                Console.WriteLine("Infinite scroll initialized from Home.razor");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error initializing infinite scroll: {ex.Message}");
            }
        }
    }

    private async Task LoadInitialPosts()
    {
        if (currentUserId == null) return;

        isLoading = true;
        try
        {
            var loadedPosts = await PostService.GetFeedPostsAsync(currentUserId, pageSize, currentPage);
            posts = loadedPosts;
            hasMorePosts = loadedPosts.Count == pageSize;

            // Load reaction data for all posts
            await LoadReactionDataForPosts(loadedPosts);

            // Load pinned status for all posts
            await LoadPinnedStatusForPosts(loadedPosts);
        }
        catch (Exception ex)
        {
            // Log error (you might want to inject ILogger here)
            Console.WriteLine($"Error loading posts: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    [JSInvokable]
    public async Task LoadMorePostsAsync()
    {
        if (currentUserId == null || isLoadingMore || !hasMorePosts) return;

        isLoadingMore = true;
        StateHasChanged(); // Update UI to show loading indicator

        try
        {
            currentPage++;
            var loadedPosts = await PostService.GetFeedPostsAsync(currentUserId, pageSize, currentPage);

            if (loadedPosts.Any())
            {
                posts.AddRange(loadedPosts);
                hasMorePosts = loadedPosts.Count == pageSize;

                // Load reaction data for new posts
                await LoadReactionDataForPosts(loadedPosts);

                // Load pinned status for new posts
                await LoadPinnedStatusForPosts(loadedPosts);
            }
            else
            {
                hasMorePosts = false;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading more posts: {ex.Message}");
            currentPage--; // Revert page increment on error
        }
        finally
        {
            isLoadingMore = false;
            StateHasChanged(); // Update UI after loading
        }
    }

    private string GetAuthorName(Post post)
    {
        if (post.Author == null) return "Unknown";

        if (!string.IsNullOrWhiteSpace(post.Author.FirstName) && !string.IsNullOrWhiteSpace(post.Author.LastName))
        {
            return $"{post.Author.FirstName} {post.Author.LastName}";
        }

        return post.Author.UserName ?? "Unknown";
    }

    private string FormatContentWithLineBreaks(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;

        // Replace newlines with <br> tags
        // Handle both \r\n (Windows) and \n (Unix) line endings
        return content.Replace("\r\n", "<br>").Replace("\n", "<br>");
    }

    private async Task LoadReactionDataForPosts(List<Post> postsToLoad)
    {
        if (currentUserId == null) return;

        foreach (var post in postsToLoad)
        {
            try
            {
                // Get reaction breakdown
                var reactions = await PostService.GetReactionBreakdownAsync(post.Id);
                postReactionData[post.Id] = reactions;

                // Get user's reaction
                var userReaction = await PostService.GetUserReactionAsync(post.Id, currentUserId);
                userReactions[post.Id] = userReaction;

                // Get direct comment count
                var directCommentCount = await PostService.GetDirectCommentCountAsync(post.Id);
                postDirectCommentCounts[post.Id] = directCommentCount;

                // Get last 3 comments for feed display
                await LoadCommentsForPost(post.Id, 3);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading reactions for post {post.Id}: {ex.Message}");
            }
        }
    }

    private async Task LoadPinnedStatusForPosts(List<Post> postsToLoad)
    {
        if (currentUserId == null) return;

        try
        {
            var postIds = postsToLoad.Select(p => p.Id).ToList();
            Console.WriteLine($"Loading pinned status for {postIds.Count} posts for user {currentUserId}");

            var pinnedStatus = await PostService.GetPinnedStatusForPostsAsync(postIds, currentUserId);

            Console.WriteLine($"Received pinned status: {string.Join(", ", pinnedStatus.Select(kvp => $"Post {kvp.Key}: {kvp.Value}"))}");

            foreach (var kvp in pinnedStatus)
            {
                pinnedPosts[kvp.Key] = kvp.Value;
                if (kvp.Value)
                {
                    Console.WriteLine($"Post {kvp.Key} is PINNED");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading pinned status: {ex.Message}");
        }
    }

    private async Task HandlePinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.PinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                pinnedPosts[postId] = true;
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"Error pinning post: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error pinning post {postId}: {ex.Message}");
        }
    }

    private async Task HandleUnpinPost(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.UnpinPostAsync(postId, currentUserId);

            if (result.Success)
            {
                pinnedPosts[postId] = false;
                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"Error unpinning post: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error unpinning post {postId}: {ex.Message}");
        }
    }

    private async Task LoadCommentsForPost(int postId, int count)
    {
        try
        {
            var comments = await PostService.GetLastCommentsAsync(postId, count);
            var commentModels = new List<CommentDisplayModel>();

            foreach (var c in comments)
            {
                var commentModel = await BuildCommentDisplayModel(c);
                commentModels.Add(commentModel);
            }

            postComments[postId] = commentModels;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading comments for post {postId}: {ex.Message}");
        }
    }

    private async Task<CommentDisplayModel> BuildCommentDisplayModel(Comment comment)
    {
        // Load replies for this comment
        var replies = await PostService.GetRepliesAsync(comment.Id);
        var replyModels = new List<CommentDisplayModel>();

        foreach (var reply in replies)
        {
            var replyModel = await BuildCommentDisplayModel(reply); // Recursive call for nested replies
            replyModels.Add(replyModel);
        }

        return new CommentDisplayModel
        {
            CommentId = comment.Id,
            UserName = GetCommentAuthorName(comment),
            UserImageUrl = comment.Author?.ProfilePictureUrl,
            CommentAuthorId = comment.AuthorId,
            CommentText = comment.Content,
            Timestamp = comment.CreatedAt,
            Replies = replyModels.Any() ? replyModels : null,
            LikeCount = await PostService.GetCommentLikeCountAsync(comment.Id),
            UserReaction = currentUserId != null ? await PostService.GetUserCommentReactionAsync(comment.Id, currentUserId) : null,
            ReactionBreakdown = await PostService.GetCommentReactionBreakdownAsync(comment.Id)
        };
    }

    private string GetCommentAuthorName(Comment comment)
    {
        if (comment.Author == null) return "Unknown";

        if (!string.IsNullOrWhiteSpace(comment.Author.FirstName) && !string.IsNullOrWhiteSpace(comment.Author.LastName))
        {
            return $"{comment.Author.FirstName} {comment.Author.LastName}";
        }

        return comment.Author.UserName ?? "Unknown";
    }

    private async Task HandleReactionChanged(int postId, LikeType reactionType)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.AddOrUpdateReactionAsync(postId, currentUserId, reactionType);

            if (result.Success)
            {
                // Update user's reaction
                var previousReaction = userReactions.ContainsKey(postId) ? userReactions[postId] : null;
                userReactions[postId] = reactionType;

                // Reload reaction breakdown
                var reactions = await PostService.GetReactionBreakdownAsync(postId);
                postReactionData[postId] = reactions;

                // Update like count if this is a new reaction
                var post = posts.FirstOrDefault(p => p.Id == postId);
                if (post != null && previousReaction == null)
                {
                    post.LikeCount++;
                }

                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error handling reaction: {ex.Message}");
        }
    }

    private async Task HandleRemoveReaction(int postId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.RemoveLikeAsync(postId, currentUserId);

            if (result.Success)
            {
                // Remove user's reaction
                userReactions[postId] = null;

                // Reload reaction breakdown
                var reactions = await PostService.GetReactionBreakdownAsync(postId);
                postReactionData[postId] = reactions;

                // Update like count
                var post = posts.FirstOrDefault(p => p.Id == postId);
                if (post != null)
                {
                    post.LikeCount = Math.Max(0, post.LikeCount - 1);
                }

                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error removing reaction: {ex.Message}");
        }
    }

    private async Task HandleCommentAdded((int PostId, string Content) data)
    {
        if (currentUserId == null) return;

        try
        {
            // Add the comment to the database
            var result = await PostService.AddCommentAsync(data.PostId, currentUserId, data.Content);

            if (result.Success)
            {
                // Update the post's comment count in the UI
                var post = posts.FirstOrDefault(p => p.Id == data.PostId);
                if (post != null)
                {
                    post.CommentCount++;
                }

                // Reload comments to show the new one
                await LoadCommentsForPost(data.PostId, 3);

                StateHasChanged();
            }
            else
            {
                // Show error message to user
                await JSRuntime.InvokeVoidAsync("alert", result.ErrorMessage ?? "Failed to add comment");
                Console.WriteLine($"Failed to add comment: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "An error occurred while adding your comment.");
            Console.WriteLine($"Error adding comment: {ex.Message}");
        }
    }

    private async Task HandleReplySubmitted((int ParentCommentId, string Content) data)
    {
        if (currentUserId == null) return;

        try
        {
            // Get the parent comment's PostId by searching through postComments
            int? postId = null;
            foreach (var kvp in postComments)
            {
                if (FindCommentById(kvp.Value, data.ParentCommentId) != null)
                {
                    postId = kvp.Key;
                    break;
                }
            }

            if (postId == null)
            {
                Console.WriteLine($"Could not find post for parent comment {data.ParentCommentId}");
                return;
            }

            // Add the reply to the database using AddCommentAsync with parentCommentId
            var result = await PostService.AddCommentAsync(postId.Value, currentUserId, data.Content, null, data.ParentCommentId);

            if (result.Success)
            {
                // Reload comments for this post to show the new reply
                await LoadCommentsForPost(postId.Value, 3);

                // Update comment count
                var post = posts.FirstOrDefault(p => p.Id == postId.Value);
                if (post != null)
                {
                    post.CommentCount++;
                }

                StateHasChanged();
            }
            else
            {
                // Show error message to user
                await JSRuntime.InvokeVoidAsync("alert", result.ErrorMessage ?? "Failed to add reply");
                Console.WriteLine($"Failed to add reply: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "An error occurred while adding your reply.");
            Console.WriteLine($"Error adding reply: {ex.Message}");
        }
    }

    private async Task HandleCommentReactionChanged((int CommentId, LikeType ReactionType) data)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.AddOrUpdateCommentReactionAsync(data.CommentId, currentUserId, data.ReactionType);

            if (result.Success)
            {
                // Update the comment's reaction data in the UI
                await UpdateCommentReactionData(data.CommentId, data.ReactionType);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error handling comment reaction: {ex.Message}");
        }
    }

    private async Task HandleRemoveCommentReaction(int commentId)
    {
        if (currentUserId == null) return;

        try
        {
            var result = await PostService.RemoveCommentReactionAsync(commentId, currentUserId);

            if (result.Success)
            {
                // Update the comment's reaction data in the UI
                await UpdateCommentReactionData(commentId, null);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error removing comment reaction: {ex.Message}");
        }
    }

    private async Task UpdateCommentReactionData(int commentId, LikeType? newReaction)
    {
        // Find the comment in the postComments dictionary and update its reaction data
        foreach (var kvp in postComments)
        {
            var comment = FindCommentById(kvp.Value, commentId);
            if (comment != null)
            {
                // Update user's reaction
                comment.UserReaction = newReaction;

                // Reload reaction breakdown and like count
                comment.ReactionBreakdown = await PostService.GetCommentReactionBreakdownAsync(commentId);
                comment.LikeCount = await PostService.GetCommentLikeCountAsync(commentId);
                break;
            }
        }
    }

    private CommentDisplayModel? FindCommentById(List<CommentDisplayModel> comments, int commentId)
    {
        foreach (var comment in comments)
        {
            if (comment.CommentId == commentId)
                return comment;

            if (comment.Replies != null)
            {
                var found = FindCommentById(comment.Replies, commentId);
                if (found != null)
                    return found;
            }
        }
        return null;
    }

    private async Task HandlePostCreated(string content)
    {
        if (currentUserId == null) return;

        try
        {
            // Create the post in the database
            var result = await PostService.CreatePostAsync(currentUserId, content);

            if (result.Success && result.Post != null)
            {
                // Reload the feed to include the new post
                await LoadInitialPosts();

                // Scroll to top to show the new post
                if (jsModule != null)
                {
                    try
                    {
                        await jsModule.InvokeVoidAsync("scrollToTop");
                    }
                    catch
                    {
                        // Ignore scroll errors
                    }
                }

                StateHasChanged();
            }
            else
            {
                Console.WriteLine($"Failed to create post: {result.ErrorMessage}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating post: {ex.Message}");
        }
    }

    private void ShowPostDetail(Post post)
    {
        selectedPost = post;
        showPostDetail = true;
        StateHasChanged();
    }

    private async Task ClosePostDetail()
    {
        // Reload comments for the post before closing, in case they were updated in the modal
        if (selectedPost != null)
        {
            await LoadCommentsForPost(selectedPost.Id, 3);
        }

        showPostDetail = false;
        selectedPost = null;
        StateHasChanged();
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (jsModule != null)
        {
            try
            {
                // Dispose the infinite scroll listener
                await jsModule.InvokeVoidAsync("disposeInfiniteScroll");
                await jsModule.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }

        dotNetHelper?.Dispose();
    }
}
