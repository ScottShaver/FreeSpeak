    {
        showRulesModal = false;
        selectedGroupForJoin = null;
        StateHasChanged();
    }

    /// <summary>
    /// Handles the user agreeing to group rules.
    /// Proceeds with the join process with rules agreement flag set to true.
    /// </summary>
    private async Task HandleRulesAgreed()
    {
        if (selectedGroupForJoin == null) return;

        var group = selectedGroupForJoin;

        // Close the modal
        CloseRulesModal();

        // Proceed with join with rules agreement
        await ProcessJoinGroup(group, hasAgreedToRules: true);
    }

    /// <summary>
    /// Processes the actual group join or join request.
    /// </summary>
    /// <param name="group">The group to join.</param>
    /// <param name="hasAgreedToRules">Whether the user has agreed to the group rules.</param>
    private async Task ProcessJoinGroup(Group group, bool hasAgreedToRules)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            if (group.RequiresJoinApproval)
            {
                // Send join request
                var (success, errorMessage, request) = await GroupMemberService.CreateJoinRequestAsync(group.Id, currentUserId, hasAgreedToRules);

                if (success)
                {
                    AlertService.ShowSuccess("Join request sent successfully!");

                    // Remove from both lists since request was sent
                    suggestedGroups.RemoveAll(g => g.Id == group.Id);
                    searchedGroups.RemoveAll(g => g.Id == group.Id);
                    StateHasChanged();
                }
                else
                {
                    AlertService.ShowError(errorMessage ?? "Failed to send join request.");
                }
            }
            else
            {
                // Join immediately
                var (success, errorMessage) = await GroupMemberService.JoinGroupAsync(group.Id, currentUserId, hasAgreedToRules);

                if (success)
                {
                    AlertService.ShowSuccess($"You've joined {group.Name}!");
                    // Navigate to the group page with force reload to refresh nav menu
                    NavigationManager.NavigateTo($"/group/{group.Id}", forceLoad: true);
                }
                else
                {
                    AlertService.ShowError(errorMessage ?? "Failed to join group.");
                }
            }
        }
        catch (Exception ex)
        {
            AlertService.ShowError("An error occurred while joining the group. " + ex.GetType());
        }
    }

    /// <summary>
    /// Cancels a pending group join request.
    /// Removes the request from the list upon successful cancellation.
    /// </summary>
    /// <param name="requestId">The ID of the join request to cancel.</param>
    private async Task CancelJoinRequest(int requestId)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            var (success, errorMessage) = await GroupMemberService.CancelJoinRequestAsync(requestId, currentUserId);

            if (success)
            {
                // Remove from the list
                groupJoinRequests.RemoveAll(r => r.Id == requestId);
                StateHasChanged();
                AlertService.ShowSuccess("Join request cancelled successfully.");
            }
            else
            {
                AlertService.ShowError(errorMessage ?? "Failed to cancel join request.");
            }
        }
        catch (Exception ex)
        {
            AlertService.ShowError("An error occurred while cancelling the join request. " + ex.GetType());
        }
    }

