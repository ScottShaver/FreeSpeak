    /// <summary>
    /// Decrements the comment count for a post in the UI.
    /// Updates both the main feed and pinned posts list.
    /// </summary>
    /// <param name="postId">The ID of the post.</param>
    /// <param name="decrementBy">The number to decrement by.</param>
    protected override void DecrementPostCommentCount(int postId, int decrementBy = 1)
    {
        var post = groupPosts.FirstOrDefault(p => p.Id == postId);
        if (post != null)
        {
            post.CommentCount = Math.Max(0, post.CommentCount - decrementBy);
        }

        // Also update pinnedGroupPostsList if post exists there
        var pinnedPost = pinnedGroupPostsList.FirstOrDefault(p => p.Id == postId);
        if (pinnedPost != null)
        {
            pinnedPost.CommentCount = Math.Max(0, pinnedPost.CommentCount - decrementBy);
        }
    }

