    /// <summary>
    /// Loads the next page of pinned group posts for infinite scroll functionality.
    /// This method is invoked from JavaScript when the user scrolls near the bottom of the pinned posts tab.
    /// </summary>
    [JSInvokable]
    public async Task LoadMorePinnedGroupPostsAsync()
    {
        if (string.IsNullOrEmpty(currentUserId) || isLoadingMorePinnedPosts || hasMorePinnedPosts == false) return;

        isLoadingMorePinnedPosts = true;
        StateHasChanged();

        try
        {
            currentPinnedPage++;

            // Get all pinned posts as projections
            var allPinnedDtos = await PinnedGroupPostService.GetPinnedGroupPostsAsProjectionAsync(currentUserId);

            // Apply group filter if selected
            if (selectedPinnedGroupId.HasValue)
            {
                allPinnedDtos = allPinnedDtos.Where(p => p.GroupId == selectedPinnedGroupId.Value).ToList();
            }

            // Calculate pagination
            var skip = (currentPinnedPage - 1) * pinnedPageSize;
            var loadedDtos = allPinnedDtos.Skip(skip).Take(pinnedPageSize).ToList();

            if (loadedDtos.Any())
            {
                var newPosts = GroupPostViewModel.FromDtos(loadedDtos);
                pinnedGroupPostsList.AddRange(newPosts);
                hasMorePinnedPosts = allPinnedDtos.Count > (currentPinnedPage * pinnedPageSize);

                // Load additional data for new posts
                await LoadGroupPostDataAsync(newPosts);

                // Mark as pinned
                foreach (var post in newPosts)
                {
                    pinnedPosts[post.Id] = true;
                }
            }
            else
            {
                hasMorePinnedPosts = false;
            }
        }
        catch (Exception)
        {
            // Silently fail - pagination will stop
        }
        finally
        {
            isLoadingMorePinnedPosts = false;
            StateHasChanged();
        }
    }

