    /// <summary>
    /// Recursively searches for a comment in a hierarchical comment tree.
    /// </summary>
    /// <param name="comments">The list of comments to search.</param>
    /// <param name="commentId">The ID of the comment to find.</param>
    /// <returns>The found comment, or null if not found.</returns>
    private GroupPostComment? FindCommentInTree(List<GroupPostComment> comments, int commentId)
    {
        foreach (var comment in comments)
        {
            if (comment.Id == commentId)
            {
                return comment;
            }

            if (comment.Replies != null && comment.Replies.Any())
            {
                var found = FindCommentInTree(comment.Replies.ToList(), commentId);
                if (found != null)
                {
                    return found;
                }
            }
        }
        return null;
    }

