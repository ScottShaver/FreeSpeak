    private async Task JoinGroup(Group group)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            if (group.RequiresJoinApproval)
            {
                // Send join request
                var (success, errorMessage, request) = await GroupMemberService.CreateJoinRequestAsync(group.Id, currentUserId);

                if (success)
                {
                    AlertService.ShowSuccess("Join request sent successfully!");
                }
                else
                {
                    AlertService.ShowError(errorMessage ?? "Failed to send join request.");
                }
            }
            else
            {
                // Join immediately
                var (success, errorMessage) = await GroupMemberService.JoinGroupAsync(group.Id, currentUserId);

                if (success)
                {
                    AlertService.ShowSuccess($"You've joined {group.Name}!");
                    // Navigate to the group page with force reload to refresh nav menu
                    NavigationManager.NavigateTo($"/group/{group.Id}", forceLoad: true);
                }
                else
                {
                    AlertService.ShowError(errorMessage ?? "Failed to join group.");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error joining group: {ex.Message}");
            AlertService.ShowError("An error occurred while joining the group.");
        }
    }

