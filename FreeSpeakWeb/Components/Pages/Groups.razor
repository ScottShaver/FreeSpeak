    /// <summary>
    /// Loads the user's pinned group posts.
    /// Applies group filtering if a specific group is selected.
    /// </summary>
    private async Task LoadPinnedGroupPosts()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        isLoadingPinnedGroupPosts = true;
        StateHasChanged();

        try
        {
            currentPinnedPage = 1;

            // Get all pinned posts as projections
            var allPinnedDtos = await PinnedGroupPostService.GetPinnedGroupPostsAsProjectionAsync(currentUserId);

            // Apply group filter if selected
            if (selectedPinnedGroupId.HasValue)
            {
                allPinnedDtos = allPinnedDtos.Where(p => p.GroupId == selectedPinnedGroupId.Value).ToList();
            }

            // Take first page and convert to ViewModels
            pinnedGroupPostsList = GroupPostViewModel.FromDtos(allPinnedDtos.Take(pinnedPageSize));
            hasMorePinnedPosts = allPinnedDtos.Count > pinnedPageSize;

            // Load additional data for pinned posts (reactions, mute status)
            await LoadGroupPostDataAsync(pinnedGroupPostsList);

            // Mark as pinned
            foreach (var post in pinnedGroupPostsList)
            {
                pinnedPosts[post.Id] = true;
            }
        }
        catch (Exception)
        {
            // Silently fail - pinned feed will show empty
        }
        finally
        {
            isLoadingPinnedGroupPosts = false;
            StateHasChanged();
        }
    }

