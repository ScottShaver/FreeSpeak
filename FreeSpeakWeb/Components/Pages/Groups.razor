    /// <summary>
    /// Handles the user's request to join a group.
    /// If the group requires rules acceptance, shows the rules modal first.
    /// Otherwise, if the group requires approval, creates a join request; otherwise, joins the group immediately.
    /// </summary>
    /// <param name="group">The group to join.</param>
    private async Task JoinGroup(Group group)
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Check if group requires rules acceptance
        if (group.RequireAcceptRules)
        {
            selectedGroupForJoin = group;
            showRulesModal = true;
            StateHasChanged();
            return;
        }

        // Proceed with join without rules requirement
        await ProcessJoinGroup(group, hasAgreedToRules: false);
    }

