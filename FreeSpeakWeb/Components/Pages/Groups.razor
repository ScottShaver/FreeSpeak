@page "/groups"
@rendermode InteractiveServer
@attribute [Authorize]
@inherits PostPageBase<GroupPost, GroupPostComment>

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Options
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Pages.Base
@using System.Security.Claims
@using Microsoft.JSInterop

@implements IAsyncDisposable

@inject IOptions<SiteSettings> SiteSettings
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject GroupPostService GroupPostService
@inject PinnedGroupPostService PinnedGroupPostService
@inject GroupService GroupService
@inject GroupMemberService GroupMemberService
@inject UserManager<ApplicationUser> UserManager
@inject NavigationStateService NavigationState
@inject UserPreferenceService UserPreferenceService
@inject HtmlSanitizationService HtmlSanitizationService
@inject AlertService AlertService

<PageTitle>@SiteSettings.Value.SiteName - Groups</PageTitle>

<div class="home-container">
    <!-- Tabbed Interface -->
    <ul class="nav nav-tabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="group-feed-tab" data-bs-toggle="tab" data-bs-target="#group-feed-content" type="button" role="tab" aria-controls="group-feed-content" aria-selected="true" @onclick="OnGroupFeedTabClick">
                    My Group Feed
                </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pinned-group-tab" data-bs-toggle="tab" data-bs-target="#pinned-group-content" type="button" role="tab" aria-controls="pinned-group-content" aria-selected="false" @onclick="OnPinnedTabClick">
                Pinned Group Posts
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="join-requests-tab" data-bs-toggle="tab" data-bs-target="#join-requests-content" type="button" role="tab" aria-controls="join-requests-content" aria-selected="false" @onclick="OnJoinRequestsTabClick">
                Group Join Requests
                @if (groupJoinRequests.Count > 0)
                {
                    <span class="badge bg-warning ms-1">@groupJoinRequests.Count</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="find-groups-tab" data-bs-toggle="tab" data-bs-target="#find-groups-content" type="button" role="tab" aria-controls="find-groups-content" aria-selected="false">
                Find Groups
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="suggested-groups-tab" data-bs-toggle="tab" data-bs-target="#suggested-groups-content" type="button" role="tab" aria-controls="suggested-groups-content" aria-selected="false" @onclick="OnSuggestedGroupsTabClick">
                Groups You Might Like
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- My Group Feed Tab -->
        <div class="tab-pane fade show active" id="group-feed-content" role="tabpanel" aria-labelledby="group-feed-tab">
            <div class="feed-section">
                <!-- Group Filter Dropdown -->
                <div class="group-filter-section">
                    <label for="groupFilter" class="form-label">Show posts from:</label>
                    <select id="groupFilter" class="form-select" @onchange="OnGroupFilterChanged">
                        <option value="">All Groups</option>
                        @foreach (var group in userGroups)
                        {
                            <option value="@group.Id" selected="@(selectedGroupId == group.Id)">@group.Name</option>
                        }
                    </select>
                </div>

                @if (isLoadingGroupFeed && !groupPosts.Any())
                {
                    <div class="loading-indicator">
                        <p>Loading your group feed...</p>
                    </div>
                }
                else if (!groupPosts.Any() && !isLoadingGroupFeed)
                {
                    <div class="empty-feed">
                        <p>No group posts to display. Join groups to see their posts here!</p>
                    </div>
                }
                else
                {
                    @foreach (var post in groupPosts)
                    {
                        var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                        var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                        var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                        var authorName = postAuthorNames.ContainsKey(post.Id) ? postAuthorNames[post.Id] : "Unknown";
                        var groupName = groupNames.ContainsKey(post.GroupId) ? groupNames[post.GroupId] : "Unknown Group";
                        var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;
                        var isMuted = postMuteStatus.ContainsKey(post.Id) ? postMuteStatus[post.Id] : (bool?)null;

                        <GroupPostArticle 
                            PostId="@post.Id"
                            GroupId="@post.GroupId"
                            GroupName="@groupName"
                            AuthorId="@post.AuthorId"
                            AuthorName="@authorName"
                            AuthorImageUrl="@post.Author?.ProfilePictureUrl"
                            CreatedAt="@post.CreatedAt"
                            LikeCount="@post.LikeCount"
                            CommentCount="@post.CommentCount"
                            ShareCount="@post.ShareCount"
                            LoadCommentsInternally="true"
                            CommentsToShow="3"
                            RefreshTrigger="@refreshTrigger"
                            CurrentUserId="@currentUserId"
                            CurrentUserImageUrl="@currentUserImageUrl"
                            CurrentUserName="@currentUserName"
                            ReactionBreakdown="@postReactions"
                            UserReaction="@userReaction"
                            IsPinned="@isPinned"
                            IsMuted="@isMuted"
                            Images="@ConvertGroupPostImagesToPostImages(post.Images)"
                            OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(post.Id, reactionType))"
                            OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(post.Id))"
                            OnPinPost="@HandlePinGroupPost"
                            OnUnpinPost="@HandleUnpinGroupPost"
                            OnPostDeleted="@HandleGroupPostDeleted"
                            OnEditPost="@HandleEditGroupPost"
                            OnCommentAdded="@HandleGroupPostCommentAdded"
                            OnReplySubmitted="@HandleGroupPostReplySubmitted"
                            OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
                            OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
                            OnShowPostDetail="@(() => ShowGroupPostDetail(post))"
                            OnShowComments="@(() => ShowGroupPostDetail(post))">
                            <ArticleContent>
                                @((MarkupString)FormatContentWithLineBreaks(post.Content))
                            </ArticleContent>
                        </GroupPostArticle>
                    }

                    @if (isLoadingMoreGroupPosts)
                    {
                        <div class="loading-more">
                            <p>Loading more posts...</p>
                        </div>
                    }

                    @if (hasMoreGroupPosts == false && groupPosts.Any())
                    {
                        <div class="no-more-posts">
                            <p>No more posts at this time</p>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Pinned Group Posts Tab -->
        <div class="tab-pane fade" id="pinned-group-content" role="tabpanel" aria-labelledby="pinned-group-tab">
            <div class="feed-section">
                <!-- Group Filter Dropdown for Pinned Posts -->
                <div class="group-filter-section">
                    <label for="pinnedGroupFilter" class="form-label">Show pinned posts from:</label>
                    <select id="pinnedGroupFilter" class="form-select" @onchange="OnPinnedGroupFilterChanged">
                        <option value="">All Groups</option>
                        @foreach (var group in userGroups)
                        {
                            <option value="@group.Id" selected="@(selectedPinnedGroupId == group.Id)">@group.Name</option>
                        }
                    </select>
                </div>

                @if (isLoadingPinnedGroupPosts && !pinnedGroupPostsList.Any())
                {
                    <div class="loading-indicator">
                        <p>Loading your pinned group posts...</p>
                    </div>
                }
                else if (!pinnedGroupPostsList.Any() && !isLoadingPinnedGroupPosts)
                {
                    <div class="empty-feed">
                        <p>You haven't pinned any group posts yet. Pin posts from groups to see them here!</p>
                    </div>
                }
                else
                {
                    @foreach (var post in pinnedGroupPostsList)
                    {
                        var postReactions = postReactionData.ContainsKey(post.Id) ? postReactionData[post.Id] : new Dictionary<LikeType, int>();
                        var userReaction = postUserReactions.ContainsKey(post.Id) ? postUserReactions[post.Id] : null;
                        var isPinned = pinnedPosts.ContainsKey(post.Id) && pinnedPosts[post.Id];
                        var authorName = postAuthorNames.ContainsKey(post.Id) ? postAuthorNames[post.Id] : "Unknown";
                        var groupName = groupNames.ContainsKey(post.GroupId) ? groupNames[post.GroupId] : "Unknown Group";
                        var refreshTrigger = postRefreshTriggers.ContainsKey(post.Id) ? postRefreshTriggers[post.Id] : 0;
                        var isMuted = postMuteStatus.ContainsKey(post.Id) ? postMuteStatus[post.Id] : (bool?)null;

                        <GroupPostArticle 
                            PostId="@post.Id"
                            GroupId="@post.GroupId"
                            GroupName="@groupName"
                            AuthorId="@post.AuthorId"
                            AuthorName="@authorName"
                            AuthorImageUrl="@post.Author?.ProfilePictureUrl"
                            CreatedAt="@post.CreatedAt"
                            LikeCount="@post.LikeCount"
                            CommentCount="@post.CommentCount"
                            ShareCount="@post.ShareCount"
                            LoadCommentsInternally="true"
                            CommentsToShow="3"
                            RefreshTrigger="@refreshTrigger"
                            CurrentUserId="@currentUserId"
                            CurrentUserImageUrl="@currentUserImageUrl"
                            CurrentUserName="@currentUserName"
                            ReactionBreakdown="@postReactions"
                            UserReaction="@userReaction"
                            IsPinned="@isPinned"
                            IsMuted="@isMuted"
                            Images="@ConvertGroupPostImagesToPostImages(post.Images)"
                            OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(post.Id, reactionType))"
                            OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(post.Id))"
                            OnPinPost="@HandlePinGroupPost"
                            OnUnpinPost="@HandleUnpinGroupPost"
                            OnPostDeleted="@HandleGroupPostDeleted"
                            OnEditPost="@HandleEditGroupPost"
                            OnCommentAdded="@HandleGroupPostCommentAdded"
                            OnReplySubmitted="@HandleGroupPostReplySubmitted"
                            OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
                            OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
                            OnShowPostDetail="@(() => ShowGroupPostDetail(post))"
                            OnShowComments="@(() => ShowGroupPostDetail(post))">
                            <ArticleContent>
                                @((MarkupString)FormatContentWithLineBreaks(post.Content))
                            </ArticleContent>
                        </GroupPostArticle>
                    }

                    @if (isLoadingMorePinnedPosts)
                    {
                        <div class="loading-more">
                            <p>Loading more posts...</p>
                        </div>
                    }

                    @if (hasMorePinnedPosts == false && pinnedGroupPostsList.Any())
                    {
                        <div class="no-more-posts">
                            <p>No more pinned posts at this time</p>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Group Join Requests Tab -->
        <div class="tab-pane fade" id="join-requests-content" role="tabpanel" aria-labelledby="join-requests-tab">
            <div class="feed-section">
                @if (isLoadingJoinRequests && !groupJoinRequests.Any())
                {
                    <div class="loading-indicator">
                        <p>Loading your join requests...</p>
                    </div>
                }
                else if (!groupJoinRequests.Any() && !isLoadingJoinRequests)
                {
                    <div class="empty-feed">
                        <p>You have no pending group join requests.</p>
                    </div>
                }
                else
                {
                    <div class="join-requests-list">
                        @foreach (var request in groupJoinRequests)
                        {
                            var groupName = groupNames.ContainsKey(request.GroupId) ? groupNames[request.GroupId] : "Unknown Group";
                            <div class="join-request-card">
                                <div class="request-info">
                                    <strong>@groupName</strong>
                                    <span class="request-date">Requested @GetRelativeTime(request.RequestedAt)</span>
                                </div>
                                <button type="button" class="btn btn-sm btn-danger" @onclick="() => CancelJoinRequest(request.Id)">
                                    Cancel Request
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Find Groups Tab -->
        <div class="tab-pane fade" id="find-groups-content" role="tabpanel" aria-labelledby="find-groups-tab">
            <div class="feed-section">
                <div class="search-section">
                    <input type="text" 
                           class="form-control" 
                           placeholder="Search for groups..." 
                           @bind="groupSearchQuery" 
                           @bind:event="oninput" 
                           @onkeyup="OnGroupSearchKeyUp" />
                </div>

                @if (isSearchingGroups)
                {
                    <div class="loading-indicator">
                        <p>Searching groups...</p>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(groupSearchQuery) && !searchedGroups.Any())
                {
                    <div class="empty-feed">
                        <p>No groups found matching "@groupSearchQuery"</p>
                    </div>
                }
                else if (searchedGroups.Any())
                {
                    <div class="groups-list">
                        @foreach (var group in searchedGroups)
                        {
                            <div class="group-card">
                                <div class="group-info">
                                    <h4>@group.Name</h4>
                                    <p>@group.Description</p>
                                    <div class="group-meta">
                                        <span><i class="bi bi-people-fill"></i> @group.MemberCount members</span>
                                        @if (group.IsPublic)
                                        {
                                            <span class="badge bg-success">Public</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Private</span>
                                        }
                                    </div>
                                </div>
                                <div class="group-actions">
                                    <button type="button" class="btn btn-primary" @onclick="() => JoinGroup(group)">
                                        @(group.RequiresJoinApproval ? "Request to Join" : "Join Now")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-feed">
                        <p>Search for groups to join!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Groups You Might Like Tab -->
        <div class="tab-pane fade" id="suggested-groups-content" role="tabpanel" aria-labelledby="suggested-groups-tab">
            <div class="feed-section">
                @if (isLoadingSuggestedGroups && !suggestedGroups.Any())
                {
                    <div class="loading-indicator">
                        <p>Loading group suggestions...</p>
                    </div>
                }
                else if (!suggestedGroups.Any() && !isLoadingSuggestedGroups)
                {
                    <div class="empty-feed">
                        <p>No group suggestions available at this time.</p>
                    </div>
                }
                else
                {
                    <div class="groups-list">
                        @foreach (var group in suggestedGroups)
                        {
                            <div class="group-card">
                                <div class="group-info">
                                    <h4>@group.Name</h4>
                                    <p>@group.Description</p>
                                    <div class="group-meta">
                                        <span><i class="bi bi-people-fill"></i> @group.MemberCount members</span>
                                        @if (group.IsPublic)
                                        {
                                            <span class="badge bg-success">Public</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Private</span>
                                        }
                                    </div>
                                </div>
                                <div class="group-actions">
                                    <button type="button" class="btn btn-primary" @onclick="() => JoinGroup(group)">
                                        @(group.RequiresJoinApproval ? "Request to Join" : "Join Now")
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (showGroupPostDetailModal && selectedGroupPost != null)
{
    var postReactions = postReactionData.ContainsKey(selectedGroupPost.Id) ? postReactionData[selectedGroupPost.Id] : new Dictionary<LikeType, int>();
    var userReaction = postUserReactions.ContainsKey(selectedGroupPost.Id) ? postUserReactions[selectedGroupPost.Id] : null;
    var isPinned = pinnedPosts.ContainsKey(selectedGroupPost.Id) && pinnedPosts[selectedGroupPost.Id];
    var authorName = postAuthorNames.ContainsKey(selectedGroupPost.Id) ? postAuthorNames[selectedGroupPost.Id] : "Unknown";
    var groupName = groupNames.ContainsKey(selectedGroupPost.GroupId) ? groupNames[selectedGroupPost.GroupId] : "Unknown Group";

    <GroupPostDetailModal 
        PostId="@selectedGroupPost.Id"
        GroupId="@selectedGroupPost.GroupId"
        GroupName="@groupName"
        AuthorId="@selectedGroupPost.AuthorId"
        AuthorName="@authorName"
        AuthorImageUrl="@selectedGroupPost.Author?.ProfilePictureUrl"
        CurrentUserId="@currentUserId"
        CreatedAt="@selectedGroupPost.CreatedAt"
        LikeCount="@selectedGroupPost.LikeCount"
        CommentCount="@selectedGroupPost.CommentCount"
        ShareCount="@selectedGroupPost.ShareCount"
        CurrentUserImageUrl="@currentUserImageUrl"
        CurrentUserName="@currentUserName"
        ReactionBreakdown="@postReactions"
        UserReaction="@userReaction"
        IsPinned="@isPinned"
        Images="@ConvertGroupPostImagesToPostImages(selectedGroupPost.Images)"
        OnReactionChanged="@(async (reactionType) => await HandleGroupPostReactionChanged(selectedGroupPost.Id, reactionType))"
        OnRemoveReaction="@(async () => await HandleRemoveGroupPostReaction(selectedGroupPost.Id))"
        OnPinPost="@HandlePinGroupPost"
        OnUnpinPost="@HandleUnpinGroupPost"
        OnPostDeleted="@HandleGroupPostDeleted"
        OnEditPost="@HandleEditGroupPost"
        OnCommentAdded="@HandleGroupPostCommentAdded"
        OnReplySubmitted="@HandleGroupPostReplySubmitted"
        OnCommentReactionChanged="@HandleGroupPostCommentReactionChanged"
        OnRemoveCommentReaction="@HandleRemoveGroupPostCommentReaction"
        OnClose="@CloseGroupPostDetailModal">
        <ArticleContent>
            @((MarkupString)FormatContentWithLineBreaks(selectedGroupPost.Content))
        </ArticleContent>
    </GroupPostDetailModal>
}

@code {
    private string? currentUserId;
    private string? currentUserImageUrl;
    private string? currentUserName;

    // Group Feed state
    private List<GroupPost> groupPosts = new();
    private bool isLoadingGroupFeed = false;
    private bool isLoadingMoreGroupPosts = false;
    private bool? hasMoreGroupPosts = null;
    private int currentGroupPage = 1;
    private const int groupPageSize = 20;

    // Group filter state
    private int? selectedGroupId = null; // null means "All Groups"
    private List<Group> userGroups = new();

    // Pinned posts state
    private int? selectedPinnedGroupId = null;
    private bool isLoadingMorePinnedPosts = false;
    private bool? hasMorePinnedPosts = null;
    private int currentPinnedPage = 1;
    private const int pinnedPageSize = 20;

    // JavaScript interop
    private IJSObjectReference? jsModule;
    private DotNetObjectReference<Groups>? dotNetHelper;

    // Pinned Group Posts state
    private List<GroupPost> pinnedGroupPostsList = new();
    private bool isLoadingPinnedGroupPosts = false;

    // Group Join Requests state
    private List<GroupJoinRequest> groupJoinRequests = new();
    private bool isLoadingJoinRequests = false;

    // Find Groups state
    private string groupSearchQuery = string.Empty;
    private List<Group> searchedGroups = new();
    private bool isSearchingGroups = false;
    private System.Threading.Timer? searchDebounceTimer;

    // Suggested Groups state
    private List<Group> suggestedGroups = new();
    private bool isLoadingSuggestedGroups = false;

    // Group-specific data dictionaries (rename to use base class naming)
    // Base class provides: postRefreshTriggers, postReactionData, postUserReactions, pinnedPosts, postAuthorNames
    private Dictionary<int, string> groupNames = new();
    private Dictionary<int, bool> postMuteStatus = new();

    // Guard flag to prevent double-loading on initial navigation
    private bool hasCompletedInitialLoad = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(currentUserId))
            {
                var appUser = await UserManager.FindByIdAsync(currentUserId);
                if (appUser != null)
                {
                    currentUserImageUrl = appUser.ProfilePictureUrl;
                    currentUserName = $"{appUser.FirstName} {appUser.LastName}";
                }

                // Load user's groups for the filter dropdown
                await LoadUserGroups();

                // Load initial group feed
                await LoadGroupFeed();

                // Load join requests count for badge
                await LoadJoinRequestsCount();

                // Mark initial load as complete to allow tab refresh on subsequent clicks
                hasCompletedInitialLoad = true;
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(currentUserId))
        {
            try
            {
                jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Groups.razor.js");
                dotNetHelper = DotNetObjectReference.Create(this);
                await jsModule.InvokeVoidAsync("initializeInfiniteScroll", (object?)null, dotNetHelper);
            }
            catch (Exception ex)
            {
                // Silently fail - infinite scroll not critical
            }
        }
    }

    private async Task LoadUserGroups()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        try
        {
            // Load all posts to extract unique groups
            var allPosts = await GroupPostService.GetAllGroupPostsForUserAsync(currentUserId, 0, 1000);

            // Extract unique groups from posts
            var uniqueGroups = allPosts
                .Where(p => p.Group != null)
                .GroupBy(p => p.GroupId)
                .Select(g => g.First().Group!)
                .OrderBy(g => g.Name)
                .ToList();

            userGroups = uniqueGroups;
        }
        catch (Exception ex)
        {
            // Silently fail - user groups list optional
        }
    }

    /// <summary>
    /// Loads the group feed posts for the current user.
    /// Includes a guard to prevent concurrent loading operations.
    /// </summary>
    private async Task LoadGroupFeed()
    {
        if (string.IsNullOrEmpty(currentUserId)) return;

        // Prevent concurrent loading operations
        if (isLoadingGroupFeed) return;

        isLoadingGroupFeed = true;
        StateHasChanged();

        try
        {
            currentGroupPage = 1;
            List<GroupPost> loadedPosts;

            if (selectedGroupId.HasValue)
            {
                // Load posts from specific group
                loadedPosts = await GroupPostService.GetGroupPostsAsync(selectedGroupId.Value, 0, groupPageSize);
            }
            else
            {
                // Load posts from all user's groups
                loadedPosts = await GroupPostService.GetAllGroupPostsForUserAsync(currentUserId, 0, groupPageSize);
            }

            groupPosts = loadedPosts;
            hasMoreGroupPosts = loadedPosts.Count >= groupPageSize;

            // Load additional data for posts
            await LoadGroupPostDataAsync(loadedPosts);
        }
        catch (Exception ex)
        {
            // Silently fail - feed will show empty
        }
        finally
        {
            isLoadingGroupFeed = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task LoadMoreGroupPostsAsync()
    {
        if (string.IsNullOrEmpty(currentUserId) || isLoadingMoreGroupPosts || hasMoreGroupPosts == false) return;

        isLoadingMoreGroupPosts = true;
        StateHasChanged();

        try
        {
            currentGroupPage++;
            var skip = (currentGroupPage - 1) * groupPageSize;
            List<GroupPost> loadedPosts;

            if (selectedGroupId.HasValue)
            {
                // Load more posts from specific group
                loadedPosts = await GroupPostService.GetGroupPostsAsync(selectedGroupId.Value, skip, groupPageSize);
            }
            else
            {
                // Load more posts from all user's groups
                loadedPosts = await GroupPostService.GetAllGroupPostsForUserAsync(currentUserId, skip, groupPageSize);
            }

            if (loadedPosts.Any())
            {
                groupPosts.AddRange(loadedPosts);
                hasMoreGroupPosts = loadedPosts.Count >= groupPageSize;

                // Load additional data for new posts
                await LoadGroupPostDataAsync(loadedPosts);
            }
            else
            {
                hasMoreGroupPosts = false;
            }
        }
        catch (Exception ex)
        {
            // Silently fail - pagination will stop
        }
        finally
        {
            isLoadingMoreGroupPosts = false;
            StateHasChanged();
        }
    }

    private async Task LoadGroupPostDataAsync(List<GroupPost> posts)
    {
        if (!posts.Any()) return;

        // Populate group names and author names
        foreach (var post in posts)
        {
            if (!groupNames.ContainsKey(post.GroupId) && post.Group != null)
            {
                groupNames[post.GroupId] = post.Group.Name;
            }

            if (!postAuthorNames.ContainsKey(post.Id) && post.Author != null)
            {
                postAuthorNames[post.Id] = $"{post.Author.FirstName} {post.Author.LastName}";
            }
        }

        // Get post IDs that need reaction data loaded
        var postIdsNeedingReactions = posts
            .Where(p => !postReactionData.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingReactions.Any())
        {
            // Load reaction data for all posts in a single query
            var reactions = await GroupPostService.GetReactionBreakdownForPostsAsync(postIdsNeedingReactions);
            foreach (var kvp in reactions)
            {
                postReactionData[kvp.Key] = kvp.Value;
            }
        }

        // Get post IDs that need user reactions loaded
        var postIdsNeedingUserReactions = posts
            .Where(p => !postUserReactions.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingUserReactions.Any() && currentUserId != null)
        {
            // Load user reactions for all posts in a single query
            var userReactions = await GroupPostService.GetUserReactionsForPostsAsync(postIdsNeedingUserReactions, currentUserId);
            foreach (var kvp in userReactions)
            {
                postUserReactions[kvp.Key] = kvp.Value;
            }
        }

        // Load pinned status (still per-post, could be optimized separately)
        foreach (var post in posts)
        {
            if (!pinnedPosts.ContainsKey(post.Id) && currentUserId != null)
            {
                var isPinned = await PinnedGroupPostService.IsGroupPostPinnedAsync(currentUserId, post.Id);
                pinnedPosts[post.Id] = isPinned;
            }
        }

        // Load mute status in batch to avoid N+1 queries
        var postIdsNeedingMuteStatus = posts
            .Where(p => !postMuteStatus.ContainsKey(p.Id))
            .Select(p => p.Id)
            .ToList();

        if (postIdsNeedingMuteStatus.Any() && currentUserId != null)
        {
            var muteStatus = await GroupPostService.GetMuteStatusForPostsAsync(postIdsNeedingMuteStatus, currentUserId);
            foreach (var kvp in muteStatus)
            {
                postMuteStatus[kvp.Key] = kvp.Value;
            }
        }
    }

