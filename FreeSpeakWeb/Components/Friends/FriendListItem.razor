@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Components.Friends
@using FreeSpeakWeb.Components.Shared
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop

@implements IDisposable

@inject FriendsService FriendsService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<FreeSpeakWeb.Resources.Friends.FriendListItem> Localizer

<div class="friend-list-item text-center" @ref="containerElement">
    @if (!string.IsNullOrEmpty(User.ProfilePictureUrl))
    {
        <img src="@User.ProfilePictureUrl" 
             alt="@GetDisplayName()" 
             class="rounded-circle mb-2 profile-image-clickable friend-profile-image" 
             id="@profileImageId"
             @ref="profileImageElement"
             @onclick="HandleProfileClick"
             @onmouseenter="HandleMouseEnter"
             @onmouseleave="HandleMouseLeave" />
    }
    else
    {
        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-2 profile-image-clickable friend-profile-image" 
             id="@profileImageId"
             @ref="profileImageElement"
             @onclick="HandleProfileClick"
             @onmouseenter="HandleMouseEnter"
             @onmouseleave="HandleMouseLeave">
            <span class="text-white friend-profile-initial">@GetInitials(GetDisplayName())</span>
        </div>
    }

    <h5 class="mb-1 friend-name">@GetDisplayName()</h5>

    @if (MutualFriendsCount > 0)
    {
        <p class="text-muted mb-2 friend-mutual-text">
            <button class="btn btn-link p-0 text-muted friend-mutual-btn" @onclick="ShowMutualFriends" style="text-decoration: none;">
                <i class="bi bi-people-fill"></i> @MutualFriendsCount @(MutualFriendsCount == 1 ? Localizer["MutualFriend"] : Localizer["MutualFriends"])
            </button>
        </p>
    }

    <div class="d-flex flex-column gap-1 gap-md-2">
        @if (ShowAccept)
        {
            <ActionButton Text="@Localizer["Accept"]"
                          Variant="success"
                          Size="sm"
                          IsLoading="@(IsProcessing && actionType == "accept")"
                          Disabled="@IsProcessing"
                          OnClick="@HandleAccept"
                          CssClass="friend-action-btn"
                          FullWidth="true" />
        }

        @if (ShowReject)
        {
            <ActionButton Text="@Localizer["Decline"]"
                          Variant="danger"
                          Outline="true"
                          Size="sm"
                          IsLoading="@(IsProcessing && actionType == "reject")"
                          Disabled="@IsProcessing"
                          OnClick="@HandleReject"
                          CssClass="friend-action-btn"
                          FullWidth="true" />
        }

        @if (ShowAddFriend)
        {
            <ActionButton Text="@Localizer["AddFriend"]"
                          Variant="primary"
                          Size="sm"
                          IsLoading="@(IsProcessing && actionType == "add")"
                          Disabled="@IsProcessing"
                          OnClick="@HandleAddFriend"
                          CssClass="friend-action-btn"
                          FullWidth="true" />
        }

        @if (ShowCancel)
        {
            <ActionButton Text="@Localizer["CancelRequest"]"
                          Variant="warning"
                          Outline="true"
                          Size="sm"
                          IsLoading="@(IsProcessing && actionType == "cancel")"
                          Disabled="@IsProcessing"
                          OnClick="@HandleCancel"
                          CssClass="friend-action-btn"
                          FullWidth="true" />
        }

        @if (ShowRemove)
        {
            <ActionButton Text="@Localizer["Remove"]"
                          Variant="secondary"
                          Outline="true"
                          Size="sm"
                          IsLoading="@(IsProcessing && actionType == "remove")"
                          Disabled="@IsProcessing"
                          OnClick="@HandleRemove"
                          CssClass="friend-action-btn"
                          FullWidth="true" />
        }
    </div>
</div>

