        line-height: 1;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .friend-mutual-text {
        font-size: 0.55rem !important;
        line-height: 1.1;
    }

    .friend-mutual-btn {
        font-size: 0.55rem !important;
        line-height: 1.1;
    }

    .friend-action-btn {
        font-size: 0.6rem !important;
        padding: 0.1rem 0.2rem !important;
        width: 100%;
        white-space: normal;
        line-height: 1.1;
    }

    /* Tablet and up */
    @@media (min-width: 768px) {
        .friend-list-item {
            max-width: 100% !important;
        }

        .friend-profile-image {
            width: 120px !important;
            height: 120px !important;
            min-width: 120px !important;
            min-height: 120px !important;
        }

        .friend-profile-image img {
            width: 120px !important;
            height: 120px !important;
        }

        .friend-profile-initial {
            font-size: 2.5rem !important;
        }

        .friend-name {
            font-size: 1.1rem !important;
        }

        .friend-mutual-text {
            font-size: 0.875rem !important;
        }

        .friend-mutual-btn {
            font-size: 0.875rem !important;
        }

        .friend-action-btn {
            font-size: 0.875rem !important;
            padding: 0.375rem 0.75rem !important;
        }
    }

    /* Desktop and up */
    @@media (min-width: 992px) {
        .friend-profile-image {
            width: 168px !important;
            height: 168px !important;
            min-width: 168px !important;
            min-height: 168px !important;
        }

        .friend-profile-image img {
            width: 168px !important;
            height: 168px !important;
        }

        .friend-profile-initial {
            font-size: 3rem !important;
        }

        .friend-name {
            font-size: 1.25rem !important;
        }

        .friend-mutual-text {
            font-size: 0.875rem !important;
        }

        .friend-mutual-btn {
            font-size: 0.875rem !important;
        }

        .friend-action-btn {
            font-size: 1rem !important;
            padding: 0.5rem 1rem !important;
        }
    }
</style>

<!-- Mutual Friends Modal -->
<BaseModal IsVisible="@showMutualFriendsModal" 
           Title="@MutualFriendsModalTitle" 
           OnClose="@CloseMutualFriends"
           Size="md"
           Scrollable="true">
    <ChildContent>
        @if (isLoadingMutualFriends)
        {
            <LoadingSpinner Size="md" />
        }
        else if (mutualFriends.Count == 0)
        {
            <EmptyState Message="No mutual friends found." Icon="bi-people" />
        }
        else
        {
            <div class="list-group">
                @foreach (var friend in mutualFriends)
                {
                    <div class="list-group-item">
                        <div class="d-flex align-items-center gap-3">
                            <UserAvatar ImageUrl="@friend.ProfilePictureUrl" 
                                        Name="@GetFriendDisplayName(friend)" 
                                        Size="md" />
                            <div class="flex-grow-1">
                                <h6 class="mb-0">@GetFriendDisplayName(friend)</h6>
                                @if (!string.IsNullOrEmpty(friend.City) && !string.IsNullOrEmpty(friend.State))
                                {
                                    <small class="text-muted">@friend.City, @friend.State</small>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button type="button" class="btn btn-secondary" @onclick="CloseMutualFriends">Close</button>
    </FooterContent>
</BaseModal>

<!-- Profile Preview Popup (hover-triggered) -->
<ProfilePreviewPopup 
    User="@User"
    IsVisible="@showProfilePreviewPopup"
    MutualFriendsCount="@MutualFriendsCount"
    PositionX="@popupPositionX"
    PositionY="@popupPositionY"
    OnMouseEnter="@HandlePopupMouseEnter"
    OnMouseLeave="@HandlePopupMouseLeave" />

@code {
    [Parameter, EditorRequired]
    public ApplicationUser User { get; set; } = default!;

    [Parameter]
    public int MutualFriendsCount { get; set; }

    [Parameter]
    public bool ShowAddFriend { get; set; }

    [Parameter]
    public bool ShowAccept { get; set; }

    [Parameter]
    public bool ShowReject { get; set; }

    [Parameter]
    public bool ShowCancel { get; set; }

    [Parameter]
    public bool ShowRemove { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnAddFriend { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnAccept { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnReject { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnCancel { get; set; }

    [Parameter]
    public EventCallback<ApplicationUser> OnRemove { get; set; }

    /// <summary>
    /// Optional event callback for custom navigation handling.
    /// If set, this will be invoked when the profile is clicked.
    /// If not set, the component will navigate directly to /friend/{userId}.
    /// </summary>
    [Parameter]
    public EventCallback<ApplicationUser> OnNavigateToProfile { get; set; }

    /// <summary>
    /// Controls whether clicking on the profile navigates to the friend's page.
    /// When true (default), clicking navigates to /friend/{userId}.
    /// When false, shows the profile preview modal instead.
    /// </summary>
    [Parameter]
    public bool EnableProfileNavigation { get; set; } = false;

    /// <summary>
    /// Controls whether the hover preview popup is enabled.
    /// When true, hovering over the profile image for 1 second shows a preview popup.
    /// </summary>
    [Parameter]
    public bool EnableHoverPreview { get; set; } = true;

    private bool IsProcessing { get; set; }
    private string actionType = "";
    private bool showMutualFriendsModal = false;
    private bool isLoadingMutualFriends = false;
    private List<ApplicationUser> mutualFriends = new();

    // Hover preview popup state
    private bool showProfilePreviewPopup = false;
    private double popupPositionX = 0;
    private double popupPositionY = 0;
    private System.Threading.Timer? hoverTimer;
    private bool isMouseOverProfile = false;
    private bool isMouseOverPopup = false;
    private ElementReference containerElement;
    private ElementReference profileImageElement;
    private string profileImageId = $"profile-img-{Guid.NewGuid():N}";

    // Hover delay in milliseconds (1 second)
    private const int HoverDelayMs = 1000;

    private string MutualFriendsModalTitle => $"Mutual Friends with {GetDisplayName()}";

    private string GetDisplayName()
    {
        if (!string.IsNullOrEmpty(User.FirstName) && !string.IsNullOrEmpty(User.LastName))
        {
            return $"{User.FirstName} {User.LastName}";
        }
        return User.UserName ?? "Unknown";
    }

    private string GetFriendDisplayName(ApplicationUser user)
    {
        if (!string.IsNullOrEmpty(user.FirstName) && !string.IsNullOrEmpty(user.LastName))
        {
            return $"{user.FirstName} {user.LastName}";
        }
        return user.UserName ?? "Unknown";
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
            return "U";

        if (parts.Length == 1)
        {
            // For single word (username), try to get first 2 characters
            var singleWord = parts[0];
            if (singleWord.Length >= 2)
                return singleWord.Substring(0, 2).ToUpper();
            else
                return singleWord.Substring(0, 1).ToUpper();
        }

        // Return first letter of first name + first letter of last name
        return $"{parts[0].Substring(0, 1)}{parts[^1].Substring(0, 1)}".ToUpper();
    }

    private async Task ShowMutualFriends()
    {
        if (MutualFriendsCount == 0) return;

        showMutualFriendsModal = true;
        isLoadingMutualFriends = true;
        StateHasChanged();

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            if (!string.IsNullOrEmpty(currentUserId))
            {
                mutualFriends = await FriendsService.GetMutualFriendsAsync(currentUserId, User.Id);
            }
        }
        catch (Exception)
        {
            mutualFriends = new List<ApplicationUser>();
        }
        finally
        {
            isLoadingMutualFriends = false;
            StateHasChanged();
        }
    }

    private void CloseMutualFriends()
    {
        showMutualFriendsModal = false;
        mutualFriends.Clear();
    }

    /// <summary>
    /// Handles the profile click. If EnableProfileNavigation is true,
    /// navigates to the friend's profile page.
    /// </summary>
    private async Task HandleProfileClick()
    {
        // Cancel any pending hover timer
        CancelHoverTimer();
        HidePopup();

        // If profile navigation is enabled, navigate to friend's page
        if (EnableProfileNavigation)
        {
            // If a custom navigation handler is provided, invoke it
            if (OnNavigateToProfile.HasDelegate)
            {
                await OnNavigateToProfile.InvokeAsync(User);
            }
            else
            {
                // Navigate to friend's profile page
                NavigationManager.NavigateTo($"/friend/{User.Id}");
            }
        }
    }

    /// <summary>
    /// Handles mouse entering the profile image area.
    /// Starts a timer to show the popup after the hover delay.
    /// </summary>
    private async Task HandleMouseEnter()
    {
        if (!EnableHoverPreview) return;

        isMouseOverProfile = true;

        // Cancel any existing timer
        CancelHoverTimer();

        // Calculate popup position
        await CalculatePopupPosition();

        // Start a new timer to show popup after delay
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (isMouseOverProfile)
                {
                    showProfilePreviewPopup = true;
                    StateHasChanged();
                }
            }),
            state: null,
            dueTime: HoverDelayMs,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse leaving the profile image area.
    /// Hides the popup after a short delay if mouse is not over the popup.
    /// </summary>
    private void HandleMouseLeave()
    {
        isMouseOverProfile = false;
        CancelHoverTimer();

        // Use a short delay to allow mouse to move to popup
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverProfile && !isMouseOverPopup)
                {
                    HidePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse entering the popup (keeps it visible).
    /// </summary>
    private void HandlePopupMouseEnter()
    {
        isMouseOverPopup = true;
        CancelHoverTimer();
    }

    /// <summary>
    /// Handles mouse leaving the popup.
    /// </summary>
    private void HandlePopupMouseLeave()
    {
        isMouseOverPopup = false;

        // Use a short delay before hiding
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverProfile && !isMouseOverPopup)
                {
                    HidePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Calculates the position for the popup based on the profile image location.
    /// </summary>
    private async Task CalculatePopupPosition()
    {
        try
        {
            var rect = await JSRuntime.InvokeAsync<BoundingClientRect>(
                "eval",
                $"(function() {{ var el = document.getElementById('{profileImageId}'); if (el) {{ var r = el.getBoundingClientRect(); return {{ left: r.left, top: r.top, width: r.width, height: r.height }}; }} return null; }})()"
            );

            if (rect != null)
            {
                // Position popup below the profile image, centered horizontally
                popupPositionX = rect.Left + (rect.Width / 2) - 140; // 140 = half of min popup width (280)
                popupPositionY = rect.Top + rect.Height + 10;

                // Ensure popup doesn't go off-screen on the left
                if (popupPositionX < 10) popupPositionX = 10;

                // Check if popup would go off-screen on the right (assuming 280px min width)
                var viewportWidth = await JSRuntime.InvokeAsync<double>("eval", "window.innerWidth");
                if (popupPositionX + 280 > viewportWidth - 10)
                {
                    popupPositionX = viewportWidth - 290;
                }

                // Check if popup would go off-screen at the bottom (assuming ~200px height)
                var viewportHeight = await JSRuntime.InvokeAsync<double>("eval", "window.innerHeight");
                if (popupPositionY + 200 > viewportHeight - 10)
                {
                    // Position above the profile image instead
                    popupPositionY = rect.Top - 210;
                    if (popupPositionY < 10) popupPositionY = 10;
                }
            }
            else
            {
                // Fallback position near cursor
                popupPositionX = 100;
                popupPositionY = 100;
            }
        }
        catch
        {
            // Fallback position
            popupPositionX = 100;
            popupPositionY = 100;
        }
    }

    /// <summary>
    /// Cancels the hover timer if active.
    /// </summary>
    private void CancelHoverTimer()
    {
        hoverTimer?.Dispose();
        hoverTimer = null;
    }

    /// <summary>
    /// Hides the popup and resets state.
    /// </summary>
    private void HidePopup()
    {
        showProfilePreviewPopup = false;
        StateHasChanged();
    }

    /// <summary>
    /// Helper class for bounding client rect from JavaScript.
    /// </summary>
    private class BoundingClientRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    private async Task HandleAccept()
    {
        if (!IsProcessing && OnAccept.HasDelegate)
        {
            IsProcessing = true;
            actionType = "accept";
            await OnAccept.InvokeAsync(User);
            IsProcessing = false;
        }
    }

    private async Task HandleReject()
    {
        if (!IsProcessing && OnReject.HasDelegate)
        {
            IsProcessing = true;
            actionType = "reject";
            await OnReject.InvokeAsync(User);
            IsProcessing = false;
        }
    }

    private async Task HandleAddFriend()
    {
        if (!IsProcessing && OnAddFriend.HasDelegate)
        {
            IsProcessing = true;
            actionType = "add";
            await OnAddFriend.InvokeAsync(User);
            IsProcessing = false;
        }
    }

    private async Task HandleCancel()
    {
        if (!IsProcessing && OnCancel.HasDelegate)
        {
            IsProcessing = true;
            actionType = "cancel";
            await OnCancel.InvokeAsync(User);
            IsProcessing = false;
        }
    }

    private async Task HandleRemove()
    {
        if (!IsProcessing && OnRemove.HasDelegate)
        {
            IsProcessing = true;
            actionType = "remove";
            await OnRemove.InvokeAsync(User);
            IsProcessing = false;
        }
    }

    /// <summary>
    /// Disposes of resources, including the hover timer.
    /// </summary>
    public void Dispose()
    {
        CancelHoverTimer();
    }
}
