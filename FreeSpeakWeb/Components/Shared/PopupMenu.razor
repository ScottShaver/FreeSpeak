@using FreeSpeakWeb.Services
@implements IDisposable
@inject PopupPortalService PortalService

@if (!UsePortal)
{
    @* Traditional inline rendering mode (backward compatible) *@
    @if (IsVisible)
    {
        <div class="popup-menu-backdrop" @onclick="Close"></div>
        <div class="popup-menu" style="@PositionStyle">
            @foreach (var item in MenuItems)
            {
                <button type="button" class="popup-menu-item" @onclick="@(() => HandleItemClick(item))">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <span class="@item.Icon"></span>
                    }
                    <span>@item.Text</span>
                </button>
            }
        </div>
    }
}

@code {
    private bool _previousIsVisible;
    private bool _isShowingPortal;

    /// <summary>
    /// Controls whether the popup menu is visible.
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }

    /// <summary>
    /// The list of menu items to display.
    /// </summary>
    [Parameter]
    public List<PopupMenuItem> MenuItems { get; set; } = new();

    /// <summary>
    /// Event callback invoked when the menu should close.
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>
    /// CSS position style for inline rendering mode.
    /// </summary>
    [Parameter]
    public string PositionStyle { get; set; } = string.Empty;

    /// <summary>
    /// When true, renders the popup through the portal at document body level.
    /// This prevents CSS overflow clipping issues in modal containers.
    /// Default is true (portal mode enabled).
    /// </summary>
    [Parameter]
    public bool UsePortal { get; set; } = true;

    /// <summary>
    /// The ID of the HTML element to anchor the portal popup to.
    /// Required when UsePortal is true.
    /// </summary>
    [Parameter]
    public string AnchorElementId { get; set; } = string.Empty;

    /// <summary>
    /// The preferred placement of the popup relative to the anchor element.
    /// Only used when UsePortal is true.
    /// </summary>
    [Parameter]
    public PopupPlacement Placement { get; set; } = PopupPlacement.BottomEnd;

    /// <summary>
    /// Handles parameter changes to manage portal visibility.
    /// </summary>
    protected override void OnParametersSet()
    {
        Console.WriteLine($"PopupMenu.OnParametersSet: UsePortal={UsePortal}, IsVisible={IsVisible}, _previousIsVisible={_previousIsVisible}, AnchorElementId={AnchorElementId}");

        if (UsePortal && IsVisible != _previousIsVisible)
        {
            Console.WriteLine($"PopupMenu: Visibility changed! IsVisible={IsVisible}, _isShowingPortal={_isShowingPortal}");
            if (IsVisible && !_isShowingPortal)
            {
                Console.WriteLine("PopupMenu: Calling ShowPortalPopup()");
                ShowPortalPopup();
            }
            else if (!IsVisible && _isShowingPortal)
            {
                Console.WriteLine("PopupMenu: Calling HidePortalPopup()");
                HidePortalPopup();
            }
        }
        _previousIsVisible = IsVisible;
    }

    /// <summary>
    /// Shows the popup through the portal service.
    /// </summary>
    private void ShowPortalPopup()
    {
        Console.WriteLine($"PopupMenu.ShowPortalPopup: AnchorElementId='{AnchorElementId}'");
        if (string.IsNullOrEmpty(AnchorElementId))
        {
            Console.WriteLine("PopupMenu.ShowPortalPopup: AnchorElementId is empty, returning early!");
            return;
        }

        _isShowingPortal = true;
        Console.WriteLine("PopupMenu.ShowPortalPopup: Building portal content and calling PortalService.ShowPopup()");

        // Build portal content with RenderTreeBuilder - styles come from PopupPortal.razor.css
        RenderFragment portalContent = builder =>
        {
            var seq = 0;
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "popup-menu popup-menu-portal");

            foreach (var item in MenuItems)
            {
                builder.OpenElement(seq++, "button");
                builder.AddAttribute(seq++, "type", "button");
                builder.AddAttribute(seq++, "class", "popup-menu-item");
                builder.AddAttribute(seq++, "tabindex", "-1"); // Prevent focus on click
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => HandleItemClick(item)));

                if (!string.IsNullOrEmpty(item.Icon))
                {
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "class", item.Icon);
                    builder.CloseElement();
                }

                builder.OpenElement(seq++, "span");
                builder.AddContent(seq++, item.Text);
                builder.CloseElement();

                builder.CloseElement();
            }

            builder.CloseElement();
        };

        PortalService.ShowPopup(portalContent, AnchorElementId, Placement, () =>
        {
            // Portal was closed externally (e.g., backdrop click)
            _isShowingPortal = false;
            InvokeAsync(async () => await Close());
        });
        Console.WriteLine("PopupMenu.ShowPortalPopup: PortalService.ShowPopup() called successfully");
    }

    /// <summary>
    /// Hides the popup from the portal.
    /// </summary>
    private void HidePortalPopup()
    {
        if (_isShowingPortal)
        {
            _isShowingPortal = false;
            PortalService.HidePopup();
        }
    }

    /// <summary>
    /// Handles clicking on a menu item.
    /// </summary>
    /// <param name="item">The menu item that was clicked.</param>
    private async Task HandleItemClick(PopupMenuItem item)
    {
        Console.WriteLine($"PopupMenu.HandleItemClick: Item '{item.Text}' clicked, HasDelegate={item.OnClick.HasDelegate}");

        // IMPORTANT: Execute the action BEFORE closing the menu
        if (item.OnClick.HasDelegate)
        {
            Console.WriteLine($"PopupMenu.HandleItemClick: Invoking OnClick for '{item.Text}'");
            try
            {
                await item.OnClick.InvokeAsync();
                Console.WriteLine($"PopupMenu.HandleItemClick: OnClick completed for '{item.Text}'");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"PopupMenu.HandleItemClick: OnClick FAILED for '{item.Text}': {ex.Message}");
            }
        }

        Console.WriteLine($"PopupMenu.HandleItemClick: Now closing menu");
        await Close();
    }

    /// <summary>
    /// Closes the popup menu.
    /// </summary>
    private async Task Close()
    {
        if (UsePortal && _isShowingPortal)
        {
            HidePortalPopup();
        }
        await OnClose.InvokeAsync();
    }

    /// <summary>
    /// Cleans up portal state when the component is disposed.
    /// </summary>
    public void Dispose()
    {
        if (_isShowingPortal)
        {
            HidePortalPopup();
        }
    }

    /// <summary>
    /// Represents a single item in the popup menu.
    /// </summary>
    public class PopupMenuItem
    {
        /// <summary>
        /// The display text for the menu item.
        /// </summary>
        public string Text { get; set; } = string.Empty;

        /// <summary>
        /// The CSS class for the icon (e.g., Bootstrap Icons class).
        /// </summary>
        public string Icon { get; set; } = string.Empty;

        /// <summary>
        /// The callback invoked when the menu item is clicked.
        /// </summary>
        public EventCallback OnClick { get; set; }
    }
}
