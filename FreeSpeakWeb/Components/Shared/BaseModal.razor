@using Microsoft.JSInterop
@inject IJSRuntime JS

@if (IsVisible)
{
    <div class="base-modal-backdrop" @onclick="HandleBackdropClick" tabindex="-1" @onkeydown="HandleKeyDown">
        <div class="base-modal-dialog @SizeClass @(Scrollable ? "base-modal-scrollable" : "")" @onclick:stopPropagation="true">
            <div class="base-modal-content">
                @if (ShowHeader)
                {
                    <div class="base-modal-header">
                        @if (HeaderContent != null)
                        {
                            @HeaderContent
                        }
                        else
                        {
                            <h5 class="base-modal-title">@Title</h5>
                        }
                        @if (ShowCloseButton)
                        {
                            <button type="button" class="base-modal-close" @onclick="Close" aria-label="Close">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </button>
                        }
                    </div>
                }
                <div class="base-modal-body">
                    @ChildContent
                </div>
                @if (FooterContent != null)
                {
                    <div class="base-modal-footer">
                        @FooterContent
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    /// <summary>
    /// Controls whether the modal is visible.
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }

    /// <summary>
    /// Event callback invoked when the modal should be closed.
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>
    /// The title displayed in the modal header (used only if HeaderContent is not provided).
    /// </summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// Main content of the modal body.
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Optional custom header content. If provided, overrides the default title + close button layout.
    /// </summary>
    [Parameter]
    public RenderFragment? HeaderContent { get; set; }

    /// <summary>
    /// Optional footer content (typically for action buttons).
    /// </summary>
    [Parameter]
    public RenderFragment? FooterContent { get; set; }

    /// <summary>
    /// Controls whether the header section is shown.
    /// </summary>
    [Parameter]
    public bool ShowHeader { get; set; } = true;

    /// <summary>
    /// Controls whether the close button (X) is shown in the header.
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// Controls whether clicking the backdrop closes the modal.
    /// </summary>
    [Parameter]
    public bool CloseOnBackdropClick { get; set; } = true;

    /// <summary>
    /// Controls whether pressing Escape closes the modal.
    /// </summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    /// <summary>
    /// Controls whether the modal body is scrollable.
    /// </summary>
    [Parameter]
    public bool Scrollable { get; set; } = true;

    /// <summary>
    /// Size of the modal: "sm", "md" (default), "lg", "xl".
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    /// <summary>
    /// Additional CSS classes to apply to the modal dialog.
    /// </summary>
    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    private string SizeClass => Size switch
    {
        "sm" => "base-modal-sm",
        "lg" => "base-modal-lg",
        "xl" => "base-modal-xl",
        _ => "base-modal-md"
    };

    /// <summary>
    /// Handles backdrop click events.
    /// </summary>
    private async Task HandleBackdropClick()
    {
        if (CloseOnBackdropClick)
        {
            await Close();
        }
    }

    /// <summary>
    /// Handles keyboard events (Escape key).
    /// </summary>
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (CloseOnEscape && e.Key == "Escape")
        {
            await Close();
        }
    }

    /// <summary>
    /// Closes the modal by invoking the OnClose callback.
    /// </summary>
    private async Task Close()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible)
        {
            try
            {
                // Focus the backdrop so keyboard events work
                await JS.InvokeVoidAsync("eval", "document.querySelector('.base-modal-backdrop')?.focus()");
            }
            catch
            {
                // Ignore if element not found
            }
        }
    }
}
