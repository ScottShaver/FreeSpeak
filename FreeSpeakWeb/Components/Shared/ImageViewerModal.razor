@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS

@if (IsVisible && CurrentImage != null)
{
    <div class="image-viewer-backdrop" @onclick="Close" tabindex="-1" @onkeydown="HandleKeyDown">
        <div class="image-viewer-container" @onclick:stopPropagation="true">
            <div class="image-viewer-header">
                <div class="image-counter">
                    @if (EnableNavigation && TotalImages > 1)
                    {
                        <span>@(CurrentIndex + 1) / @TotalImages</span>
                    }
                </div>
                <button type="button" class="close-button" @onclick="Close" title="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                    </svg>
                </button>
            </div>

            <div class="image-viewer-content">
                @if (EnableNavigation && TotalImages > 1 && CurrentIndex > 0)
                {
                    <button type="button" class="nav-button nav-prev" @onclick="ShowPrevious" title="Previous">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
                        </svg>
                    </button>
                }

                <div class="image-display">
                    <img src="@CurrentImage" alt="Full size image" />
                </div>

                @if (EnableNavigation && TotalImages > 1 && CurrentIndex < TotalImages - 1)
                {
                    <button type="button" class="nav-button nav-next" @onclick="ShowNext" title="Next">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public List<string>? ImageUrls { get; set; }

    [Parameter]
    public int InitialIndex { get; set; } = 0;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public bool EnableNavigation { get; set; } = true;

    private int CurrentIndex { get; set; }
    private string? CurrentImage => ImageUrls != null && CurrentIndex >= 0 && CurrentIndex < ImageUrls.Count 
        ? ImageUrls[CurrentIndex] 
        : null;
    private int TotalImages => ImageUrls?.Count ?? 0;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            CurrentIndex = InitialIndex;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsVisible)
        {
            try
            {
                // Focus the backdrop so keyboard events work
                await JS.InvokeVoidAsync("eval", "document.querySelector('.image-viewer-backdrop')?.focus()");
            }
            catch
            {
                // Ignore if element not found
            }
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            await Close();
        }
        else if (EnableNavigation && e.Key == "ArrowLeft")
        {
            ShowPrevious();
        }
        else if (EnableNavigation && e.Key == "ArrowRight")
        {
            ShowNext();
        }
    }

    private void ShowPrevious()
    {
        if (CurrentIndex > 0)
        {
            CurrentIndex--;
        }
    }

    private void ShowNext()
    {
        if (CurrentIndex < TotalImages - 1)
        {
            CurrentIndex++;
        }
    }

    private async Task Close()
    {
        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }
}
