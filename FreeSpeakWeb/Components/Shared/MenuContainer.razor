@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Services
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<FreeSpeakWeb.Resources.Shared.MenuContainer> Localizer

@code {
    private string _anchorId = $"menu-anchor-{Guid.NewGuid():N}";

    /// <summary>
    /// The menu items to display in the popup.
    /// </summary>
    [Parameter, EditorRequired]
    public List<PopupMenu.PopupMenuItem> MenuItems { get; set; } = new();

    /// <summary>
    /// Controls whether the menu is currently visible.
    /// </summary>
    [Parameter]
    public bool IsVisible { get; set; }

    /// <summary>
    /// Event callback when visibility changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    /// <summary>
    /// Tooltip text for the menu button.
    /// </summary>
    [Parameter]
    public string? Tooltip { get; set; }

    /// <summary>
    /// Gets the effective tooltip, using the localized default if not explicitly set.
    /// </summary>
    private string EffectiveTooltip => Tooltip ?? Localizer["MoreOptions"];

    /// <summary>
    /// Size of the menu icon: "sm" (16px), "md" (20px), "lg" (24px).
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "md";

    /// <summary>
    /// Position style for the popup menu (used when UsePortal is false).
    /// </summary>
    [Parameter]
    public string PopupPositionStyle { get; set; } = "position: absolute; top: 100%; right: 0;";

    /// <summary>
    /// Additional CSS classes for the container.
    /// </summary>
    [Parameter]
    public string CssClass { get; set; } = string.Empty;

    /// <summary>
    /// Whether the menu button should be shown. Useful for conditional display.
    /// </summary>
    [Parameter]
    public bool ShowButton { get; set; } = true;

    /// <summary>
    /// When true (default), renders the popup through the portal at document body level.
    /// This prevents CSS overflow clipping issues in modal containers.
    /// Set to false only if portal rendering causes issues in specific contexts.
    /// </summary>
    [Parameter]
    public bool UsePortal { get; set; } = true;

    /// <summary>
    /// The preferred placement of the popup relative to the anchor element.
    /// Only used when UsePortal is true.
    /// </summary>
    [Parameter]
    public PopupPlacement Placement { get; set; } = PopupPlacement.BottomEnd;

    private int IconSize => Size switch
    {
        "sm" => 16,
        "lg" => 24,
        _ => 20
    };

    private async Task ToggleMenu()
    {
        var newValue = !IsVisible;
        IsVisible = newValue;
        if (IsVisibleChanged.HasDelegate)
        {
            await IsVisibleChanged.InvokeAsync(newValue);
        }
    }

    private async Task CloseMenu()
    {
        IsVisible = false;
        if (IsVisibleChanged.HasDelegate)
        {
            await IsVisibleChanged.InvokeAsync(false);
        }
    }
}

@if (ShowButton)
{
    <div id="@_anchorId" class="menu-container @CssClass">
        <button type="button" 
                class="menu-trigger-button" 
                @onclick="ToggleMenu"
                @onclick:stopPropagation="true"
                title="@EffectiveTooltip">
            <svg xmlns="http://www.w3.org/2000/svg" width="@IconSize" height="@IconSize" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
            </svg>
        </button>
        <PopupMenu IsVisible="@IsVisible" 
                   MenuItems="@MenuItems" 
                   OnClose="@CloseMenu"
                   PositionStyle="@PopupPositionStyle"
                   UsePortal="@UsePortal"
                   AnchorElementId="@_anchorId"
                   Placement="@Placement" />
    </div>
}
