@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using Microsoft.Extensions.Localization
@inject IJSRuntime JS
@inject GroupPostService GroupPostService
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Options.IOptions<SiteSettings> SiteSettings
@inject UserPreferenceService UserPreferenceService
@inject AlertService AlertService
@inject IAuditLogRepository AuditLogRepository
@inject IStringLocalizer<FreeSpeakWeb.Resources.SocialFeed.FeedArticle> Localizer
@implements IAsyncDisposable

<div class="feed-article @(showMenu ? "menu-open" : "")">
    <!-- 1. Header Area -->
    <FeedArticleHeader 
        AuthorName="@GetFormattedAuthorName()"
        AuthorImageUrl="@AuthorImageUrl"
        AuthorId="@AuthorId"
        CreatedAt="@CreatedAt"
        AudienceType="@AudienceType.Public"
        IsPinned="@currentIsPinned"
        LikeCount="@LikeCount"
        CommentCount="@CommentCount"
        ShareCount="@ShareCount"
        ReactionBreakdown="@ReactionBreakdown"
        IsModalView="@IsModalView"
        IsReadOnly="@IsReadOnly"
        OnShowLikesModal="@ShowLikesModal"
        OnCommentCountClick="@OnCommentCountClick"
        ShowMenu="@showMenu"
        MenuItems="@menuItems"
        MenuPositionStyle="@menuPositionStyle"
        OnToggleMenu="@ToggleMenu"
        OnCloseMenu="@CloseMenu"
        GroupId="@GroupId"
        AuthorGroupPoints="@AuthorGroupPoints" />

    <!-- 2. Main Content Area -->
    <FeedArticleContent 
        ArticleContent="@ArticleContent"
        IsModalView="@IsModalView"
        IsTruncated="@isTruncated"
        ShouldShowExpandButton="@shouldShowExpandButton"
        OnShowPostDetail="@ShowPostDetail"
        OnContentElementRendered="@HandleContentElementRendered"
        ClickToSeeFullPostText="@Localizer["ClickToSeeFullPost"]" />

    <!-- 2.5 Post Images -->
    <FeedArticleImages 
        Images="@Images"
        OnOpenImageViewer="@OpenImageViewer" />

    <!-- 4. Action Links -->
    <FeedArticleActions 
        IsReadOnly="@IsReadOnly"
        IsOwnPost="@IsOwnPost"
        IsModalView="@IsModalView"
        UserReaction="@UserReaction"
        ShowReactionPicker="@showReactionPicker"
        OnShowReactionPicker="@ShowReactionPicker"
        OnStartHideTimer="@StartHideTimer"
        OnCancelHideTimer="@CancelHideTimer"
        OnLikeClick="@OnLikeClick"
        OnReactionPicked="@HandleReaction"
        OnRemoveReaction="@HandleRemoveReaction"
        OnCommentClick="@OnCommentClick"
        OnShareClick="@OnShareClick" />

    @{
        var commentsToDisplay = LoadCommentsInternally ? internalComments : (Comments ?? new List<CommentDisplayModel>());
        var directCount = LoadCommentsInternally ? internalDirectCommentCount : DirectCommentCount;
    }

    <!-- More Comments Indicator -->
    @if (!IsModalView && directCount > 0 && commentsToDisplay != null && directCount > commentsToDisplay.Count)
    {
        <div class="more-comments-indicator">
            <button type="button" class="more-comments-button" @onclick="OnCommentClick">
                @Localizer["ViewMoreComments"]
            </button>
        </div>
    }

    <!-- 5. Display Existing Comments -->
    @if (commentsToDisplay != null && commentsToDisplay.Any())
    {
        <div class="article-comments">
            @foreach (var comment in commentsToDisplay)
            {
                <MultiLineCommentDisplay
                    CommentId="@comment.CommentId"
                    UserName="@comment.UserName"
                    UserImageUrl="@comment.UserImageUrl"
                    CommentAuthorId="@comment.CommentAuthorId"
                    CommentText="@comment.CommentText"
                    ImageUrl="@comment.ImageUrl"
                    Timestamp="@comment.Timestamp"
                    Replies="@comment.Replies"
                    LikeCount="@comment.LikeCount"
                    UserReaction="@comment.UserReaction"
                    ReactionBreakdown="@comment.ReactionBreakdown"
                    CurrentUserId="@CurrentUserId"
                    CurrentUserImageUrl="@CurrentUserImageUrl"
                    CurrentUserName="@CurrentUserName"
                    Depth="0"
                    OnReactionChanged="@OnCommentReactionChanged"
                    OnRemoveReaction="@OnRemoveCommentReaction"
                    OnReplySubmitted="@OnReplySubmittedLocally"
                    OnDeleteComment="@OnCommentDeleted"
                    OnEditComment="@OnCommentEditedLocally"
                    OnCommentUpdated="@OnCommentUpdatedLocally"
                    OnReportComment="@OnReportComment" />
            }
        </div>
    }

    <!-- 6. Comment Editor -->
    <FeedArticleCommentEditor 
        HideCommentEditor="@HideCommentEditor"
        IsReadOnly="@IsReadOnly"
        HasReachedCommentLimit="@HasReachedCommentLimit"
        CurrentUserImageUrl="@CurrentUserImageUrl"
        CurrentUserName="@CurrentUserName"
        OnCommentSubmitted="@OnCommentSubmitted" />
</div>

@if (showLikesModal)
{
    <LikesModal Likes="@likes" isLoading="@isLoadingLikes" OnClose="CloseLikesModal" />
}

<ImageViewerModal 
    IsVisible="@showImageViewer"
    ImageUrls="@imageUrls"
    InitialIndex="@selectedImageIndex"
    OnClose="CloseImageViewer" />

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirmation)
{
    <div class="modal-backdrop" @onclick="CancelDeletePost" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div class="confirmation-modal" @onclick:stopPropagation="true" style="background: var(--surface-color); border: 2px solid var(--border-color); border-radius: 8px; padding: 24px; max-width: 400px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <h3 style="margin: 0 0 16px 0; font-size: 20px; font-weight: 600; color: var(--text-primary);">Delete Post</h3>
            <p style="margin: 0 0 24px 0; color: var(--text-secondary); line-height: 1.5;">Are you sure you want to delete this group post? This action cannot be undone and will permanently remove the post, all comments, likes, and images.</p>
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" @onclick="CancelDeletePost" style="padding: 8px 16px; border: 1px solid var(--border-color); background: var(--surface-color); border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500; color: var(--text-secondary);">
                    Cancel
                </button>
                <button type="button" @onclick="ConfirmDeletePost" style="padding: 8px 16px; border: none; background: var(--danger-color); color: white; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500;">
                    Delete Post
                </button>
            </div>
        </div>
    </div>
}

@* Report Post Modal *@
@if (showReportModal)
{
    <FreeSpeakWeb.Components.Groups.ReportContentModal
        GroupId="@GroupId"
        PostId="@PostId"
        ReporterId="@CurrentUserId"
        OnClose="CloseReportModal"
        OnReportSubmitted="HandleReportSubmitted" />
}

@code {
    [Parameter]
    public int PostId { get; set; }

    [Parameter]
    public int GroupId { get; set; }

    [Parameter]
    public string GroupName { get; set; } = string.Empty;

    [Parameter]
    public string AuthorId { get; set; } = string.Empty;

    [Parameter]
    public string AuthorName { get; set; } = "Anonymous";

    [Parameter]
    public string? AuthorImageUrl { get; set; }

    [Parameter]
    public int? AuthorGroupPoints { get; set; }

    [Parameter]
    public string? CurrentUserId { get; set; }

    [Parameter]
    public DateTime CreatedAt { get; set; } = DateTime.Now;

    [Parameter]
    public RenderFragment? ArticleContent { get; set; }

    [Parameter]
    public int LikeCount { get; set; } = 0;

    [Parameter]
    public int CommentCount { get; set; } = 0;

    [Parameter]
    public int ShareCount { get; set; } = 0;

    [Parameter]
    public int DirectCommentCount { get; set; } = 0;

    [Parameter]
    public List<CommentDisplayModel>? Comments { get; set; }

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public Dictionary<LikeType, int>? ReactionBreakdown { get; set; }

    [Parameter]
    public LikeType? UserReaction { get; set; }

    [Parameter]
    public EventCallback<LikeType> OnReactionChanged { get; set; }

    [Parameter]
    public EventCallback OnRemoveReaction { get; set; }

    [Parameter]
    public EventCallback<(int PostId, string Content)> OnCommentAdded { get; set; }

    [Parameter]
    public EventCallback<(int ParentCommentId, string Content)> OnReplySubmitted { get; set; }

    [Parameter]
    public EventCallback<(int CommentId, LikeType ReactionType)> OnCommentReactionChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnRemoveCommentReaction { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to delete their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnDeleteComment { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to edit their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string CurrentContent)> OnEditComment { get; set; }

    /// <summary>
    /// Event callback invoked when a comment is successfully updated with new content via inline editing.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string NewContent)> OnCommentUpdated { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to report another user's comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnReportComment { get; set; }

    [Parameter]
    public bool HideCommentEditor { get; set; } = false;

    [Parameter]
    public bool IsModalView { get; set; } = false;

    [Parameter]
    public EventCallback OnShowPostDetail { get; set; }

    [Parameter]
    public EventCallback OnShowComments { get; set; }

    [Parameter]
    public bool IsPinned { get; set; } = false;

    [Parameter]
    public EventCallback<int> OnPinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnUnpinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnPostDeleted { get; set; }

    [Parameter]
    public EventCallback<int> OnEditPost { get; set; }

    [Parameter]
    public List<PostImage>? Images { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public bool LoadCommentsInternally { get; set; } = false;

    [Parameter]
    public int CommentsToShow { get; set; } = 3;

    [Parameter]
    public int RefreshTrigger { get; set; } = 0;

    /// <summary>
    /// Gets or sets whether notifications are muted for this group post.
    /// When provided by parent, avoids N+1 queries by using batch-loaded mute status.
    /// </summary>
    [Parameter]
    public bool? IsMuted { get; set; }

    // Internal state for pinned status
    private bool currentIsPinned = false;
    private bool hasLocalPinnedChange = false;

    // Notification mute state - uses IsMuted parameter if provided, otherwise loaded on first render
    private bool isNotificationMuted = false;
    private bool hasMuteStatusFromParameter = false;

    private bool showReactionPicker = false;
    private bool showLikesModal = false;
    private bool isLoadingLikes = false;
    private List<(ApplicationUser User, LikeType Type, DateTime CreatedAt)> likes = new();
    private System.Threading.Timer? hideTimer;
    private ElementReference contentElement;
    private IJSObjectReference? module;
    private DotNetObjectReference<GroupPostArticle>? dotNetHelper;
    private bool isTruncated = false;
    private bool shouldShowExpandButton = false;
    private bool showMenu = false;
    private List<PopupMenu.PopupMenuItem> menuItems = new();
    private string menuPositionStyle = string.Empty;

    // Delete confirmation state
    private bool showDeleteConfirmation = false;

    // Report modal state
    private bool showReportModal = false;

    // Image viewer state
    private bool showImageViewer = false;
    private List<string> imageUrls = new();
    private int selectedImageIndex = 0;

    // Internal comment loading state
    private List<CommentDisplayModel> internalComments = new();
    private int internalDirectCommentCount = 0;
    private bool isLoadingComments = false;
    private int? lastLoadedPostId = null;
    private int lastRefreshTrigger = 0;

    private bool IsOwnPost => !string.IsNullOrEmpty(CurrentUserId) && !string.IsNullOrEmpty(AuthorId) && CurrentUserId == AuthorId;

    private bool HasReachedCommentLimit => DirectCommentCount >= SiteSettings.Value.MaxFeedPostDirectCommentCount;

    private async Task HandleContentElementRendered(ElementReference elementRef)
    {
        contentElement = elementRef;
    }

    private void ShowReactionPicker()
    {
        if (IsOwnPost) return;

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void CancelHideTimer()
    {
        if (IsOwnPost) return;

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void StartHideTimer()
    {
        hideTimer?.Dispose();
        hideTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                showReactionPicker = false;
                StateHasChanged();
            });
        }, null, 500, Timeout.Infinite);
    }

    private void HideReactionPicker()
    {
        showReactionPicker = false;
    }

    private async Task HandleReaction(LikeType reactionType)
    {
        showReactionPicker = false;
        await OnReactionChanged.InvokeAsync(reactionType);
    }

    private async Task HandleRemoveReaction()
    {
        showReactionPicker = false;
        if (OnRemoveReaction.HasDelegate)
        {
            await OnRemoveReaction.InvokeAsync();
        }
    }

    private async Task OnLikeClick()
    {
        await OnReactionChanged.InvokeAsync(LikeType.Like);
    }

    private void ToggleMenu()
    {
        if (showMenu)
        {
            CloseMenu();
        }
        else
        {
            BuildMenuItems();
            showMenu = true;
            menuPositionStyle = "right: 0; top: 40px;";
            StateHasChanged();
        }
    }

    private void BuildMenuItems()
    {
        menuItems.Clear();

        if (IsOwnPost)
        {
            if (IsModalView)
            {
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = currentIsPinned ? Localizer["UnpinPost"] : Localizer["PinPost"],
                    Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
                });

                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = Localizer["CopyLink"],
                    Icon = "bi bi-link-45deg",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                });
            }
            else
            {
                    menuItems.Add(new PopupMenu.PopupMenuItem
                        {
                            Text = Localizer["EditPost"],
                            Icon = "bi bi-pencil",
                            OnClick = EventCallback.Factory.Create(this, async () => await HandleEditPostClick())
                        });

                        menuItems.Add(new PopupMenu.PopupMenuItem
                        {
                            Text = currentIsPinned ? Localizer["UnpinPost"] : Localizer["PinPost"],
                            Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                            OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
                        });

                        menuItems.Add(new PopupMenu.PopupMenuItem
                        {
                            Text = isNotificationMuted ? Localizer["TurnOnNotifications"] : Localizer["TurnOffNotifications"],
                            Icon = isNotificationMuted ? "bi bi-bell" : "bi bi-bell-slash",
                            OnClick = EventCallback.Factory.Create(this, async () => await HandleToggleNotificationsClick())
                        });

                        menuItems.Add(new PopupMenu.PopupMenuItem
                        {
                            Text = Localizer["DeletePost"],
                            Icon = "bi bi-trash",
                            OnClick = EventCallback.Factory.Create(this, ShowDeleteConfirmation)
                        });

                        menuItems.Add(new PopupMenu.PopupMenuItem
                        {
                            Text = Localizer["CopyLink"],
                            Icon = "bi bi-link-45deg",
                            OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                        });
                    }
                }
                else if (!string.IsNullOrEmpty(CurrentUserId))
                {
                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = currentIsPinned ? Localizer["UnpinPost"] : Localizer["PinPost"],
                        Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                        OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
                    });

                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = isNotificationMuted ? Localizer["TurnOnNotifications"] : Localizer["TurnOffNotifications"],
                        Icon = isNotificationMuted ? "bi bi-bell" : "bi bi-bell-slash",
                        OnClick = EventCallback.Factory.Create(this, async () => await HandleToggleNotificationsClick())
                    });

                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = Localizer["ReportPost"],
                        Icon = "bi bi-flag",
                        OnClick = EventCallback.Factory.Create(this, () => ShowReportModal())
                    });

                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = Localizer["CopyLink"],
                        Icon = "bi bi-link-45deg",
                        OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                    });
                }
        else
        {
            menuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = Localizer["CopyLink"],
                Icon = "bi bi-link-45deg",
                OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
            });
        }
    }

    private void CloseMenu()
    {
        showMenu = false;
        StateHasChanged();
    }

    private void ShowDeleteConfirmation()
    {
        CloseMenu();
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    private void CancelDeletePost()
    {
        showDeleteConfirmation = false;
        StateHasChanged();
    }

    /// <summary>
    /// Shows the report post modal.
    /// </summary>
    private void ShowReportModal()
    {
        CloseMenu();
        showReportModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Closes the report post modal.
    /// </summary>
    private void CloseReportModal()
    {
        showReportModal = false;
        StateHasChanged();
    }

    /// <summary>
    /// Handles when a report is successfully submitted.
    /// </summary>
    private Task HandleReportSubmitted()
    {
        AlertService.ShowSuccess("Report submitted successfully. Thank you for helping keep our community safe.");
        return Task.CompletedTask;
    }

    private async Task ConfirmDeletePost()
    {
        showDeleteConfirmation = false;
        StateHasChanged();

        var result = await GroupPostService.DeleteGroupPostAsync(PostId, AuthorId);

        if (result.Success)
        {
            // Log group post deletion to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserGroupPost, new UserGroupPostDetails
                {
                    PostId = PostId,
                    GroupId = GroupId,
                    OperationType = OperationTypeEnum.Delete.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            if (OnPostDeleted.HasDelegate)
            {
                await OnPostDeleted.InvokeAsync(PostId);
            }
        }
        else
        {
            AlertService.ShowError(result.ErrorMessage ?? "Failed to delete post.");
        }
    }

    private async Task HandleEditPostClick()
    {
        CloseMenu();

        if (OnEditPost.HasDelegate)
        {
            await OnEditPost.InvokeAsync(PostId);
        }
    }

    private async Task HandlePinUnpinClick()
    {
        if (IsPinned)
        {
            if (OnUnpinPost.HasDelegate)
            {
                await OnUnpinPost.InvokeAsync(PostId);
            }
        }
        else
        {
            if (OnPinPost.HasDelegate)
            {
                await OnPinPost.InvokeAsync(PostId);
            }
        }
    }

    private async Task HandleCopyLink()
    {
        CloseMenu();

        try
        {
            var baseUri = NavigationManager.BaseUri.TrimEnd('/');
            var postUrl = $"{baseUri}/group/{GroupId}/post/{PostId}";

            await JS.InvokeVoidAsync("navigator.clipboard.writeText", postUrl);

            // Log link copy to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserGroupPost, new UserGroupPostDetails
                {
                    PostId = PostId,
                    GroupId = GroupId,
                    OperationType = OperationTypeEnum.CopyLink.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }
        }
        catch (Exception)
        {
            AlertService.ShowError("Failed to copy link to clipboard.");
        }
    }

    /// <summary>
    /// Handles toggling notification mute status for this group post.
    /// </summary>
    private async Task HandleToggleNotificationsClick()
    {
        CloseMenu();

        if (string.IsNullOrEmpty(CurrentUserId)) return;

        try
        {
            if (isNotificationMuted)
            {
                var result = await GroupPostService.UnmutePostNotificationsAsync(PostId, CurrentUserId);
                if (result.Success)
                {
                    isNotificationMuted = false;

                    // Log notification unmute to audit log
                    try
                    {
                        await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserNotification, new UserNotificationDetails
                        {
                            OperationType = OperationTypeEnum.UnmuteGroupPost.ToString(),
                            ContentSummary = $"Unmuted notifications for group post {PostId} in group {GroupId}"
                        });
                    }
                    catch { /* Audit logging should not fail the operation */ }

                    StateHasChanged();
                }
            }
            else
            {
                var result = await GroupPostService.MutePostNotificationsAsync(PostId, CurrentUserId);
                if (result.Success)
                {
                    isNotificationMuted = true;

                    // Log notification mute to audit log
                    try
                    {
                        await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserNotification, new UserNotificationDetails
                        {
                            OperationType = OperationTypeEnum.MuteGroupPost.ToString(),
                            ContentSummary = $"Muted notifications for group post {PostId} in group {GroupId}"
                        });
                    }
                    catch { /* Audit logging should not fail the operation */ }

                    StateHasChanged();
                }
            }
        }
        catch (Exception)
        {
            AlertService.ShowError("Failed to update notification settings.");
        }
    }

    private async Task ShowMenu()
    {
        await JS.InvokeVoidAsync("alert", "Article Menu");
    }

    private async Task OnCommentClick()
    {
        if (OnShowComments.HasDelegate)
        {
            await OnShowComments.InvokeAsync();
        }
    }

    private async Task OnShareClick()
    {
        await JS.InvokeVoidAsync("alert", "Share");
    }

    private async Task ShowLikesModal()
    {
        if (LikeCount == 0) return;

        showLikesModal = true;
        isLoadingLikes = true;
        StateHasChanged();

        try
        {
            likes = await GroupPostService.GetGroupPostLikesWithDetailsAsync(PostId);
        }
        catch (Exception)
        {
            // Silently fail - likes list optional
        }
        finally
        {
            isLoadingLikes = false;
            StateHasChanged();
        }
    }

    private void CloseLikesModal()
    {
        showLikesModal = false;
        likes.Clear();
    }

    private void OpenImageViewer(int imageIndex)
    {
        if (Images == null || !Images.Any()) return;

        imageUrls = Images.Select(img => $"{img.ImageUrl}?size=full").ToList();
        selectedImageIndex = imageIndex;
        showImageViewer = true;
        StateHasChanged();
    }

    private void CloseImageViewer()
    {
        showImageViewer = false;
        StateHasChanged();
    }

    private async Task OnCommentSubmitted(string commentText)
    {
        if (OnCommentAdded.HasDelegate && !string.IsNullOrWhiteSpace(commentText))
        {
            await OnCommentAdded.InvokeAsync((PostId, commentText));

            // If loading internally, reload comments
            if (LoadCommentsInternally)
            {
                await LoadCommentsAsync();
            }
        }
    }

    /// <summary>
    /// Handles when a comment is deleted, forwarding to the parent and reloading internal comments if necessary.
    /// </summary>
    /// <param name="commentId">The ID of the comment that was deleted</param>
    private async Task OnCommentDeleted(int commentId)
    {
        if (OnDeleteComment.HasDelegate)
        {
            await OnDeleteComment.InvokeAsync(commentId);

            // If loading internally, reload comments to reflect the deletion
            if (LoadCommentsInternally)
            {
                await LoadCommentsAsync();
            }
        }
    }

    /// <summary>
    /// Handles when a reply is submitted, forwarding to the parent and reloading internal comments if necessary.
    /// </summary>
    /// <param name="args">Tuple containing the ParentCommentId and reply Content</param>
    private async Task OnReplySubmittedLocally((int ParentCommentId, string Content) args)
    {
        if (OnReplySubmitted.HasDelegate)
        {
            await OnReplySubmitted.InvokeAsync(args);

            // If loading internally, reload comments to reflect the new reply
            if (LoadCommentsInternally)
            {
                await LoadCommentsAsync();
            }
        }
    }

    /// <summary>
    /// Handles when a comment is edited, forwarding to the parent and reloading internal comments if necessary.
    /// </summary>
    /// <param name="args">Tuple containing the CommentId and CurrentContent</param>
    private async Task OnCommentEditedLocally((int CommentId, string CurrentContent) args)
    {
        if (OnEditComment.HasDelegate)
        {
            await OnEditComment.InvokeAsync(args);

            // If loading internally, reload comments to reflect the edit
            if (LoadCommentsInternally)
            {
                await LoadCommentsAsync();
            }
        }
    }

    /// <summary>
    /// Handles when a comment is successfully updated via inline editing, forwarding to the parent and reloading internal comments if necessary.
    /// </summary>
    /// <param name="args">Tuple containing the CommentId and NewContent</param>
    private async Task OnCommentUpdatedLocally((int CommentId, string NewContent) args)
    {
        if (OnCommentUpdated.HasDelegate)
        {
            await OnCommentUpdated.InvokeAsync(args);

            // If loading internally, reload comments to reflect the update
            if (LoadCommentsInternally)
            {
                await LoadCommentsAsync();
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!hasLocalPinnedChange)
        {
            currentIsPinned = IsPinned;
        }
        else if (currentIsPinned == IsPinned)
        {
            hasLocalPinnedChange = false;
        }

        // Use IsMuted parameter if provided (batch-loaded by parent to avoid N+1)
        if (IsMuted.HasValue)
        {
            isNotificationMuted = IsMuted.Value;
            hasMuteStatusFromParameter = true;
        }

        // Load comments if internal loading enabled and (PostId has changed OR RefreshTrigger has changed)
        if (LoadCommentsInternally && !isLoadingComments && (lastLoadedPostId != PostId || lastRefreshTrigger != RefreshTrigger))
        {
            lastLoadedPostId = PostId;
            lastRefreshTrigger = RefreshTrigger;
            await LoadCommentsAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Only load mute status if not provided by parent parameter (avoids N+1 queries)
            if (!hasMuteStatusFromParameter && !string.IsNullOrEmpty(CurrentUserId))
            {
                try
                {
                    isNotificationMuted = await GroupPostService.IsPostNotificationMutedAsync(PostId, CurrentUserId);
                    StateHasChanged();
                }
                catch (Exception)
                {
                    // Silently fail - mute status optional
                }
            }

            if (!IsModalView)
            {
                try
                {
                    module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/SocialFeed/FeedArticle.razor.js");
                    dotNetHelper = DotNetObjectReference.Create(this);
                    await module.InvokeVoidAsync("initializeContentMeasurement", contentElement, dotNetHelper);
                }
                catch (Exception)
                {
                    // Silently fail - content measurement optional
                }
            }
        }
    }

    [JSInvokable]
    public void SetContentOverflow(bool isOverflowing)
    {
        shouldShowExpandButton = isOverflowing;
        isTruncated = isOverflowing;
        StateHasChanged();
    }

    private async Task ShowPostDetail()
    {
        if (OnShowPostDetail.HasDelegate)
        {
            await OnShowPostDetail.InvokeAsync();
        }
    }

    private async Task OnCommentCountClick()
    {
        if (CommentCount == 0) return;

        if (OnShowComments.HasDelegate)
        {
            await OnShowComments.InvokeAsync();
        }
    }

    private string GetFormattedAuthorName()
    {
        if (!string.IsNullOrEmpty(GroupName))
        {
            return $"{GroupName} > {AuthorName}";
        }
        return AuthorName;
    }

    private async Task LoadCommentsAsync()
    {
        if (isLoadingComments) return;
        isLoadingComments = true;

        try
        {
            var allComments = await GroupPostService.GetCommentsAsync(PostId);

            // Select N newest, display oldest-first (per spec)
            var topComments = allComments
                .OrderByDescending(c => c.CreatedAt)
                .Take(CommentsToShow)
                .OrderBy(c => c.CreatedAt)
                .ToList();

            // Build comment display models with full nesting
            internalComments = await BuildCommentModelsAsync(topComments);
            internalDirectCommentCount = allComments.Count(c => c.ParentCommentId == null);
        }
        catch (Exception)
        {
            // Silently fail - comments optional
        }
        finally
        {
            isLoadingComments = false;
        }
    }

    private async Task<List<CommentDisplayModel>> BuildCommentModelsAsync(List<GroupPostComment> comments)
    {
        var models = new List<CommentDisplayModel>();
        foreach (var c in comments)
        {
            models.Add(await BuildCommentModelAsync(c));
        }
        return models;
    }

    private async Task<CommentDisplayModel> BuildCommentModelAsync(GroupPostComment comment)
    {
        // Load replies recursively using separate queries (same approach as modal)
        var replies = await GroupPostService.GetRepliesAsync(comment.Id);
        var replyModels = new List<CommentDisplayModel>();

        foreach (var reply in replies)
        {
            var replyModel = await BuildCommentModelAsync(reply); // Recursive call
            replyModels.Add(replyModel);
        }

        // Get user display name
        var userName = "Unknown";
        if (comment.Author != null)
        {
            userName = await UserPreferenceService.FormatUserDisplayNameAsync(
                comment.Author.Id,
                comment.Author.FirstName,
                comment.Author.LastName,
                comment.Author.UserName ?? "Unknown"
            );
        }

        // Get user's reaction
        LikeType? userReaction = null;
        if (!string.IsNullOrEmpty(CurrentUserId))
        {
            var userLike = await GroupPostService.GetUserCommentLikeAsync(comment.Id, CurrentUserId);
            userReaction = userLike?.Type;
        }

        return new CommentDisplayModel
        {
            CommentId = comment.Id,
            UserName = userName,
            UserImageUrl = comment.Author?.ProfilePictureUrl,
            CommentAuthorId = comment.AuthorId,
            CommentText = comment.Content,
            ImageUrl = comment.ImageUrl,
            Timestamp = comment.CreatedAt,
            Replies = replyModels.Any() ? replyModels : null,
            LikeCount = 0, // TODO: Get actual like count
            UserReaction = userReaction,
            ReactionBreakdown = new Dictionary<LikeType, int>()
        };
    }

    public async ValueTask DisposeAsync()
    {
        hideTimer?.Dispose();

        if (module != null)
        {
            try
            {
                await module.InvokeVoidAsync("cleanupContentMeasurement");
                await module.DisposeAsync();
            }
            catch { }
        }

        dotNetHelper?.Dispose();
    }
}
