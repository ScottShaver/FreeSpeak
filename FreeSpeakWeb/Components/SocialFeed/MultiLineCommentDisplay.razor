@inject IJSRuntime JS
@inject Microsoft.Extensions.Options.IOptions<SiteSettings> SiteSettings
@inject HtmlSanitizationService HtmlSanitizationService
@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Friends
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using Microsoft.Extensions.Localization
@using Microsoft.AspNetCore.Identity
@implements IAsyncDisposable

@inject IStringLocalizer<FreeSpeakWeb.Resources.SocialFeed.MultiLineCommentDisplay> Localizer
@inject UserManager<ApplicationUser> UserManager

<div class="comment-display" data-comment-id="@CommentId" @ref="commentElement">
    <div class="comment-avatar">
        @if (!string.IsNullOrEmpty(UserImageUrl))
        {
            <img src="@UserImageUrl" 
                 alt="@UserName" 
                 class="avatar-img" 
                 id="@commentAvatarId"
                 @onmouseenter="HandleAvatarMouseEnter"
                 @onmouseleave="HandleAvatarMouseLeave" />
        }
        else
        {
            <div class="avatar-img avatar-placeholder"
                 id="@commentAvatarId"
                 @onmouseenter="HandleAvatarMouseEnter"
                 @onmouseleave="HandleAvatarMouseLeave">
                <span class="avatar-initial">@GetInitials(UserName)</span>
            </div>
        }
    </div>
    
    <div class="comment-content">
        @if (isEditMode)
        {
            <!-- Inline Edit Mode -->
            <div class="comment-edit-container">
                <div class="comment-edit-wrapper">
                    <MultiLineCommentEditor @ref="commentEditor" @bind-CommentText="editedCommentText" OnCommentSubmitted="@HandleEditSubmitted" />
                </div>
                <div class="comment-edit-actions">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="CancelEdit">
                        @Localizer["Cancel"]
                    </button>
                    <button type="button" class="btn btn-sm btn-primary" @onclick="SaveEdit" disabled="@(!CanSaveEdit)">
                        @Localizer["Save"]
                    </button>
                </div>
            </div>
        }
        else
        {
            <!-- Normal Display Mode -->
            <div class="comment-bubble-container">
                <div class="comment-bubble">
                    <div class="comment-author">@UserName</div>
                    <div class="comment-text">@((MarkupString)FormatContentWithLineBreaks(CommentText))</div>
                </div>
                @if (!string.IsNullOrEmpty(CurrentUserId))
                {
                    <div class="comment-menu-container" style="position: relative;">
                        <button type="button" 
                                class="comment-menu-button" 
                                @onclick="ToggleCommentMenu"
                                title="@Localizer["MoreOptions"]">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                            </svg>
                        </button>
                        <PopupMenu IsVisible="@showCommentMenu" 
                                   MenuItems="@commentMenuItems" 
                                   OnClose="@CloseCommentMenu"
                                   PositionStyle="position: absolute; top: 100%; right: 0;" />
                    </div>
                }
            </div>
        }

        @if (!string.IsNullOrEmpty(ImageUrl) && !isEditMode)
        {
            <div class="comment-image-container">
                <img src="@ImageUrl" alt="Comment image" class="comment-image" @onclick="OnImageClick" />
            </div>
        }

        @if (!isEditMode)
        {
            <div class="comment-meta">
            <span class="comment-timestamp" title="@FullTimestamp">@FormattedTimestamp</span>

            @if (ShouldShowLikeButton)
            {
                <div class="like-button-container" @onmouseenter="ShowReactionPicker" @onmouseleave="StartHideTimer" @onmouseenter:stopPropagation="true">
                    <button type="button" class="comment-like-button @(UserReaction != null ? "reacted" : "")" @onclick="OnLikeClick">
                        @if (UserReaction != null)
                        {
                            <span class="user-reaction-emoji">@GetReactionEmoji(UserReaction.Value)</span>
                            <span class="reaction-text">@GetReactionText(UserReaction.Value)</span>
                        }
                        else
                        {
                            <span>@Localizer["Like"]</span>
                        }
                    </button>
                    @if (showReactionPicker)
                    {
                        <ReactionPicker HasUserReaction="@(UserReaction != null)" OnReactionPicked="HandleReaction" OnRemoveReaction="HandleRemoveReaction" OnClose="StartHideTimer" OnEnter="CancelHideTimer" />
                    }
                </div>
            }
            @if (ShouldShowReplyButton)
            {
                <button type="button" class="comment-reply-button" @onclick="ToggleReplyEditor">
                    <span>@Localizer["Reply"]</span>
                </button>
            }
            else if (!string.IsNullOrEmpty(CurrentUserId) && Depth >= SiteSettings.Value.MaxFeedPostCommentDepth)
            {
                <span class="comment-reply-disabled">@Localizer["NoMoreRepliesAllowed"]</span>
            }

            @if (LikeCount > 0)
            {
                <div class="comment-stats">
                    @if (ReactionBreakdown != null && ReactionBreakdown.Any())
                    {
                        <div class="comment-reaction-icons">
                            @foreach (var reactionType in ReactionBreakdown.Keys.OrderByDescending(k => ReactionBreakdown[k]).Take(3))
                            {
                                <span class="comment-reaction-icon">@GetReactionEmoji(reactionType)</span>
                            }
                        </div>
                    }
                    <span class="comment-like-count">@LikeCount</span>
                </div>
            }
        </div>
        }

        @if (showReplyEditor && !isEditMode)
        {
            <div class="comment-reply-editor" @ref="replyEditorRef">
                @if (!string.IsNullOrEmpty(CurrentUserImageUrl))
                {
                    <img src="@CurrentUserImageUrl" alt="You" class="reply-user-avatar" />
                }
                else
                {
                    <div class="reply-user-avatar reply-avatar-placeholder">
                        <span class="reply-avatar-initial">@GetInitials(CurrentUserName ?? "User")</span>
                    </div>
                }
                <div class="reply-editor-wrapper">
                    <MultiLineCommentEditor OnCommentSubmitted="@HandleReplySubmitted" />
                </div>
            </div>
        }

        @if (Replies != null && Replies.Any() && !isEditMode)
        {
            @if (Depth == 0 && !showReplies)
            {
                <div class="comment-view-replies">
                    <button type="button" class="view-replies-button" @onclick="ToggleReplies">
                        @string.Format(Localizer["ViewReplies"], CountAllReplies(Replies))
                    </button>
                </div>
            }
            @if (Depth > 0 || showReplies)
            {
                <div class="comment-replies">
                    @foreach (var reply in Replies)
                    {
                        <MultiLineCommentDisplay 
                            CommentId="@reply.CommentId"
                            UserName="@reply.UserName"
                            UserImageUrl="@reply.UserImageUrl"
                            CommentText="@reply.CommentText"
                            ImageUrl="@reply.ImageUrl"
                            Timestamp="@reply.Timestamp"
                            Replies="@reply.Replies"
                            LikeCount="@reply.LikeCount"
                            UserReaction="@reply.UserReaction"
                            ReactionBreakdown="@reply.ReactionBreakdown"
                            CurrentUserId="@CurrentUserId"
                            CurrentUserImageUrl="@CurrentUserImageUrl"
                            CurrentUserName="@CurrentUserName"
                            CommentAuthorId="@reply.CommentAuthorId"
                            Depth="@(Depth + 1)"
                            OnReactionChanged="@OnReactionChanged"
                            OnRemoveReaction="@OnRemoveReaction"
                            OnReplySubmitted="@OnReplySubmitted"
                            OnDeleteComment="@OnDeleteComment"
                            OnEditComment="@OnEditComment"
                            OnCommentUpdated="@OnCommentUpdated"
                            OnReportComment="@OnReportComment" />
                    }
                </div>
                @if (Depth == 0 && showReplies)
                {
                    <div class="comment-hide-replies">
                        <button type="button" class="hide-replies-button" @onclick="ToggleReplies">
                            @Localizer["HideReplies"]
                        </button>
                    </div>
                }
            }
        }
    </div>
</div>

<!-- Profile Preview Popup (hover-triggered) -->
@if (commentAuthorUser != null)
{
    <ProfilePreviewPopup 
        User="@commentAuthorUser"
        IsVisible="@showProfilePreviewPopup"
        MutualFriendsCount="0"
        PositionX="@popupPositionX"
        PositionY="@popupPositionY"
        OnMouseEnter="@HandlePopupMouseEnter"
        OnMouseLeave="@HandlePopupMouseLeave" />
}

@code {
    [Parameter]
    public int CommentId { get; set; }

    [Parameter]
    public string UserName { get; set; } = "Anonymous";

    [Parameter]
    public string? UserImageUrl { get; set; }

    [Parameter]
    public string CommentText { get; set; } = "";

    [Parameter]
    public string? ImageUrl { get; set; }

    [Parameter]
    public DateTime Timestamp { get; set; } = DateTime.Now;

    [Parameter]
    public List<CommentDisplayModel>? Replies { get; set; }

    [Parameter]
    public int LikeCount { get; set; } = 0;

    [Parameter]
    public LikeType? UserReaction { get; set; }

    [Parameter]
    public Dictionary<LikeType, int>? ReactionBreakdown { get; set; }

    [Parameter]
    public string? CurrentUserId { get; set; }

    [Parameter]
    public string? CommentAuthorId { get; set; }

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public int Depth { get; set; } = 0;

    [Parameter]
    public EventCallback<(int CommentId, LikeType ReactionType)> OnReactionChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnRemoveReaction { get; set; }

    [Parameter]
    public EventCallback<(int ParentCommentId, string Content)> OnReplySubmitted { get; set; }

    /// <summary>
    /// Event callback invoked when the user requests to delete their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnDeleteComment { get; set; }

    /// <summary>
    /// Event callback invoked when the user requests to edit their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string CurrentContent)> OnEditComment { get; set; }

    /// <summary>
    /// Event callback invoked when the comment is successfully updated with new content.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string NewContent)> OnCommentUpdated { get; set; }

    /// <summary>
    /// Event callback invoked when the user requests to report another user's comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnReportComment { get; set; }

    /// <summary>
    /// Controls whether the hover preview popup is enabled.
    /// </summary>
    [Parameter]
    public bool EnableHoverPreview { get; set; } = true;

    private bool showReactionPicker = false;
    private bool showReplyEditor = false;
    private bool showReplies = false;
    private bool showCommentMenu = false;
    private bool isEditMode = false;
    private string editedCommentText = "";
    private List<PopupMenu.PopupMenuItem> commentMenuItems = new();
    private System.Threading.Timer? hideTimer;
    private ElementReference replyEditorRef;
    private ElementReference commentElement;
    private IJSObjectReference? jsModule;
    private MultiLineCommentEditor? commentEditor;

    // Hover preview popup state
    private bool showProfilePreviewPopup = false;
    private double popupPositionX = 0;
    private double popupPositionY = 0;
    private System.Threading.Timer? profileHoverTimer;
    private bool isMouseOverAvatar = false;
    private bool isMouseOverPopup = false;
    private ApplicationUser? commentAuthorUser = null;
    private bool isLoadingAuthor = false;
    private string commentAvatarId = $"comment-avatar-{Guid.NewGuid():N}";

    // Hover delay in milliseconds (1 second)
    private const int ProfileHoverDelayMs = 1000;

    private bool IsOwnComment => !string.IsNullOrEmpty(CurrentUserId) && !string.IsNullOrEmpty(CommentAuthorId) && CurrentUserId == CommentAuthorId;

    // Show like button if: user is logged in AND (either CommentAuthorId is missing OR it's not the user's own comment)
    private bool ShouldShowLikeButton => !string.IsNullOrEmpty(CurrentUserId) && (string.IsNullOrEmpty(CommentAuthorId) || CurrentUserId != CommentAuthorId);

    // Show reply button if: user is logged in AND depth hasn't reached the maximum
    private bool ShouldShowReplyButton => !string.IsNullOrEmpty(CurrentUserId) && Depth < SiteSettings.Value.MaxFeedPostCommentDepth;

    // Can save edit if the text is not empty, not just whitespace, and different from original
    private bool CanSaveEdit => !string.IsNullOrWhiteSpace(editedCommentText) && editedCommentText.Trim() != CommentText.Trim();

    /// <summary>
    /// Toggles the comment menu visibility and builds the menu items based on ownership.
    /// </summary>
    private void ToggleCommentMenu()
    {
        showCommentMenu = !showCommentMenu;
        if (showCommentMenu)
        {
            BuildCommentMenuItems();
        }
        StateHasChanged();
    }

    /// <summary>
    /// Closes the comment menu.
    /// </summary>
    private void CloseCommentMenu()
    {
        showCommentMenu = false;
        StateHasChanged();
    }

    /// <summary>
    /// Builds the menu items based on whether the current user owns the comment.
    /// Owner sees: Delete My Comment, Edit My Comment
    /// Non-owner sees: Report Comment
    /// </summary>
    private void BuildCommentMenuItems()
    {
        commentMenuItems.Clear();

        if (IsOwnComment)
        {
            // Owner menu items
            commentMenuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = Localizer["DeleteMyComment"],
                Icon = "bi bi-trash",
                OnClick = EventCallback.Factory.Create(this, HandleDeleteComment)
            });
            commentMenuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = Localizer["EditMyComment"],
                Icon = "bi bi-pencil",
                OnClick = EventCallback.Factory.Create(this, HandleEditComment)
            });
        }
        else
        {
            // Non-owner menu items
            commentMenuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = Localizer["ReportComment"],
                Icon = "bi bi-flag",
                OnClick = EventCallback.Factory.Create(this, HandleReportComment)
            });
        }
    }

    /// <summary>
    /// Handles the delete comment action by invoking the OnDeleteComment callback.
    /// </summary>
    private async Task HandleDeleteComment()
    {
        showCommentMenu = false;
        if (OnDeleteComment.HasDelegate)
        {
            await OnDeleteComment.InvokeAsync(CommentId);
        }
    }

    /// <summary>
    /// Handles the edit comment action by activating inline edit mode.
    /// </summary>
    private async Task HandleEditComment()
    {
        showCommentMenu = false;
        editedCommentText = CommentText;
        isEditMode = true;
        StateHasChanged();

        // Wait for the editor to render, then focus it
        await Task.Delay(100); // Small delay to ensure editor is rendered
        if (commentEditor != null)
        {
            await commentEditor.FocusAsync();
        }
    }

    /// <summary>
    /// Saves the edited comment by invoking the OnCommentUpdated callback.
    /// </summary>
    private async Task SaveEdit()
    {
        // Get the latest text from the editor component
        if (commentEditor != null)
        {
            editedCommentText = commentEditor.CommentText;
        }

        if (!CanSaveEdit) return;

        if (OnCommentUpdated.HasDelegate)
        {
            await OnCommentUpdated.InvokeAsync((CommentId, editedCommentText));
        }

        isEditMode = false;
        StateHasChanged();
    }

    /// <summary>
    /// Cancels the edit and returns to normal display mode.
    /// </summary>
    private void CancelEdit()
    {
        isEditMode = false;
        editedCommentText = "";
        StateHasChanged();
    }

    /// <summary>
    /// Handles when the user submits via the editor (Enter key).
    /// </summary>
    private async Task HandleEditSubmitted(string content)
    {
        editedCommentText = content;
        if (CanSaveEdit)
        {
            await SaveEdit();
        }
    }

    /// <summary>
    /// Handles the report comment action by invoking the OnReportComment callback.
    /// </summary>
    private async Task HandleReportComment()
    {
        showCommentMenu = false;
        if (OnReportComment.HasDelegate)
        {
            await OnReportComment.InvokeAsync(CommentId);
        }
    }

    private void ShowReactionPicker()
    {
        if (IsOwnComment) return;

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void CancelHideTimer()
    {
        if (IsOwnComment) return;

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void StartHideTimer()
    {
        hideTimer?.Dispose();
        hideTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                showReactionPicker = false;
                StateHasChanged();
            });
        }, null, 500, Timeout.Infinite);
    }

    private async Task HandleReaction(LikeType reactionType)
    {
        showReactionPicker = false;
        await OnReactionChanged.InvokeAsync((CommentId, reactionType));
    }

    private async Task HandleRemoveReaction()
    {
        showReactionPicker = false;
        if (OnRemoveReaction.HasDelegate)
        {
            await OnRemoveReaction.InvokeAsync(CommentId);
        }
    }

    private async Task OnLikeClick()
    {
        await OnReactionChanged.InvokeAsync((CommentId, LikeType.Like));
    }

    /// <summary>
    /// Toggles the visibility of reply comments
    /// </summary>
    private void ToggleReplies()
    {
        showReplies = !showReplies;
        StateHasChanged();
    }

    private async Task ToggleReplyEditor()
    {
        showReplyEditor = !showReplyEditor;
        StateHasChanged();

        // If showing the editor, scroll it into view after a short delay to ensure it's rendered
        if (showReplyEditor)
        {
            await Task.Delay(50); // Small delay to ensure the element is rendered
            await ScrollReplyEditorIntoView();
        }
    }

    private async Task ScrollReplyEditorIntoView()
    {
        try
        {
            // Try PostDetailModal first
            jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/SocialFeed/PostDetailModal.razor.js");
            await jsModule.InvokeVoidAsync("scrollReplyEditorIntoView", replyEditorRef);
        }
        catch
        {
            try
            {
                // Try GroupPostDetailModal if PostDetailModal fails
                jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/SocialFeed/GroupPostDetailModal.razor.js");
                await jsModule.InvokeVoidAsync("scrollReplyEditorIntoView", replyEditorRef);
            }
            catch (Exception)
            {
                // Silently fail - scrolling not critical
            }
        }
    }

    private async Task HandleReplySubmitted(string content)
    {
        if (OnReplySubmitted.HasDelegate && !string.IsNullOrWhiteSpace(content))
        {
            await OnReplySubmitted.InvokeAsync((CommentId, content));
            showReplyEditor = false;

            // Keep replies visible after submitting a reply at the top level
            if (Depth == 0)
            {
                showReplies = true;
            }

            StateHasChanged();
        }
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
            return "U";

        if (parts.Length == 1)
        {
            var singleWord = parts[0];
            if (singleWord.Length >= 2)
                return singleWord.Substring(0, 2).ToUpper();
            else
                return singleWord.Substring(0, 1).ToUpper();
        }

        return $"{parts[0].Substring(0, 1)}{parts[^1].Substring(0, 1)}".ToUpper();
    }

    /// <summary>
    /// Recursively counts all nested replies (children, grandchildren, etc.)
    /// </summary>
    /// <param name="replies">The list of replies to count</param>
    /// <returns>Total count of all nested replies</returns>
    private int CountAllReplies(List<CommentDisplayModel>? replies)
    {
        if (replies == null || !replies.Any())
            return 0;

        int count = replies.Count;
        foreach (var reply in replies)
        {
            count += CountAllReplies(reply.Replies);
        }
        return count;
    }

    private string GetReactionEmoji(LikeType reactionType)
    {
        return reactionType switch
        {
            LikeType.Like => "👍",
            LikeType.Love => "❤️",
            LikeType.Care => "🤗",
            LikeType.Haha => "😂",
            LikeType.Wow => "😮",
            LikeType.Sad => "😢",
            LikeType.Angry => "😠",
            _ => "👍"
        };
    }

    private string GetReactionText(LikeType reactionType)
    {
        return reactionType switch
        {
            LikeType.Like => Localizer["Like"],
            LikeType.Love => Localizer["Love"],
            LikeType.Care => Localizer["Care"],
            LikeType.Haha => Localizer["Haha"],
            LikeType.Wow => Localizer["Wow"],
            LikeType.Sad => Localizer["Sad"],
            LikeType.Angry => Localizer["Angry"],
            _ => Localizer["Like"]
        };
    }

    private string FormattedTimestamp => FormatTimestamp(Timestamp);

    private string FullTimestamp => Timestamp.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm:ss tt");

    private string FormatTimestamp(DateTime timestamp)
    {
        var timeSpan = DateTime.UtcNow - timestamp;

        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d";

        return timestamp.ToLocalTime().ToString("MMMM d 'at' h:mm tt");
    }

    private string FormatContentWithLineBreaks(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;

        // SECURITY: Sanitize user content to prevent XSS attacks
        return HtmlSanitizationService.SanitizeAndFormatContent(content);
    }

    private async Task OnImageClick()
    {
        await JS.InvokeVoidAsync("alert", "Image Clicked");
    }

    /// <summary>
    /// Handles mouse entering the comment author avatar area.
    /// Starts a timer to show the popup after the hover delay.
    /// </summary>
    private async Task HandleAvatarMouseEnter()
    {
        if (!EnableHoverPreview || string.IsNullOrEmpty(CommentAuthorId)) return;

        isMouseOverAvatar = true;

        // Cancel any existing timer
        CancelProfileHoverTimer();

        // Calculate popup position
        await CalculatePopupPosition();

        // Start loading author data if not already loaded
        if (commentAuthorUser == null && !isLoadingAuthor)
        {
            isLoadingAuthor = true;
            try
            {
                commentAuthorUser = await UserManager.FindByIdAsync(CommentAuthorId);
            }
            catch
            {
                commentAuthorUser = null;
            }
            finally
            {
                isLoadingAuthor = false;
            }
        }

        // Start a new timer to show popup after delay
        profileHoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (isMouseOverAvatar && commentAuthorUser != null)
                {
                    showProfilePreviewPopup = true;
                    StateHasChanged();
                }
            }),
            state: null,
            dueTime: ProfileHoverDelayMs,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse leaving the comment author avatar area.
    /// Hides the popup after a short delay if mouse is not over the popup.
    /// </summary>
    private void HandleAvatarMouseLeave()
    {
        isMouseOverAvatar = false;
        CancelProfileHoverTimer();

        // Use a short delay to allow mouse to move to popup
        profileHoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverAvatar && !isMouseOverPopup)
                {
                    HideProfilePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse entering the popup (keeps it visible).
    /// </summary>
    private void HandlePopupMouseEnter()
    {
        isMouseOverPopup = true;
        CancelProfileHoverTimer();
    }

    /// <summary>
    /// Handles mouse leaving the popup.
    /// </summary>
    private void HandlePopupMouseLeave()
    {
        isMouseOverPopup = false;

        // Use a short delay before hiding
        profileHoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverAvatar && !isMouseOverPopup)
                {
                    HideProfilePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Calculates the position for the popup based on the avatar location.
    /// </summary>
    private async Task CalculatePopupPosition()
    {
        try
        {
            var rect = await JS.InvokeAsync<BoundingClientRect>(
                "eval",
                $"(function() {{ var el = document.getElementById('{commentAvatarId}'); if (el) {{ var r = el.getBoundingClientRect(); return {{ left: r.left, top: r.top, width: r.width, height: r.height }}; }} return null; }})()"
            );

            if (rect != null)
            {
                // Position popup below and to the right of the avatar
                popupPositionX = rect.Left;
                popupPositionY = rect.Top + rect.Height + 10;

                // Ensure popup doesn't go off-screen on the left
                if (popupPositionX < 10) popupPositionX = 10;

                // Check if popup would go off-screen on the right (assuming 280px min width)
                var viewportWidth = await JS.InvokeAsync<double>("eval", "window.innerWidth");
                if (popupPositionX + 280 > viewportWidth - 10)
                {
                    popupPositionX = viewportWidth - 290;
                }

                // Check if popup would go off-screen at the bottom (assuming ~200px height)
                var viewportHeight = await JS.InvokeAsync<double>("eval", "window.innerHeight");
                if (popupPositionY + 200 > viewportHeight - 10)
                {
                    // Position above the avatar instead
                    popupPositionY = rect.Top - 210;
                    if (popupPositionY < 10) popupPositionY = 10;
                }
            }
            else
            {
                // Fallback position
                popupPositionX = 100;
                popupPositionY = 100;
            }
        }
        catch
        {
            // Fallback position
            popupPositionX = 100;
            popupPositionY = 100;
        }
    }

    /// <summary>
    /// Cancels the profile hover timer if active.
    /// </summary>
    private void CancelProfileHoverTimer()
    {
        profileHoverTimer?.Dispose();
        profileHoverTimer = null;
    }

    /// <summary>
    /// Hides the profile popup and resets state.
    /// </summary>
    private void HideProfilePopup()
    {
        showProfilePreviewPopup = false;
        StateHasChanged();
    }

    /// <summary>
    /// Helper class for bounding client rect from JavaScript.
    /// </summary>
    private class BoundingClientRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        hideTimer?.Dispose();
        CancelProfileHoverTimer();

        if (jsModule != null)
        {
            try
            {
                await jsModule.DisposeAsync();
            }
            catch
            {
                // Ignore disposal errors
            }
        }
    }
}
