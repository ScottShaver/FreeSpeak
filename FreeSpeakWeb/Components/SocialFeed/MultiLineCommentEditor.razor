@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Services
@using Microsoft.Extensions.Localization
@inject IJSRuntime JS
@inject IStringLocalizer<FreeSpeakWeb.Resources.SocialFeed.MultiLineCommentEditor> Localizer

@implements IAsyncDisposable

<div class="comment-editor">
    <div style="position: relative; display: flex; align-items: center; gap: 4px;">
        <button type="button" class="emoji-button-comment" @onclick="ToggleEmojiPicker" @ref="emojiButtonElement" title="@Localizer["AddEmoji"]">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M4.285 9.567a.5.5 0 0 1 .683.183A3.498 3.498 0 0 0 8 11.5a3.498 3.498 0 0 0 3.032-1.75.5.5 0 1 1 .866.5A4.498 4.498 0 0 1 8 12.5a4.498 4.498 0 0 1-3.898-2.25.5.5 0 0 1 .183-.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z"/>
            </svg>
        </button>
        <EmojiPicker IsVisible="@showEmojiPicker"
                    OnClose="@CloseEmojiPicker"
                    OnEmojiSelect="@HandleEmojiSelected"
                    PositionStyle="@emojiPickerPositionStyle" />
    </div>

    <textarea 
        @bind="CommentText"
        @bind:event="oninput"
        @bind:after="HandleInputAfter"
        @ref="textareaElement"
        @onkeydown="HandleKeyDown"
        placeholder="@Localizer["WriteAComment"]"
        rows="1"
        class="comment-textarea"></textarea>

    <button
        type="button" 
        class="submit-arrow @(CanSubmit ? "active" : "disabled")"
        disabled="@(!CanSubmit)"
        @onclick="OnSubmitComment">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
        </svg>
    </button>
</div>

@code {
    private ElementReference textareaElement;
    private ElementReference emojiButtonElement;
    private string commentText = "";
    private IJSObjectReference? module;
    private bool showEmojiPicker = false;
    private string emojiPickerPositionStyle = string.Empty;
    private bool _disposed = false;

    [Parameter]
    public string CommentText 
    { 
        get => commentText;
        set => commentText = value;
    }

    [Parameter]
    public EventCallback<string> CommentTextChanged { get; set; }

    [Parameter]
    public EventCallback<string> OnCommentSubmitted { get; set; }

    private bool CanSubmit => !string.IsNullOrWhiteSpace(CommentText);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/SocialFeed/MultiLineCommentEditor.razor.js");
        }
    }

    private async Task HandleInputAfter()
    {
        // Auto-replace text emojis with cursor preservation
        var originalContent = CommentText;
        var newContent = EmojiService.ReplaceTextEmojis(CommentText);

        if (originalContent != newContent && module is not null)
        {
            // Use JavaScript to update text while preserving cursor position
            try
            {
                await module.InvokeVoidAsync("replaceTextPreserveCursor", textareaElement, newContent);
                CommentText = newContent;
            }
            catch
            {
                // Fallback to normal assignment
                CommentText = newContent;
            }
        }

        // Resize the textarea
        if (module is not null)
        {
            await module.InvokeVoidAsync("resizeTextarea", textareaElement);
        }

        // Notify parent of text change
        if (CommentTextChanged.HasDelegate)
        {
            await CommentTextChanged.InvokeAsync(CommentText);
        }

        // If content changed due to emoji replacement, update the UI
        if (originalContent != CommentText)
        {
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Handle Escape key to clear text
        if (e.Key == "Escape" && !string.IsNullOrWhiteSpace(CommentText))
        {
            CommentText = "";
            if (module is not null)
            {
                await module.InvokeVoidAsync("resizeTextarea", textareaElement);
            }
            StateHasChanged();
        }
        // Handle Enter key to resize textarea
        else if (e.Key == "Enter")
        {
            // Give the textarea a moment to update with the new line, then resize
            await Task.Delay(10);
            if (module is not null)
            {
                await module.InvokeVoidAsync("resizeTextarea", textareaElement);
            }
        }
    }

    private async Task ToggleEmojiPicker()
    {
        if (showEmojiPicker)
        {
            CloseEmojiPicker();
        }
        else
        {
            showEmojiPicker = true;

            // Calculate position using JavaScript
            if (module is not null)
            {
                emojiPickerPositionStyle = await module.InvokeAsync<string>("calculateEmojiPickerPosition", emojiButtonElement);
            }
            else
            {
                emojiPickerPositionStyle = "left: 0; bottom: 40px;";
            }

            StateHasChanged();
        }
    }

    private async Task HandleEmojiSelected(string emoji)
    {
        if (module != null)
        {
            try
            {
                // Insert emoji at cursor position using JavaScript
                var newContent = await module.InvokeAsync<string>("insertTextAtCursor", textareaElement, emoji);
                CommentText = newContent;

                // Resize the textarea
                await module.InvokeVoidAsync("resizeTextarea", textareaElement);
            }
            catch (Exception)
            {
                // Fallback to appending
                CommentText += emoji;
                if (module is not null)
                {
                    await module.InvokeVoidAsync("resizeTextarea", textareaElement);
                }
            }
        }
        else
        {
            // Fallback if module not loaded
            CommentText += emoji;
        }
        StateHasChanged();
    }

    private void CloseEmojiPicker()
    {
        showEmojiPicker = false;
        StateHasChanged();
    }

    private async Task OnSubmitComment()
    {
        if (CanSubmit)
        {
            var textToSubmit = CommentText;
            CommentText = "";

            // Reset textarea to single-line collapsed state BEFORE invoking callback
            // This prevents accessing a disposed module if the callback causes re-rendering
            if (module is not null && !_disposed)
            {
                try
                {
                    await module.InvokeVoidAsync("resetTextarea", textareaElement);
                }
                catch (ObjectDisposedException)
                {
                    // Component was disposed during the operation, ignore
                }
                catch (JSDisconnectedException)
                {
                    // Circuit disconnected, ignore
                }
            }

            // Invoke the parent callback last, as it may cause this component to be disposed/recreated
            if (OnCommentSubmitted.HasDelegate)
            {
                await OnCommentSubmitted.InvokeAsync(textToSubmit);
            }

            // Only call StateHasChanged if we haven't been disposed
            if (!_disposed)
            {
                StateHasChanged();
            }
        }
    }

    /// <summary>
    /// Focuses the textarea element and moves the cursor to the end.
    /// </summary>
    public async Task FocusAsync()
    {
        if (module is not null && !_disposed)
        {
            try
            {
                await module.InvokeVoidAsync("focusTextarea", textareaElement);
            }
            catch (Exception)
            {
                // Silently fail if focus fails
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already disconnected, no action needed
            }
        }
    }
}
