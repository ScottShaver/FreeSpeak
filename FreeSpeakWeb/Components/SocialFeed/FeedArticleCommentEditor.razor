@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<FreeSpeakWeb.Resources.SocialFeed.FeedArticleCommentEditor> Localizer

@if (!HideCommentEditor && !IsReadOnly)
{
    @if (!HasReachedCommentLimit)
    {
        <div class="article-comment-editor">
            <UserAvatar ImageUrl="@CurrentUserImageUrl" 
                        Name="@(CurrentUserName ?? "User")" 
                        Size="sm"
                        CssClass="comment-user-avatar" />
            <div class="editor-wrapper">
                <MultiLineCommentEditor OnCommentSubmitted="OnCommentSubmitted" />
            </div>
        </div>
    }
    else
    {
        <div class="article-comment-limit-message">
            <span>@Localizer["NoMoreCommentsAllowed"]</span>
        </div>
    }
}

@code {
    [Parameter]
    public bool HideCommentEditor { get; set; } = false;

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public bool HasReachedCommentLimit { get; set; } = false;

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public EventCallback<string> OnCommentSubmitted { get; set; }
}
