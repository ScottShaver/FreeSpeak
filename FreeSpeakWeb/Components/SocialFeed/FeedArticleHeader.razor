@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Components.Groups
@using FreeSpeakWeb.Components.Friends
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@using Microsoft.Extensions.Localization
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Identity

@implements IDisposable

@inject IStringLocalizer<FreeSpeakWeb.Resources.SocialFeed.FeedArticleHeader> Localizer
@inject TimestampFormattingService TimestampFormatter
@inject IJSRuntime JSRuntime
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager
@inject GroupPointsService GroupPointsService

<div class="article-header @GetAudienceHeaderClass()" @ref="headerElement">
    @if (!string.IsNullOrEmpty(AuthorImageUrl))
    {
        <img src="@AuthorImageUrl" 
             alt="@AuthorName" 
             class="author-avatar" 
             id="@avatarElementId"
             @onmouseenter="HandleMouseEnter"
             @onmouseleave="HandleMouseLeave" />
    }
    else
    {
        <div class="author-avatar author-avatar-placeholder"
             id="@avatarElementId"
             @onmouseenter="HandleMouseEnter"
             @onmouseleave="HandleMouseLeave">
            <span class="author-avatar-initial">@GetInitials(AuthorName)</span>
        </div>
    }
    <div class="author-info">
        <div class="author-name-container">
            <span class="author-name">
                @if (!string.IsNullOrEmpty(GroupName) && GroupId.HasValue)
                {
                    <a href="@($"/group/{GroupId}")" class="group-name-link">@GroupName</a>
                    <span> &gt; </span>
                }
                @if (!string.IsNullOrEmpty(AuthorId) && !IsOwnAuthor)
                {
                    <a href="@($"/friend/{AuthorId}")" class="author-name-link">@AuthorName</a>
                }
                else
                {
                    @AuthorName
                }
            </span>
            @if (GroupId.HasValue && EnablePointsSystem && AuthorGroupPoints.HasValue)
            {
                <MemberLevelBadge 
                    Level="@GroupPointsService.GetMemberLevel(AuthorGroupPoints.Value)"
                    Points="@AuthorGroupPoints"
                    ShowText="true"
                    ShowPoints="false"
                    ShowForAllLevels="true"
                    CssClass="ms-1 badge-sm" />
            }
            @if (GroupId.HasValue && IsGroupAdmin)
            {
                <RoleBadge 
                    Role="RoleType.GroupAdmin"
                    ShowText="true"
                    CssClass="ms-1" />
            }
            @if (GroupId.HasValue && IsGroupModerator)
            {
                <RoleBadge 
                    Role="RoleType.GroupModerator"
                    ShowText="true"
                    CssClass="ms-1" />
            }
        </div>
        <div class="article-timestamp-container">
            <span class="article-timestamp" title="@FullTimestamp">@FormattedTimestamp</span>
            @if (AudienceType == AudienceType.Public)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                    <title>@Localizer["Public"]</title>
                    <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM2.04 4.326c.325 1.329 2.532 2.54 3.717 3.19.48.263.793.434.743.484-.08.08-.162.158-.242.234-.416.396-.787.749-.758 1.266.035.634.618.824 1.214 1.017.577.188 1.168.38 1.286.983.082.417-.075.988-.22 1.52-.215.782-.406 1.48.22 1.48 1.5-.5 3.798-3.186 4-5 .138-1.243-2-2-3.5-2.5-.478-.16-.755.081-.99.284-.172.15-.322.279-.51.216-.445-.148-2.5-2-1.5-2.5.78-.39.952-.171 1.227.182.078.099.163.208.273.318.609.304.662-.132.723-.633.039-.322.081-.671.277-.867.434-.434 1.265-.791 2.028-1.12.712-.306 1.365-.587 1.579-.88A7 7 0 1 1 2.04 4.327Z"/>
                </svg>
            }
            else if (AudienceType == AudienceType.FriendsOnly)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                    <title>@Localizer["FriendsOnly"]</title>
                    <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>
                </svg>
            }
            else if (AudienceType == AudienceType.MeOnly)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                    <title>@Localizer["OnlyMe"]</title>
                    <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                </svg>
            }
            @if (IsPinned)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#0066cc" class="pinned-icon" viewBox="0 0 16 16">
                    <title>@Localizer["PinnedPost"]</title>
                    <path d="M9.828.722a.5.5 0 0 1 .354.146l4.95 4.95a.5.5 0 0 1 0 .707c-.48.48-1.072.588-1.503.588-.177 0-.335-.018-.46-.039l-3.134 3.134a5.927 5.927 0 0 1 .16 1.013c.046.702-.032 1.687-.72 2.375a.5.5 0 0 1-.707 0l-2.829-2.828-3.182 3.182c-.195.195-1.219.902-1.414.707-.195-.195.512-1.22.707-1.414l3.182-3.182-2.828-2.829a.5.5 0 0 1 0-.707c.688-.688 1.673-.767 2.375-.72a5.922 5.922 0 0 1 1.013.16l3.134-3.133a2.772 2.772 0 0 1-.04-.461c0-.43.108-1.022.589-1.503a.5.5 0 0 1 .353-.146z"/>
                </svg>
            }
        </div>
    </div>

    <!-- Embedded Actions (compact, centered in header) -->
    <FeedArticleActions 
        IsReadOnly="@IsReadOnly"
        IsOwnPost="@IsOwnPost"
        IsModalView="@IsModalView"
        ArticlePostType="@ArticlePostType"
        AudienceType="@AudienceType"
        UserReaction="@UserReaction"
        ShowReactionPicker="@ShowReactionPicker"
        OnShowReactionPicker="@OnShowReactionPicker"
        OnStartHideTimer="@OnStartHideTimer"
        OnCancelHideTimer="@OnCancelHideTimer"
        OnLikeClick="@OnLikeClick"
        OnReactionPicked="@OnReactionPicked"
        OnRemoveReaction="@OnRemoveReaction"
        OnCommentClick="@OnCommentButtonClick"
        OnShareClick="@OnShareClick" />

    <div class="header-stats">
        @if (IsModalView || IsReadOnly)
        {
            <div class="header-stat-item" title="@Localizer["Likes"]">
                @if (ReactionBreakdown != null && ReactionBreakdown.Any())
                {
                    <div class="header-reaction-icons">
                        @foreach (var reactionType in ReactionBreakdown.Keys.OrderByDescending(k => ReactionBreakdown[k]).Take(3))
                        {
                            <span class="header-reaction-icon">@GetReactionEmoji(reactionType)</span>
                        }
                    </div>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="header-like-icon" viewBox="0 0 16 16">
                        <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2.144 2.144 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a9.84 9.84 0 0 0-.443.05 9.365 9.365 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111L8.864.046zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a8.908 8.908 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.224 2.224 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.866.866 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                    </svg>
                }
                <span class="header-stat-count">@LikeCount</span>
            </div>
        }
        else
        {
            <div class="header-stat-item header-stat-clickable" title="@Localizer["ClickToSeeLikes"]" @onclick="HandleShowLikesModal">
                @if (ReactionBreakdown != null && ReactionBreakdown.Any())
                {
                    <div class="header-reaction-icons">
                        @foreach (var reactionType in ReactionBreakdown.Keys.OrderByDescending(k => ReactionBreakdown[k]).Take(3))
                        {
                            <span class="header-reaction-icon">@GetReactionEmoji(reactionType)</span>
                        }
                    </div>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="header-like-icon" viewBox="0 0 16 16">
                        <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2.144 2.144 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a9.84 9.84 0 0 0-.443.05 9.365 9.365 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111L8.864.046zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a8.908 8.908 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.224 2.224 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.866.866 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                    </svg>
                }
                <span class="header-stat-count">@LikeCount</span>
            </div>
        }
        @if (IsModalView || IsReadOnly)
        {
            <div class="header-stat-item" title="@Localizer["Comments"]">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="header-comment-icon" viewBox="0 0 16 16">
                    <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                </svg>
                <span class="header-stat-count">@CommentCount</span>
            </div>
        }
        else
        {
            <div class="header-stat-item header-stat-clickable" title="@Localizer["ClickToViewComments"]" @onclick="HandleCommentCountClick">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="header-comment-icon" viewBox="0 0 16 16">
                    <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                </svg>
                <span class="header-stat-count">@CommentCount</span>
            </div>
        }
        <div class="header-stat-item" title="@Localizer["Shares"]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="header-share-icon" viewBox="0 0 16 16">
                <path d="M11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5z"/>
            </svg>
            <span class="header-stat-count">@ShareCount</span>
        </div>
    </div>
    <div id="@_menuAnchorId" style="position: relative; z-index: 10;">
        <button type="button" 
                class="menu-button" 
                @onclick="ToggleMenu">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
            </svg>
        </button>
        <PopupMenu IsVisible="@ShowMenu" 
                   MenuItems="@MenuItems" 
                   OnClose="@OnCloseMenu"
                   PositionStyle="@MenuPositionStyle"
                   UsePortal="@UsePortalMenu"
                   AnchorElementId="@_menuAnchorId"
                   Placement="PopupPlacement.BottomEnd" />
    </div>
</div>

<!-- Profile Preview Popup (hover-triggered) -->
@if (authorUser != null)
{
    <ProfilePreviewPopup 
        User="@authorUser"
        IsVisible="@showProfilePreviewPopup"
        MutualFriendsCount="0"
        PositionX="@popupPositionX"
        PositionY="@popupPositionY"
        OnMouseEnter="@HandlePopupMouseEnter"
        OnMouseLeave="@HandlePopupMouseLeave" />
}

@code {
    [Parameter]
    public string AuthorName { get; set; } = "Anonymous";

    [Parameter]
    public string? AuthorImageUrl { get; set; }

    /// <summary>
    /// The author's user ID for loading profile preview data.
    /// </summary>
    [Parameter]
    public string? AuthorId { get; set; }

    /// <summary>
    /// The current logged-in user's ID, used to prevent linking to own profile.
    /// </summary>
    [Parameter]
    public string? CurrentUserId { get; set; }

    /// <summary>
    /// Controls whether the hover preview popup is enabled.
    /// </summary>
    [Parameter]
    public bool EnableHoverPreview { get; set; } = true;

    [Parameter]
    public DateTime CreatedAt { get; set; } = DateTime.Now;

    [Parameter]
    public AudienceType AudienceType { get; set; } = AudienceType.Public;

    [Parameter]
    public bool IsPinned { get; set; } = false;

    [Parameter]
    public int LikeCount { get; set; } = 0;

    [Parameter]
    public int CommentCount { get; set; } = 0;

    [Parameter]
    public int ShareCount { get; set; } = 0;

    [Parameter]
    public Dictionary<LikeType, int>? ReactionBreakdown { get; set; }

    [Parameter]
    public bool IsModalView { get; set; } = false;

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public EventCallback OnShowLikesModal { get; set; }

    [Parameter]
    public EventCallback OnCommentCountClick { get; set; }

    [Parameter]
    public bool ShowMenu { get; set; } = false;

    [Parameter]
    public List<PopupMenu.PopupMenuItem> MenuItems { get; set; } = new();

    [Parameter]
    public string MenuPositionStyle { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnToggleMenu { get; set; }

    [Parameter]
    public EventCallback OnCloseMenu { get; set; }

    /// <summary>
    /// When true, renders the popup menu through the portal at document body level.
    /// This prevents CSS overflow clipping issues in modal containers.
    /// </summary>
    [Parameter]
    public bool UsePortalMenu { get; set; } = false;

    [Parameter]
    public int? GroupId { get; set; }

    /// <summary>
    /// The name of the group where the post was made. When provided along with GroupId,
    /// the group name will be displayed as a clickable link before the author name.
    /// </summary>
    [Parameter]
    public string? GroupName { get; set; }

    [Parameter]
    public int? AuthorGroupPoints { get; set; }

    /// <summary>
    /// Indicates whether the points system is enabled for the group.
    /// When true, the member level badge will be displayed.
    /// </summary>
    [Parameter]
    public bool EnablePointsSystem { get; set; } = false;

    /// <summary>
    /// Indicates whether the author is an admin of the group.
    /// </summary>
    [Parameter]
    public bool IsGroupAdmin { get; set; } = false;

    /// <summary>
    /// Indicates whether the author is a moderator of the group.
    /// </summary>
    [Parameter]
    public bool IsGroupModerator { get; set; } = false;

    // ========================
    // Action Parameters (for embedded FeedArticleActions)
    // ========================

    /// <summary>
    /// Indicates whether the current user is the author of the post (for action display).
    /// </summary>
    [Parameter]
    public bool IsOwnPost { get; set; } = false;

    /// <summary>
    /// The type of post (UserPost or GroupPost) for determining share button visibility.
    /// </summary>
    [Parameter]
    public PostType ArticlePostType { get; set; } = PostType.UserPost;

    /// <summary>
    /// The current user's reaction type on the post.
    /// </summary>
    [Parameter]
    public LikeType? UserReaction { get; set; }

    /// <summary>
    /// Controls whether the reaction picker is visible.
    /// </summary>
    [Parameter]
    public bool ShowReactionPicker { get; set; } = false;

    /// <summary>
    /// Event callback for showing the reaction picker.
    /// </summary>
    [Parameter]
    public EventCallback OnShowReactionPicker { get; set; }

    /// <summary>
    /// Event callback for starting the hide timer on the reaction picker.
    /// </summary>
    [Parameter]
    public EventCallback OnStartHideTimer { get; set; }

    /// <summary>
    /// Event callback for canceling the hide timer on the reaction picker.
    /// </summary>
    [Parameter]
    public EventCallback OnCancelHideTimer { get; set; }

    /// <summary>
    /// Event callback for the like button click.
    /// </summary>
    [Parameter]
    public EventCallback OnLikeClick { get; set; }

    /// <summary>
    /// Event callback for when a reaction is picked.
    /// </summary>
    [Parameter]
    public EventCallback<LikeType> OnReactionPicked { get; set; }

    /// <summary>
    /// Event callback for removing the current reaction.
    /// </summary>
    [Parameter]
    public EventCallback OnRemoveReaction { get; set; }

    /// <summary>
    /// Event callback for the comment button click.
    /// </summary>
    [Parameter]
    public EventCallback OnCommentButtonClick { get; set; }

    /// <summary>
    /// Event callback for the share button click.
    /// </summary>
    [Parameter]
    public EventCallback OnShareClick { get; set; }

    /// <summary>
    /// Gets whether the current user is the author of this post.
    /// </summary>
    private bool IsOwnAuthor => !string.IsNullOrEmpty(CurrentUserId) && !string.IsNullOrEmpty(AuthorId) && CurrentUserId == AuthorId;

    private string FormattedTimestamp => TimestampFormatter.FormatTimeAgo(CreatedAt);
    private string FullTimestamp => CreatedAt.ToLocalTime().ToString("MMMM d, yyyy 'at' h:mm:ss tt");

    private string _menuAnchorId = $"header-menu-{Guid.NewGuid():N}";

    private string GetAudienceHeaderClass()
    {
        return AudienceType switch
        {
            AudienceType.Public => "header-public",
            AudienceType.FriendsOnly => "header-friends",
            AudienceType.MeOnly => "header-private",
            _ => "header-friends"
        };
    }

    /// <summary>
    /// Extracts initials from a name string.
    /// </summary>
    /// <param name="name">The name to extract initials from.</param>
    /// <returns>One or two character initials in uppercase.</returns>
    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
            return "U";

        if (parts.Length == 1)
        {
            var singleWord = parts[0];
            if (singleWord.Length >= 2)
                return singleWord.Substring(0, 2).ToUpper();
            else
                return singleWord.Substring(0, 1).ToUpper();
        }

        return $"{parts[0].Substring(0, 1)}{parts[^1].Substring(0, 1)}".ToUpper();
    }

    private string GetReactionEmoji(LikeType reactionType)
    {
        return reactionType switch
        {
            LikeType.Like => "👍",
            LikeType.Love => "❤️",
            LikeType.Care => "🤗",
            LikeType.Haha => "😂",
            LikeType.Wow => "😮",
            LikeType.Sad => "😢",
            LikeType.Angry => "😠",
            _ => "👍"
        };
    }

    private async Task ToggleMenu()
    {
        if (OnToggleMenu.HasDelegate)
        {
            await OnToggleMenu.InvokeAsync();
        }
    }

    private async Task HandleShowLikesModal()
    {
        if (OnShowLikesModal.HasDelegate)
        {
            await OnShowLikesModal.InvokeAsync();
        }
    }

    private async Task HandleCommentCountClick()
    {
        if (OnCommentCountClick.HasDelegate)
        {
            await OnCommentCountClick.InvokeAsync();
        }
    }

    // Hover preview popup state
    private bool showProfilePreviewPopup = false;
    private double popupPositionX = 0;
    private double popupPositionY = 0;
    private System.Threading.Timer? hoverTimer;
    private bool isMouseOverAvatar = false;
    private bool isMouseOverPopup = false;
    private ElementReference headerElement;
    private ApplicationUser? authorUser = null;
    private bool isLoadingAuthor = false;
    private string avatarElementId = $"author-avatar-{Guid.NewGuid():N}";

    // Hover delay in milliseconds (1 second)
    private const int HoverDelayMs = 1000;

    /// <summary>
    /// Handles mouse entering the author avatar area.
    /// Starts a timer to show the popup after the hover delay.
    /// </summary>
    private async Task HandleMouseEnter()
    {
        if (!EnableHoverPreview || string.IsNullOrEmpty(AuthorId)) return;

        isMouseOverAvatar = true;

        // Cancel any existing timer
        CancelHoverTimer();

        // Calculate popup position
        await CalculatePopupPosition();

        // Start loading author data if not already loaded
        if (authorUser == null && !isLoadingAuthor)
        {
            isLoadingAuthor = true;
            try
            {
                authorUser = await UserManager.FindByIdAsync(AuthorId);
            }
            catch
            {
                authorUser = null;
            }
            finally
            {
                isLoadingAuthor = false;
            }
        }

        // Start a new timer to show popup after delay
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (isMouseOverAvatar && authorUser != null)
                {
                    showProfilePreviewPopup = true;
                    StateHasChanged();
                }
            }),
            state: null,
            dueTime: HoverDelayMs,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse leaving the author avatar area.
    /// Hides the popup after a short delay if mouse is not over the popup.
    /// </summary>
    private void HandleMouseLeave()
    {
        isMouseOverAvatar = false;
        CancelHoverTimer();

        // Use a short delay to allow mouse to move to popup
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverAvatar && !isMouseOverPopup)
                {
                    HidePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Handles mouse entering the popup (keeps it visible).
    /// </summary>
    private void HandlePopupMouseEnter()
    {
        isMouseOverPopup = true;
        CancelHoverTimer();
    }

    /// <summary>
    /// Handles mouse leaving the popup.
    /// </summary>
    private void HandlePopupMouseLeave()
    {
        isMouseOverPopup = false;

        // Use a short delay before hiding
        hoverTimer = new System.Threading.Timer(
            callback: _ => InvokeAsync(() =>
            {
                if (!isMouseOverAvatar && !isMouseOverPopup)
                {
                    HidePopup();
                }
            }),
            state: null,
            dueTime: 150,
            period: System.Threading.Timeout.Infinite
        );
    }

    /// <summary>
    /// Calculates the position for the popup based on the avatar location.
    /// </summary>
    private async Task CalculatePopupPosition()
    {
        try
        {
            var rect = await JSRuntime.InvokeAsync<BoundingClientRect>(
                "eval",
                $"(function() {{ var el = document.getElementById('{avatarElementId}'); if (el) {{ var r = el.getBoundingClientRect(); return {{ left: r.left, top: r.top, width: r.width, height: r.height }}; }} return null; }})()"
            );

            if (rect != null)
            {
                // Position popup below the avatar, slightly to the right
                popupPositionX = rect.Left;
                popupPositionY = rect.Top + rect.Height + 10;

                // Ensure popup doesn't go off-screen on the left
                if (popupPositionX < 10) popupPositionX = 10;

                // Check if popup would go off-screen on the right (assuming 280px min width)
                var viewportWidth = await JSRuntime.InvokeAsync<double>("eval", "window.innerWidth");
                if (popupPositionX + 280 > viewportWidth - 10)
                {
                    popupPositionX = viewportWidth - 290;
                }

                // Check if popup would go off-screen at the bottom (assuming ~200px height)
                var viewportHeight = await JSRuntime.InvokeAsync<double>("eval", "window.innerHeight");
                if (popupPositionY + 200 > viewportHeight - 10)
                {
                    // Position above the avatar instead
                    popupPositionY = rect.Top - 210;
                    if (popupPositionY < 10) popupPositionY = 10;
                }
            }
            else
            {
                // Fallback position
                popupPositionX = 100;
                popupPositionY = 100;
            }
        }
        catch
        {
            // Fallback position
            popupPositionX = 100;
            popupPositionY = 100;
        }
    }

    /// <summary>
    /// Cancels the hover timer if active.
    /// </summary>
    private void CancelHoverTimer()
    {
        hoverTimer?.Dispose();
        hoverTimer = null;
    }

    /// <summary>
    /// Hides the popup and resets state.
    /// </summary>
    private void HidePopup()
    {
        showProfilePreviewPopup = false;
        StateHasChanged();
    }

    /// <summary>
    /// Helper class for bounding client rect from JavaScript.
    /// </summary>
    private class BoundingClientRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }

    /// <summary>
    /// Disposes of resources, including the hover timer.
    /// </summary>
    public void Dispose()
    {
        CancelHoverTimer();
    }
}
