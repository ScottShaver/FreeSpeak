@using FreeSpeakWeb.Data
@inject IJSRuntime JS

@if (Images != null && Images.Any())
{
    <div class="article-images">
        <div class="image-counter">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
            </svg>
            <span>@Images.Count @(Images.Count == 1 ? "image" : "images")</span>
        </div>

        @if (Images.Count > 1)
        {
            <button type="button" class="scroll-button scroll-left" @onclick="ScrollLeft" title="Previous image">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
                </svg>
            </button>
        }

        <div class="image-scroll-container" @ref="scrollContainer">
            @for (int i = 0; i < Images.Count; i++)
            {
                var index = i;
                <div class="image-item" @onclick="@(() => HandleOpenImageViewer(index))">
                    <img src="@Images[index].ImageUrl" alt="Post image @(index + 1)" />
                </div>
            }
        </div>

        @if (Images.Count > 1)
        {
            <button type="button" class="scroll-button scroll-right" @onclick="ScrollRight" title="Next image">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                </svg>
            </button>
        }
    </div>
}

@code {
    [Parameter]
    public List<PostImage>? Images { get; set; }

    [Parameter]
    public EventCallback<int> OnOpenImageViewer { get; set; }

    private ElementReference scrollContainer;
    private IJSObjectReference? jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            jsModule = await JS.InvokeAsync<IJSObjectReference>("import", 
                "./Components/SocialFeed/FeedArticleImages.razor.js");
        }
    }

    private async Task HandleOpenImageViewer(int index)
    {
        if (OnOpenImageViewer.HasDelegate)
        {
            await OnOpenImageViewer.InvokeAsync(index);
        }
    }

    private async Task ScrollLeft()
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("scrollContainer", scrollContainer, "left");
        }
    }

    private async Task ScrollRight()
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("scrollContainer", scrollContainer, "right");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (jsModule != null)
        {
            await jsModule.DisposeAsync();
        }
    }
}
