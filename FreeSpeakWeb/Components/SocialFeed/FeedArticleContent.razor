@inject IJSRuntime JS

<div class="article-content @(!IsModalView ? "truncated" : "")" @ref="contentElementRef">
    @ArticleContent
</div>

@if (ShouldShowExpandButton && !IsModalView)
{
    <div class="expand-post-section">
        <button type="button" class="expand-post-button" @onclick="OnShowPostDetail">
            @ClickToSeeFullPostText
        </button>
    </div>
}

@code {
    [Parameter]
    public RenderFragment? ArticleContent { get; set; }

    [Parameter]
    public bool IsModalView { get; set; } = false;

    [Parameter]
    public bool IsTruncated { get; set; } = false;

    [Parameter]
    public bool ShouldShowExpandButton { get; set; } = false;

    [Parameter]
    public EventCallback OnShowPostDetail { get; set; }

    [Parameter]
    public EventCallback<ElementReference> OnContentElementRendered { get; set; }

    /// <summary>
    /// Localized text for the "Click to see full post" button.
    /// </summary>
    [Parameter]
    public string ClickToSeeFullPostText { get; set; } = "... Click to see full post";

    private ElementReference contentElementRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && OnContentElementRendered.HasDelegate)
        {
            await OnContentElementRendered.InvokeAsync(contentElementRef);
        }
    }
}
