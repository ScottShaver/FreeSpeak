@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Services
@inject IJSRuntime JS

@implements IAsyncDisposable

<div class="post-creator">
    <div class="post-creator-header">
        @if (!string.IsNullOrEmpty(CurrentUserImageUrl))
        {
            <img src="@CurrentUserImageUrl" alt="You" class="post-creator-avatar" />
        }
        else
        {
            <div class="post-creator-avatar post-avatar-placeholder">
                <span class="post-avatar-initial">@GetInitials(CurrentUserName ?? "User")</span>
            </div>
        }
        <textarea 
            @bind="PostContent"
            @bind:event="oninput"
            @bind:after="HandleInputAfter"
            @ref="textareaElement"
            @onkeydown="HandleKeyDown"
            placeholder="What's on your mind?"
            rows="1"
            class="post-textarea"
            @onfocus="OnFocus"
            @onblur="OnBlur"></textarea>

        <div style="position: relative;">
            <button type="button" class="emoji-button" @onclick="ToggleEmojiPicker" @ref="emojiButtonElement" title="Add emoji">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="M4.285 9.567a.5.5 0 0 1 .683.183A3.498 3.498 0 0 0 8 11.5a3.498 3.498 0 0 0 3.032-1.75.5.5 0 1 1 .866.5A4.498 4.498 0 0 1 8 12.5a4.498 4.498 0 0 1-3.898-2.25.5.5 0 0 1 .183-.683zM7 6.5C7 7.328 6.552 8 6 8s-1-.672-1-1.5S5.448 5 6 5s1 .672 1 1.5zm4 0c0 .828-.448 1.5-1 1.5s-1-.672-1-1.5S9.448 5 10 5s1 .672 1 1.5z"/>
                </svg>
            </button>
            <EmojiPicker IsVisible="@showEmojiPicker"
                        OnClose="@CloseEmojiPicker"
                        OnEmojiSelect="@HandleEmojiSelected"
                        PositionStyle="@emojiPickerPositionStyle" />
        </div>

        <div style="position: relative;">
            <button type="button" class="audience-selector-button" @onclick="ToggleAudienceMenu" @ref="audienceButtonElement">
                @if (SelectedAudienceType == AudienceType.Public)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <title>Public</title>
                        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM2.04 4.326c.325 1.329 2.532 2.54 3.717 3.19.48.263.793.434.743.484-.08.08-.162.158-.242.234-.416.396-.787.749-.758 1.266.035.634.618.824 1.214 1.017.577.188 1.168.38 1.286.983.082.417-.075.988-.22 1.52-.215.782-.406 1.48.22 1.48 1.5-.5 3.798-3.186 4-5 .138-1.243-2-2-3.5-2.5-.478-.16-.755.081-.99.284-.172.15-.322.279-.51.216-.445-.148-2.5-2-1.5-2.5.78-.39.952-.171 1.227.182.078.099.163.208.273.318.609.304.662-.132.723-.633.039-.322.081-.671.277-.867.434-.434 1.265-.791 2.028-1.12.712-.306 1.365-.587 1.579-.88A7 7 0 1 1 2.04 4.327Z"/>
                    </svg>
                }
                else if (SelectedAudienceType == AudienceType.FriendsOnly)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <title>Friends Only</title>
                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>
                    </svg>
                }
                else if (SelectedAudienceType == AudienceType.MeOnly)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <title>Only Me</title>
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                }
            </button>
            <PopupMenu IsVisible="@showAudienceMenu" 
                       MenuItems="@audienceMenuItems" 
                       OnClose="@CloseAudienceMenu"
                       PositionStyle="@audienceMenuPositionStyle" />
        </div>
    </div>

    @if (isExpanded)
    {
        @if (selectedImages.Any())
        {
            <div class="post-images-preview">
                <div class="images-preview-header">
                    <span>@selectedImages.Count @(selectedImages.Count == 1 ? "image" : "images")</span>
                    <button type="button" class="edit-images-button" @onclick="OpenImageUpload" @onmousedown:preventDefault="true">Edit Images</button>
                </div>
                <div class="images-preview-grid">
                    @foreach (var image in selectedImages.Take(4))
                    {
                        <div class="preview-image-item">
                            <img src="@image.DataUrl" alt="Selected image" />
                            @if (selectedImages.Count > 4 && image == selectedImages[3])
                            {
                                <div class="more-images-overlay">+@(selectedImages.Count - 4)</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="post-creator-actions">
            <button type="button" class="image-upload-button" @onclick="OpenImageUpload" @onmousedown:preventDefault="true" title="Add images">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                    <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
                </svg>
                <span>Images</span>
            </button>
            <div style="flex: 1;"></div>
            <button type="button" class="cancel-button" @onclick="Cancel" @onmousedown:preventDefault="true">Cancel</button>
            <button 
                type="button" 
                class="submit-button @(CanSubmit ? "active" : "disabled")"
                disabled="@(!CanSubmit)"
                @onclick="OnSubmitPost"
                @onmousedown:preventDefault="true">
                Post
            </button>
        </div>
    }

    <ImageUploadModal IsVisible="@showImageUpload"
                     OnClose="@CloseImageUpload"
                     OnImagesSelected="@HandleImagesSelected"
                     ExistingImages="@selectedImages"
                     MaxImages="10"
                     MaxFileSizeMB="10" />

    @* Public Audience Confirmation Modal *@
    @if (showPublicConfirmation)
    {
        <div class="confirmation-backdrop" @onclick="CancelPublicConfirmation">
            <div class="confirmation-modal" @onclick:stopPropagation="true">
                <div class="confirmation-header">
                    <h5>Change Post to Public?</h5>
                    <button type="button" class="close-button" @onclick="CancelPublicConfirmation">×</button>
                </div>
                <div class="confirmation-body">
                    <div class="warning-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                        </svg>
                    </div>
                    <p class="confirmation-message">
                        <strong>Public posts are visible to everyone</strong> — not just your friends. 
                        Anyone on the internet can see, share, and comment on your public post.
                    </p>
                    <p class="confirmation-question">
                        Are you sure you want to make this post public?
                    </p>
                </div>
                <div class="confirmation-footer">
                    <button type="button" class="btn-secondary" @onclick="CancelPublicConfirmation">Cancel</button>
                    <button type="button" class="btn-warning" @onclick="ConfirmPublicAudience">Yes, Make it Public</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ElementReference textareaElement;
    private ElementReference audienceButtonElement;
    private ElementReference emojiButtonElement;
    private string postContent = "";
    private bool isExpanded = false;
    private IJSObjectReference? module;
    private bool showAudienceMenu = false;
    private bool showEmojiPicker = false;
    private bool showImageUpload = false;
    private bool showPublicConfirmation = false;
    private AudienceType pendingAudienceType = AudienceType.FriendsOnly;
    private List<PopupMenu.PopupMenuItem> audienceMenuItems = new();
    private string audienceMenuPositionStyle = string.Empty;
    private string emojiPickerPositionStyle = string.Empty;
    private AudienceType selectedAudienceType = AudienceType.FriendsOnly;
    private List<ImageUploadModal.SelectedImage> selectedImages = new();

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public EventCallback<(string Content, AudienceType AudienceType, List<ImageUploadModal.SelectedImage> Images)> OnPostCreated { get; set; }

    private string PostContent 
    { 
        get => postContent;
        set => postContent = value;
    }

    private AudienceType SelectedAudienceType
    {
        get => selectedAudienceType;
        set
        {
            selectedAudienceType = value;
            StateHasChanged();
        }
    }

    private bool CanSubmit => !string.IsNullOrWhiteSpace(PostContent) || selectedImages.Any();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/SocialFeed/MultiLineCommentEditor.razor.js");
            BuildAudienceMenuItems();
        }
    }

    private async Task HandleInputAfter()
    {
        // Auto-replace text emojis
        var originalContent = PostContent;
        PostContent = EmojiService.ReplaceTextEmojis(PostContent);

        // Resize the textarea
        if (module is not null)
        {
            await module.InvokeVoidAsync("resizeTextarea", textareaElement);
        }

        // If content changed due to emoji replacement, update the UI
        if (originalContent != PostContent)
        {
            StateHasChanged();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Handle Escape key to clear text
        if (e.Key == "Escape" && !string.IsNullOrWhiteSpace(PostContent))
        {
            PostContent = "";
            if (module is not null)
            {
                await module.InvokeVoidAsync("resizeTextarea", textareaElement);
            }
            StateHasChanged();
        }
        // Handle Enter key to resize textarea
        else if (e.Key == "Enter")
        {
            // Give the textarea a moment to update with the new line, then resize
            await Task.Delay(10);
            if (module is not null)
            {
                await module.InvokeVoidAsync("resizeTextarea", textareaElement);
            }
        }
    }

    private void OnFocus()
    {
        isExpanded = true;
    }

    private void OnBlur()
    {
        // Only collapse if there's no content AND no images
        if (string.IsNullOrWhiteSpace(PostContent) && !selectedImages.Any())
        {
            isExpanded = false;
        }
    }

    private void Cancel()
    {
        PostContent = "";
        selectedImages.Clear();
        isExpanded = false;
        StateHasChanged();
    }

    private async Task OnSubmitPost()
    {
        if (CanSubmit && OnPostCreated.HasDelegate)
        {
            await OnPostCreated.InvokeAsync((PostContent, SelectedAudienceType, selectedImages.ToList()));
            PostContent = "";
            selectedImages.Clear();
            isExpanded = false;
            StateHasChanged();
        }
    }

    private void OpenImageUpload()
    {
        showImageUpload = true;
        StateHasChanged();
    }

    private void CloseImageUpload()
    {
        showImageUpload = false;
        StateHasChanged();
    }

    private void HandleImagesSelected(List<ImageUploadModal.SelectedImage> images)
    {
        selectedImages = images;
        showImageUpload = false;

        // Keep the PostCreator expanded if images are selected
        if (selectedImages.Any())
        {
            isExpanded = true;
        }

        StateHasChanged();
    }

    private void ToggleEmojiPicker()
    {
        if (showEmojiPicker)
        {
            CloseEmojiPicker();
        }
        else
        {
            showEmojiPicker = true;
            emojiPickerPositionStyle = "right: 50px; top: 40px;";
            StateHasChanged();
        }
    }

    private async Task HandleEmojiSelected(string emoji)
    {
        PostContent += emoji;
        if (module is not null)
        {
            await module.InvokeVoidAsync("resizeTextarea", textareaElement);
        }
        StateHasChanged();
    }

    private void CloseEmojiPicker()
    {
        showEmojiPicker = false;
        StateHasChanged();
    }

    private void ToggleAudienceMenu()
    {
        if (showAudienceMenu)
        {
            CloseAudienceMenu();
        }
        else
        {
            showAudienceMenu = true;
            audienceMenuPositionStyle = "right: 0; top: 40px;";
            StateHasChanged();
        }
    }

    private void BuildAudienceMenuItems()
    {
        audienceMenuItems.Clear();

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Public",
            Icon = "bi bi-globe",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.Public))
        });

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Friends Only",
            Icon = "bi bi-people",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.FriendsOnly))
        });

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Only Me",
            Icon = "bi bi-lock",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.MeOnly))
        });
    }

    private void SelectAudienceType(AudienceType audienceType)
    {
        CloseAudienceMenu();

        // If selecting Public, show confirmation dialog
        if (audienceType == AudienceType.Public)
        {
            pendingAudienceType = audienceType;
            showPublicConfirmation = true;
            StateHasChanged();
        }
        else
        {
            // For Friends Only and Only Me, apply immediately
            SelectedAudienceType = audienceType;
        }
    }

    private void ConfirmPublicAudience()
    {
        SelectedAudienceType = pendingAudienceType;
        showPublicConfirmation = false;
        StateHasChanged();
    }

    private void CancelPublicConfirmation()
    {
        showPublicConfirmation = false;
        pendingAudienceType = SelectedAudienceType; // Reset to current
        StateHasChanged();
    }

    private void CloseAudienceMenu()
    {
        showAudienceMenu = false;
        StateHasChanged();
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "U";

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 0)
            return "U";

        if (parts.Length == 1)
        {
            var singleWord = parts[0];
            if (singleWord.Length >= 2)
                return singleWord.Substring(0, 2).ToUpper();
            else
                return singleWord.Substring(0, 1).ToUpper();
        }

        return $"{parts[0].Substring(0, 1)}{parts[^1].Substring(0, 1)}".ToUpper();
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The circuit is already disconnected, no action needed
            }
        }
    }
}
