@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Services
@inject IJSRuntime JS
@inject PostService PostService
@inject Microsoft.Extensions.Options.IOptions<SiteSettings> SiteSettings
@implements IAsyncDisposable

<div class="feed-article">
    <!-- 1. Header Area -->
    <div class="article-header @GetAudienceHeaderClass()">
        @if (!string.IsNullOrEmpty(AuthorImageUrl))
        {
            <img src="@AuthorImageUrl" alt="@AuthorName" class="author-avatar" />
        }
        else
        {
            <div class="author-avatar author-avatar-placeholder">
                <span class="author-avatar-initial">@GetInitials(AuthorName)</span>
            </div>
        }
        <div class="author-info">
            <div class="author-name-container">
                <span class="author-name">@AuthorName</span>
                @if (currentAudienceType == AudienceType.Public)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                        <title>Public</title>
                        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0ZM2.04 4.326c.325 1.329 2.532 2.54 3.717 3.19.48.263.793.434.743.484-.08.08-.162.158-.242.234-.416.396-.787.749-.758 1.266.035.634.618.824 1.214 1.017.577.188 1.168.38 1.286.983.082.417-.075.988-.22 1.52-.215.782-.406 1.48.22 1.48 1.5-.5 3.798-3.186 4-5 .138-1.243-2-2-3.5-2.5-.478-.16-.755.081-.99.284-.172.15-.322.279-.51.216-.445-.148-2.5-2-1.5-2.5.78-.39.952-.171 1.227.182.078.099.163.208.273.318.609.304.662-.132.723-.633.039-.322.081-.671.277-.867.434-.434 1.265-.791 2.028-1.12.712-.306 1.365-.587 1.579-.88A7 7 0 1 1 2.04 4.327Z"/>
                    </svg>
                }
                else if (currentAudienceType == AudienceType.FriendsOnly)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                        <title>Friends Only</title>
                        <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7Zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm-5.784 6A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216ZM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>
                    </svg>
                }
                else if (currentAudienceType == AudienceType.MeOnly)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="audience-icon" viewBox="0 0 16 16">
                        <title>Only Me</title>
                        <path d="M8 1a2 2 0 0 1 2 2v4H6V3a2 2 0 0 1 2-2zm3 6V3a3 3 0 0 0-6 0v4a2 2 0 0 0-2 2v5a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
                    </svg>
                }
            </div>
            <div class="article-timestamp-container">
                <span class="article-timestamp" title="@FullTimestamp">@FormattedTimestamp</span>
                @if (currentIsPinned)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="#0066cc" class="pinned-icon" viewBox="0 0 16 16">
                        <title>Pinned post</title>
                        <path d="M9.828.722a.5.5 0 0 1 .354.146l4.95 4.95a.5.5 0 0 1 0 .707c-.48.48-1.072.588-1.503.588-.177 0-.335-.018-.46-.039l-3.134 3.134a5.927 5.927 0 0 1 .16 1.013c.046.702-.032 1.687-.72 2.375a.5.5 0 0 1-.707 0l-2.829-2.828-3.182 3.182c-.195.195-1.219.902-1.414.707-.195-.195.512-1.22.707-1.414l3.182-3.182-2.828-2.829a.5.5 0 0 1 0-.707c.688-.688 1.673-.767 2.375-.72a5.922 5.922 0 0 1 1.013.16l3.134-3.133a2.772 2.772 0 0 1-.04-.461c0-.43.108-1.022.589-1.503a.5.5 0 0 1 .353-.146z"/>
                    </svg>
                }
            </div>
        </div>
        <div style="position: relative;">
            <button type="button" class="menu-button" @onclick="ToggleMenu" @ref="menuButtonElement">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/>
                </svg>
            </button>
            <PopupMenu IsVisible="@showMenu" 
                       MenuItems="@menuItems" 
                       OnClose="@CloseMenu"
                       PositionStyle="@menuPositionStyle" />
        </div>
    </div>

    <!-- 2. Main Content Area -->
    <div class="article-content @(isTruncated && !IsModalView ? "truncated" : "")" @ref="contentElement">
        @ArticleContent
    </div>

    <!-- 2.5 Post Images -->
    @if (Images != null && Images.Any())
    {
        <div class="article-images">
            @if (Images.Count == 1)
            {
                <div class="image-single" @onclick="() => OpenImageViewer(0)">
                    <img src="@Images[0].ImageUrl" alt="Post image" />
                </div>
            }
            else if (Images.Count == 2)
            {
                <div class="image-grid-2">
                    @for (int i = 0; i < Images.Count; i++)
                    {
                        var index = i;
                        <div class="image-item" @onclick="() => OpenImageViewer(index)">
                            <img src="@Images[index].ImageUrl" alt="Post image" />
                        </div>
                    }
                </div>
            }
            else if (Images.Count == 3)
            {
                <div class="image-grid-3">
                    <div class="image-item image-large" @onclick="() => OpenImageViewer(0)">
                        <img src="@Images[0].ImageUrl" alt="Post image" />
                    </div>
                    <div class="image-column">
                        <div class="image-item" @onclick="() => OpenImageViewer(1)">
                            <img src="@Images[1].ImageUrl" alt="Post image" />
                        </div>
                        <div class="image-item" @onclick="() => OpenImageViewer(2)">
                            <img src="@Images[2].ImageUrl" alt="Post image" />
                        </div>
                    </div>
                </div>
            }
            else if (Images.Count == 4)
            {
                <div class="image-grid-4">
                    @for (int i = 0; i < Images.Count; i++)
                    {
                        var index = i;
                        <div class="image-item" @onclick="() => OpenImageViewer(index)">
                            <img src="@Images[index].ImageUrl" alt="Post image" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="image-grid-many">
                    @for (int i = 0; i < Math.Min(4, Images.Count); i++)
                    {
                        var index = i;
                        <div class="image-item" @onclick="() => HandleImageClick(index)">
                            <img src="@Images[index].ImageUrl" alt="Post image" />
                            @if (Images.Count > 4 && index == 3)
                            {
                                <div class="image-overlay">
                                    <span>+@(Images.Count - 4)</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (shouldShowExpandButton && !IsModalView)
    {
        <div class="expand-post-section">
            <button type="button" class="expand-post-button" @onclick="ShowPostDetail">
                ... Click to see full post
            </button>
        </div>
    }

    <!-- 3. Stats Area -->
    <div class="article-stats">
        <div class="stat-reactions">
            @if (ReactionBreakdown != null && ReactionBreakdown.Any())
            {
                <div class="reaction-icons">
                    @foreach (var reactionType in ReactionBreakdown.Keys.OrderByDescending(k => ReactionBreakdown[k]).Take(3))
                    {
                        <span class="reaction-icon">@GetReactionEmoji(reactionType)</span>
                    }
                </div>
            }
            @if (IsModalView)
            {
                <span class="stat-item">@LikeCount @(LikeCount == 1 ? "like" : "likes")</span>
            }
            else
            {
                <span class="stat-item stat-item-clickable" @onclick="ShowLikesModal">@LikeCount @(LikeCount == 1 ? "like" : "likes")</span>
            }
        </div>
        @if (IsModalView)
        {
            <span class="stat-item">@CommentCount @(CommentCount == 1 ? "comment" : "comments")</span>
        }
        else
        {
            <span class="stat-item stat-item-clickable" @onclick="OnCommentCountClick">@CommentCount @(CommentCount == 1 ? "comment" : "comments")</span>
        }
    </div>

    <!-- 4. Action Links -->
    <div class="article-actions">
        @if (!IsOwnPost)
        {
            <div class="like-button-container" @onmouseenter="ShowReactionPicker" @onmouseleave="StartHideTimer" @onmouseenter:stopPropagation="true">
                <button type="button" class="action-button @(UserReaction != null ? "reacted" : "")" @onclick="OnLikeClick">
                    @if (UserReaction != null)
                    {
                        <span class="user-reaction-emoji">@GetReactionEmoji(UserReaction.Value)</span>
                        <span class="reaction-text">@GetReactionText(UserReaction.Value)</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2.144 2.144 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a9.84 9.84 0 0 0-.443.05 9.365 9.365 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111L8.864.046zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a8.908 8.908 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.224 2.224 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.866.866 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"/>
                        </svg>
                        <span>Like</span>
                    }
                </button>
                @if (showReactionPicker)
                {
                    <ReactionPicker HasUserReaction="@(UserReaction != null)" OnReactionPicked="HandleReaction" OnRemoveReaction="HandleRemoveReaction" OnClose="StartHideTimer" OnEnter="CancelHideTimer" />
                }
            </div>
        }
        else
        {
            <div class="like-button-placeholder"></div>
        }
        @if (!IsModalView)
        {
            <div class="comment-button-container">
                <button type="button" class="action-button" @onclick="OnCommentClick">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M2.678 11.894a1 1 0 0 1 .287.801 10.97 10.97 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8.06 8.06 0 0 0 8 14c3.996 0 7-2.807 7-6 0-3.192-3.004-6-7-6S1 4.808 1 8c0 1.468.617 2.83 1.678 3.894zm-.493 3.905a21.682 21.682 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a9.68 9.68 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9.06 9.06 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105z"/>
                    </svg>
                    Comment
                </button>
            </div>
        }
        else
        {
            <div class="comment-button-placeholder"></div>
        }
        <div class="share-button-container">
            <button type="button" class="action-button" @onclick="OnShareClick">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5z"/>
                </svg>
                Share
            </button>
        </div>
    </div>

    <!-- 5. Display Existing Comments -->
    @if (Comments != null && Comments.Any())
    {
        <div class="article-comments">
            @foreach (var comment in Comments)
            {
                <MultiLineCommentDisplay 
                    CommentId="@comment.CommentId"
                    UserName="@comment.UserName"
                    UserImageUrl="@comment.UserImageUrl"
                    CommentAuthorId="@comment.CommentAuthorId"
                    CommentText="@comment.CommentText"
                    ImageUrl="@comment.ImageUrl"
                    Timestamp="@comment.Timestamp"
                    Replies="@comment.Replies"
                    LikeCount="@comment.LikeCount"
                    UserReaction="@comment.UserReaction"
                    ReactionBreakdown="@comment.ReactionBreakdown"
                    CurrentUserId="@CurrentUserId"
                    CurrentUserImageUrl="@CurrentUserImageUrl"
                    CurrentUserName="@CurrentUserName"
                    Depth="0"
                    OnReactionChanged="@OnCommentReactionChanged"
                    OnRemoveReaction="@OnRemoveCommentReaction"
                    OnReplySubmitted="@OnReplySubmitted" />
            }
        </div>
    }

    <!-- 6. Comment Editor -->
    @if (!HideCommentEditor)
    {
        @if (!HasReachedCommentLimit)
        {
            <div class="article-comment-editor">
                @if (!string.IsNullOrEmpty(CurrentUserImageUrl))
                {
                    <img src="@CurrentUserImageUrl" alt="You" class="comment-user-avatar" />
                }
                else
                {
                    <div class="comment-user-avatar comment-avatar-placeholder">
                        <span class="comment-avatar-initial">@GetInitials(CurrentUserName ?? "User")</span>
                    </div>
                }
                <div class="editor-wrapper">
                    <MultiLineCommentEditor OnCommentSubmitted="OnCommentSubmitted" />
                </div>
            </div>
        }
        else
        {
            <div class="article-comment-limit-message">
                <span>No more comments allowed</span>
            </div>
        }
    }
</div>

@if (showLikesModal)
{
    <LikesModal Likes="@likes" isLoading="@isLoadingLikes" OnClose="CloseLikesModal" />
}

<ImageViewerModal 
    IsVisible="@showImageViewer"
    ImageUrls="@imageUrls"
    InitialIndex="@selectedImageIndex"
    OnClose="CloseImageViewer" />

<ImageGalleryModal 
    IsVisible="@showImageGallery"
    Images="@thumbnailUrls"
    OnClose="CloseImageGallery"
    OnImageClick="OpenImageViewerFromGallery" />

<!-- Audience Selection Menu -->
@if (showAudienceMenu)
{
    <div class="modal-backdrop" @onclick="CloseAudienceMenu" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div @onclick:stopPropagation="true" style="position: relative;">
            <PopupMenu IsVisible="@showAudienceMenu" 
                       MenuItems="@audienceMenuItems" 
                       OnClose="@CloseAudienceMenu"
                       PositionStyle="position: relative;" />
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirmation)
{
    <div class="modal-backdrop" @onclick="CancelDeletePost" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div class="confirmation-modal" @onclick:stopPropagation="true" style="background: white; border-radius: 8px; padding: 24px; max-width: 400px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <h3 style="margin: 0 0 16px 0; font-size: 20px; font-weight: 600; color: #333;">Delete Post</h3>
            <p style="margin: 0 0 24px 0; color: #666; line-height: 1.5;">Are you sure you want to delete this post? This action cannot be undone and will permanently remove the post, all comments, likes, and images.</p>
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" @onclick="CancelDeletePost" style="padding: 8px 16px; border: 1px solid #ddd; background: white; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500; color: #666;">
                    Cancel
                </button>
                <button type="button" @onclick="ConfirmDeletePost" style="padding: 8px 16px; border: none; background: #dc3545; color: white; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500;">
                    Delete Post
                </button>
            </div>
        </div>
    </div>
}

<!-- Public Audience Confirmation Modal -->
@if (showPublicConfirmation)
{
    <div class="modal-backdrop" @onclick="CancelPublicConfirmation" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 2000; display: flex; align-items: center; justify-content: center;">
        <div class="public-confirmation-modal" @onclick:stopPropagation="true" style="background: white; border-radius: 12px; max-width: 500px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid #e4e6eb;">
                <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: #1c1e21;">Change Post to Public?</h3>
                <button type="button" @onclick="CancelPublicConfirmation" style="background: none; border: none; font-size: 32px; line-height: 1; color: #65676b; cursor: pointer; padding: 0; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background-color 0.2s;">×</button>
            </div>
            <div style="padding: 24px; text-align: center;">
                <div style="color: #f59e0b; margin-bottom: 16px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                    </svg>
                </div>
                <p style="font-size: 15px; color: #1c1e21; margin-bottom: 12px; line-height: 1.5;">
                    <strong style="color: #f59e0b;">Public posts are visible to everyone</strong> — not just your friends. 
                    Anyone on the internet can see, share, and comment on your public post.
                </p>
                <p style="font-size: 15px; color: #65676b; margin: 0;">
                    Are you sure you want to make this post public?
                </p>
            </div>
            <div style="display: flex; gap: 12px; padding: 16px 24px; border-top: 1px solid #e4e6eb; justify-content: flex-end;">
                <button type="button" @onclick="CancelPublicConfirmation" style="padding: 10px 20px; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; background-color: #e4e6eb; color: #1c1e21; transition: background-color 0.2s;">
                    Cancel
                </button>
                <button type="button" @onclick="ConfirmPublicAudience" style="padding: 10px 20px; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; background-color: #f59e0b; color: white; transition: background-color 0.2s;">
                    Yes, Make it Public
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int PostId { get; set; }

    [Parameter]
    public string AuthorId { get; set; } = string.Empty;

    [Parameter]
    public string AuthorName { get; set; } = "Anonymous";

    [Parameter]
    public string? AuthorImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserId { get; set; }

    [Parameter]
    public DateTime CreatedAt { get; set; } = DateTime.Now;

    [Parameter]
    public RenderFragment? ArticleContent { get; set; }

    [Parameter]
    public int LikeCount { get; set; } = 0;

    [Parameter]
    public int CommentCount { get; set; } = 0;

    [Parameter]
    public int DirectCommentCount { get; set; } = 0;

    [Parameter]
    public List<CommentDisplayModel>? Comments { get; set; }

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public Dictionary<LikeType, int>? ReactionBreakdown { get; set; }

    [Parameter]
    public LikeType? UserReaction { get; set; }

    [Parameter]
    public EventCallback<LikeType> OnReactionChanged { get; set; }

    [Parameter]
    public EventCallback OnRemoveReaction { get; set; }

    [Parameter]
    public EventCallback<(int PostId, string Content)> OnCommentAdded { get; set; }

    [Parameter]
    public EventCallback<(int ParentCommentId, string Content)> OnReplySubmitted { get; set; }

    [Parameter]
    public EventCallback<(int CommentId, LikeType ReactionType)> OnCommentReactionChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnRemoveCommentReaction { get; set; }

    [Parameter]
    public bool HideCommentEditor { get; set; } = false;

    [Parameter]
    public bool IsModalView { get; set; } = false;

    [Parameter]
    public EventCallback OnShowPostDetail { get; set; }

    [Parameter]
    public EventCallback OnShowComments { get; set; }

    [Parameter]
    public AudienceType AudienceType { get; set; } = AudienceType.Public;

    [Parameter]
    public EventCallback<AudienceType> OnAudienceTypeChanged { get; set; }

    [Parameter]
    public bool IsPinned { get; set; } = false;

    [Parameter]
    public EventCallback<int> OnPinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnUnpinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnPostDeleted { get; set; }

    [Parameter]
    public List<PostImage>? Images { get; set; }

    // Internal state for audience and pinned status (to properly handle re-renders)
    // These are the source of truth for rendering
    private AudienceType currentAudienceType = AudienceType.Public;
    private bool currentIsPinned = false;

    // Track if we've made local changes that parent hasn't reflected yet
    private bool hasLocalAudienceChange = false;
    private bool hasLocalPinnedChange = false;

    private bool showReactionPicker = false;
    private bool showLikesModal = false;
    private bool isLoadingLikes = false;
    private List<(ApplicationUser User, LikeType Type, DateTime CreatedAt)> likes = new();
    private System.Threading.Timer? hideTimer;
    private ElementReference contentElement;
