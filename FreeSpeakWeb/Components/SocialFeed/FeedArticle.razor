    private void OpenImageViewer(int imageIndex)
    {
        if (Images == null || !Images.Any()) return;

        // Request full-size images for the viewer by appending size=full query parameter
        imageUrls = Images.Select(img => $"{img.ImageUrl}?size=full").ToList();
        selectedImageIndex = imageIndex;
        showImageViewer = true;
        StateHasChanged();
    }

    private void HandleImageClick(int imageIndex)
    {
        // If clicking the 4th image and there are more than 4 images, show gallery
        // Otherwise, show the image viewer
        if (imageIndex == 3 && Images != null && Images.Count > 4)
        {
            OpenImageGallery();
        }
        else
        {
            OpenImageViewer(imageIndex);
        }
    }

    private void CloseImageViewer()
    {
        showImageViewer = false;
        StateHasChanged();
    }

    private void OpenImageGallery()
    {
        if (Images == null || !Images.Any()) return;

        // Gallery shows medium-size thumbnails for better grid performance
        thumbnailUrls = Images.Select(img => $"{img.ImageUrl}?size=medium").ToList();
        // Prepare full-size URLs for when user clicks an image
        imageUrls = Images.Select(img => $"{img.ImageUrl}?size=full").ToList();
        showImageGallery = true;
        StateHasChanged();
    }

    private void CloseImageGallery()
    {
        showImageGallery = false;
        StateHasChanged();
    }

    private void OpenImageViewerFromGallery(int imageIndex)
    {
        showImageGallery = false;
        selectedImageIndex = imageIndex;
        showImageViewer = true;
        StateHasChanged();
    }

