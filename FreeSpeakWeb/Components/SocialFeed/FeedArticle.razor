@using FreeSpeakWeb.Components.SocialFeed
@using FreeSpeakWeb.Components.Shared
@using FreeSpeakWeb.Data
@using FreeSpeakWeb.Data.AuditLogDetails
@using FreeSpeakWeb.Repositories.Abstractions
@using FreeSpeakWeb.Services
@using FreeSpeakWeb.Helpers
@inject IJSRuntime JS
@inject PostService PostService
@inject UserPreferenceService UserPreferenceService
@inject NavigationManager NavigationManager
@inject Microsoft.Extensions.Options.IOptions<SiteSettings> SiteSettings
@inject AlertService AlertService
@inject IAuditLogRepository AuditLogRepository
@implements IAsyncDisposable

<div class="feed-article @(showMenu ? "menu-open" : "")">
    <!-- 1. Header Area -->
    <FeedArticleHeader 
        AuthorName="@AuthorName"
        AuthorImageUrl="@AuthorImageUrl"
        CreatedAt="@CreatedAt"
        AudienceType="@currentAudienceType"
        IsPinned="@currentIsPinned"
        LikeCount="@LikeCount"
        CommentCount="@CommentCount"
        ShareCount="@ShareCount"
        ReactionBreakdown="@ReactionBreakdown"
        IsModalView="@IsModalView"
        IsReadOnly="@IsReadOnly"
        OnShowLikesModal="@ShowLikesModal"
        OnCommentCountClick="@OnCommentCountClick"
        ShowMenu="@showMenu"
        MenuItems="@menuItems"
        MenuPositionStyle="@menuPositionStyle"
        OnToggleMenu="@ToggleMenu"
        OnCloseMenu="@CloseMenu" />

    <!-- 2. Main Content Area -->
    <FeedArticleContent 
        ArticleContent="@ArticleContent"
        IsModalView="@IsModalView"
        IsTruncated="@isTruncated"
        ShouldShowExpandButton="@shouldShowExpandButton"
        OnShowPostDetail="@ShowPostDetail"
        OnContentElementRendered="@HandleContentElementRendered" />

    <!-- 2.5 Post Images -->
    <FeedArticleImages 
        Images="@Images"
        OnOpenImageViewer="@OpenImageViewer" />

    <!-- 4. Action Links -->
    <FeedArticleActions 
        IsReadOnly="@IsReadOnly"
        IsOwnPost="@IsOwnPost"
        IsModalView="@IsModalView"
        UserReaction="@UserReaction"
        ShowReactionPicker="@showReactionPicker"
        OnShowReactionPicker="@ShowReactionPicker"
        OnStartHideTimer="@StartHideTimer"
        OnCancelHideTimer="@CancelHideTimer"
        OnLikeClick="@OnLikeClick"
        OnReactionPicked="@HandleReaction"
        OnRemoveReaction="@HandleRemoveReaction"
        OnCommentClick="@OnCommentClick"
        OnShareClick="@OnShareClick" />

    @{
        var commentsToDisplay = LoadCommentsInternally ? internalComments : (Comments ?? new List<CommentDisplayModel>());
        var directCount = LoadCommentsInternally ? internalDirectCommentCount : DirectCommentCount;
    }

    <!-- More Comments Indicator -->
    @if (!IsModalView && directCount > 0 && commentsToDisplay != null && directCount > commentsToDisplay.Count)
    {
        <div class="more-comments-indicator">
            <button type="button" class="more-comments-button" @onclick="OnCommentClick">
                View more comments
            </button>
        </div>
    }

    <!-- 5. Display Existing Comments -->
    @if (commentsToDisplay != null && commentsToDisplay.Any())
    {
        <div class="article-comments">
            @foreach (var comment in commentsToDisplay)
            {
                <MultiLineCommentDisplay 
                    CommentId="@comment.CommentId"
                    UserName="@comment.UserName"
                    UserImageUrl="@comment.UserImageUrl"
                    CommentAuthorId="@comment.CommentAuthorId"
                    CommentText="@comment.CommentText"
                    ImageUrl="@comment.ImageUrl"
                    Timestamp="@comment.Timestamp"
                    Replies="@comment.Replies"
                    LikeCount="@comment.LikeCount"
                    UserReaction="@comment.UserReaction"
                    ReactionBreakdown="@comment.ReactionBreakdown"
                    CurrentUserId="@CurrentUserId"
                    CurrentUserImageUrl="@CurrentUserImageUrl"
                    CurrentUserName="@CurrentUserName"
                    Depth="0"
                    OnReactionChanged="@OnCommentReactionChanged"
                    OnRemoveReaction="@OnRemoveCommentReaction"
                    OnReplySubmitted="@OnReplySubmittedLocally"
                    OnDeleteComment="@OnCommentDeleted"
                    OnEditComment="@OnCommentEditedLocally"
                    OnCommentUpdated="@OnCommentUpdatedLocally"
                    OnReportComment="@OnReportComment" />
            }
        </div>
    }

    <!-- 6. Comment Editor -->
    <FeedArticleCommentEditor 
        HideCommentEditor="@HideCommentEditor"
        IsReadOnly="@IsReadOnly"
        HasReachedCommentLimit="@HasReachedCommentLimit"
        CurrentUserImageUrl="@CurrentUserImageUrl"
        CurrentUserName="@CurrentUserName"
        OnCommentSubmitted="@OnCommentSubmitted" />
</div>

@if (showLikesModal)
{
    <LikesModal Likes="@likes" isLoading="@isLoadingLikes" OnClose="CloseLikesModal" />
}

<ImageViewerModal 
    IsVisible="@showImageViewer"
    ImageUrls="@imageUrls"
    InitialIndex="@selectedImageIndex"
    OnClose="CloseImageViewer" />

<!-- Audience Selection Menu -->
@if (showAudienceMenu)
{
    <div class="modal-backdrop" @onclick="CloseAudienceMenu" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div @onclick:stopPropagation="true" style="position: relative;">
            <PopupMenu IsVisible="@showAudienceMenu" 
                       MenuItems="@audienceMenuItems" 
                       OnClose="@CloseAudienceMenu"
                       PositionStyle="position: relative;" />
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirmation)
{
    <div class="modal-backdrop" @onclick="CancelDeletePost" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div class="confirmation-modal" @onclick:stopPropagation="true" style="background: var(--surface-color); border: 2px solid var(--border-color); border-radius: 8px; padding: 24px; max-width: 400px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            <h3 style="margin: 0 0 16px 0; font-size: 20px; font-weight: 600; color: var(--text-primary);">Delete Post</h3>
            <p style="margin: 0 0 24px 0; color: var(--text-secondary); line-height: 1.5;">Are you sure you want to delete this post? This action cannot be undone and will permanently remove the post, all comments, likes, and images.</p>
            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button type="button" @onclick="CancelDeletePost" style="padding: 8px 16px; border: 1px solid var(--border-color); background: var(--surface-color); border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500; color: var(--text-secondary);">
                    Cancel
                </button>
                <button type="button" @onclick="ConfirmDeletePost" style="padding: 8px 16px; border: none; background: var(--danger-color); color: white; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: 500;">
                    Delete Post
                </button>
            </div>
        </div>
    </div>
}

<!-- Public Audience Confirmation Modal -->
@if (showPublicConfirmation)
{
    <div class="modal-backdrop" @onclick="CancelPublicConfirmation" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 2000; display: flex; align-items: center; justify-content: center;">
        <div class="public-confirmation-modal" @onclick:stopPropagation="true" style="background: var(--surface-color); border: 2px solid var(--border-color); border-radius: 12px; max-width: 500px; width: 90%; box-shadow: 0 8px 32px rgba(0,0,0,0.3);">
            <div style="display: flex; justify-content: space-between; align-items: center; padding: 20px 24px; border-bottom: 1px solid var(--border-color);">
                <h3 style="margin: 0; font-size: 18px; font-weight: 600; color: var(--text-primary);">Change Post to Public?</h3>
                <button type="button" @onclick="CancelPublicConfirmation" style="background: none; border: none; font-size: 32px; line-height: 1; color: var(--text-secondary); cursor: pointer; padding: 0; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background-color 0.2s;">×</button>
            </div>
            <div style="padding: 24px; text-align: center;">
                <div style="color: var(--warning-color); margin-bottom: 16px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                    </svg>
                </div>
                <p style="font-size: 15px; color: var(--text-primary); margin-bottom: 12px; line-height: 1.5;">
                    <strong style="color: var(--warning-color);">Public posts are visible to everyone</strong> — not just your friends. 
                    Anyone on the internet can see, share, and comment on your public post.
                </p>
                <p style="font-size: 15px; color: var(--text-secondary); margin: 0;">
                    Are you sure you want to make this post public?
                </p>
            </div>
            <div style="display: flex; gap: 12px; padding: 16px 24px; border-top: 1px solid var(--border-color); justify-content: flex-end;">
                <button type="button" @onclick="CancelPublicConfirmation" style="padding: 10px 20px; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; background-color: var(--surface-secondary); color: var(--text-primary); transition: background-color 0.2s;">
                    Cancel
                </button>
                <button type="button" @onclick="ConfirmPublicAudience" style="padding: 10px 20px; border: none; border-radius: 6px; font-size: 15px; font-weight: 600; cursor: pointer; background-color: var(--warning-color); color: white; transition: background-color 0.2s;">
                    Yes, Make it Public
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int PostId { get; set; }

    [Parameter]
    public string AuthorId { get; set; } = string.Empty;

    [Parameter]
    public string AuthorName { get; set; } = "Anonymous";

    [Parameter]
    public string? AuthorImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserId { get; set; }

    [Parameter]
    public DateTime CreatedAt { get; set; } = DateTime.Now;

    [Parameter]
    public RenderFragment? ArticleContent { get; set; }

    [Parameter]
    public int LikeCount { get; set; } = 0;

    [Parameter]
    public int CommentCount { get; set; } = 0;

    [Parameter]
    public int ShareCount { get; set; } = 0;

    [Parameter]
    public int DirectCommentCount { get; set; } = 0;

    [Parameter]
    public List<CommentDisplayModel>? Comments { get; set; }

    [Parameter]
    public string? CurrentUserImageUrl { get; set; }

    [Parameter]
    public string? CurrentUserName { get; set; }

    [Parameter]
    public Dictionary<LikeType, int>? ReactionBreakdown { get; set; }

    [Parameter]
    public LikeType? UserReaction { get; set; }

    [Parameter]
    public EventCallback<LikeType> OnReactionChanged { get; set; }

    [Parameter]
    public EventCallback OnRemoveReaction { get; set; }

    [Parameter]
    public EventCallback<(int PostId, string Content)> OnCommentAdded { get; set; }

    [Parameter]
    public EventCallback<(int ParentCommentId, string Content)> OnReplySubmitted { get; set; }

    [Parameter]
    public EventCallback<(int CommentId, LikeType ReactionType)> OnCommentReactionChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnRemoveCommentReaction { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to delete their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnDeleteComment { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to edit their own comment.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string CurrentContent)> OnEditComment { get; set; }

    /// <summary>
    /// Event callback invoked when a comment is successfully updated with new content via inline editing.
    /// </summary>
    [Parameter]
    public EventCallback<(int CommentId, string NewContent)> OnCommentUpdated { get; set; }

    /// <summary>
    /// Event callback invoked when a user requests to report another user's comment.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnReportComment { get; set; }

    [Parameter]
    public bool HideCommentEditor { get; set; } = false;

    [Parameter]
    public bool IsModalView { get; set; } = false;

    [Parameter]
    public EventCallback OnShowPostDetail { get; set; }

    [Parameter]
    public EventCallback OnShowComments { get; set; }

    [Parameter]
    public AudienceType AudienceType { get; set; } = AudienceType.Public;

    [Parameter]
    public EventCallback<AudienceType> OnAudienceTypeChanged { get; set; }

    [Parameter]
    public bool IsPinned { get; set; } = false;

    [Parameter]
    public EventCallback<int> OnPinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnUnpinPost { get; set; }

    [Parameter]
    public EventCallback<int> OnPostDeleted { get; set; }

    [Parameter]
    public EventCallback<int> OnEditPost { get; set; }

    [Parameter]
    public List<PostImage>? Images { get; set; }

    [Parameter]
    public bool IsReadOnly { get; set; } = false;

    [Parameter]
    public bool LoadCommentsInternally { get; set; } = false;

    [Parameter]
    public int CommentsToShow { get; set; } = 3;

    [Parameter]
    public int RefreshTrigger { get; set; } = 0;

    /// <summary>
    /// Gets or sets whether notifications are muted for this post.
    /// When provided by parent, avoids N+1 queries by using batch-loaded mute status.
    /// </summary>
    [Parameter]
    public bool? IsMuted { get; set; }

    // Internal state for audience and pinned status (to properly handle re-renders)
    // These are the source of truth for rendering
    private AudienceType currentAudienceType = AudienceType.Public;
    private bool currentIsPinned = false;

    // Track if we've made local changes that parent hasn't reflected yet
    private bool hasLocalAudienceChange = false;
    private bool hasLocalPinnedChange = false;

    // Notification mute state - uses IsMuted parameter if provided, otherwise loaded on first render
    private bool isNotificationMuted = false;
    private bool hasMuteStatusFromParameter = false;

    private bool showReactionPicker = false;
    private bool showLikesModal = false;
    private bool isLoadingLikes = false;
    private List<(ApplicationUser User, LikeType Type, DateTime CreatedAt)> likes = new();
    private System.Threading.Timer? hideTimer;
    private ElementReference contentElement;
    private IJSObjectReference? module;
    private DotNetObjectReference<FeedArticle>? dotNetHelper;
    private bool isTruncated = false;
    private bool shouldShowExpandButton = false;
    private bool showMenu = false;
    private List<PopupMenu.PopupMenuItem> menuItems = new();
    private string menuPositionStyle = string.Empty;

    // Audience selection state
    private bool showAudienceMenu = false;
    private bool showPublicConfirmation = false;
    private AudienceType pendingAudienceType = AudienceType.FriendsOnly;
    private List<PopupMenu.PopupMenuItem> audienceMenuItems = new();
    private string audienceMenuPositionStyle = string.Empty;

    // Delete confirmation state
    private bool showDeleteConfirmation = false;

    // Image viewer state
    private bool showImageViewer = false;
    private List<string> imageUrls = new();
    private int selectedImageIndex = 0;

    // Internal comment loading state
    private List<CommentDisplayModel> internalComments = new();
    private int internalDirectCommentCount = 0;
    private bool isLoadingComments = false;
    private int? lastLoadedPostId = null;
    private int lastRefreshTrigger = 0;

    private bool IsOwnPost => !string.IsNullOrEmpty(CurrentUserId) && !string.IsNullOrEmpty(AuthorId) && CurrentUserId == AuthorId;


    private bool HasReachedCommentLimit => DirectCommentCount >= SiteSettings.Value.MaxFeedPostDirectCommentCount;

    private async Task HandleContentElementRendered(ElementReference elementRef)
    {
        contentElement = elementRef;
        // JavaScript initialization will happen in OnAfterRenderAsync
    }

    private void ShowReactionPicker()
    {
        if (IsOwnPost) return; // Don't show picker for own posts

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void CancelHideTimer()
    {
        if (IsOwnPost) return; // Don't show picker for own posts

        hideTimer?.Dispose();
        showReactionPicker = true;
        StateHasChanged();
    }

    private void StartHideTimer()
    {
        hideTimer?.Dispose();
        hideTimer = new System.Threading.Timer(_ =>
        {
            InvokeAsync(() =>
            {
                showReactionPicker = false;
                StateHasChanged();
            });
        }, null, 500, Timeout.Infinite);
    }

    private void HideReactionPicker()
    {
        showReactionPicker = false;
    }

    private async Task HandleReaction(LikeType reactionType)
    {
        showReactionPicker = false;
        await OnReactionChanged.InvokeAsync(reactionType);
    }

    private async Task HandleRemoveReaction()
    {
        showReactionPicker = false;
        // Signal removal by invoking with a special parameter
        // We'll update Home.razor to handle this
        if (OnRemoveReaction.HasDelegate)
        {
            await OnRemoveReaction.InvokeAsync();
        }
    }

    private async Task OnLikeClick()
    {
        // Default like action
        await OnReactionChanged.InvokeAsync(LikeType.Like);
    }

    private void ToggleMenu()
    {
        if (showMenu)
        {
            CloseMenu();
        }
        else
        {
            BuildMenuItems();
            showMenu = true;
            menuPositionStyle = "right: 0; top: 40px;";
            StateHasChanged();
        }
    }

    private void BuildMenuItems()
    {
        menuItems.Clear();

        if (IsOwnPost)
        {
            // In modal view, only show Pin and Copy Link for own posts
            if (IsModalView)
            {
                // Pin/Unpin Post
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = currentIsPinned ? "Unpin Post" : "Pin Post",
                    Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
                });

                // Copy Link - only for public posts
                if (currentAudienceType == AudienceType.Public)
                {
                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = "Copy Link",
                        Icon = "bi bi-link-45deg",
                        OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                    });
                }
            }
            else
            {
                // Menu items for user's own posts in regular feed view
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = "Edit Post",
                    Icon = "bi bi-pencil",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleEditPostClick())
                });

                // Pin/Unpin Post - changes based on current state
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = currentIsPinned ? "Unpin Post" : "Pin Post",
                    Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
                });

                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = "Change Post Audience",
                    Icon = "bi bi-globe",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleChangeAudienceClick())
                });

                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = isNotificationMuted ? "Turn On Notifications" : "Turn Off Notifications",
                    Icon = isNotificationMuted ? "bi bi-bell" : "bi bi-bell-slash",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleToggleNotificationsClick())
                });

                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = "Delete Post",
                    Icon = "bi bi-trash",
                    OnClick = EventCallback.Factory.Create(this, ShowDeleteConfirmation)
                });

                // Copy Link - only for public posts
                if (currentAudienceType == AudienceType.Public)
                {
                    menuItems.Add(new PopupMenu.PopupMenuItem
                    {
                        Text = "Copy Link",
                        Icon = "bi bi-link-45deg",
                        OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                    });
                }
            }
        }
        else if (!string.IsNullOrEmpty(CurrentUserId))
        {
            // Menu items for other users' posts (only if user is logged in)

            // Pin/Unpin Post - available for all posts
            menuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = currentIsPinned ? "Unpin Post" : "Pin Post",
                Icon = currentIsPinned ? "bi bi-pin-angle-fill" : "bi bi-pin-angle",
                OnClick = EventCallback.Factory.Create(this, async () => await HandlePinUnpinClick())
            });

            menuItems.Add(new PopupMenu.PopupMenuItem
            {
                Text = "Report Post",
                Icon = "bi bi-flag",
                OnClick = EventCallback.Factory.Create(this, async () => await JS.InvokeVoidAsync("alert", "Report Post"))
            });

            // Copy Link - only for public posts
            if (currentAudienceType == AudienceType.Public)
            {
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = "Copy Link",
                    Icon = "bi bi-link-45deg",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                });
            }
        }
        else
        {
            // Copy Link - only for public posts (even when not logged in)
            if (currentAudienceType == AudienceType.Public)
            {
                menuItems.Add(new PopupMenu.PopupMenuItem
                {
                    Text = "Copy Link",
                    Icon = "bi bi-link-45deg",
                    OnClick = EventCallback.Factory.Create(this, async () => await HandleCopyLink())
                });
            }
        }
    }

    private void CloseMenu()
    {
        showMenu = false;
        StateHasChanged();
    }

    private void BuildAudienceMenuItems()
    {
        audienceMenuItems.Clear();

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Public",
            Icon = "bi bi-globe",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.Public))
        });

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Friends Only",
            Icon = "bi bi-people",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.FriendsOnly))
        });

        audienceMenuItems.Add(new PopupMenu.PopupMenuItem
        {
            Text = "Only Me",
            Icon = "bi bi-lock",
            OnClick = EventCallback.Factory.Create(this, () => SelectAudienceType(AudienceType.MeOnly))
        });
    }

    private async Task HandleChangeAudienceClick()
    {
        // Close the main menu
        CloseMenu();

        // Build and show the audience menu
        BuildAudienceMenuItems();
        showAudienceMenu = true;
        audienceMenuPositionStyle = "right: 0; top: 40px;";
        StateHasChanged();
    }

    private async Task SelectAudienceType(AudienceType newAudienceType)
    {
        // Close the audience menu
        CloseAudienceMenu();

        // Don't update if it's the same audience type
        if (currentAudienceType == newAudienceType)
        {
            return;
        }

        // If selecting Public, show confirmation dialog
        if (newAudienceType == AudienceType.Public)
        {
            pendingAudienceType = newAudienceType;
            showPublicConfirmation = true;
            StateHasChanged();
            return;
        }

        // For Friends Only and Only Me, apply immediately
        await ApplyAudienceChange(newAudienceType);
    }

    private async Task ConfirmPublicAudience()
    {
        showPublicConfirmation = false;
        StateHasChanged();
        await ApplyAudienceChange(pendingAudienceType);
    }

    private void CancelPublicConfirmation()
    {
        showPublicConfirmation = false;
        pendingAudienceType = currentAudienceType; // Reset to current
        StateHasChanged();
    }

    private async Task ApplyAudienceChange(AudienceType newAudienceType)
    {
        // Update the post audience
        var result = await PostService.UpdatePostAudienceAsync(PostId, AuthorId, newAudienceType);

        if (result.Success)
        {
            // Update internal state and mark that we have a local change
            currentAudienceType = newAudienceType;
            hasLocalAudienceChange = true;

            // Unpin the post since audience changed (pinned posts are removed from DB)
            if (currentIsPinned)
            {
                currentIsPinned = false;
                hasLocalPinnedChange = true;

                // Notify parent component that the post was unpinned
                if (OnUnpinPost.HasDelegate)
                {
                    await OnUnpinPost.InvokeAsync(PostId);
                }
            }

            // Notify parent component of the audience change
            if (OnAudienceTypeChanged.HasDelegate)
            {
                await OnAudienceTypeChanged.InvokeAsync(newAudienceType);
            }

            // Log post visibility update to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserPost, new UserPostDetails
                {
                    PostId = PostId,
                    Visibility = newAudienceType.ToString(),
                    OperationType = OperationTypeEnum.Update.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            // Force an immediate re-render to show the new state
            StateHasChanged();
        }
        else
        {
            // Show error message
            AlertService.ShowError(result.ErrorMessage ?? "Failed to update post audience.");
        }
    }

    private void CloseAudienceMenu()
    {
        showAudienceMenu = false;
        StateHasChanged();
    }

    private void ShowDeleteConfirmation()
    {
        // Close the main menu
        CloseMenu();

        // Show the delete confirmation modal
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    private void CancelDeletePost()
    {
        showDeleteConfirmation = false;
        StateHasChanged();
    }

    private async Task ConfirmDeletePost()
    {
        // Close the confirmation modal
        showDeleteConfirmation = false;
        StateHasChanged();

        // Delete the post
        var result = await PostService.DeletePostAsync(PostId, AuthorId);

        if (result.Success)
        {
            // Log post deletion to audit log
            try
            {
                await AuditLogRepository.LogActionAsync(CurrentUserId, ActionCategory.UserPost, new UserPostDetails
                {
                    PostId = PostId,
                    OperationType = OperationTypeEnum.Delete.ToString()
                });
            }
            catch { /* Audit logging should not fail the operation */ }

            // Notify parent component that the post was deleted
            if (OnPostDeleted.HasDelegate)
            {
                await OnPostDeleted.InvokeAsync(PostId);
            }
        }
        else
        {
            // Show error message
            AlertService.ShowError(result.ErrorMessage ?? "Failed to delete post.");
        }
    }

